{% doc %}
  @prompt
    Create a premium 3-section customer testimonial layout with 3 individual testimonial cards displayed in a horizontal row. Each card should include a star rating (5 stars), a customer quote, customer name, and optional subtitle or product name. Design should match a luxury D2C brand aesthetic — clean typography, minimal borders or subtle card shadows, and smooth hover effects. Should be fully responsive (stacks vertically on mobile), no external dependencies, pure Liquid/CSS/JS only.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ai-testimonials-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    opacity: 0.8;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.cards_top_spacing }}px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-testimonial-card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.hover_lift }}px);
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.hover_shadow_vertical }}px {{ block.settings.hover_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    justify-content: {{ block.settings.card_content_alignment }};
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.6;
    color: {{ block.settings.quote_color }};
    margin: 0;
    text-align: {{ block.settings.card_content_alignment }};
    flex-grow: 1;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: {{ block.settings.card_content_alignment }};
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ai-testimonial-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 0 {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 0.8 }}px;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<testimonials-block-{{ ai_gen_id }} class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-testimonials-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-testimonials-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign quote_key = 'testimonial_' | append: i | append: '_quote'
          assign name_key = 'testimonial_' | append: i | append: '_name'
          assign subtitle_key = 'testimonial_' | append: i | append: '_subtitle'
          
          assign quote = block.settings[quote_key]
          assign name = block.settings[name_key]
          assign subtitle = block.settings[subtitle_key]
        %}

        <div class="ai-testimonial-card-{{ ai_gen_id }}">
          <div class="ai-testimonial-stars-{{ ai_gen_id }}">
            {% for star in (1..5) %}
              <svg class="ai-testimonial-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endfor %}
          </div>

          {% if quote != blank %}
            <p class="ai-testimonial-quote-{{ ai_gen_id }}">{{ quote }}</p>
          {% else %}
            <p class="ai-testimonial-quote-{{ ai_gen_id }}" style="opacity: 0.4; font-style: italic;">Add a customer testimonial here</p>
          {% endif %}

          <div class="ai-testimonial-author-{{ ai_gen_id }}">
            {% if name != blank %}
              <p class="ai-testimonial-name-{{ ai_gen_id }}">{{ name }}</p>
            {% else %}
              <p class="ai-testimonial-name-{{ ai_gen_id }}" style="opacity: 0.4; font-style: italic;">Customer name</p>
            {% endif %}

            {% if subtitle != blank %}
              <p class="ai-testimonial-subtitle-{{ ai_gen_id }}">{{ subtitle }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</testimonials-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-testimonial-card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.setAttribute('role', 'article');
          card.setAttribute('aria-label', 'Customer testimonial');
        });
      }
    }

    customElements.define('testimonials-block-{{ ai_gen_id }}', TestimonialsBlock{{ ai_gen_id }});
  })();
</script>

