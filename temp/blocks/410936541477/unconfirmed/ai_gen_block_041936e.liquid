{% doc %}
  @prompt
    Create a **Shopify Liquid marquee announcement bar section** that matches a high-converting ecommerce banner.
    
    ### Design Style:
    
    * Full-width top bar
    * Background color: deep maroon/brown (#5A2D1F or similar)
    * Text color: white
    * Clean, minimal, premium look
    * Medium font weight, modern sans-serif
    
    ### Content (scrolling continuously):
    
    * Get 10% off on your first order | Use Code: ET10
    * Free Shipping On All Orders
    * Shipping PAN India | COD Available
    
    These items should **repeat seamlessly in a loop** across the screen.
    
    ### Animation:
    
    * Continuous smooth scrolling from right to left
    * Infinite loop (no visible break or gap)
    * Speed should feel premium (not too fast)
    * Pause scrolling on hover
    
    ### Layout:
    
    * Text separated by "|" or spacing
    * Equal spacing between items
    * No line breaks (single-line scrolling)
    
    ### Shopify Customization:
    
    * Add section schema with:
    
      * Editable text blocks (multiple announcements)
      * Scroll speed control (range slider)
      * Background color picker
      * Text color picker
    * Ability to add/remove announcements dynamically
    
    ### Technical Requirements:
    
    * Use Shopify Liquid section format
    * Use CSS keyframes for marquee animation (no deprecated <marquee> tag)
    * No external libraries
    * Fully responsive (mobile + desktop)
    * Optimized performance (no lag or jump)
    
    ### Output:
    
    * Provide full working code (Liquid + CSS + schema)
    * Ready to paste into a new section file (marquee.liquid)
    
    Goal: Create a **smooth, luxury-feel moving announcement bar** like modern D2C brands, with seamless scrolling and strong readability.
    , make 2 more announcement bar 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rotating-announcement-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    text-align: center;
    padding: {{ block.settings.bar_height }}px 20px;
    display: block;
    position: relative;
    overflow: hidden;
  }

  .ai-rotating-announcement-wrapper-{{ ai_gen_id }} {
    position: relative;
    height: {{ block.settings.font_size | times: 1.4 }}px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-rotating-announcement-item-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: 0.5px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .ai-rotating-announcement-item-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-rotating-announcement-nav-{{ ai_gen_id }} {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    padding: 5px 0;
  }

  .ai-rotating-announcement-dot-{{ ai_gen_id }} {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: {{ block.settings.text_color }};
    opacity: 0.3;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-rotating-announcement-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.3);
  }

  .ai-rotating-announcement-dot-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-rotating-announcement-item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-rotating-announcement-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.font_size | times: 1.26 }}px;
    }
  }
{% endstyle %}

<rotating-announcement-{{ ai_gen_id }} class="ai-rotating-announcement-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-rotating-announcement-wrapper-{{ ai_gen_id }}">
    {% if block.settings.announcement_1 != blank %}
      <div class="ai-rotating-announcement-item-{{ ai_gen_id }} active" data-index="0">
        {{ block.settings.announcement_1 }}
      </div>
    {% endif %}
    
    {% if block.settings.announcement_2 != blank %}
      <div class="ai-rotating-announcement-item-{{ ai_gen_id }}" data-index="1">
        {{ block.settings.announcement_2 }}
      </div>
    {% endif %}
    
    {% if block.settings.announcement_3 != blank %}
      <div class="ai-rotating-announcement-item-{{ ai_gen_id }}" data-index="2">
        {{ block.settings.announcement_3 }}
      </div>
    {% endif %}
  </div>
  
  {% if block.settings.show_navigation %}
    <div class="ai-rotating-announcement-nav-{{ ai_gen_id }}">
      {% if block.settings.announcement_1 != blank %}
        <button class="ai-rotating-announcement-dot-{{ ai_gen_id }} active" data-index="0" aria-label="Show announcement 1"></button>
      {% endif %}
      {% if block.settings.announcement_2 != blank %}
        <button class="ai-rotating-announcement-dot-{{ ai_gen_id }}" data-index="1" aria-label="Show announcement 2"></button>
      {% endif %}
      {% if block.settings.announcement_3 != blank %}
        <button class="ai-rotating-announcement-dot-{{ ai_gen_id }}" data-index="2" aria-label="Show announcement 3"></button>
      {% endif %}
    </div>
  {% endif %}
</rotating-announcement-{{ ai_gen_id }}>

<script>
  (function() {
    class RotatingAnnouncement{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoRotateInterval = null;
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-rotating-announcement-item-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-rotating-announcement-dot-{{ ai_gen_id }}');
        
        if (this.items.length > 1) {
          this.startAutoRotate();
          this.setupNavigation();
        }
      }

      disconnectedCallback() {
        this.stopAutoRotate();
      }

      startAutoRotate() {
        this.autoRotateInterval = setInterval(() => {
          this.rotate();
        }, {{ block.settings.rotation_speed | times: 1000 }});
      }

      stopAutoRotate() {
        if (this.autoRotateInterval) {
          clearInterval(this.autoRotateInterval);
        }
      }

      rotate() {
        this.items[this.currentIndex].classList.remove('active');
        if (this.dots[this.currentIndex]) {
          this.dots[this.currentIndex].classList.remove('active');
        }

        this.currentIndex = (this.currentIndex + 1) % this.items.length;

        this.items[this.currentIndex].classList.add('active');
        if (this.dots[this.currentIndex]) {
          this.dots[this.currentIndex].classList.add('active');
        }
      }

      setupNavigation() {
        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const index = parseInt(dot.getAttribute('data-index'));
            this.goToSlide(index);
          });
        });
      }

      goToSlide(index) {
        this.stopAutoRotate();
        
        this.items[this.currentIndex].classList.remove('active');
        if (this.dots[this.currentIndex]) {
          this.dots[this.currentIndex].classList.remove('active');
        }

        this.currentIndex = index;

        this.items[this.currentIndex].classList.add('active');
        if (this.dots[this.currentIndex]) {
          this.dots[this.currentIndex].classList.add('active');
        }

        this.startAutoRotate();
      }
    }

    customElements.define('rotating-announcement-{{ ai_gen_id }}', RotatingAnnouncement{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Rotating announcement bar",
  "settings": [
    {
      "type": "header",
      "content": "Announcements"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_1",
      "label": "Announcement 1",
      "default": "Free Shipping On All Orders"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_2",
      "label": "Announcement 2",
      "default": "Get 10% off with code WELCOME10"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_3",
      "label": "Announcement 3",
      "default": "COD Available | Shipping PAN India"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Rotation speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#334fb4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Rotating announcement bar"
    }
  ]
}
{% endschema %}
