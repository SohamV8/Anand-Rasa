{% doc %}
  @prompt
    Create a **Shopify Liquid marquee announcement bar section** that matches a high-converting ecommerce banner.
    
    ### Design Style:
    
    * Full-width top bar
    * Background color: deep maroon/brown (#5A2D1F or similar)
    * Text color: white
    * Clean, minimal, premium look
    * Medium font weight, modern sans-serif
    
    ### Content (scrolling continuously):
    
    * Get 10% off on your first order | Use Code: ET10
    * Free Shipping On All Orders
    * Shipping PAN India | COD Available
    
    These items should **repeat seamlessly in a loop** across the screen.
    
    ### Animation:
    
    * Continuous smooth scrolling from right to left
    * Infinite loop (no visible break or gap)
    * Speed should feel premium (not too fast)
    * Pause scrolling on hover
    
    ### Layout:
    
    * Text separated by "|" or spacing
    * Equal spacing between items
    * No line breaks (single-line scrolling)
    
    ### Shopify Customization:
    
    * Add section schema with:
    
      * Editable text blocks (multiple announcements)
      * Scroll speed control (range slider)
      * Background color picker
      * Text color picker
    * Ability to add/remove announcements dynamically
    
    ### Technical Requirements:
    
    * Use Shopify Liquid section format
    * Use CSS keyframes for marquee animation (no deprecated <marquee> tag)
    * No external libraries
    * Fully responsive (mobile + desktop)
    * Optimized performance (no lag or jump)
    
    ### Output:
    
    * Provide full working code (Liquid + CSS + schema)
    * Ready to paste into a new section file (marquee.liquid)
    
    Goal: Create a **smooth, luxury-feel moving announcement bar** like modern D2C brands, with seamless scrolling and strong readability.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-bar-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.bar_height }}px 0;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    display: block;
  }

  .ai-marquee-bar-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-marquee-bar-{{ ai_gen_id }}:hover .ai-marquee-bar-wrapper-{{ ai_gen_id }} {
    {% if block.settings.pause_on_hover %}
      animation-play-state: paused;
    {% endif %}
  }

  .ai-marquee-bar-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding-right: {{ block.settings.item_spacing }}px;
  }

  .ai-marquee-bar-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 0 {{ block.settings.item_spacing }}px;
  }

  .ai-marquee-bar-separator-{{ ai_gen_id }} {
    margin: 0 {{ block.settings.separator_spacing }}px;
    opacity: 0.7;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-bar-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: {{ block.settings.bar_height | times: 0.8 }}px 0;
    }
  }
{% endstyle %}

<marquee-bar-{{ ai_gen_id }} class="ai-marquee-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-bar-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-bar-content-{{ ai_gen_id }}">
      {% for block_item in block.settings.announcements %}
        {% if block_item.text != blank %}
          <span class="ai-marquee-bar-item-{{ ai_gen_id }}">{{ block_item.text }}</span>
          {% unless forloop.last %}
            <span class="ai-marquee-bar-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
    <div class="ai-marquee-bar-content-{{ ai_gen_id }}" aria-hidden="true">
      {% for block_item in block.settings.announcements %}
        {% if block_item.text != blank %}
          <span class="ai-marquee-bar-item-{{ ai_gen_id }}">{{ block_item.text }}</span>
          {% unless forloop.last %}
            <span class="ai-marquee-bar-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</marquee-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustSpeed();
      }

      adjustSpeed() {
        const wrapper = this.querySelector('.ai-marquee-bar-wrapper-{{ ai_gen_id }}');
        if (!wrapper) return;

        const content = this.querySelector('.ai-marquee-bar-content-{{ ai_gen_id }}');
        if (!content) return;

        const contentWidth = content.offsetWidth;
        const speed = {{ block.settings.scroll_speed }};
        const pixelsPerSecond = contentWidth / speed;

        wrapper.style.animationDuration = `${speed}s`;
      }
    }

    customElements.define('marquee-bar-{{ ai_gen_id }}', MarqueeBar{{ ai_gen_id }});
  })();
</script>

