    {
      "type": "inline_richtext",
      "id": "announcement_2",
      "label": "Announcement 2",
      "default": "Free Shipping On All Orders"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_3",
      "label": "Announcement 3",
      "default": "Shipping PAN India | COD Available"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_4",
      "label": "Announcement 4"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_5",
      "label": "Announcement 5"
