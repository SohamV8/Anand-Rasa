{% doc %}
  @prompt
    Create a testimonial section for the product page with 3-4 customer reviews. Each testimonial should include a star rating (5 stars), customer name, location, and a short review quote. Display them in a clean card layout that works well on mobile. Style should be warm and elegant, suitable for a fragrance/attar/incense product store. Text fields should be editable in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.card_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-stars-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: currentColor;
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.6;
    color: {{ block.settings.quote_color }};
    font-style: italic;
    margin: 0;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: auto;
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0;
  }

  .ai-testimonial-location-{{ ai_gen_id }} {
    font-size: {{ block.settings.location_size }}px;
    color: {{ block.settings.location_color }};
    margin: 0;
  }
{% endstyle %}

<testimonials-block-{{ ai_gen_id }} class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign testimonial_enabled_key = 'testimonial_' | append: i | append: '_enabled'
          assign testimonial_quote_key = 'testimonial_' | append: i | append: '_quote'
          assign testimonial_name_key = 'testimonial_' | append: i | append: '_name'
          assign testimonial_location_key = 'testimonial_' | append: i | append: '_location'

          assign testimonial_enabled = block.settings[testimonial_enabled_key]
          assign testimonial_quote = block.settings[testimonial_quote_key]
          assign testimonial_name = block.settings[testimonial_name_key]
          assign testimonial_location = block.settings[testimonial_location_key]
        %}

        {% if testimonial_enabled %}
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            <div class="ai-testimonial-stars-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>

            {% if testimonial_quote != blank %}
              <p class="ai-testimonial-quote-{{ ai_gen_id }}">{{ testimonial_quote }}</p>
            {% endif %}

            <div class="ai-testimonial-author-{{ ai_gen_id }}">
              {% if testimonial_name != blank %}
                <p class="ai-testimonial-name-{{ ai_gen_id }}">{{ testimonial_name }}</p>
              {% endif %}
              {% if testimonial_location != blank %}
                <p class="ai-testimonial-location-{{ ai_gen_id }}">{{ testimonial_location }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonials-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('testimonials-block-{{ ai_gen_id }}', TestimonialsBlock{{ ai_gen_id }});
  })();
</script>

