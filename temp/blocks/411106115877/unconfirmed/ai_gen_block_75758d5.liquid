{% doc %}
  @prompt
    Create a premium side cart drawer for a D2C Shopify brand (like Sadhna.co style). Requirements:
    
    1. RIGHT-SIDE SLIDING DRAWER that opens when "Add to Cart" is clicked — no page reload, uses Shopify AJAX Cart API (/cart/add.js, /cart.js, /cart/change.js).
    
    2. DRAWER DESIGN (clean, premium D2C UI):
       - Product image, name, price
       - Quantity selector (+ / - buttons)
       - Remove item (×) button
       - Subtotal + Total section
       - Sticky "Checkout" button at bottom
       - Overlay backdrop that closes drawer on click
    
    3. PROGRESS BAR:
       - Dynamic bar showing "Add ₹300 more to unlock FREE GIFT"
       - Updates in real-time as cart value changes
       - Threshold configurable via JS variable
    
    4. UPSELL SECTION ("You may also like"):
       - Show 2–4 recommended products inside drawer
       - Each with image, name, price, and "Add" button
       - AJAX add to cart (no page reload)
    
    5. TRUST BADGES inside drawer:
       - "🚚 Free Shipping on orders above ₹999"
       - "💵 COD Available"
       - Discount applied indicator (if discount code active)
    
    6. ANIMATIONS:
       - Smooth slide-in from right (CSS transition)
       - Fade-in overlay
       - Quantity update fade animation
    
    7. MOBILE:
       - Full-width drawer on mobile (100vw)
       - Touch-friendly buttons
    
    8. CODE STRUCTURE:
       - Split into Liquid (structure), CSS (styling), JS (logic)
       - Must work with any Shopify theme
       - Lightweight — no jQuery or heavy libraries
    
    Make it look premium like top Indian D2C brands. Use modern CSS (flexbox, custom properties). Include clear comments on where to paste each section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-drawer-{{ ai_gen_id }} {
    display: block;
  }

  .ai-cart-drawer-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-cart-drawer-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-cart-drawer-panel-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    right: 0;
    width: {{ block.settings.drawer_width_desktop }}px;
    max-width: 100%;
    height: 100%;
    background-color: {{ block.settings.drawer_bg_color }};
    z-index: 1000;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
  }

  .ai-cart-drawer-panel-{{ ai_gen_id }}.active {
    transform: translateX(0);
  }

  .ai-cart-drawer-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-cart-drawer-title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-cart-drawer-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    font-size: 24px;
    line-height: 1;
  }

  .ai-cart-drawer-progress-{{ ai_gen_id }} {
    padding: 16px 24px;
    background-color: {{ block.settings.progress_bg_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-cart-drawer-progress-text-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
    text-align: center;
  }

  .ai-cart-drawer-progress-bar-bg-{{ ai_gen_id }} {
    width: 100%;
    height: 8px;
    background-color: #e0e0e0;
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-cart-drawer-progress-bar-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.progress_bar_color }};
    transition: width 0.3s ease;
    border-radius: 4px;
  }

  .ai-cart-drawer-body-{{ ai_gen_id }} {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
  }

  .ai-cart-drawer-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-drawer-empty-{{ ai_gen_id }} p {
    font-size: 16px;
    margin-bottom: 20px;
  }

  .ai-cart-drawer-item-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-cart-drawer-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-cart-drawer-item-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-cart-drawer-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cart-drawer-item-details-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-cart-drawer-item-name-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-cart-drawer-item-variant-{{ ai_gen_id }} {
    font-size: 12px;
    color: #666;
  }

  .ai-cart-drawer-item-price-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-drawer-item-actions-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  .ai-cart-drawer-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    padding: 4px;
  }

  .ai-cart-drawer-quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    color: {{ block.settings.text_color }};
    font-size: 16px;
    line-height: 1;
  }

  .ai-cart-drawer-quantity-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-cart-drawer-quantity-value-{{ ai_gen_id }} {
    font-size: 14px;
    min-width: 20px;
    text-align: center;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-drawer-remove-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #999;
    font-size: 18px;
    line-height: 1;
  }

  .ai-cart-drawer-remove-{{ ai_gen_id }}:hover {
    color: #d32f2f;
  }

  .ai-cart-drawer-trust-badges-{{ ai_gen_id }} {
    margin-top: 24px;
    padding: 16px;
    background-color: {{ block.settings.trust_badge_bg }};
    border-radius: 8px;
  }

  .ai-cart-drawer-trust-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
  }

  .ai-cart-drawer-trust-badge-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-cart-drawer-upsell-{{ ai_gen_id }} {
    margin-top: 24px;
  }

  .ai-cart-drawer-upsell-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
  }

  .ai-cart-drawer-upsell-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .ai-cart-drawer-upsell-item-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 8px;
    padding: 12px;
    text-align: center;
  }

  .ai-cart-drawer-upsell-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: 8px;
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-cart-drawer-upsell-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cart-drawer-upsell-name-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .ai-cart-drawer-upsell-price-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
  }

  .ai-cart-drawer-upsell-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: 8px 12px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
  }

  .ai-cart-drawer-upsell-btn-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-cart-drawer-footer-{{ ai_gen_id }} {
    padding: 20px 24px;
    border-top: 1px solid {{ block.settings.border_color }};
    background-color: {{ block.settings.drawer_bg_color }};
  }

  .ai-cart-drawer-subtotal-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .ai-cart-drawer-subtotal-label-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-drawer-subtotal-value-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-drawer-checkout-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px;
    background-color: {{ block.settings.checkout_btn_bg }};
    color: {{ block.settings.checkout_btn_text }};
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-cart-drawer-checkout-btn-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .ai-cart-drawer-panel-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-cart-drawer-upsell-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}

<premium-cart-drawer-{{ ai_gen_id }} class="ai-cart-drawer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cart-drawer-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-cart-drawer-panel-{{ ai_gen_id }}">
    <div class="ai-cart-drawer-header-{{ ai_gen_id }}">
      <h2 class="ai-cart-drawer-title-{{ ai_gen_id }}">{{ block.settings.drawer_title }}</h2>
      <button class="ai-cart-drawer-close-{{ ai_gen_id }}" aria-label="Close cart">×</button>
    </div>

    {% if block.settings.show_progress_bar %}
      <div class="ai-cart-drawer-progress-{{ ai_gen_id }}">
        <div class="ai-cart-drawer-progress-text-{{ ai_gen_id }}"></div>
        <div class="ai-cart-drawer-progress-bar-bg-{{ ai_gen_id }}">
          <div class="ai-cart-drawer-progress-bar-fill-{{ ai_gen_id }}" style="width: 0%;"></div>
        </div>
      </div>
    {% endif %}

    <div class="ai-cart-drawer-body-{{ ai_gen_id }}">
      <div class="ai-cart-drawer-items-{{ ai_gen_id }}"></div>

      {% if block.settings.show_trust_badges %}
        <div class="ai-cart-drawer-trust-badges-{{ ai_gen_id }}">
          {% if block.settings.trust_badge_1 != blank %}
            <div class="ai-cart-drawer-trust-badge-{{ ai_gen_id }}">
              <span>{{ block.settings.trust_badge_1_icon }}</span>
              <span>{{ block.settings.trust_badge_1 }}</span>
            </div>
          {% endif %}
          {% if block.settings.trust_badge_2 != blank %}
            <div class="ai-cart-drawer-trust-badge-{{ ai_gen_id }}">
              <span>{{ block.settings.trust_badge_2_icon }}</span>
              <span>{{ block.settings.trust_badge_2 }}</span>
            </div>
          {% endif %}
          {% if block.settings.trust_badge_3 != blank %}
            <div class="ai-cart-drawer-trust-badge-{{ ai_gen_id }}">
              <span>{{ block.settings.trust_badge_3_icon }}</span>
              <span>{{ block.settings.trust_badge_3 }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_upsell and block.settings.upsell_products != blank %}
        <div class="ai-cart-drawer-upsell-{{ ai_gen_id }}">
          <h3 class="ai-cart-drawer-upsell-title-{{ ai_gen_id }}">{{ block.settings.upsell_title }}</h3>
          <div class="ai-cart-drawer-upsell-grid-{{ ai_gen_id }}">
            {% for product in block.settings.upsell_products limit: 4 %}
              <div class="ai-cart-drawer-upsell-item-{{ ai_gen_id }}" data-product-id="{{ product.variants.first.id }}">
                <div class="ai-cart-drawer-upsell-image-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 200 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="200"
                      height="200"
                    >
                  {% endif %}
                </div>
                <div class="ai-cart-drawer-upsell-name-{{ ai_gen_id }}">{{ product.title }}</div>
                <div class="ai-cart-drawer-upsell-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                <button class="ai-cart-drawer-upsell-btn-{{ ai_gen_id }}" data-variant-id="{{ product.variants.first.id }}">
                  {{ block.settings.upsell_button_text }}
                </button>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-cart-drawer-footer-{{ ai_gen_id }}">
      <div class="ai-cart-drawer-subtotal-{{ ai_gen_id }}">
        <span class="ai-cart-drawer-subtotal-label-{{ ai_gen_id }}">{{ block.settings.subtotal_label }}</span>
        <span class="ai-cart-drawer-subtotal-value-{{ ai_gen_id }}"></span>
      </div>
      <button class="ai-cart-drawer-checkout-btn-{{ ai_gen_id }}">{{ block.settings.checkout_button_text }}</button>
    </div>
  </div>
</premium-cart-drawer-{{ ai_gen_id }}>

<script>
  (function() {
    class PremiumCartDrawer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.overlay = this.querySelector('.ai-cart-drawer-overlay-{{ ai_gen_id }}');
        this.panel = this.querySelector('.ai-cart-drawer-panel-{{ ai_gen_id }}');
        this.closeBtn = this.querySelector('.ai-cart-drawer-close-{{ ai_gen_id }}');
        this.itemsContainer = this.querySelector('.ai-cart-drawer-items-{{ ai_gen_id }}');
        this.subtotalValue = this.querySelector('.ai-cart-drawer-subtotal-value-{{ ai_gen_id }}');
        this.checkoutBtn = this.querySelector('.ai-cart-drawer-checkout-btn-{{ ai_gen_id }}');
        this.progressText = this.querySelector('.ai-cart-drawer-progress-text-{{ ai_gen_id }}');
        this.progressFill = this.querySelector('.ai-cart-drawer-progress-bar-fill-{{ ai_gen_id }}');
        this.freeGiftThreshold = {{ block.settings.free_gift_threshold }};
        this.currencySymbol = '{{ cart.currency.symbol }}';
      }

      connectedCallback() {
        this.setupEventListeners();
        this.interceptAddToCart();
      }

      setupEventListeners() {
        this.closeBtn.addEventListener('click', () => this.close());
        this.overlay.addEventListener('click', () => this.close());
        
        this.checkoutBtn.addEventListener('click', () => {
          window.location.href = '/checkout';
        });

        this.itemsContainer.addEventListener('click', (e) => {
          if (e.target.classList.contains('ai-cart-drawer-quantity-btn-{{ ai_gen_id }}')) {
            const action = e.target.dataset.action;
            const key = e.target.dataset.key;
            const currentQty = parseInt(e.target.dataset.qty);
            
            if (action === 'increase') {
              this.updateQuantity(key, currentQty + 1);
            } else if (action === 'decrease' && currentQty > 1) {
              this.updateQuantity(key, currentQty - 1);
            }
          }

          if (e.target.classList.contains('ai-cart-drawer-remove-{{ ai_gen_id }}')) {
            const key = e.target.dataset.key;
            this.updateQuantity(key, 0);
          }
        });

        const upsellBtns = this.querySelectorAll('.ai-cart-drawer-upsell-btn-{{ ai_gen_id }}');
        upsellBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const variantId = e.target.dataset.variantId;
            this.addToCart(variantId, 1);
          });
        });
      }

      interceptAddToCart() {
        document.addEventListener('submit', (e) => {
          if (e.target.matches('form[action="/cart/add"]')) {
            e.preventDefault();
            const formData = new FormData(e.target);
            const variantId = formData.get('id');
            const quantity = formData.get('quantity') || 1;
            this.addToCart(variantId, quantity);
          }
        });

        document.addEventListener('click', (e) => {
          if (e.target.matches('[name="add"]') || e.target.closest('[name="add"]')) {
            const form = e.target.closest('form[action="/cart/add"]');
            if (form) {
              e.preventDefault();
              const formData = new FormData(form);
              const variantId = formData.get('id');
              const quantity = formData.get('quantity') || 1;
              this.addToCart(variantId, quantity);
            }
          }
        });
      }

      addToCart(variantId, quantity) {
        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: variantId,
            quantity: parseInt(quantity)
          })
        })
        .then(response => response.json())
        .then(() => {
          this.fetchCart();
          this.open();
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
        });
      }

      updateQuantity(key, quantity) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: key,
            quantity: quantity
          })
        })
        .then(response => response.json())
        .then(() => {
          this.fetchCart();
        })
        .catch(error => {
          console.error('Error updating cart:', error);
        });
      }

      fetchCart() {
        fetch('/cart.js')
          .then(response => response.json())
          .then(cart => {
            this.renderCart(cart);
            this.updateProgress(cart.total_price);
          })
          .catch(error => {
            console.error('Error fetching cart:', error);
          });
      }

      renderCart(cart) {
        if (cart.item_count === 0) {
          this.itemsContainer.innerHTML = `
            <div class="ai-cart-drawer-empty-{{ ai_gen_id }}">
              <p>{{ block.settings.empty_cart_message }}</p>
            </div>
          `;
          this.subtotalValue.textContent = this.formatMoney(0);
          return;
        }

        let itemsHTML = '';
        cart.items.forEach(item => {
          const variantTitle = item.variant_title !== 'Default Title' ? item.variant_title : '';
          itemsHTML += `
            <div class="ai-cart-drawer-item-{{ ai_gen_id }}">
              <div class="ai-cart-drawer-item-image-{{ ai_gen_id }}">
                <img src="${item.image}" alt="${item.product_title}" loading="lazy">
              </div>
              <div class="ai-cart-drawer-item-details-{{ ai_gen_id }}">
                <h4 class="ai-cart-drawer-item-name-{{ ai_gen_id }}">${item.product_title}</h4>
                ${variantTitle ? `<div class="ai-cart-drawer-item-variant-{{ ai_gen_id }}">${variantTitle}</div>` : ''}
                <div class="ai-cart-drawer-item-price-{{ ai_gen_id }}">${this.formatMoney(item.final_line_price)}</div>
                <div class="ai-cart-drawer-item-actions-{{ ai_gen_id }}">
                  <div class="ai-cart-drawer-quantity-{{ ai_gen_id }}">
                    <button class="ai-cart-drawer-quantity-btn-{{ ai_gen_id }}" data-action="decrease" data-key="${item.key}" data-qty="${item.quantity}" ${item.quantity <= 1 ? 'disabled' : ''}>−</button>
                    <span class="ai-cart-drawer-quantity-value-{{ ai_gen_id }}">${item.quantity}</span>
                    <button class="ai-cart-drawer-quantity-btn-{{ ai_gen_id }}" data-action="increase" data-key="${item.key}" data-qty="${item.quantity}">+</button>
                  </div>
                  <button class="ai-cart-drawer-remove-{{ ai_gen_id }}" data-key="${item.key}" aria-label="Remove item">×</button>
                </div>
              </div>
            </div>
          `;
        });

        this.itemsContainer.innerHTML = itemsHTML;
        this.subtotalValue.textContent = this.formatMoney(cart.total_price);
      }

      updateProgress(totalPrice) {
        if (!this.progressText || !this.progressFill) return;

        const totalInCurrency = totalPrice / 100;
        const remaining = this.freeGiftThreshold - totalInCurrency;
        const percentage = Math.min((totalInCurrency / this.freeGiftThreshold) * 100, 100);

        this.progressFill.style.width = percentage + '%';

        if (remaining > 0) {
          this.progressText.textContent = `{{ block.settings.progress_message_prefix }} ${this.currencySymbol}${remaining.toFixed(0)} {{ block.settings.progress_message_suffix }}`;
        } else {
          this.progressText.textContent = '{{ block.settings.progress_complete_message }}';
        }
      }

      formatMoney(cents) {
        const amount = (cents / 100).toFixed(2);
        return `${this.currencySymbol}${amount}`;
      }

      open() {
        this.overlay.classList.add('active');
        this.panel.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      close() {
        this.overlay.classList.remove('active');
        this.panel.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    customElements.define('premium-cart-drawer-{{ ai_gen_id }}', PremiumCartDrawer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Premium cart drawer",
  "settings": [
    {
      "type": "header",
      "content": "Drawer settings"
    },
    {
      "type": "text",
      "id": "drawer_title",
      "label": "Drawer title",
      "default": "Your Cart"
    },
    {
      "type": "range",
