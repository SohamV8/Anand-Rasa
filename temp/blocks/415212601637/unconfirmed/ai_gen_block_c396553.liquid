{% doc %}
  @prompt
    Create a premium, mobile-first Shopify section called "Ingredient Story Grid" for a luxury fragrance product page.
    
    Design Requirements
    Inspired by luxury brands like Forest Essentials, Aesop, Le Labo, and heritage Indian perfumery.
    Clean ivory/off-white background (#F8F3EA).
    Center-aligned section heading.
    Four ingredient cards displayed in a responsive grid.
    Desktop: 4 columns.
    Tablet: 2 columns.
    Mobile: 1 column with proper spacing.
    Elegant borders with subtle shadows.
    Rounded corners (10-12px).
    Luxury serif typography for headings.
    High readability and premium spacing.
    Smooth hover animation on desktop.
    Fast loading and optimized for Shopify Online Store 2.0.
    Section Structure
    
    Top Heading:
    Four Ingredients. One Solar Ritual.
    
    Below the heading display ingredient cards.
    
    Each ingredient card contains:
    
    Ingredient Image
    Ingredient Name
    Short Description
    Source Location
    
    Example:
    
    Card 1
    
    Image
    Cambodian Oud
    Grounds the fire & anchors presence.
    Sourced From Cambodia
    
    Card 2
    
    Image
    Black Peppercorns
    Ignites courage & cuts through doubt.
    Malabar, India
    
    Card 3
    
    Image
    Green Cardamom
    Opens the heart & sharpens intuition.
    Malabar, India
    
    Card 4
    
    Image
    Red Musk
    Stabilizes fire & builds endurance.
    Himalayas, India
    Metafield Support (Important)
    
    Every content field must be dynamically connectable to Shopify metafields.
    
    Create editable settings for:
    
    Section Settings
    Section Heading
    Section Subheading (optional)
    Background Color
    Card Background Color
    Border Color
    Heading Color
    Text Color
    Source Text Color
    Ingredient Block Settings
    
    For each block create:
    
    Ingredient Image
    Ingredient Name
    Ingredient Description
    Ingredient Source
    
    Each field must support:
    
    Static content
    Dynamic Source (Metafield connection)
    Schema Requirements
    
    Use Shopify section schema with:
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-story-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_bg_color }};
    padding: 60px 20px;
  }

  .ai-ingredient-story-grid__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-ingredient-story-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-ingredient-story-grid__heading-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 36px;
    font-weight: 500;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    letter-spacing: 0.5px;
  }

  .ai-ingredient-story-grid__subheading-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-ingredient-story-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ai-ingredient-story-grid__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .ai-ingredient-story-grid__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-ingredient-story-grid__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    margin-bottom: 20px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-ingredient-story-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-ingredient-story-grid__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-story-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-ingredient-story-grid__name-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    letter-spacing: 0.3px;
  }

  .ai-ingredient-story-grid__description-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-ingredient-story-grid__source-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 500;
    color: {{ block.settings.source_text_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-ingredient-story-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .ai-ingredient-story-grid__heading-{{ ai_gen_id }} {
      font-size: 30px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-story-grid-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-ingredient-story-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-ingredient-story-grid__heading-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-ingredient-story-grid__card-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-ingredient-story-grid__card-{{ ai_gen_id }}:hover {
      transform: none;
    }
  }
{% endstyle %}

<ingredient-story-grid-{{ ai_gen_id }} class="ai-ingredient-story-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ingredient-story-grid__container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank or block.settings.section_subheading != blank %}
      <div class="ai-ingredient-story-grid__header-{{ ai_gen_id }}">
        {% if block.settings.section_heading != blank %}
          <h2 class="ai-ingredient-story-grid__heading-{{ ai_gen_id }}">
            {{ block.settings.section_heading }}
          </h2>
        {% endif %}
        {% if block.settings.section_subheading != blank %}
          <p class="ai-ingredient-story-grid__subheading-{{ ai_gen_id }}">
            {{ block.settings.section_subheading }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-ingredient-story-grid__grid-{{ ai_gen_id }}">
      {% liquid
        assign ingredient_1_name = block.settings.ingredient_1_name
        assign ingredient_1_description = block.settings.ingredient_1_description
        assign ingredient_1_source = block.settings.ingredient_1_source
        assign ingredient_1_image = block.settings.ingredient_1_image

        assign ingredient_2_name = block.settings.ingredient_2_name
        assign ingredient_2_description = block.settings.ingredient_2_description
        assign ingredient_2_source = block.settings.ingredient_2_source
        assign ingredient_2_image = block.settings.ingredient_2_image

        assign ingredient_3_name = block.settings.ingredient_3_name
        assign ingredient_3_description = block.settings.ingredient_3_description
        assign ingredient_3_source = block.settings.ingredient_3_source
        assign ingredient_3_image = block.settings.ingredient_3_image

        assign ingredient_4_name = block.settings.ingredient_4_name
        assign ingredient_4_description = block.settings.ingredient_4_description
        assign ingredient_4_source = block.settings.ingredient_4_source
        assign ingredient_4_image = block.settings.ingredient_4_image
      %}

      <div class="ai-ingredient-story-grid__card-{{ ai_gen_id }}">
        <div class="ai-ingredient-story-grid__image-wrapper-{{ ai_gen_id }}">
          {% if ingredient_1_image %}
            <img
              src="{{ ingredient_1_image | image_url: width: 400 }}"
              alt="{{ ingredient_1_name | escape }}"
              class="ai-ingredient-story-grid__image-{{ ai_gen_id }}"
              loading="lazy"
              width="400"
              height="400"
            >
          {% else %}
            <div class="ai-ingredient-story-grid__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if ingredient_1_name != blank %}
          <h3 class="ai-ingredient-story-grid__name-{{ ai_gen_id }}">{{ ingredient_1_name }}</h3>
        {% endif %}
        {% if ingredient_1_description != blank %}
          <p class="ai-ingredient-story-grid__description-{{ ai_gen_id }}">{{ ingredient_1_description }}</p>
        {% endif %}
        {% if ingredient_1_source != blank %}
          <p class="ai-ingredient-story-grid__source-{{ ai_gen_id }}">Sourced From {{ ingredient_1_source }}</p>
        {% endif %}
      </div>

      <div class="ai-ingredient-story-grid__card-{{ ai_gen_id }}">
        <div class="ai-ingredient-story-grid__image-wrapper-{{ ai_gen_id }}">
          {% if ingredient_2_image %}
            <img
              src="{{ ingredient_2_image | image_url: width: 400 }}"
              alt="{{ ingredient_2_name | escape }}"
              class="ai-ingredient-story-grid__image-{{ ai_gen_id }}"
              loading="lazy"
              width="400"
              height="400"
            >
          {% else %}
            <div class="ai-ingredient-story-grid__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if ingredient_2_name != blank %}
          <h3 class="ai-ingredient-story-grid__name-{{ ai_gen_id }}">{{ ingredient_2_name }}</h3>
        {% endif %}
        {% if ingredient_2_description != blank %}
          <p class="ai-ingredient-story-grid__description-{{ ai_gen_id }}">{{ ingredient_2_description }}</p>
        {% endif %}
        {% if ingredient_2_source != blank %}
          <p class="ai-ingredient-story-grid__source-{{ ai_gen_id }}">Sourced From {{ ingredient_2_source }}</p>
        {% endif %}
      </div>

      <div class="ai-ingredient-story-grid__card-{{ ai_gen_id }}">
        <div class="ai-ingredient-story-grid__image-wrapper-{{ ai_gen_id }}">
          {% if ingredient_3_image %}
            <img
              src="{{ ingredient_3_image | image_url: width: 400 }}"
              alt="{{ ingredient_3_name | escape }}"
              class="ai-ingredient-story-grid__image-{{ ai_gen_id }}"
              loading="lazy"
              width="400"
              height="400"
            >
          {% else %}
            <div class="ai-ingredient-story-grid__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if ingredient_3_name != blank %}
          <h3 class="ai-ingredient-story-grid__name-{{ ai_gen_id }}">{{ ingredient_3_name }}</h3>
        {% endif %}
        {% if ingredient_3_description != blank %}
          <p class="ai-ingredient-story-grid__description-{{ ai_gen_id }}">{{ ingredient_3_description }}</p>
        {% endif %}
        {% if ingredient_3_source != blank %}
          <p class="ai-ingredient-story-grid__source-{{ ai_gen_id }}">Sourced From {{ ingredient_3_source }}</p>
        {% endif %}
      </div>

      <div class="ai-ingredient-story-grid__card-{{ ai_gen_id }}">
        <div class="ai-ingredient-story-grid__image-wrapper-{{ ai_gen_id }}">
          {% if ingredient_4_image %}
            <img
              src="{{ ingredient_4_image | image_url: width: 400 }}"
              alt="{{ ingredient_4_name | escape }}"
              class="ai-ingredient-story-grid__image-{{ ai_gen_id }}"
              loading="lazy"
              width="400"
              height="400"
            >
          {% else %}
            <div class="ai-ingredient-story-grid__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if ingredient_4_name != blank %}
          <h3 class="ai-ingredient-story-grid__name-{{ ai_gen_id }}">{{ ingredient_4_name }}</h3>
        {% endif %}
        {% if ingredient_4_description != blank %}
          <p class="ai-ingredient-story-grid__description-{{ ai_gen_id }}">{{ ingredient_4_description }}</p>
        {% endif %}
        {% if ingredient_4_source != blank %}
          <p class="ai-ingredient-story-grid__source-{{ ai_gen_id }}">Sourced From {{ ingredient_4_source }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</ingredient-story-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class IngredientStoryGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.loadGoogleFont();
      }

      loadGoogleFont() {
        if (!document.querySelector('link[href*="Cormorant+Garamond"]')) {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap';
          document.head.appendChild(link);
        }
      }
    }

    customElements.define('ingredient-story-grid-{{ ai_gen_id }}', IngredientStoryGrid{{ ai_gen_id }});
  })();
</script>

