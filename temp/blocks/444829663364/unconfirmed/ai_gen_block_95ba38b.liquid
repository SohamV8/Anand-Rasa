{% doc %}
  @prompt
    Create a small trust and review section to display at the top of the product page. It should include star ratings, a short review count (e.g., "4.8 ★ | 200+ Reviews"), and 2-3 trust badges or icons such as "100% Natural", "Secure Checkout", and "Fast Shipping". Keep it compact, visually clean, and suitable for a fragrance/incense product store. It should sit just below the product title or at the very top of the product details area.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-review-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-trust-review-content-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-trust-review-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: {{ block.settings.rating_font_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-trust-review-stars-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 2px;
    color: {{ block.settings.star_color }};
  }

  .ai-trust-review-stars-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: currentColor;
  }

  .ai-trust-review-divider-{{ ai_gen_id }} {
    width: 1px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
  }

  .ai-trust-review-badges-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.badge_gap }}px;
    flex-wrap: wrap;
  }

  .ai-trust-review-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: {{ block.settings.badge_font_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-trust-review-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.badge_icon_size }}px;
    height: {{ block.settings.badge_icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.badge_icon_color }};
  }

  .ai-trust-review-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-review-section-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-trust-review-content-{{ ai_gen_id }} {
      gap: {{ block.settings.gap | times: 0.8 }}px;
    }

    .ai-trust-review-rating-{{ ai_gen_id }} {
      font-size: {{ block.settings.rating_font_size | times: 0.9 }}px;
    }

    .ai-trust-review-stars-{{ ai_gen_id }} svg {
      width: {{ block.settings.star_size | times: 0.9 }}px;
      height: {{ block.settings.star_size | times: 0.9 }}px;
    }

    .ai-trust-review-badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.9 }}px;
    }

    .ai-trust-review-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.badge_icon_size | times: 0.9 }}px;
      height: {{ block.settings.badge_icon_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<trust-review-section-{{ ai_gen_id }}
  class="ai-trust-review-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-trust-review-content-{{ ai_gen_id }}">
    <div class="ai-trust-review-rating-{{ ai_gen_id }}">
      <span>{{ block.settings.rating_value }}</span>
      <div class="ai-trust-review-stars-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <span>|</span>
      <span>{{ block.settings.review_count }}</span>
    </div>

    {% if block.settings.show_divider %}
      <div class="ai-trust-review-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-trust-review-badges-{{ ai_gen_id }}">
      {% if block.settings.badge_1_enabled %}
        <div class="ai-trust-review-badge-{{ ai_gen_id }}">
          <div class="ai-trust-review-badge-icon-{{ ai_gen_id }}">
            {% if block.settings.badge_1_icon == 'leaf' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.66-1.89C6 20 6 20 6 20c0-1.66 1.34-3 3-3s3 1.34 3 3v1h2v-1c0-1.66 1.34-3 3-3s3 1.34 3 3c0 0 0 0 .34.66l1.89-.66C20.1 16.17 18 10 9 8c0 0 0 0 0 0 0-1.66 1.34-3 3-3s3 1.34 3 3c0 0 0 0 0 0l2 0c0-2.76-2.24-5-5-5S7 5.24 7 8z"/>
              </svg>
            {% elsif block.settings.badge_1_icon == 'shield' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
              </svg>
            {% elsif block.settings.badge_1_icon == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M18 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-9H17V12h4.46L19.5 9.5zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM20 8l3 4v5h-2c0 1.66-1.34 3-3 3s-3-1.34-3-3H9c0 1.66-1.34 3-3 3s-3-1.34-3-3H1V6c0-1.1.9-2 2-2h14v4h3zM3 6v9h.76c.55-.61 1.35-1 2.24-1s1.69.39 2.24 1H15V6H3z"/>
              </svg>
            {% endif %}
          </div>
          <span>{{ block.settings.badge_1_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.badge_2_enabled %}
        <div class="ai-trust-review-badge-{{ ai_gen_id }}">
          <div class="ai-trust-review-badge-icon-{{ ai_gen_id }}">
            {% if block.settings.badge_2_icon == 'leaf' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.66-1.89C6 20 6 20 6 20c0-1.66 1.34-3 3-3s3 1.34 3 3v1h2v-1c0-1.66 1.34-3 3-3s3 1.34 3 3c0 0 0 0 .34.66l1.89-.66C20.1 16.17 18 10 9 8c0 0 0 0 0 0 0-1.66 1.34-3 3-3s3 1.34 3 3c0 0 0 0 0 0l2 0c0-2.76-2.24-5-5-5S7 5.24 7 8z"/>
              </svg>
            {% elsif block.settings.badge_2_icon == 'shield' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
              </svg>
            {% elsif block.settings.badge_2_icon == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M18 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-9H17V12h4.46L19.5 9.5zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM20 8l3 4v5h-2c0 1.66-1.34 3-3 3s-3-1.34-3-3H9c0 1.66-1.34 3-3 3s-3-1.34-3-3H1V6c0-1.1.9-2 2-2h14v4h3zM3 6v9h.76c.55-.61 1.35-1 2.24-1s1.69.39 2.24 1H15V6H3z"/>
              </svg>
            {% endif %}
          </div>
          <span>{{ block.settings.badge_2_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.badge_3_enabled %}
        <div class="ai-trust-review-badge-{{ ai_gen_id }}">
          <div class="ai-trust-review-badge-icon-{{ ai_gen_id }}">
            {% if block.settings.badge_3_icon == 'leaf' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.66-1.89C6 20 6 20 6 20c0-1.66 1.34-3 3-3s3 1.34 3 3v1h2v-1c0-1.66 1.34-3 3-3s3 1.34 3 3c0 0 0 0 .34.66l1.89-.66C20.1 16.17 18 10 9 8c0 0 0 0 0 0 0-1.66 1.34-3 3-3s3 1.34 3 3c0 0 0 0 0 0l2 0c0-2.76-2.24-5-5-5S7 5.24 7 8z"/>
              </svg>
            {% elsif block.settings.badge_3_icon == 'shield' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
              </svg>
            {% elsif block.settings.badge_3_icon == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M18 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-9H17V12h4.46L19.5 9.5zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM20 8l3 4v5h-2c0 1.66-1.34 3-3 3s-3-1.34-3-3H9c0 1.66-1.34 3-3 3s-3-1.34-3-3H1V6c0-1.1.9-2 2-2h14v4h3zM3 6v9h.76c.55-.61 1.35-1 2.24-1s1.69.39 2.24 1H15V6H3z"/>
              </svg>
            {% endif %}
          </div>
          <span>{{ block.settings.badge_3_text }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</trust-review-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustReviewSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('trust-review-section-{{ ai_gen_id }}', TrustReviewSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Trust and review section",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "text",
      "id": "rating_value",
      "label": "Rating value",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "200+ Reviews"
    },
    {
      "type": "range",
      "id": "rating_font_size",
      "label": "Rating font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#FFB800"
    },
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "checkbox",
      "id": "badge_1_enabled",
      "label": "Enable badge 1",
      "default": true
    },
    {
      "type": "select",
      "id": "badge_1_icon",
      "label": "Icon",
      "options": [
        {
          "value": "leaf",
          "label": "Leaf (Natural)"
        },
        {
          "value": "shield",
          "label": "Shield (Secure)"
        },
        {
          "value": "truck",
          "label": "Truck (Shipping)"
        }
      ],
      "default": "leaf"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Text",
      "default": "100% Natural"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "checkbox",
      "id": "badge_2_enabled",
      "label": "Enable badge 2",
      "default": true
    },
    {
      "type": "select",
      "id": "badge_2_icon",
      "label": "Icon",
      "options": [
        {
          "value": "leaf",
          "label": "Leaf (Natural)"
        },
        {
          "value": "shield",
          "label": "Shield (Secure)"
        },
        {
          "value": "truck",
          "label": "Truck (Shipping)"
        }
      ],
      "default": "shield"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Text",
      "default": "Secure Checkout"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "checkbox",
      "id": "badge_3_enabled",
      "label": "Enable badge 3",
      "default": true
    },
    {
      "type": "select",
      "id": "badge_3_icon",
      "label": "Icon",
      "options": [
        {
          "value": "leaf",
          "label": "Leaf (Natural)"
        },
        {
          "value": "shield",
          "label": "Shield (Secure)"
        },
        {
          "value": "truck",
          "label": "Truck (Shipping)"
        }
      ],
      "default": "truck"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Text",
