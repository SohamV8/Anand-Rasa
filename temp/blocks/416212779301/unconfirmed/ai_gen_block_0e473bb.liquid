{% doc %}
  @prompt
    reate a premium trust strip section positioned directly below the hero banner.
    
    Section Layout
    Full-width horizontal trust bar
    4 equal columns on desktop
    2 columns on tablet
    1 column on mobile
    Minimal luxury design matching a premium fragrance/attar brand
    Clean line icons above each heading
    Plenty of white space
    Center-aligned content
    Subtle top and bottom border
    Background: #F8F6F2
    Text color: #1E1E1E
    Content
    Column 1
    
    Icon: Leaf / Droplet
    
    Heading: 100% Alcohol-Free
    
    Description: Pure oil attars, never diluted with spirit or synthetic fragrances.
    
    Column 2
    
    Icon: Zodiac / Star
    
    Heading: Personalised by Astrology
    
    Description: Every attar mapped to a planet, zodiac sign, or nakshatra.
    
    Column 3
    
    Icon: Copper Still / Craft
    
    Heading: Hand-Distilled in India
    
    Description: Traditional deg-bhapka distillation. Crafted in small sacred batches.
    
    Column 4
    
    Icon: Rabbit / Vegan
    
    Heading: Vegan & Cruelty-Free
    
    Description: Plant-derived ingredients. Never tested on animals.
    
    Design Requirements
    Premium luxury fragrance aesthetic
    Elegant typography
    Heading font weight: 600-700
    Description font size: 14-16px
    Icons should be thin-outline style
    Smooth hover animation on each column
    Mobile optimized
    Fast loading and lightweight
    Accessible contrast ratios
    Add optional divider lines between columns on desktop
    Section Heading
    
    Hide section heading by default. The trust strip should appear as a clean credibility band directly under the hero section.
    
    Brand Context
    
    This section is for Anand Rasa, India's first astrology-personalized attar house, combining Vedic astrology, sacred perfumery, and traditional Indian attar craftsmanship.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-strip-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-top: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-trust-strip-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.padding_horizontal }}px;
  }

  .ai-trust-strip-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-trust-strip-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.column_padding }}px;
    transition: transform 0.3s ease;
    position: relative;
  }

  .ai-trust-strip-column-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-trust-strip-column-{{ ai_gen_id }}:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(-{{ block.settings.column_gap }}px / 2);
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: {{ block.settings.divider_height }}%;
    background-color: {{ block.settings.divider_color }};
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
  }

  .ai-trust-strip-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    color: {{ block.settings.icon_color }};
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-trust-strip-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .ai-trust-strip-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.3;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  .ai-trust-strip-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-trust-strip-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.column_gap | times: 0.8 }}px;
    }

    .ai-trust-strip-column-{{ ai_gen_id }}:nth-child(2n)::after {
      display: none;
    }

    .ai-trust-strip-column-{{ ai_gen_id }}:nth-child(n+3) {
      margin-top: {{ block.settings.column_gap | times: 0.5 }}px;
    }

    .ai-trust-strip-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }

    .ai-trust-strip-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-trust-strip-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-trust-strip-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_gap | times: 0.6 }}px;
    }

    .ai-trust-strip-column-{{ ai_gen_id }}::after {
      display: none;
    }

    .ai-trust-strip-column-{{ ai_gen_id }}:not(:last-child) {
      padding-bottom: {{ block.settings.column_padding | times: 1.5 }}px;
      border-bottom: 1px solid {{ block.settings.divider_color }};
      opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
    }

    .ai-trust-strip-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px 0;
    }

    .ai-trust-strip-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-trust-strip-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-trust-strip-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-strip-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-strip-container-{{ ai_gen_id }}">
    <div class="ai-trust-strip-grid-{{ ai_gen_id }}">
      <div class="ai-trust-strip-column-{{ ai_gen_id }}">
        <div class="ai-trust-strip-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
          </svg>
        </div>
        <h3 class="ai-trust-strip-heading-{{ ai_gen_id }}">{{ block.settings.column_1_heading }}</h3>
        <p class="ai-trust-strip-description-{{ ai_gen_id }}">{{ block.settings.column_1_description }}</p>
      </div>

      <div class="ai-trust-strip-column-{{ ai_gen_id }}">
        <div class="ai-trust-strip-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
            <path d="M16.24 7.76l-2.12 2.12"/>
            <path d="M9.88 14.12l-2.12 2.12"/>
          </svg>
        </div>
        <h3 class="ai-trust-strip-heading-{{ ai_gen_id }}">{{ block.settings.column_2_heading }}</h3>
        <p class="ai-trust-strip-description-{{ ai_gen_id }}">{{ block.settings.column_2_description }}</p>
      </div>

      <div class="ai-trust-strip-column-{{ ai_gen_id }}">
        <div class="ai-trust-strip-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3 class="ai-trust-strip-heading-{{ ai_gen_id }}">{{ block.settings.column_3_heading }}</h3>
        <p class="ai-trust-strip-description-{{ ai_gen_id }}">{{ block.settings.column_3_description }}</p>
      </div>

      <div class="ai-trust-strip-column-{{ ai_gen_id }}">
        <div class="ai-trust-strip-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/>
            <line x1="16" y1="8" x2="2" y2="22"/>
            <line x1="17.5" y1="15" x2="9" y2="15"/>
          </svg>
        </div>
        <h3 class="ai-trust-strip-heading-{{ ai_gen_id }}">{{ block.settings.column_4_heading }}</h3>
        <p class="ai-trust-strip-description-{{ ai_gen_id }}">{{ block.settings.column_4_description }}</p>
      </div>
    </div>
  </div>
</div>

