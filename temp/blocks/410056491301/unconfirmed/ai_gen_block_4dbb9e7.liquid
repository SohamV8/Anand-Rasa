{% doc %}
  @prompt
    Create a premium, minimal “Process Section” for an incense brand website.
    
    SECTION TITLE:
    
    * Heading: “The Process of Incense Making”
    * Center aligned
    * Elegant serif font (luxury feel)
    * Color: deep maroon or dark brown
    * Medium-large size with good spacing
    
    SECTION LAYOUT:
    
    * Horizontal 6-step process (grid layout)
    * Desktop: 6 columns in one row
    * Tablet: 3 columns per row
    * Mobile: 2 columns per row
    * Each step centered vertically and horizontally
    
    EACH STEP DESIGN:
    
    * Icon at top (line-style, minimal, gold color)
    * Icon size: medium (not too large, clean spacing)
    * Below icon: short description (1–2 lines)
    * Font: simple sans-serif
    * Color: dark grey or muted tone
    
    CONTENT (exact text for each step):
    
    1. “Flowers are collected from temples.”
    2. “The flowers are taken for sorting.”
    3. “They are handpicked and separated carefully.”
    4. “The dried flowers are turned into powder.”
    5. “A paste is made to prepare dhoop and incense sticks.”
    6. “The incense is blended and dipped in pure essential oils.”
    
    STYLE & DESIGN:
    
    * Background: off-white / light beige
    * Icons color: gold (#C9A34E or similar)
    * Spacing: generous padding (top & bottom)
    * Clean luxury Ayurvedic / spiritual brand aesthetic
    * No borders, no shadows (keep minimal)
    * Smooth alignment and equal spacing between items
    
    OPTIONAL ENHANCEMENTS:
    
    * Add subtle hover effect (icon slightly scales or color deepens)
    * Add small divider line under heading
    * Slight fade-in animation when scrolling
    
    TECH REQUIREMENTS:
    
    * Fully responsive
    * Optimized for Shopify Dawn theme
    * Section should be reusable and customizable
    * Allow editing of text and icons from theme editor
    
    GOAL:
    Design should feel premium, spiritual, and handcrafted — matching an incense or pooja product brand.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-process-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-process-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-process-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.divider_spacing }}px;
    line-height: 1.3;
  }

  .ai-process-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 auto;
  }

  .ai-process-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  .ai-process-step-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .ai-process-step-{{ ai_gen_id }}:hover {
    transform: {{ block.settings.hover_effect }};
  }

  .ai-process-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-process-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-process-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-weight: {{ block.settings.description_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-process-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }

    .ai-process-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-process-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-process-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.75);
    }

    .ai-process-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.85);
      height: calc({{ block.settings.icon_size }}px * 0.85);
    }

    .ai-process-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<incense-process-{{ ai_gen_id }} class="ai-process-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-process-container-{{ ai_gen_id }}">
    <div class="ai-process-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-process-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.show_divider %}
        <div class="ai-process-divider-{{ ai_gen_id }}"></div>
      {% endif %}
    </div>

    <div class="ai-process-grid-{{ ai_gen_id }}">
      {% if block.settings.step_1_enabled %}
        <div class="ai-process-step-{{ ai_gen_id }}">
          <div class="ai-process-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/>
              <path d="M12 6v6l4 2"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <p class="ai-process-description-{{ ai_gen_id }}">{{ block.settings.step_1_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.step_2_enabled %}
        <div class="ai-process-step-{{ ai_gen_id }}">
          <div class="ai-process-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M3 3h18v18H3z"/>
              <path d="M9 9h6v6H9z"/>
              <path d="M3 9h6M15 9h6M9 3v6M9 15v6M15 3v6M15 15v6"/>
            </svg>
          </div>
          <p class="ai-process-description-{{ ai_gen_id }}">{{ block.settings.step_2_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.step_3_enabled %}
        <div class="ai-process-step-{{ ai_gen_id }}">
          <div class="ai-process-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M9 11l3 3L22 4"/>
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
          </div>
          <p class="ai-process-description-{{ ai_gen_id }}">{{ block.settings.step_3_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.step_4_enabled %}
        <div class="ai-process-step-{{ ai_gen_id }}">
          <div class="ai-process-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
              <path d="M16.24 7.76l-2.12 2.12M7.76 16.24l2.12-2.12"/>
            </svg>
          </div>
          <p class="ai-process-description-{{ ai_gen_id }}">{{ block.settings.step_4_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.step_5_enabled %}
        <div class="ai-process-step-{{ ai_gen_id }}">
          <div class="ai-process-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="7.5 4.21 12 6.81 16.5 4.21"/>
              <polyline points="7.5 19.79 7.5 14.6 3 12"/>
              <polyline points="21 12 16.5 14.6 16.5 19.79"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
          </div>
          <p class="ai-process-description-{{ ai_gen_id }}">{{ block.settings.step_5_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.step_6_enabled %}
        <div class="ai-process-step-{{ ai_gen_id }}">
          <div class="ai-process-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
          </div>
          <p class="ai-process-description-{{ ai_gen_id }}">{{ block.settings.step_6_text }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</incense-process-{{ ai_gen_id }}>

<script>
  (function() {
    class IncenseProcess{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupObserver();
      }

      setupObserver() {
        const steps = this.querySelectorAll('.ai-process-step-{{ ai_gen_id }}');
        
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }
            });
          }, {
            threshold: 0.1
          });

          steps.forEach((step, index) => {
            step.style.opacity = '0';
            step.style.transform = 'translateY(20px)';
            step.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
            observer.observe(step);
          });
        }
      }
    }

    customElements.define('incense-process-{{ ai_gen_id }}', IncenseProcess{{ ai_gen_id }});
  })();
</script>

