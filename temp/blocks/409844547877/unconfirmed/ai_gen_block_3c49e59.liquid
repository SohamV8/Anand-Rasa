<script>
  (function() {
    class ProductComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const addToCartButton = this.querySelector('[data-add-to-cart]');
        if (addToCartButton) {
          addToCartButton.addEventListener('click', this.handleAddToCart.bind(this));
        }
      }

      handleAddToCart(event) {
        event.preventDefault();
        const form = document.querySelector('form[action="/cart/add"]');
        if (form) {
          const submitButton = form.querySelector('[type="submit"]');
          if (submitButton) {
            submitButton.click();
          }
        }
