      "content": "Tags filter"
    },
    {
      "type": "checkbox",
      "id": "show_tags_filter",
      "label": "Show tags filter",
      "default": true
    },
    {
      "type": "text",
      "id": "tags_label",
      "label": "Tags label",
      "default": "Tags"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
