{% doc %}
  @prompt
    Create a section with 4 short feature pointers, each with a small icon or image, a short heading, and a one-line description. Display them in a horizontal row or 2x2 grid. Style should be clean and minimal, suitable for a fragrance/incense product store. Examples: "100% Natural Ingredients", "Hand Crafted", "Long Lasting Fragrance", "Eco Friendly Packaging". Each pointer should have an uploadable image/icon field and editable text.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-features-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_desktop }}px;
  }

  .ai-feature-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-feature-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    flex-shrink: 0;
  }

  .ai-feature-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-feature-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-feature-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.3;
  }

  .ai-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-features-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-feature-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-feature-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-feature-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-features-container-{{ ai_gen_id }}">
    <div class="ai-features-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'feature_' | append: i | append: '_icon'
          assign heading_key = 'feature_' | append: i | append: '_heading'
          assign description_key = 'feature_' | append: i | append: '_description'
          
          assign icon = block.settings[icon_key]
          assign heading = block.settings[heading_key]
          assign description = block.settings[description_key]
        %}
        
        <div class="ai-feature-item-{{ ai_gen_id }}">
          <div class="ai-feature-icon-wrapper-{{ ai_gen_id }}">
            {% if icon %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt="{{ heading | escape }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-feature-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if heading != blank %}
            <h3 class="ai-feature-heading-{{ ai_gen_id }}">{{ heading }}</h3>
          {% endif %}
          
          {% if description != blank %}
            <p class="ai-feature-description-{{ ai_gen_id }}">{{ description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Feature pointers",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 800,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap on desktop",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap on mobile",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Feature 1"
    },
    {
      "type": "image_picker",
      "id": "feature_1_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "feature_1_heading",
      "label": "Heading",
      "default": "100% Natural Ingredients"
    },
    {
      "type": "textarea",
      "id": "feature_1_description",
      "label": "Description",
      "default": "Pure and authentic fragrances from nature"
    },
    {
      "type": "header",
      "content": "Feature 2"
    },
    {
      "type": "image_picker",
      "id": "feature_2_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "feature_2_heading",
      "label": "Heading",
      "default": "Hand Crafted"
    },
    {
      "type": "textarea",
      "id": "feature_2_description",
      "label": "Description",
      "default": "Carefully made with traditional techniques"
    },
    {
      "type": "header",
      "content": "Feature 3"
    },
    {
      "type": "image_picker",
      "id": "feature_3_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "feature_3_heading",
      "label": "Heading",
      "default": "Long Lasting Fragrance"
    },
    {
      "type": "textarea",
      "id": "feature_3_description",
      "label": "Description",
      "default": "Enjoy hours of aromatic bliss"
    },
    {
      "type": "header",
      "content": "Feature 4"
    },
    {
      "type": "image_picker",
      "id": "feature_4_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "feature_4_heading",
      "label": "Heading",
      "default": "Eco Friendly Packaging"
    },
    {
