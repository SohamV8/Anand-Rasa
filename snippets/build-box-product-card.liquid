{%- comment -%}
  Luxury fragrance card — Build Your Attar Box

  @param product {Product}
  @param size_label {String} optional, e.g. "6ml" or "20ml"
{%- endcomment -%}
{%- liquid
  assign byb_size_label = size_label | default: '6ml'
  assign byb_variant = product.selected_or_first_available_variant
  assign byb_available = byb_variant.available
  assign byb_price_cents = byb_variant.price

  capture byb_notes
    render 'build-box-product-notes', product: product
  endcapture
  assign byb_notes = byb_notes | strip

  capture byb_category
    render 'build-box-category', product: product
  endcapture
  assign byb_category = byb_category | strip

  capture byb_img_asset
    render 'bestseller-image-lookup', bs_product: product
  endcapture
  assign byb_img_asset = byb_img_asset | strip

  if byb_img_asset != blank
    assign byb_img = byb_img_asset | asset_url
    assign byb_img_srcset = ''
  elsif product.featured_image
    assign byb_img = product.featured_image | image_url: width: 600
    assign byb_img_w400 = product.featured_image | image_url: width: 400
    assign byb_img_w600 = product.featured_image | image_url: width: 600
    assign byb_img_w900 = product.featured_image | image_url: width: 900
    assign byb_img_srcset = byb_img_w400 | append: ' 400w, ' | append: byb_img_w600 | append: ' 600w, ' | append: byb_img_w900 | append: ' 900w'
  else
    assign byb_img = ''
    assign byb_img_srcset = ''
  endif

  if byb_notes != blank
    assign byb_notes = byb_notes | truncate: 110
  endif
-%}

<article
  class="byb-card"
  data-byb-card
  data-variant-id="{{ byb_variant.id }}"
  data-product-id="{{ product.id }}"
  data-product-url="{{ product.url }}"
  data-product-title="{{ product.title | escape }}"
  data-product-image="{{ byb_img | escape }}"
  data-variant-price="{{ byb_price_cents }}"
  data-available="{{ byb_available }}"
  aria-pressed="false"
  tabindex="0"
>
  <div class="byb-card__glow" aria-hidden="true"></div>

  <a href="{{ product.url }}" class="byb-card__media-link" tabindex="-1" aria-hidden="true">
    <div class="byb-card__media">
      <div class="byb-card__media-glass" aria-hidden="true"></div>
      {%- if byb_img != blank -%}
        <img
          class="byb-card__img"
          src="{{ byb_img }}"
          {% if byb_img_srcset != blank %}srcset="{{ byb_img_srcset }}" sizes="(min-width: 1100px) 300px, (min-width: 640px) 46vw, 92vw"{% endif %}
          alt="{{ product.title | escape }} — {{ byb_size_label }} luxury fragrance"
          width="480"
          height="480"
          loading="lazy"
          decoding="async"
        >
      {%- endif -%}
      <span class="byb-card__size">{{ byb_size_label }}</span>
    </div>
  </a>

  <div class="byb-card__body">
    {%- if byb_category != blank -%}
      <p class="byb-card__category">{{ byb_category }}</p>
    {%- endif -%}
    <h3 class="byb-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    {%- if byb_notes != blank -%}
      <p class="byb-card__notes">{{ byb_notes }}</p>
    {%- endif -%}
    <p class="byb-card__price">{{ byb_variant.price | money }}</p>
  </div>

  <button
    type="button"
    class="byb-card__ritual"
    data-byb-toggle
    {% unless byb_available %}disabled aria-disabled="true"{% endunless %}
  >
    <span class="byb-card__ritual-label" data-byb-toggle-add>Add to Ritual</span>
    <span class="byb-card__ritual-label" data-byb-toggle-on hidden>In Your Ritual</span>
  </button>

  <span class="byb-card__check" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  </span>
</article>
