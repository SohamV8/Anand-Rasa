{%- comment -%}
  Inline SVG icons for Planetary Mantra Experience blessing cards.
  @param icon {string} lotus | sun | peace | sparkle | shield | harmony | leaf | flame | moon
{%- endcomment -%}

{%- case icon -%}
  {%- when 'sun' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
  {%- when 'peace' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3c-3.5 2.5-6 5.5-6 9a6 6 0 1012 0c0-3.5-2.5-6.5-6-9z" stroke="currentColor" stroke-width="1.4"/><path d="M12 14v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
  {%- when 'sparkle' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l1.2 4.8L18 8l-4.8 1.2L12 14l-1.2-4.8L6 8l4.8-1.2L12 2zM19 14l.6 2.4L22 17l-2.4.6L19 20l-.6-2.4L16 17l2.4-.6L19 14z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
  {%- when 'shield' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
  {%- when 'harmony' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="8" cy="12" r="4" stroke="currentColor" stroke-width="1.4"/><circle cx="16" cy="12" r="4" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'leaf' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 4C10 4 4 10 4 20c10 0 16-6 16-16z" stroke="currentColor" stroke-width="1.4"/><path d="M4 20c4-2 8-6 10-10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
  {%- when 'flame' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3c2 3 4 5 4 8a4 4 0 11-8 0c0-3 2-5 4-8z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
  {%- when 'moon' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 14.5A7.5 7.5 0 1111.5 6 6.5 6.5 0 0020 14.5z" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3c-1.5 2-3 4.5-3 7a3 3 0 006 0c0-2.5-1.5-5-3-7z" stroke="currentColor" stroke-width="1.4"/><path d="M8 17c1.2 1.5 2.6 2 4 2s2.8-.5 4-2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M7 20h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
{%- endcase -%}
