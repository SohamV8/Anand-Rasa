{%- comment -%} 4. SHOP TRIO {%- endcomment -%}
{%- capture ar_trio_incense_url -%}{% render 'ar-collection-url', handle: 'incense-sticks' %}{%- endcapture -%}
{%- capture ar_trio_stress_url -%}{% render 'ar-collection-url', handle: 'stress-relief' %}{%- endcapture -%}
{%- capture ar_trio_love_url -%}{% render 'ar-collection-url', handle: 'love-attar' %}{%- endcapture -%}
<section class="ar-trio">
  <div class="ar-trio__grid">
    <div class="ar-trio__left">
      <a href="{{ section.settings.t1_url | default: ar_trio_incense_url }}" class="ar-trio__card">
        {%- if section.settings.t1_image != blank -%}<img src="{{ section.settings.t1_image | image_url: width: 1200 }}" alt="{{ section.settings.t1_image.alt | default: 'Incense Sticks' }}" width="1200" height="800" loading="lazy" class="ar-trio__img">{%- else -%}<img src="{{ 'Incensehero.webp' | asset_url }}" alt="Incense Sticks" width="1200" height="800" loading="lazy" class="ar-trio__img">{%- endif -%}
        <div class="ar-trio__ov"></div>
        <div class="ar-trio__cta-wrap"><span class="ar-trio__cta">{{ section.settings.t1_label | default: 'Shop Now' }}</span></div>
      </a>
    </div>
    <div class="ar-trio__right">
      <a href="{{ section.settings.t2_url | default: ar_trio_stress_url }}" class="ar-trio__card">
        {%- if section.settings.t2_image != blank -%}<img src="{{ section.settings.t2_image | image_url: width: 800 }}" alt="{{ section.settings.t2_image.alt | default: 'Stress Relief' }}" width="800" height="600" loading="lazy" class="ar-trio__img">{%- else -%}<img src="{{ 'stress_calm.webp' | asset_url }}" alt="Stress Relief" width="800" height="600" loading="lazy" class="ar-trio__img">{%- endif -%}
        <div class="ar-trio__ov"></div>
        <div class="ar-trio__cta-wrap"><span class="ar-trio__cta">{{ section.settings.t2_label | default: 'Shop Now' }}</span></div>
      </a>
      <a href="{{ section.settings.t3_url | default: ar_trio_love_url }}" class="ar-trio__card">
        {%- if section.settings.t3_image != blank -%}<img src="{{ section.settings.t3_image | image_url: width: 800 }}" alt="{{ section.settings.t3_image.alt | default: 'Love Attars' }}" width="800" height="600" loading="lazy" class="ar-trio__img">{%- else -%}<img src="{{ 'love.webp' | asset_url }}" alt="Love Attars" width="800" height="600" loading="lazy" class="ar-trio__img">{%- endif -%}
        <div class="ar-trio__ov"></div>
        <div class="ar-trio__cta-wrap"><span class="ar-trio__cta">{{ section.settings.t3_label | default: 'Shop Now' }}</span></div>
      </a>
    </div>
  </div>
</section>
