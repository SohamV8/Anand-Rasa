{%- comment -%} 9. INCENSE BANNER {%- endcomment -%}
{%- capture ar_incense_banner_url -%}{% render 'ar-collection-url', handle: 'incense-sticks' %}{%- endcapture -%}
{%- liquid
  assign ar_incense_url = section.settings.incense_url | strip
  if ar_incense_url == blank or ar_incense_url contains 'collections' or ar_incense_url contains 'shopify://collections'
    assign ar_incense_url = ar_incense_banner_url
  endif
-%}
{%- if section.settings.incense_image != blank -%}
  <a href="{{ ar_incense_url }}" class="ar-incense" aria-label="Shop Incense Sticks">
    <img
      src="{{ section.settings.incense_image | image_url: width: 1600 }}"
      srcset="{{ section.settings.incense_image | image_url: width: 600 }} 600w, {{ section.settings.incense_image | image_url: width: 1000 }} 1000w, {{ section.settings.incense_image | image_url: width: 1600 }} 1600w, {{ section.settings.incense_image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      alt="{{ section.settings.incense_image.alt | default: 'Anand Rasa Incense Sticks' }}"
      width="{{ section.settings.incense_image.width | default: 2000 }}"
      height="{{ section.settings.incense_image.height | default: 800 }}"
      loading="lazy"
    >
  </a>
{%- else -%}
  <a href="{{ ar_incense_url }}" class="ar-incense" aria-label="Shop Incense Sticks">
    <img
      src="{{ 'incense.jpeg' | asset_url }}"
      sizes="100vw"
      alt="Anand Rasa Incense Sticks"
      width="2000"
      height="800"
      loading="lazy"
    >
  </a>
{%- endif -%}
