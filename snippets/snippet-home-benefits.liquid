<section class="ar-bp">
  <div class="ar-bp__container">

    <h2 class="ar-bp__heading">
      {{ heading }}
    </h2>

    <div class="ar-bp__grid">

      {% if card_title_1 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_1 }}</div>
          <p class="ar-bp__text">{{ card_text_1 }}</p>
        </div>
      </div>
      {% endif %}

      {% if card_title_2 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_2 }}</div>
          <p class="ar-bp__text">{{ card_text_2 }}</p>
        </div>
      </div>
      {% endif %}

      {% if card_title_3 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_3 }}</div>
          <p class="ar-bp__text">{{ card_text_3 }}</p>
        </div>
      </div>
      {% endif %}

      {% if card_title_4 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_4 }}</div>
          <p class="ar-bp__text">{{ card_text_4 }}</p>
        </div>
      </div>
      {% endif %}

    </div>
  </div>
</section>


<section class="ar-dk">
  <div class="ar-dk__container">

    <div class="ar-dk__imageWrap">
      {% if combo_image != blank %}
        <img src="{{ combo_image }}" class="ar-dk__image" loading="lazy" alt="{{ combo_heading }}">
      {% endif %}
    </div>

    <div class="ar-dk__content">
      <h2 class="ar-dk__heading">{{ combo_heading }}</h2>
      <p class="ar-dk__text">{{ combo_text }}</p>

      {% if combo_url != blank %}
        <a href="{{ combo_url }}" class="ar-dk__btn">
          {{ combo_btn }}
        </a>
      {% endif %}
    </div>

  </div>
</section>


<section class="ar-story">
  <div class="ar-story__container">

    <h2 class="ar-story__heading">
      {{ story_heading }}
    </h2>

    <p class="ar-story__text">
      {{ story_text }}
    </p>

    {% if story_url != blank %}
      <a href="{{ story_url }}" class="ar-story__btn">
        {{ story_btn }}
      </a>
    {% endif %}

  </div>
</section>


<style>

/* =====================
   ANIMATION
   ===================== */
.ar-bp__item,
.ar-story__container,
.ar-dk__container {
  opacity: 0;
  transform: translateY(36px) scale(0.98);
  transition: opacity 0.75s cubic-bezier(0.22, 1, 0.36, 1),
              transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
}

.ar-animate {
  opacity: 1 !important;
  transform: translateY(0) scale(1) !important;
}

/* =====================
   BRAND PHILOSOPHY
   ===================== */
.ar-bp {
  min-height: 90vh;
  display: flex;
  align-items: center;
  background: #F6F1E7;
   border-bottom: 1.5px solid #111;
}

.ar-bp__container {
  max-width: 1380px;
  margin: 0 auto;
  padding: 90px 32px;
}

.ar-bp__heading {
  font-size: clamp(32px, 4.5vw, 58px);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.1;
  text-align: center;
  color: #111;
  margin-bottom: 64px;
}

.ar-bp__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

/* Card wrapper — creates the offset shadow illusion */
.ar-bp__item {
  position: relative;
}



.ar-bp__card {
  position: relative;
  z-index: 1;
  background: #ffffff;
  border-radius: 20px;
  padding: 28px 24px 32px;
  border: 1.5px solid #111;
  height: 100%;
  box-sizing: border-box;
  box-shadow: 8px 8px 0 #e79abc;
}

.ar-bp__pill {
  display: inline-block;
  padding: 9px 18px;
  background: #e88ba4;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: #111;
  margin-bottom: 18px;
  line-height: 1.3;
  text-align: center;
}

.ar-bp__text {
  font-size: 14.5px;
  line-height: 1.75;
  color: #333;
  margin: 0;
}

/* =====================
   DISCOVERY KIT
   ===================== */
.ar-dk {
  min-height: 80vh;
  display: flex;
  align-items: center;
  background: #FFFFFF;
}

.ar-dk__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 80px 32px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: center;
}

/* Image — sharp edges, constrained size */
.ar-dk__imageWrap {
  display: flex;
  justify-content: center;
  align-items: center;
}

.ar-dk__image {
  width: 100%;
  max-width: 420px;
  height: auto;
  display: block;
  border-radius: 0;              /* sharp edges */
  object-fit: cover;
}

.ar-dk__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.ar-dk__heading {
  font-size: clamp(28px, 3vw, 42px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #111;
  margin: 0 0 16px;
  line-height: 1.15;
}

.ar-dk__text {
  font-size: 16px;
  line-height: 1.75;
  color: #555;
  margin: 0 0 32px;
}

/* Discovery Kit CTA button */
.ar-dk__btn {
  display: inline-block;
  padding: 13px 32px;
  border: 1.5px solid #111;
  background: transparent;
  color: #111;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 0;
  transition: background 0.22s ease, color 0.22s ease;
  cursor: pointer;
}

.ar-dk__btn:hover {
  background: #111;
  color: #fff;
}

/* =====================
   STORY (More than fragrance)
   ===================== */
.ar-story {
  position: relative;
  overflow: hidden;
  isolation: isolate;
  min-height: 70vh;
  display: flex;
  align-items: center;
  text-align: center;
  background-color: #0f0f0f;
}

.ar-story::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -2;
  background:
    linear-gradient(180deg, rgba(15, 15, 15, 0.32) 0%, rgba(15, 15, 15, 0.58) 100%),
    url('{{ "about.webp" | asset_url }}') center center / cover no-repeat;
  transform: scale(1.03);
  animation: ar-story-drift 13s cubic-bezier(0.22, 1, 0.36, 1) infinite alternate;
}

.ar-story::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(90deg, rgba(15, 15, 15, 0.18), rgba(15, 15, 15, 0.28));
}

.ar-story__container {
  position: relative;
  z-index: 1;
  max-width: 760px;
  margin: 0 auto;
  padding: 80px 24px;
}

.ar-story__heading {
  font-size: clamp(30px, 4vw, 50px);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #ffffff;
  margin: 0 0 18px;
  line-height: 1.15;
}

.ar-story__text {
  font-size: 16px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.9);
  margin: 0 0 28px;
}

/* Smaller, refined story button */
.ar-story__btn {
  display: inline-block;
  padding: 9px 22px;
  border: 1.5px solid rgba(255, 255, 255, 0.9);
  color: #ffffff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  background: rgba(255, 255, 255, 0.08);
  transition: background 0.22s ease, color 0.22s ease;
  cursor: pointer;
}

.ar-story__btn:hover {
  background: #ffffff;
  color: #111;
}

@keyframes ar-story-drift {
  0% {
    transform: scale(1.03) translate3d(0, 0, 0);
  }
  100% {
    transform: scale(1.08) translate3d(0, -10px, 0);
  }
}

/* =====================
   RESPONSIVE
   ===================== */
@media (max-width: 1100px) {
  .ar-bp__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 900px) {
  .ar-dk__container {
    grid-template-columns: 1fr;
    gap: 40px;
    text-align: center;
  }

  .ar-dk__content {
    align-items: center;
  }

  .ar-dk__imageWrap {
    justify-content: center;
  }

  .ar-dk__image {
    max-width: 340px;
  }
}

@media (max-width: 640px) {
  .ar-bp__grid {
    grid-template-columns: 1fr;
  }

  .ar-bp__heading {
    font-size: 32px;
  }

  .ar-dk__container {
    padding: 60px 20px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .ar-story::before {
    animation: none;
    transform: none;
  }
}

</style>


<script>
document.addEventListener("DOMContentLoaded", () => {
  const els = document.querySelectorAll(".ar-bp__item, .ar-story__container, .ar-dk__container");
  if (!els.length) return;

  const obs = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add("ar-animate");
        }, i * 110);
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  els.forEach(el => obs.observe(el));
});
</script>
