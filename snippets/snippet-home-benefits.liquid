<section class="ar-bp">
  <div class="ar-bp__container">

    <h2 class="ar-bp__heading">
      {{ heading }}
    </h2>

    <div class="ar-bp__grid">

      {% if card_title_1 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_1 }}</div>
          <p class="ar-bp__text">{{ card_text_1 }}</p>
        </div>
      </div>
      {% endif %}

      {% if card_title_2 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_2 }}</div>
          <p class="ar-bp__text">{{ card_text_2 }}</p>
        </div>
      </div>
      {% endif %}

      {% if card_title_3 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_3 }}</div>
          <p class="ar-bp__text">{{ card_text_3 }}</p>
        </div>
      </div>
      {% endif %}

      {% if card_title_4 != blank %}
      <div class="ar-bp__item">
        
        <div class="ar-bp__card">
          <div class="ar-bp__pill">{{ card_title_4 }}</div>
          <p class="ar-bp__text">{{ card_text_4 }}</p>
        </div>
      </div>
      {% endif %}

    </div>
  </div>
</section>

{%- capture ar_combo_default_url -%}{% render 'ar-page-url', handle: 'build-your-box' %}{%- endcapture -%}
{%- capture ar_story_default_url -%}{% render 'ar-page-url', handle: 'about' %}{%- endcapture -%}
{%- liquid
  assign ar_combo_href = combo_url | strip
  assign ar_story_href = story_url | strip
  if ar_combo_href == blank or ar_combo_href contains 'collections' or ar_combo_href contains 'shopify://collections'
    assign ar_combo_href = ar_combo_default_url
  endif
  if ar_story_href == blank or ar_story_href contains '/pages/about'
    assign ar_story_href = ar_story_default_url
  endif
  assign ar_gift_sets_href = gift_sets_url | strip
  if ar_gift_sets_href == blank
    capture ar_gift_sets_href
      render 'ar-collection-url', handle: 'gift-sets'
    endcapture
    assign ar_gift_sets_href = ar_gift_sets_href | strip
  endif
  if ar_gift_sets_href == blank or ar_gift_sets_href == routes.collections_url
    assign ar_gift_sets_href = '/collections/gift-set?view=gift-sets'
  endif
-%}

<section class="ar-dk" aria-labelledby="ar-dk-heading">
  <div class="ar-dk__container">

    <div class="ar-dk__media">
      <div class="ar-dk__media-frame">
        <div class="ar-dk__media-glow" aria-hidden="true"></div>
        {%- if combo_image != blank -%}
          <img
            class="ar-dk__image"
            src="{{ combo_image }}"
            {% if combo_image_srcset != blank %}srcset="{{ combo_image_srcset }}" sizes="(min-width: 900px) 48vw, 92vw"{% endif %}
            width="{{ combo_image_width | default: 1400 }}"
            height="{{ combo_image_height | default: 1050 }}"
            alt="{{ combo_heading | default: 'Build Your Attar Box' | escape }}"
            loading="lazy"
            decoding="async"
          >
        {%- endif -%}
      </div>
    </div>

    <div class="ar-dk__content">
      {%- if combo_eyebrow != blank -%}
        <p class="ar-dk__eyebrow">{{ combo_eyebrow }}</p>
      {%- endif -%}

      {%- if combo_heading != blank -%}
        <h2 id="ar-dk-heading" class="ar-dk__heading">{{ combo_heading }}</h2>
      {%- endif -%}

      {%- if combo_text != blank -%}
        <p class="ar-dk__text">{{ combo_text }}</p>
      {%- endif -%}

      {%- if combo_note != blank -%}
        <p class="ar-dk__note">{{ combo_note }}</p>
      {%- endif -%}

      {%- if ar_combo_href != blank and combo_btn != blank -%}
        <a href="{{ ar_combo_href }}" class="ar-dk__btn">
          <span class="ar-dk__btn-label">{{ combo_btn }}</span>
        </a>
      {%- endif -%}
    </div>

  </div>

  <div class="ar-dk__gift">
    <a href="{{ ar_gift_sets_href }}" class="ar-dk__gift-link" aria-label="Shop gift sets — curated attar and perfume gift collections">
      <img
        class="ar-dk__gift-image"
        src="{{ 'gift.webp' | asset_url }}"
        alt="Anand Rasa luxury attar and perfume gift sets"
        width="2400"
        height="800"
        sizes="100vw"
        loading="lazy"
        decoding="async"
      >
    </a>
  </div>
</section>


<section class="ar-story">
  <div class="ar-story__container">

    <h2 class="ar-story__heading">
      {{ story_heading }}
    </h2>

    <p class="ar-story__text">
      {{ story_text }}
    </p>

    {% if ar_story_href != blank %}
      <a href="{{ ar_story_href }}" class="ar-story__btn">
        {{ story_btn }}
      </a>
    {% endif %}

  </div>
</section>


<style>

/* =====================
   ANIMATION
   ===================== */
.ar-bp__item,
.ar-story__container,
.ar-dk {
  opacity: 0;
  transform: translateY(36px) scale(0.98);
  transition: opacity 0.75s cubic-bezier(0.22, 1, 0.36, 1),
              transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
}

.ar-dk__content > * {
  opacity: 0;
  transform: translateY(18px);
  transition:
    opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
}

.ar-dk.ar-animate .ar-dk__content > * {
  opacity: 1;
  transform: translateY(0);
}

.ar-dk.ar-animate .ar-dk__eyebrow { transition-delay: 0.05s; }
.ar-dk.ar-animate .ar-dk__heading { transition-delay: 0.12s; }
.ar-dk.ar-animate .ar-dk__text { transition-delay: 0.2s; }
.ar-dk.ar-animate .ar-dk__note { transition-delay: 0.28s; }
.ar-dk.ar-animate .ar-dk__btn { transition-delay: 0.36s; }

.ar-dk__media-frame {
  opacity: 0;
  transform: translateY(24px) scale(0.98);
  transition:
    opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
}

.ar-dk.ar-animate .ar-dk__media-frame {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.ar-animate {
  opacity: 1 !important;
  transform: translateY(0) scale(1) !important;
}

/* =====================
   BRAND PHILOSOPHY
   ===================== */
.ar-bp {
  min-height: 90vh;
  display: flex;
  align-items: center;
  background: #F6F1E7;
   border-bottom: 1.5px solid #111;
}

.ar-bp__container {
  max-width: 1380px;
  margin: 0 auto;
  padding: 90px 32px;
}

.ar-bp__heading {
  font-size: clamp(32px, 4.5vw, 58px);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.1;
  text-align: center;
  color: #111;
  margin-bottom: 64px;
}

.ar-bp__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

/* Card wrapper — creates the offset shadow illusion */
.ar-bp__item {
  position: relative;
}



.ar-bp__card {
  position: relative;
  z-index: 1;
  background: #ffffff;
  border-radius: 20px;
  padding: 28px 24px 32px;
  border: 1.5px solid #111;
  height: 100%;
  box-sizing: border-box;
  box-shadow: 8px 8px 0 #e79abc;
}

.ar-bp__pill {
  display: inline-block;
  padding: 9px 18px;
  background: #e88ba4;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.01em;
  color: #111;
  margin-bottom: 18px;
  line-height: 1.3;
  text-align: center;
}

.ar-bp__text {
  font-size: 14.5px;
  line-height: 1.75;
  color: #333;
  margin: 0;
}

/* =====================
   BUILD YOUR ATTAR BOX
   ===================== */
.ar-dk {
  --ar-dk-ink: #1e2023;
  --ar-dk-muted: #4a4540;
  --ar-dk-soft: #6b6560;
  --ar-dk-gold: #b8943a;
  --ar-dk-gold-glow: rgba(184, 148, 58, 0.1);
  --ar-dk-ease: cubic-bezier(0.22, 1, 0.36, 1);
  min-height: min(88vh, 920px);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  background: #ffffff;
  font-family: var(--font-body-family, Georgia, serif);
  overflow: hidden;
}

.ar-dk__container {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: clamp(64px, 8vw, 104px) clamp(20px, 4vw, 40px);
  display: grid;
  grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
  gap: clamp(40px, 6vw, 88px);
  align-items: center;
}

.ar-dk__media {
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
}

.ar-dk__media-frame {
  position: relative;
  width: 100%;
  max-width: min(540px, 100%);
  aspect-ratio: 4 / 3;
  display: flex;
  align-items: center;
  justify-content: center;
  will-change: transform;
  animation: ar-dk-float 9s var(--ar-dk-ease) infinite alternate;
}

.ar-dk__media-glow {
  position: absolute;
  inset: 8% 6% 4%;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 42%, var(--ar-dk-gold-glow), transparent 68%);
  pointer-events: none;
  z-index: 0;
  opacity: 0.85;
}

.ar-dk__image {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
  filter: drop-shadow(0 28px 48px rgba(30, 32, 35, 0.14));
  transform: translateZ(0) scale(1);
  transition: transform 1.1s var(--ar-dk-ease), filter 1.1s var(--ar-dk-ease);
  backface-visibility: hidden;
}

@media (hover: hover) and (pointer: fine) {
  .ar-dk__media-frame:hover .ar-dk__image {
    transform: translateZ(0) scale(1.035);
    filter: drop-shadow(0 34px 56px rgba(30, 32, 35, 0.18));
  }
}

.ar-dk__gift {
  width: 100%;
  margin: 0 0 clamp(24px, 4vw, 40px);
  padding: 0;
}

.ar-dk__gift-link {
  display: block;
  width: 100%;
  margin: 0;
  border-radius: 0;
  overflow: hidden;
  box-shadow: none;
}

.ar-dk__gift-image {
  display: block;
  width: 100%;
  height: auto;
  object-fit: cover;
  object-position: center;
  box-shadow: none;
  filter: none;
}

.ar-dk__gift-link:focus-visible {
  outline: 2px solid var(--ar-dk-gold);
  outline-offset: -2px;
}

.ar-dk__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  max-width: 38rem;
  min-width: 0;
}

.ar-dk__eyebrow {
  margin: 0 0 clamp(16px, 2.2vw, 22px);
  font-family: var(--font-heading-family, 'Poppins', sans-serif);
  font-size: clamp(11px, 1.35vw, 13px);
  font-weight: 600;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--ar-dk-gold);
  line-height: 1.4;
}

.ar-dk__heading {
  font-family: var(--font-heading-family, 'Poppins', sans-serif);
  font-size: clamp(2.35rem, 5.2vw, 3.65rem);
  font-weight: 600;
  letter-spacing: -0.035em;
  color: var(--ar-dk-ink);
  margin: 0 0 clamp(20px, 2.8vw, 28px);
  line-height: 1.08;
  text-wrap: balance;
}

.ar-dk__text {
  font-family: var(--font-body-family, 'Caudex', Georgia, serif);
  font-size: clamp(1.125rem, 1.85vw, 1.375rem);
  line-height: 1.72;
  color: var(--ar-dk-muted);
  margin: 0 0 clamp(16px, 2.2vw, 22px);
  max-width: 36rem;
}

.ar-dk__note {
  font-family: var(--font-body-family, 'Caudex', Georgia, serif);
  font-size: clamp(1rem, 1.5vw, 1.2rem);
  line-height: 1.62;
  color: var(--ar-dk-soft);
  margin: 0 0 clamp(32px, 4vw, 40px);
  max-width: 32rem;
}

.ar-dk__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  padding: 16px 40px;
  border: 1px solid rgba(30, 32, 35, 0.88);
  border-radius: 2px;
  background: #ffffff;
  color: var(--ar-dk-ink);
  font-family: var(--font-heading-family, 'Poppins', sans-serif);
  font-size: clamp(11px, 1.1vw, 12px);
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.9) inset,
    0 10px 28px rgba(30, 32, 35, 0.06);
  transform: translateY(0) translateZ(0);
  transition:
    transform 0.45s var(--ar-dk-ease),
    background 0.45s var(--ar-dk-ease),
    color 0.45s var(--ar-dk-ease),
    border-color 0.45s var(--ar-dk-ease),
    box-shadow 0.45s var(--ar-dk-ease);
  cursor: pointer;
}

.ar-dk__btn-label {
  position: relative;
  z-index: 1;
}

@media (hover: hover) and (pointer: fine) {
  .ar-dk__btn:hover,
  .ar-dk__btn:focus-visible {
    transform: translateY(-2px) translateZ(0);
    background: var(--ar-dk-ink);
    border-color: var(--ar-dk-ink);
    color: #fff;
    box-shadow:
      0 14px 36px rgba(30, 32, 35, 0.14),
      0 0 0 1px rgba(184, 148, 58, 0.12);
  }
}

.ar-dk__btn:focus-visible {
  outline: 2px solid var(--ar-dk-gold);
  outline-offset: 3px;
}


@keyframes ar-dk-float {
  0% {
    transform: translate3d(0, 0, 0);
  }
  100% {
    transform: translate3d(0, -8px, 0);
  }
}

/* =====================
   STORY (More than fragrance)
   ===================== */
.ar-story {
  position: relative;
  overflow: hidden;
  isolation: isolate;
  min-height: 70vh;
  display: flex;
  align-items: center;
  text-align: center;
  background-color: #0f0f0f;
}

.ar-story::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -2;
  background:
    linear-gradient(180deg, rgba(15, 15, 15, 0.32) 0%, rgba(15, 15, 15, 0.58) 100%),
    url('{{ "about.webp" | asset_url }}') center center / cover no-repeat;
  transform: scale(1.03);
  animation: ar-story-drift 13s cubic-bezier(0.22, 1, 0.36, 1) infinite alternate;
}

.ar-story::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(90deg, rgba(15, 15, 15, 0.18), rgba(15, 15, 15, 0.28));
}

.ar-story__container {
  position: relative;
  z-index: 1;
  max-width: 760px;
  margin: 0 auto;
  padding: 80px 24px;
}

.ar-story__heading {
  font-size: clamp(30px, 4vw, 50px);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #ffffff;
  margin: 0 0 18px;
  line-height: 1.15;
}

.ar-story__text {
  font-size: 16px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.9);
  margin: 0 0 28px;
}

/* Smaller, refined story button */
.ar-story .ar-story__btn {
  display: inline-block;
  padding: 12px 32px;
  border: 1.5px solid rgba(255, 255, 255, 0.85);
  border-radius: 0;
  color: #ffffff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  background: transparent;
  transition:
    transform 350ms cubic-bezier(0.22, 1, 0.36, 1),
    background-color 350ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 350ms cubic-bezier(0.22, 1, 0.36, 1),
    color 350ms cubic-bezier(0.22, 1, 0.36, 1);
  cursor: pointer;
}

.ar-story .ar-story__btn:hover {
  background-color: #111111;
  border-color: #111111;
  color: #ffffff;
  transform: translateY(-2px);
}

@keyframes ar-story-drift {
  0% {
    transform: scale(1.03) translate3d(0, 0, 0);
  }
  100% {
    transform: scale(1.08) translate3d(0, -10px, 0);
  }
}

/* =====================
   RESPONSIVE
   ===================== */
@media (max-width: 1100px) {
  .ar-bp__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 900px) {
  .ar-dk {
    min-height: 0;
  }

  .ar-dk__container {
    grid-template-columns: 1fr;
    gap: clamp(32px, 6vw, 48px);
    padding-top: clamp(56px, 10vw, 72px);
    padding-bottom: clamp(56px, 10vw, 72px);
  }

  .ar-dk__media {
    order: -1;
  }

  .ar-dk__media-frame {
    max-width: min(420px, 92vw);
    margin: 0 auto;
  }

  .ar-dk__content {
    align-items: center;
    text-align: center;
    margin: 0 auto;
  }

  .ar-dk__text,
  .ar-dk__note {
    margin-left: auto;
    margin-right: auto;
  }

  .ar-dk__heading {
    font-size: clamp(2.1rem, 8vw, 2.85rem);
  }

  .ar-dk__text {
    font-size: clamp(1.1rem, 4.2vw, 1.25rem);
  }

  .ar-dk__note {
    font-size: clamp(1rem, 3.8vw, 1.1rem);
  }
}

@media (max-width: 640px) {
  .ar-bp__grid {
    grid-template-columns: 1fr;
  }

  .ar-bp__heading {
    font-size: 32px;
  }

  .ar-dk__container {
    padding-left: 20px;
    padding-right: 20px;
  }

  .ar-dk__btn {
    width: 100%;
    max-width: 320px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .ar-story::before {
    animation: none;
    transform: none;
  }

  .ar-dk,
  .ar-dk__content > *,
  .ar-dk__media-frame {
    opacity: 1;
    transform: none;
    transition: none;
  }

  .ar-dk__media-frame {
    animation: none;
  }

  .ar-dk__image,
  .ar-dk__btn {
    transition: none;
  }
}

</style>


<script>
document.addEventListener("DOMContentLoaded", () => {
  const els = document.querySelectorAll(".ar-bp__item, .ar-story__container, .ar-dk");
  if (!els.length) return;

  const obs = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add("ar-animate");
        }, i * 110);
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  els.forEach(el => obs.observe(el));
});
</script>
