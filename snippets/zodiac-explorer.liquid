  color: var(--ink-4); display: block; margin-bottom: 8px;
}
.zx__info-cell--shadow .zx__info-label { color: #EF4444; }
.zx__info-cell--light  .zx__info-label { color: #10B981; }
.zx__info-cell--tips   .zx__info-label { color: #818CF8; }
.zx__info-val { font-size: 13px; line-height: 1.7; color: var(--ink-2); font-weight: 300; }

/* Benefits */
