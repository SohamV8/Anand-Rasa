@media (max-width: 768px) { .zx__header { padding: 64px 24px 44px; } }
@media (max-width: 480px) {
  .zx__header { padding: 48px 16px 32px; }
  .zx__panel-right { padding: 28px 20px; }
  .zx__img-wrap { width: 130px; height: 130px; }
}
