.zx__panel[data-sign="libra"]       .zx__bdot { background:var(--z-libra-mid); }
.zx__panel[data-sign="scorpio"]     .zx__bdot { background:var(--z-scorpio-mid); }
.zx__panel[data-sign="sagittarius"] .zx__bdot { background:var(--z-sagit-mid); }
.zx__panel[data-sign="capricorn"]   .zx__bdot { background:var(--z-capri-mid); }
.zx__panel[data-sign="aquarius"]    .zx__bdot { background:var(--z-aqua-mid); }
.zx__panel[data-sign="pisces"]      .zx__bdot { background:var(--z-pisces-mid); }

/* Usage tiles */
.zx__usage {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 10px;
}
@media (max-width: 560px) { .zx__usage { grid-template-columns: 1fr 1fr; } }
.zx__tile {
  background: var(--bg); border-radius: 16px; padding: 16px 14px;
  display: flex; flex-direction: column; gap: 5px;
  transition: transform var(--ts), box-shadow var(--te);
}
.zx__tile:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
.zx__tile-icon  { font-size: 22px; line-height: 1; }
.zx__tile-label { font-size: 12px; font-weight: 700; color: var(--ink); letter-spacing: 0.02em; }
.zx__tile-val   { font-size: 11.5px; color: var(--ink-3); font-weight: 300; line-height: 1.45; }

/* Attribute pills */
.zx__attrs { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.zx__attr {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 6px 13px; border-radius: 999px;
  font-size: 12px; font-weight: 500;
  border: 1.5px solid var(--border); color: var(--ink); background: var(--surface);
  transition: transform var(--tf), box-shadow var(--tf);
}
.zx__attr:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); }
.zx__attr-lbl {
  font-family: var(--ff-label); font-size: 9px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-4); margin-right: 2px;
}

/* ============================================================
