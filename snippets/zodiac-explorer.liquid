/* View link */
.zx__view {
  position: relative; z-index: 1;
  width: 100%; padding: 11px 20px; border-radius: 999px;
  border: 1.5px solid rgba(24,24,26,0.13);
  background: rgba(255,255,255,0.65);
  font-family: var(--ff-body); font-size: 11px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink);
  display: flex; align-items: center; justify-content: center; gap: 6px;
  transition: transform var(--ts), border-color var(--te), background var(--te);
  backdrop-filter: blur(4px);
}
.zx__view:hover { transform:translateY(-2px); border-color:rgba(24,24,26,0.28); background:rgba(255,255,255,0.9); }

/* ── RIGHT column ── */
.zx__panel-right {
  padding: 48px 52px;
  display: flex; flex-direction: column; gap: 28px;
  border-left: 1px solid var(--border);
}
@media (max-width: 860px) {
  .zx__panel-right { padding: 36px 28px; border-left: none; border-top: 1px solid var(--border); gap: 22px; }
}

/* Title */
.zx__panel-title { display: flex; flex-direction: column; gap: 5px; }
.zx__panel-num {
  font-family: var(--ff-label); font-size: 10px; font-weight: 500;
  letter-spacing: 0.24em; text-transform: uppercase; color: var(--ink-4);
}
.zx__panel-h {
  font-family: var(--ff-display);
  font-size: clamp(30px, 4vw, 50px);
  font-weight: 300; color: var(--ink);
  letter-spacing: -0.03em; line-height: 1.03;
}
.zx__panel-sub {
  font-family: var(--ff-label); font-size: 11px; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--ink-3); opacity: 0.75;
}

/* Description */
.zx__desc {
  font-size: 15px; line-height: 1.88; color: var(--ink-2);
  font-weight: 300; padding-left: 20px; border-left: 2.5px solid;
}
.zx__panel[data-sign="aries"]       .zx__desc { border-color:var(--z-aries-mid); }
