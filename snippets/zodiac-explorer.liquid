/* 3-col info grid */
.zx__info-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border); border-radius: 18px; overflow: hidden;
}
@media (max-width: 560px) { .zx__info-grid { grid-template-columns: 1fr; } }

.zx__info-cell { background: var(--surface); padding: 18px 16px; }
.zx__info-label {
