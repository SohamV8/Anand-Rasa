<section class="zx" aria-label="Zodiac Attar Explorer" itemscope itemtype="https://schema.org/ItemList">
  <meta itemprop="name" content="Zodiac Attar Collection">
  <div class="zx__wrap">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    <header class="zx__header">
      <span class="zx__eyebrow">{{ section.settings.eyebrow | default: 'Zodiac Collection' }}</span>
      <h2 class="zx__title">{{ section.settings.title | default: 'The Twelve Zodiac <em>Attars</em>' }}</h2>
      <p class="zx__sub">{{ section.settings.subtitle | default: 'Twelve rare botanical attars — each formulated for the soul, shadow, and stars of its zodiac sign. Find your fragrance in the cosmos.' }}</p>
      <div class="zx__divider" aria-hidden="true">
        <span class="zx__div-line"></span>
        <span class="zx__div-dot"></span>
        <span class="zx__div-star">✦</span>
        <span class="zx__div-dot"></span>
        <span class="zx__div-line"></span>
      </div>
    </header>

    {%- comment -%} ── SIGN GRID ── {%- endcomment -%}
    <div class="zx__grid" role="tablist" aria-label="Select your zodiac sign">
      {%- for i in (0..11) -%}
        {%- assign sk = zx_keys[i] -%}
        <button
          type="button"
          class="zx__card{% if i == 0 %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if i == 0 %}true{% else %}false{% endif %}"
          aria-controls="zxp-{{ sk }}"
          data-sign="{{ sk }}"
          id="zxt-{{ sk }}"
        >
          <span class="zx__orb" aria-hidden="true">{{ zx_glyphs[i] }}</span>
          <span class="zx__card-name">{{ zx_names[i] }}</span>
          <span class="zx__card-dates">{{ zx_dates[i] }}</span>
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%} ── DETAIL PANELS ── {%- endcomment -%}
    <div class="zx__panels">
      {%- for i in (0..11) -%}
        {%- liquid
          assign sk      = zx_keys[i]
          assign zx_prod = blank
          assign zx_setting_key = 'product_' | append: sk
          assign zx_setting_product = section.settings[zx_setting_key]

          if collection != blank and collection.products_count > 0
            for cp in collection.products
              assign cp_handle = cp.handle | downcase
              if sk == 'capricorn'
                if cp_handle contains 'capricorn' or cp_handle contains 'capricon'
                  assign zx_prod = cp
                  break
                endif
              elsif sk == 'aquarius'
                if cp_handle contains 'aquarius' or cp_handle contains 'aquaris'
                  assign zx_prod = cp
                  break
                endif
              else
                if cp_handle contains sk
                  assign zx_prod = cp
                  break
                endif
              endif
            endfor
          endif

          if zx_prod == blank and zx_setting_product != blank
            assign zx_prod = all_products[zx_setting_product]
          endif

          if zx_prod == blank
            if sk == 'capricorn'
              assign zx_prod = all_products['capricon-zodiac-attar']
            elsif sk == 'aquarius'
              assign zx_prod = all_products['aquaris-zodiac-attar']
            endif
          endif

          if zx_prod == blank
            assign zx_fallback_handle = sk | append: '-zodiac-attar'
            assign zx_prod = all_products[zx_fallback_handle]
          endif
        -%}
        <div
          class="zx__panel{% if i == 0 %} is-active{% endif %}"
          id="zxp-{{ sk }}"
          role="tabpanel"
          aria-labelledby="zxt-{{ sk }}"
          data-sign="{{ sk }}"
          itemscope
          itemprop="itemListElement"
          itemtype="https://schema.org/ListItem"
        >
          <meta itemprop="position" content="{{ i | plus: 1 }}">
          <meta itemprop="name" content="{{ zx_names[i] }} Attar">

          <div class="zx__panel-bar" aria-hidden="true"></div>
          <div class="zx__panel-inner">

            {%- comment -%} LEFT: Product ── {%- endcomment -%}
            <div class="zx__panel-left">
              <span class="zx__orbit-ring" aria-hidden="true"></span>
              <span class="zx__orbit-ring" aria-hidden="true"></span>

              <span class="zx__sign-big" aria-label="{{ zx_names[i] }} symbol" role="img">{{ zx_glyphs[i] }}</span>

              {%- if zx_prod != blank and zx_prod != empty -%}
                <a href="{{ zx_prod.url }}" class="zx__img-wrap" aria-label="{{ zx_prod.title | escape }}">
                  {%- if zx_prod.featured_image -%}
                    <img
                      class="zx__img"
                      src="{{ zx_prod.featured_image | image_url: width: 600 }}"
                      alt="{{ zx_prod.featured_image.alt | default: zx_prod.title | escape }}"
                      width="600" height="600"
                      loading="lazy" decoding="async"
                    >
                  {%- else -%}
                    <div class="zx__img-ph">{{ zx_glyphs[i] }}</div>
                  {%- endif -%}
                </a>
                <p class="zx__prod-type">{{ zx_prod.type | default: 'Zodiac Attar' }}</p>
                <h3 class="zx__prod-name">{{ zx_prod.title }}</h3>
                <div class="zx__prod-price">
                  {%- if zx_prod.compare_at_price > zx_prod.price -%}
                    <span class="zx__prod-compare">{{ zx_prod.compare_at_price | money }}</span>
                  {%- endif -%}
                  {{ zx_prod.price | money }}
                </div>
                {%- if zx_prod.available -%}
                  <button
                    type="button"
                    class="zx__atc js-zx-atc"
                    data-id="{{ zx_prod.variants.first.id }}"
                    aria-label="Add {{ zx_prod.title | escape }} to cart"
                  >
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39A2 2 0 0 0 9.62 16h9.76a2 2 0 0 0 1.97-1.67L23 6H6"/></svg>
                    <span>Add to Cart</span>
                  </button>
                  <a href="{{ zx_prod.url }}" class="zx__view">
                    View Details
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                {%- else -%}
                  <button type="button" class="zx__atc" disabled>Sold Out</button>
                {%- endif -%}
              {%- else -%}
                <div class="zx__img-wrap"><div class="zx__img-ph">{{ zx_glyphs[i] }}</div></div>
                <p class="zx__prod-type">Zodiac Attar</p>
                <h3 class="zx__prod-name">{{ zx_names[i] }} Attar</h3>
                <p style="font-size:12px;color:var(--ink-3);margin-top:8px;text-align:center;position:relative;z-index:1;">Assign product in Theme Editor</p>
              {%- endif -%}
            </div>

            {%- comment -%} RIGHT: Info ── {%- endcomment -%}
            <div class="zx__panel-right">

              <div class="zx__panel-title">
                <span class="zx__panel-num">Sign {{ zx_nums[i] }} · {{ zx_elem[i] }} · {{ zx_mode[i] }}</span>
                <h3 class="zx__panel-h">{{ zx_names[i] }}</h3>
                <span class="zx__panel-sub">{{ zx_dates[i] }} · Ruler: {{ zx_ruler[i] }} · Stone: {{ zx_stone[i] | truncate: 28, '…' }}</span>
              </div>

              <p class="zx__desc">{{ zx_descs[i] }}</p>

              <div class="zx__info-grid" role="table">
                <div class="zx__info-cell zx__info-cell--shadow" role="cell">
                  <span class="zx__info-label">Shadow Side</span>
                  <p class="zx__info-val">{{ zx_shadow[i] }}</p>
                </div>
                <div class="zx__info-cell zx__info-cell--light" role="cell">
                  <span class="zx__info-label">Light Side</span>
                  <p class="zx__info-val">{{ zx_light[i] }}</p>
                </div>
                <div class="zx__info-cell zx__info-cell--tips" role="cell">
                  <span class="zx__info-label">Best Worn When</span>
                  <p class="zx__info-val">{{ zx_tips[i] }}</p>
                </div>
              </div>

              <div class="zx__benefits">
                <span class="zx__benefits-h">Attar Benefits</span>
                <div class="zx__benefit"><span class="zx__bdot" aria-hidden="true"></span>{{ zx_b1[i] }}</div>
                <div class="zx__benefit"><span class="zx__bdot" aria-hidden="true"></span>{{ zx_b2[i] }}</div>
                <div class="zx__benefit"><span class="zx__bdot" aria-hidden="true"></span>{{ zx_b3[i] }}</div>
              </div>

              <div class="zx__usage" aria-label="How to use">
                <div class="zx__tile">
                  <span class="zx__tile-icon">🌙</span>
                  <span class="zx__tile-label">Pulse Points</span>
                  <span class="zx__tile-val">Wrists, temples, behind ears, base of throat</span>
                </div>
                <div class="zx__tile">
                  <span class="zx__tile-icon">🧘</span>
                  <span class="zx__tile-label">Ritual Use</span>
                  <span class="zx__tile-val">Apply before meditation, journaling, or sign-specific practices</span>
                </div>
                <div class="zx__tile">
                  <span class="zx__tile-icon">✨</span>
                  <span class="zx__tile-label">Best Moment</span>
                  <span class="zx__tile-val">New Moon or Full Moon in {{ zx_names[i] }} for peak resonance</span>
                </div>
              </div>

              <div class="zx__attrs" aria-label="Key properties">
                <span class="zx__attr"><span class="zx__attr-lbl">Essence</span>{{ zx_essence[i] | truncate: 36, '…' }}</span>
                <span class="zx__attr"><span class="zx__attr-lbl">Element</span>{{ zx_elem[i] }}</span>
                <span class="zx__attr"><span class="zx__attr-lbl">Ruler</span>{{ zx_ruler[i] }}</span>
                <span class="zx__attr"><span class="zx__attr-lbl">Stone</span>{{ zx_stone[i] | truncate: 28, '…' }}</span>
              </div>

            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
(function () {
  'use strict';

  var tabs   = document.querySelectorAll('.zx__card');
  var panels = document.querySelectorAll('.zx__panel');

  function activate(sign) {
    tabs.forEach(function (t) {
      var on = t.dataset.sign === sign;
      t.classList.toggle('is-active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var on = p.dataset.sign === sign;
      if (on) {
        p.style.display = 'block';
        p.classList.add('is-active');
        p.style.animation = 'none';
        void p.offsetWidth;
        p.style.animation = '';
      } else {
        p.classList.remove('is-active');
        p.style.display = 'none';
      }
    });
    if (window.innerWidth < 860) {
      var pw = document.querySelector('.zx__panels');
      if (pw) setTimeout(function () { pw.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 80);
    }
  }

  var allTabs = Array.from(tabs);
  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () { activate(tab.dataset.sign); });
    tab.addEventListener('keydown', function (e) {
      var idx = allTabs.indexOf(tab);
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(tab.dataset.sign); }
      if (e.key === 'ArrowRight') { e.preventDefault(); var n = allTabs[(idx+1)%allTabs.length]; activate(n.dataset.sign); n.focus(); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); var p = allTabs[(idx-1+allTabs.length)%allTabs.length]; activate(p.dataset.sign); p.focus(); }
    });
  });

  /* ATC */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.js-zx-atc');
    if (!btn) return;
    e.preventDefault();
    var id = parseInt(btn.dataset.id, 10);
    var span = btn.querySelector('span');
    var orig = span ? span.textContent : 'Add to Cart';
    if (!id) return;
    btn.disabled = true;
    if (span) span.textContent = 'Adding…';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: id, quantity: 1 })
    })
    .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
    .then(function () {
      if (span) span.textContent = '✓ Added';
      document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
      setTimeout(function () { btn.disabled = false; if (span) span.textContent = orig; }, 2600);
    })
    .catch(function () { btn.disabled = false; if (span) span.textContent = orig; });
  });

})();
</script>
