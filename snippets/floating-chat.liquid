<div class="ar-floating-chat-container" aria-label="Quick actions">
  <button
    type="button"
    class="ar-floating-btn ar-floating-chat"
    id="ar-floating-chat-toggle"
    aria-controls="ar-ai-chatbox"
    aria-expanded="false"
    aria-label="Open AI Assistant chat"
  >
    <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
      <path
        fill="currentColor"
        d="M12 2a10 10 0 0 0-8.66 15l-1.11 3.79a.75.75 0 0 0 .93.93L6.95 20A10 10 0 1 0 12 2Zm0 18a8 8 0 0 1-4.29-1.24.75.75 0 0 0-.57-.1l-2.87.84.85-2.87a.75.75 0 0 0-.1-.57A8 8 0 1 1 12 20Zm-4.25-7.5a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5Zm4.25 0a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5Zm4.25 0a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5Z"
      ></path>
    </svg>
  </button>

  <a
    class="ar-floating-btn ar-floating-whatsapp"
    href="https://wa.me/917206264199?text=Hi%20Anand%20Rasa%20team%2C%20I%20would%20like%20help%20with%20your%20attars%20and%20incense%20collections."
    target="_blank"
    rel="noopener"
    aria-label="Chat on WhatsApp"
  >
    <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
      <path
        fill="currentColor"
        d="M20.52 3.48A11.86 11.86 0 0 0 12.05 0C5.52 0 .19 5.33.19 11.86c0 2.09.55 4.14 1.59 5.95L0 24l6.39-1.67a11.87 11.87 0 0 0 5.67 1.44h.01c6.53 0 11.86-5.33 11.86-11.86 0-3.17-1.24-6.16-3.41-8.43ZM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.21-3.79.99 1.01-3.7-.24-.38a9.8 9.8 0 0 1-1.52-5.2c0-5.42 4.41-9.83 9.84-9.83 2.62 0 5.09 1.02 6.93 2.88a9.77 9.77 0 0 1 2.88 6.95c0 5.42-4.41 9.83-9.84 9.83Zm5.39-7.35c-.3-.15-1.78-.88-2.06-.98-.27-.1-.47-.15-.66.15-.2.29-.76.97-.94 1.17-.17.2-.34.22-.64.07-.3-.15-1.24-.45-2.36-1.43-.87-.78-1.46-1.74-1.63-2.04-.17-.3-.02-.47.13-.61.14-.14.3-.34.44-.51.15-.17.2-.29.3-.49.1-.2.05-.37-.02-.52-.08-.15-.66-1.59-.9-2.18-.24-.57-.48-.49-.66-.5h-.56c-.2 0-.52.07-.8.37-.27.29-1.05 1.03-1.05 2.52 0 1.49 1.08 2.92 1.23 3.12.15.2 2.12 3.23 5.12 4.53.72.31 1.29.5 1.73.64.73.23 1.39.2 1.92.12.59-.09 1.78-.73 2.03-1.44.25-.71.25-1.32.17-1.44-.07-.12-.27-.2-.56-.34Z"
      ></path>
    </svg>
  </a>
</div>

<section id="ar-ai-chatbox" class="ar-chatbox" aria-label="AI Assistant">
  <header class="ar-chatbox__header">
    <h3>AI Assistant</h3>
    <button type="button" id="ar-chatbox-close" aria-label="Close chat">×</button>
  </header>
  <div id="ar-chatbox-messages" class="ar-chatbox__messages">
    <div class="ar-msg ar-msg--ai">Hello! How can I help you today?</div>
  </div>
  <form id="ar-chatbox-form" class="ar-chatbox__inputbar">
    <input id="ar-chatbox-input" type="text" placeholder="Type your message..." autocomplete="off">
    <button type="submit">Send</button>
  </form>
</section>

<style>
  .ar-floating-chat-container {
    position: fixed;
    left: 20px;
    bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 9999;
  }

  .ar-floating-btn {
    width: 48px;
    height: 48px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease, filter 0.3s ease;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    color: #fff;
    text-decoration: none;
  }

  .ar-floating-btn:hover {
    transform: translateY(-3px);
    filter: brightness(1.02);
  }

  .ar-floating-chat {
    background: #2563eb;
  }

  .ar-floating-whatsapp {
    background: #25d366;
  }

  .ar-chatbox {
    position: fixed;
    left: 80px;
    bottom: 20px;
    width: 300px;
    height: 400px;
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    display: none;
    z-index: 9999;
    border: 1px solid rgba(17, 24, 39, 0.08);
  }

  .ar-chatbox.active {
    display: flex;
    flex-direction: column;
  }

  .ar-chatbox__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    background: #0f172a;
    color: #fff;
  }

  .ar-chatbox__header h3 {
    margin: 0;
    font-size: 14px;
    line-height: 1.2;
  }

  .ar-chatbox__header button {
    border: 0;
    background: transparent;
    color: #fff;
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    padding: 0;
  }

  .ar-chatbox__messages {
    flex: 1;
    padding: 12px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: #f8fafc;
  }

  .ar-msg {
    max-width: 88%;
    padding: 8px 10px;
    border-radius: 4px;
    font-size: 13px;
    line-height: 1.4;
    word-break: break-word;
  }

  .ar-msg--ai {
    align-self: flex-start;
    background: #e2e8f0;
    color: #0f172a;
  }

  .ar-msg--user {
    align-self: flex-end;
    background: #2563eb;
    color: #fff;
  }

  .ar-chatbox__inputbar {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    padding: 10px;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
    background: #fff;
  }

  .ar-chatbox__inputbar input {
    min-width: 0;
    border: 1px solid rgba(15, 23, 42, 0.18);
    border-radius: 4px;
    padding: 8px 10px;
    font-size: 13px;
    outline: none;
  }

  .ar-chatbox__inputbar button {
    border: 0;
    border-radius: 4px;
    padding: 8px 12px;
    background: #2563eb;
    color: #fff;
    font-size: 13px;
    cursor: pointer;
  }

  @media (max-width: 749px) {
    .ar-floating-chat-container {
      left: 12px;
      bottom: 16px;
      gap: 10px;
    }

    .ar-floating-btn {
      width: 42px;
      height: 42px;
      border-radius: 4px;
    }

    .ar-chatbox {
      left: 12px;
      right: 12px;
      width: auto;
      bottom: 16px;
      height: min(62vh, 420px);
      border-radius: 6px;
    }
  }
</style>

<script>
  (function () {
    if (window.__arFloatingChatInit) return;
    window.__arFloatingChatInit = true;

    var toggleBtn = document.getElementById('ar-floating-chat-toggle');
    var closeBtn = document.getElementById('ar-chatbox-close');
    var chatbox = document.getElementById('ar-ai-chatbox');
    var form = document.getElementById('ar-chatbox-form');
    var input = document.getElementById('ar-chatbox-input');
    var messages = document.getElementById('ar-chatbox-messages');

    if (!toggleBtn || !chatbox || !form || !input || !messages) return;

    function setOpenState(isOpen) {
      chatbox.classList.toggle('active', isOpen);
      toggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      if (isOpen) input.focus();
    }

    function appendMessage(text, role) {
      var msg = document.createElement('div');
      msg.className = 'ar-msg ' + (role === 'user' ? 'ar-msg--user' : 'ar-msg--ai');
      msg.textContent = text;
      messages.appendChild(msg);
      messages.scrollTop = messages.scrollHeight;
    }

    toggleBtn.addEventListener('click', function () {
      setOpenState(!chatbox.classList.contains('active'));
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', function () {
        setOpenState(false);
      });
    }

    form.addEventListener('submit', function (event) {
      event.preventDefault();
      var text = input.value.trim();
      if (!text) return;

      appendMessage(text, 'user');
      input.value = '';

      window.setTimeout(function () {
        appendMessage('Thanks for your message. Our team will connect with you shortly.', 'ai');
      }, 350);
    });
  })();
</script>
