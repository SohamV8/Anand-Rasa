{{ 'ar-ai-chat.css' | asset_url | stylesheet_tag }}

<div class="ar-chat-root" data-ar-chat-root>
  <div class="ar-chat-backdrop" data-ar-chat-backdrop hidden aria-hidden="true"></div>

  <section
    id="ar-ai-chatbox"
    class="ar-chatbox"
    role="dialog"
    aria-modal="true"
    aria-labelledby="ar-chatbox-title"
    aria-hidden="true"
  >
    <header class="ar-chatbox__header">
      <div class="ar-chatbox__avatar" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" focusable="false">
          <path fill="currentColor" d="M12 2a7 7 0 0 0-4 12.9V18a1 1 0 0 0 1 1h1v1a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-1h1a1 1 0 0 0 1-1v-3.1A7 7 0 0 0 12 2Zm0 12a5 5 0 1 1 0-10 5 5 0 0 1 0 10Z"/>
        </svg>
      </div>
      <div class="ar-chatbox__meta">
        <h2 class="ar-chatbox__title" id="ar-chatbox-title">Astro Concierge</h2>
        <p class="ar-chatbox__subtitle">
          <span class="ar-chatbox__status" aria-hidden="true"></span>
          <span>Online · Anand Rasa</span>
        </p>
      </div>
      <button type="button" class="ar-chatbox__close" id="ar-chatbox-close" aria-label="Close chat">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
    </header>

    <div id="ar-chatbox-messages" class="ar-chatbox__messages" role="log" aria-live="polite" aria-relevant="additions">
      <div class="ar-msg ar-msg--ai" role="article">
        <span>Hello! How can I help you today?</span>
      </div>
      <div class="ar-chat-typing" data-ar-chat-typing aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div class="ar-chatbox__composer">
      <form id="ar-chatbox-form" class="ar-chatbox__inputbar">
        <label class="visually-hidden" for="ar-chatbox-input">Message</label>
        <textarea
          id="ar-chatbox-input"
          rows="1"
          placeholder="Ask about attars, incense, or your order…"
          autocomplete="off"
          aria-label="Type your message"
        ></textarea>
        <button type="submit" class="ar-chatbox__send" data-ar-chat-send aria-label="Send message">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M3.4 20.6 21 12 3.4 3.4l2.8 7.2L17 12l-10.8 1.4-2.8 7.2Z"/>
          </svg>
        </button>
      </form>
    </div>
  </section>

  <div class="ar-chat-launchers" aria-label="Quick actions">
    <button
      type="button"
      class="ar-floating-btn ar-floating-chat"
      id="ar-floating-chat-toggle"
      aria-controls="ar-ai-chatbox"
      aria-expanded="false"
      aria-label="Open AI Assistant chat"
    >
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M12 2a10 10 0 0 0-8.66 15l-1.11 3.79a.75.75 0 0 0 .93.93L6.95 20A10 10 0 1 0 12 2Zm0 18a8 8 0 0 1-4.29-1.24.75.75 0 0 0-.57-.1l-2.87.84.85-2.87a.75.75 0 0 0-.1-.57A8 8 0 1 1 12 20Zm-4.25-7.5a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5Zm4.25 0a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5Zm4.25 0a1.25 1.25 0 1 1 0-2.5 1.25 1.25 0 0 1 0 2.5Z"/>
      </svg>
    </button>

    <a
      class="ar-floating-btn ar-floating-whatsapp"
      href="https://api.whatsapp.com/send?phone=917206264199&text=Hi%20Anand%20Rasa%20team%2C%20I%20would%20like%20help%20with%20your%20attars%20and%20incense%20collections."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat on WhatsApp"
    >
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M20.52 3.48A11.86 11.86 0 0 0 12.05 0C5.52 0 .19 5.33.19 11.86c0 2.09.55 4.14 1.59 5.95L0 24l6.39-1.67a11.87 11.87 0 0 0 5.67 1.44h.01c6.53 0 11.86-5.33 11.86-11.86 0-3.17-1.24-6.16-3.41-8.43ZM12.07 21.7h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.21-3.79.99 1.01-3.7-.24-.38a9.8 9.8 0 0 1-1.52-5.2c0-5.42 4.41-9.83 9.84-9.83 2.62 0 5.09 1.02 6.93 2.88a9.77 9.77 0 0 1 2.88 6.95c0 5.42-4.41 9.83-9.84 9.83Zm5.39-7.35c-.3-.15-1.78-.88-2.06-.98-.27-.1-.47-.15-.66.15-.2.29-.76.97-.94 1.17-.17.2-.34.22-.64.07-.3-.15-1.24-.45-2.36-1.43-.87-.78-1.46-1.74-1.63-2.04-.17-.3-.02-.47.13-.61.14-.14.3-.34.44-.51.15-.17.2-.29.3-.49.1-.2.05-.37-.02-.52-.08-.15-.66-1.59-.9-2.18-.24-.57-.48-.49-.66-.5h-.56c-.2 0-.52.07-.8.37-.27.29-1.05 1.03-1.05 2.52 0 1.49 1.08 2.92 1.23 3.12.15.2 2.12 3.23 5.12 4.53.72.31 1.29.5 1.73.64.73.23 1.39.2 1.92.12.59-.09 1.78-.73 2.03-1.44.25-.71.25-1.32.17-1.44-.07-.12-.27-.2-.56-.34Z"/>
      </svg>
    </a>
  </div>
</div>

<script src="{{ 'ar-ai-chat.js' | asset_url }}" defer></script>
