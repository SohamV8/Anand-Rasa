{%- comment -%} Assign afflicted/exalted/remedies per planet index {%- endcomment -%}

<section class="nav-x" aria-label="Navagraha Attar Explorer">
  <div class="nav-x__wrap">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    <header class="nav-x__header">
      <span class="nav-x__eyebrow">{{ section.settings.eyebrow | default: 'Navagraha Collection' }}</span>
      <h2 class="nav-x__title">{{ section.settings.title | default: 'The Nine Planetary <em>Attars</em>' }}</h2>
      <p class="nav-x__sub">{{ section.settings.subtitle | default: 'Ancient Vedic wisdom distilled into rare botanical essences. Each attar is formulated under the planetary hour of its ruling graha.' }}</p>
      <div class="nav-x__divider" aria-hidden="true">
        <span class="nav-x__divider-line"></span>
        <span class="nav-x__divider-dot"></span>
        <img class="nav-x__divider-icon" src="{{ 'Planet/Saturn.webp' | asset_url }}" alt="" loading="lazy" decoding="async">
        <span class="nav-x__divider-dot"></span>
        <span class="nav-x__divider-line"></span>
      </div>
    </header>

    {%- comment -%} ── PLANET GRID ── {%- endcomment -%}
    <div class="nav-x__grid" role="tablist" aria-label="Select planet">
      {%- for i in (0..8) -%}
        {%- assign pk = pl_keys[i] -%}
        <button
          type="button"
          class="nav-x__card{% if i == 0 %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if i == 0 %}true{% else %}false{% endif %}"
          aria-controls="nvp-{{ pk }}"
          data-planet="{{ pk }}"
          id="nvt-{{ pk }}"
        >
          <span class="nav-x__orb" aria-hidden="true">
            <img class="nav-x__orb-img" src="{{ pl_images[i] | asset_url }}" alt="" loading="lazy" decoding="async">
          </span>
          <span class="nav-x__card-name">{{ pl_names[i] }}</span>
          <span class="nav-x__card-en">{{ pl_english[i] }}</span>
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%} ── DETAIL PANELS ── {%- endcomment -%}
    <div class="nav-x__panels">
      {%- for i in (0..8) -%}
        {%- liquid
          assign pk = pl_keys[i]
          assign block_index = i
          assign ck_prod = blank
          if section.blocks[block_index]
            assign ck_prod = section.blocks[block_index].settings.product
          endif

          if ck_prod == blank and collection != blank and collection.products_count > 0
            for cp in collection.products
              assign cp_handle = cp.handle | downcase
              case pk
                when 'surya'
                  if cp_handle contains 'surya' or cp_handle contains 'sun'
                    assign ck_prod = cp
                    break
                  endif
                when 'chandra'
                  if cp_handle contains 'chandra' or cp_handle contains 'moon'
                    assign ck_prod = cp
                    break
                  endif
                when 'mangal'
                  if cp_handle contains 'mangal' or cp_handle contains 'mars'
                    assign ck_prod = cp
                    break
                  endif
                when 'budha'
                  if cp_handle contains 'budha' or cp_handle contains 'budh' or cp_handle contains 'mercury'
                    assign ck_prod = cp
                    break
                  endif
                when 'guru'
                  if cp_handle contains 'guru' or cp_handle contains 'jupiter' or cp_handle contains 'brihaspati'
                    assign ck_prod = cp
                    break
                  endif
                when 'shukra'
                  if cp_handle contains 'shukra' or cp_handle contains 'venus'
                    assign ck_prod = cp
                    break
                  endif
                when 'shani'
                  if cp_handle contains 'shani' or cp_handle contains 'saturn'
                    assign ck_prod = cp
                    break
                  endif
                when 'rahu'
                  if cp_handle contains 'rahu'
                    assign ck_prod = cp
                    break
                  endif
                when 'ketu'
                  if cp_handle contains 'ketu'
                    assign ck_prod = cp
                    break
                  endif
              endcase
            endfor
          endif

          if ck_prod == blank
            case pk
              when 'surya'
                assign ck_prod = all_products['surya-attar']
              when 'chandra'
                assign ck_prod = all_products['chandra-attar']
              when 'mangal'
                assign ck_prod = all_products['mangal-attar']
              when 'budha'
                assign ck_prod = all_products['budha-attar']
                if ck_prod == blank
                  assign ck_prod = all_products['budh-attar']
                endif
              when 'guru'
                assign ck_prod = all_products['guru-attar']
              when 'shukra'
                assign ck_prod = all_products['shukra-attar']
              when 'shani'
                assign ck_prod = all_products['shani-attar']
              when 'rahu'
                assign ck_prod = all_products['rahu-attar']
              when 'ketu'
                assign ck_prod = all_products['ketu-attar']
            endcase
          endif

          case i
            when 0
              assign aff_str = 'Low confidence, lack of authority, poor vitality, dependency on others'
              assign exl_str = 'Leadership, fame, vitality, radiant health, creative success'
              assign rem_str = 'Offer water to rising sun daily, wear Ruby, chant Gayatri Mantra 108×, honour father figures'
            when 1
              assign aff_str = 'Emotional instability, anxiety, mood swings, insomnia, fear'
              assign exl_str = 'Emotional intelligence, creativity, empathy, calm and receptive mind'
              assign rem_str = 'Fast on Mondays, offer milk to Shiva, wear Pearl, meditate under moonlight'
            when 2
              assign aff_str = 'Aggression, impulsiveness, uncontrolled conflict, recklessness'
              assign exl_str = 'Courage, ambition, athletic prowess, victory over enemies and adversity'
              assign rem_str = 'Recite Hanuman Chalisa, offer red flowers, wear Red Coral, fast on Tuesdays'
            when 3
              assign aff_str = 'Indecision, poor communication, scattered focus, nervous anxiety'
              assign exl_str = 'Eloquence, sharp intellect, business success, versatility and wit'
              assign rem_str = 'Feed green vegetables to cows, wear Emerald, chant Budha mantra on Wednesdays'
            when 4
              assign aff_str = 'Poor judgment, overindulgence, financial loss, arrogance, false beliefs'
              assign exl_str = 'Wisdom, wealth, spiritual grace, generosity, expansion and good fortune'
              assign rem_str = 'Serve teachers and elders, donate turmeric, wear Yellow Sapphire, fast Thursdays'
            when 5
              assign aff_str = 'Heartbreak, vanity, laziness, creative blocks, romantic failure'
              assign exl_str = 'Beauty, romance, artistic genius, sensuality, material abundance'
              assign rem_str = 'Offer white flowers to Goddess Lakshmi, donate to artists, wear Diamond, fast Fridays'
            when 6
              assign aff_str = 'Delays, chronic obstacles, depression, illness, pessimism and fear'
              assign exl_str = 'Discipline, longevity, spiritual depth, justice, karmic rewards'
              assign rem_str = 'Serve elderly and underprivileged, pour sesame oil on Shani idol, wear Blue Sapphire'
            when 7
              assign aff_str = 'Obsession, illusion, deception, addiction, material confusion'
              assign exl_str = 'Innovation, psychic powers, foreign success, out-of-the-box vision'
              assign rem_str = 'Feed stray animals, burn camphor at dusk, wear Hessonite Garnet, chant Rahu mantra'
            when 8
              assign aff_str = 'Spiritual confusion, deep losses, isolation, meaninglessness'
              assign exl_str = 'Moksha, liberation, deep meditation, clairvoyance, past-life healing'
              assign rem_str = "Worship Ganesha, burn Gugal incense, wear Cat's Eye, practise daily silence"
          endcase
        -%}
        <div
          class="nav-x__panel{% if i == 0 %} is-active{% endif %}"
          id="nvp-{{ pk }}"
          role="tabpanel"
          aria-labelledby="nvt-{{ pk }}"
          data-planet="{{ pk }}"
        >
          <div class="nav-x__panel-accent" aria-hidden="true"></div>
          <div class="nav-x__panel-inner">

            {%- comment -%} ── LEFT: Product ── {%- endcomment -%}
            <div class="nav-x__panel-left">
              <span class="nav-x__orbit-ring" aria-hidden="true"></span>
              <span class="nav-x__orbit-ring" aria-hidden="true"></span>

              {%- if ck_prod != blank and ck_prod != nil -%}
                <a href="{{ ck_prod.url }}" class="nav-x__img-wrap" aria-label="{{ ck_prod.title | escape }}">
                  {%- if ck_prod.featured_image -%}
                    <img
                      class="nav-x__img"
                      src="{{ ck_prod.featured_image | image_url: width: 600 }}"
                      alt="{{ ck_prod.featured_image.alt | default: ck_prod.title | escape }}"
                      width="600" height="600"
                      loading="lazy"
                      decoding="async"
                    >
                  {%- else -%}
                    <div class="nav-x__img-ph"><img class="nav-x__orb-img" src="{{ pl_images[i] | asset_url }}" alt="" loading="lazy" decoding="async"></div>
                  {%- endif -%}
                </a>
                <p class="nav-x__prod-type">{{ ck_prod.type | default: 'Navagraha Attar' }}</p>
                <h3 class="nav-x__prod-name">{{ ck_prod.title }}</h3>
                <div class="nav-x__prod-price">
                  {%- if ck_prod.compare_at_price > ck_prod.price -%}
                    <span class="nav-x__prod-compare">{{ ck_prod.compare_at_price | money }}</span>
                  {%- endif -%}
                  {{ ck_prod.price | money }}
                </div>
                {%- if ck_prod.available -%}
                  <button
                    type="button"
                    class="nav-x__atc js-nv-atc"
                    data-id="{{ ck_prod.variants.first.id }}"
                    aria-label="Add {{ ck_prod.title | escape }} to cart"
                  >
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39A2 2 0 0 0 9.62 16h9.76a2 2 0 0 0 1.97-1.67L23 6H6"/></svg>
                    <span>Add to Cart</span>
                  </button>
                  <a href="{{ ck_prod.url }}" class="nav-x__view">
                    View Full Details
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                {%- else -%}
                  <button type="button" class="nav-x__atc" disabled>Sold Out</button>
                {%- endif -%}
              {%- else -%}
                <img class="nav-x__planet-img" src="{{ pl_images[i] | asset_url }}" alt="" loading="lazy" decoding="async" aria-hidden="true">
                <div class="nav-x__img-wrap"><div class="nav-x__img-ph"><img class="nav-x__orb-img" src="{{ pl_images[i] | asset_url }}" alt="" loading="lazy" decoding="async"></div></div>
                <p class="nav-x__prod-type">Navagraha Attar</p>
                <h3 class="nav-x__prod-name">{{ pl_names[i] }} Attar</h3>
                <p style="font-size:12px;color:var(--ink-3);margin-top:8px;text-align:center;position:relative;z-index:1;">Assign product in Theme Editor</p>
              {%- endif -%}
            </div>

            {%- comment -%} ── RIGHT: Info ── {%- endcomment -%}
            <div class="nav-x__panel-right">

              {%- comment -%} Title {%- endcomment -%}
              <div class="nav-x__panel-title">
                <span class="nav-x__panel-num">Graha {{ pl_nums[i] }} · {{ pl_day[i] }}</span>
                <h3 class="nav-x__panel-h">{{ pl_names[i] }}</h3>
                <span class="nav-x__panel-sub">{{ pl_english[i] }} · {{ pl_mantra[i] | truncate: 36, '…' }}</span>
              </div>

              {%- comment -%} Description {%- endcomment -%}
              <p class="nav-x__desc">{{ pl_descs[i] }}</p>

              {%- comment -%} Afflicted / Exalted / Remedies {%- endcomment -%}
              <div class="nav-x__info-grid" role="table">
                <div class="nav-x__info-cell nav-x__info-cell--afflicted" role="cell">
                  <span class="nav-x__info-cell-label">When Afflicted</span>
                  <p class="nav-x__info-cell-val">{{ aff_str }}</p>
                </div>
                <div class="nav-x__info-cell nav-x__info-cell--exalted" role="cell">
                  <span class="nav-x__info-cell-label">When Exalted</span>
                  <p class="nav-x__info-cell-val">{{ exl_str }}</p>
                </div>
                <div class="nav-x__info-cell nav-x__info-cell--remedies" role="cell">
                  <span class="nav-x__info-cell-label">Vedic Remedies</span>
                  <p class="nav-x__info-cell-val">{{ rem_str }}</p>
                </div>
              </div>

              {%- comment -%} Benefits {%- endcomment -%}
              <div class="nav-x__benefits">
                <span class="nav-x__benefits-h">Attar Benefits</span>
                <div class="nav-x__benefit">
                  <span class="nav-x__benefit-dot" aria-hidden="true"></span>
                  {{ pl_b1[i] }}
                </div>
                <div class="nav-x__benefit">
                  <span class="nav-x__benefit-dot" aria-hidden="true"></span>
                  {{ pl_b2[i] }}
                </div>
                <div class="nav-x__benefit">
                  <span class="nav-x__benefit-dot" aria-hidden="true"></span>
                  {{ pl_b3[i] }}
                </div>
              </div>

              {%- comment -%} Usage tiles {%- endcomment -%}
              <div class="nav-x__usage" aria-label="How to use">
                <div class="nav-x__usage-tile">
                  <span class="nav-x__usage-icon">🧘</span>
                  <span class="nav-x__usage-label">Planetary Hour</span>
                  <span class="nav-x__usage-val">Apply before {{ pl_day[i] | downcase }} morning sadhana for peak potency</span>
                </div>
                <div class="nav-x__usage-tile">
                  <span class="nav-x__usage-icon">🌿</span>
                  <span class="nav-x__usage-label">Pulse Points</span>
                  <span class="nav-x__usage-val">Wrists, behind ears, third eye, and base of throat</span>
                </div>
                <div class="nav-x__usage-tile">
                  <span class="nav-x__usage-icon">🕯️</span>
                  <span class="nav-x__usage-label">Ritual Use</span>
                  <span class="nav-x__usage-val">Anoint oil lamp, prayer space or diya during planetary hour</span>
                </div>
              </div>

              {%- comment -%} Attribute pills {%- endcomment -%}
              <div class="nav-x__attrs" aria-label="Key attributes">
                <span class="nav-x__attr">
                  <span class="nav-x__attr-label">Essence</span>
                  {{ pl_essence[i] | truncate: 38, '…' }}
                </span>
                <span class="nav-x__attr">
                  <span class="nav-x__attr-label">Stone</span>
                  {{ pl_stone[i] }}
                </span>
                <span class="nav-x__attr">
                  <span class="nav-x__attr-label">Metal</span>
                  {{ pl_metal[i] }}
                </span>
                <span class="nav-x__attr">
                  <span class="nav-x__attr-label">Color</span>
                  {{ pl_color[i] }}
                </span>
              </div>

            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
(function () {
  'use strict';

  var tabs   = document.querySelectorAll('.nav-x__card');
  var panels = document.querySelectorAll('.nav-x__panel');

  function activate(planet) {
    tabs.forEach(function (t) {
      var on = t.dataset.planet === planet;
      t.classList.toggle('is-active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var on = p.dataset.planet === planet;
      if (on) {
        p.style.display = 'block';
        p.classList.add('is-active');
        /* re-trigger entrance animation */
        p.style.animation = 'none';
        void p.offsetWidth;
        p.style.animation = '';
      } else {
        p.classList.remove('is-active');
        p.style.display = 'none';
      }
    });

    /* Scroll to panel on mobile */
    if (window.innerWidth < 860) {
      var panelWrap = document.querySelector('.nav-x__panels');
      if (panelWrap) {
        setTimeout(function () {
          panelWrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
      }
    }
  }

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () { activate(tab.dataset.planet); });
    tab.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(tab.dataset.planet); }
      /* Arrow key navigation */
      var allTabs = Array.from(tabs);
      var idx     = allTabs.indexOf(tab);
      if (e.key === 'ArrowRight') { e.preventDefault(); activate(allTabs[(idx + 1) % allTabs.length].dataset.planet); allTabs[(idx + 1) % allTabs.length].focus(); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); activate(allTabs[(idx - 1 + allTabs.length) % allTabs.length].dataset.planet); allTabs[(idx - 1 + allTabs.length) % allTabs.length].focus(); }
    });
  });

  /* Add to Cart */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.js-nv-atc');
    if (!btn) return;
    e.preventDefault();

    var id   = parseInt(btn.dataset.id, 10);
    var span = btn.querySelector('span');
    var orig = span ? span.textContent : 'Add to Cart';
    if (!id) return;

    btn.disabled = true;
    if (span) span.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: id, quantity: 1 })
    })
    .then(function (r) { if (!r.ok) throw new Error('cart error'); return r.json(); })
    .then(function () {
      if (span) span.textContent = '✓ Added';
      btn.style.opacity = '0.85';
      document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
      setTimeout(function () {
        btn.disabled = false;
        btn.style.opacity = '';
        if (span) span.textContent = orig;
      }, 2600);
    })
    .catch(function () {
      btn.disabled = false;
      if (span) span.textContent = orig;
    });
  });

})();
</script>
