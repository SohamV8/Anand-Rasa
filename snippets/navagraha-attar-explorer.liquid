{% comment %}
  NAVAGRAHA — Vedic Planet Attar Explorer
  sections/navagraha-attar-explorer.liquid
  Click a planet card → reveals full detail panel with product + info
  9 Planets: Surya, Chandra, Mangal, Budha, Guru, Shukra, Shani, Rahu, Ketu
{% endcomment %}

<style>
/* ============================================================
   DESIGN TOKENS
   ============================================================ */
.nav-x {
  --ff-display: 'Cormorant Garamond', 'Didot', 'Georgia', serif;
  --ff-body:    'DM Sans', 'SF Pro Text', -apple-system, system-ui, sans-serif;
  --ff-label:   'DM Mono', 'SF Mono', 'Fira Mono', monospace;

  /* Base palette */
  --bg:rgb(255, 255, 255);
  --surface:   #FFFFFF;
  --ink:       #18181A;
  --ink-2:     #3C3C40;
  --ink-3:     #8A8A90;
  --ink-4:     #C4C4CA;
  --border:    rgba(24,24,26,0.08);
  --shadow-sm: 0 2px 8px rgba(0,0,0,0.06);
  --shadow-md: 0 8px 32px rgba(0,0,0,0.10);
  --shadow-lg: 0 24px 72px rgba(0,0,0,0.14);

  --trans-spring: 0.44s cubic-bezier(0.34, 1.56, 0.64, 1);
  --trans-ease:   0.32s cubic-bezier(0.25, 1, 0.5, 1);
  --trans-fast:   0.18s ease;

  font-family: var(--ff-body);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  color: var(--ink);
}

/* Planet color tokens */
:root {
  /* Surya — Sun */
  --p-surya-bg:   #FFF3DB; --p-surya-mid:  #F59E0B; --p-surya-deep: #92400E; --p-surya-glow: rgba(245,158,11,0.22);
  /* Chandra — Moon */
  --p-chandra-bg: #EEF2FF; --p-chandra-mid:#818CF8; --p-chandra-deep:#1E1B4B; --p-chandra-glow:rgba(129,140,248,0.20);
  /* Mangal — Mars */
  --p-mangal-bg:  #FFF0EE; --p-mangal-mid: #EF4444; --p-mangal-deep:#7F1D1D; --p-mangal-glow: rgba(239,68,68,0.20);
  /* Budha — Mercury */
  --p-budha-bg:   #ECFDF5; --p-budha-mid:  #10B981; --p-budha-deep: #064E3B; --p-budha-glow:  rgba(16,185,129,0.20);
  /* Guru — Jupiter */
  --p-guru-bg:    #FEF9EE; --p-guru-mid:   #D97706; --p-guru-deep:  #451A03; --p-guru-glow:   rgba(217,119,6,0.20);
  /* Shukra — Venus */
  --p-shukra-bg:  #FDF2F8; --p-shukra-mid: #EC4899; --p-shukra-deep:#831843; --p-shukra-glow: rgba(236,72,153,0.20);
  /* Shani — Saturn */
  --p-shani-bg:   #F5F3FF; --p-shani-mid:  #7C3AED; --p-shani-deep: #2E1065; --p-shani-glow:  rgba(124,58,237,0.20);
  /* Rahu — North Node */
  --p-rahu-bg:    #F0FDF4; --p-rahu-mid:   #16A34A; --p-rahu-deep:  #14532D; --p-rahu-glow:   rgba(22,163,74,0.20);
  /* Ketu — South Node */
  --p-ketu-bg:    #FFF7ED; --p-ketu-mid:   #EA580C; --p-ketu-deep:  #431407; --p-ketu-glow:   rgba(234,88,12,0.20);
}

.nav-x *, .nav-x *::before, .nav-x *::after { box-sizing: border-box; margin: 0; padding: 0; }
.nav-x a  { text-decoration: none; color: inherit; }
.nav-x img { display: block; max-width: 100%; }
.nav-x button { font-family: var(--ff-body); cursor: pointer; border: none; background: none; }

/* ============================================================
   SECTION WRAPPER
   ============================================================ */
.nav-x__wrap {
  background: var(--bg);
  padding-bottom: 100px;
  position: relative;
  overflow: hidden;
}

/* Grain overlay */
.nav-x__wrap::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* ============================================================
   HEADER
   ============================================================ */
.nav-x__header {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 88px 48px 60px;
}

.nav-x__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--ff-label);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--ink-3);
  margin-bottom: 18px;
  opacity: 0;
  animation: nv-rise 0.7s ease 0.1s forwards;
}
.nav-x__eyebrow::before,
.nav-x__eyebrow::after {
  content: '';
  width: 28px;
  height: 1px;
  background: currentColor;
  opacity: 0.5;
}

.nav-x__title {
  font-family: var(--ff-display);
  font-size: clamp(38px, 5.5vw, 72px);
  font-weight: 300;
  color: var(--ink);
  letter-spacing: -0.04em;
  line-height: 1.02;
  margin-bottom: 18px;
  opacity: 0;
  animation: nv-rise 0.7s ease 0.2s forwards;
}
.nav-x__title em {
  font-style: italic;
  font-weight: 400;
}

.nav-x__sub {
  font-size: 15px;
  color: var(--ink-3);
  line-height: 1.8;
  font-weight: 300;
  max-width: 520px;
  margin: 0 auto 32px;
  opacity: 0;
  animation: nv-rise 0.7s ease 0.3s forwards;
}

/* Celestial divider */
.nav-x__divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  opacity: 0;
  animation: nv-rise 0.7s ease 0.4s forwards;
}
.nav-x__divider-line {
  width: 60px;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--ink-4));
}
.nav-x__divider-line:last-child {
  background: linear-gradient(to left, transparent, var(--ink-4));
}
.nav-x__divider-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--ink-4);
}
.nav-x__divider-icon {
  width: 18px;
  height: 18px;
  object-fit: contain;
  display: block;
}

/* ============================================================
   PLANET GRID — 9-card orbital strip
   ============================================================ */
.nav-x__grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(9, 1fr);
  gap: 10px;
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 28px;
  opacity: 0;
  animation: nv-rise 0.7s ease 0.5s forwards;
}

@media (max-width: 1000px) { .nav-x__grid { grid-template-columns: repeat(5, 1fr); gap: 9px; } }
@media (max-width: 580px)  { .nav-x__grid { grid-template-columns: repeat(3, 1fr); gap: 8px; padding: 0 16px; } }

/* ── Planet card ── */
.nav-x__card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 10px 16px;
  border-radius: 24px;
  cursor: pointer;
  transition:
    transform var(--trans-spring),
    box-shadow var(--trans-ease),
    background var(--trans-ease);
  outline: none;
  -webkit-tap-highlight-color: transparent;
  isolation: isolate;
  overflow: hidden;
}

/* Shimmer on hover */
.nav-x__card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.55) 0%, transparent 50%);
  opacity: 0;
  transition: opacity var(--trans-ease);
  border-radius: inherit;
  pointer-events: none;
}
.nav-x__card:hover::before { opacity: 1; }

.nav-x__card:hover {
  transform: translateY(-8px) scale(1.04);
  box-shadow: 0 16px 48px rgba(0,0,0,0.12);
}
.nav-x__card.is-active {
  transform: translateY(-5px) scale(1.05);
  box-shadow: 0 14px 44px rgba(0,0,0,0.14);
}

/* Active ring */
.nav-x__card.is-active::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 26px;
  border: 2px solid currentColor;
  opacity: 0.45;
  pointer-events: none;
}

/* Per-planet backgrounds */
.nav-x__card[data-planet="surya"]   { background: var(--p-surya-bg);   color: var(--p-surya-mid);   }
.nav-x__card[data-planet="chandra"] { background: var(--p-chandra-bg); color: var(--p-chandra-mid); }
.nav-x__card[data-planet="mangal"]  { background: var(--p-mangal-bg);  color: var(--p-mangal-mid);  }
.nav-x__card[data-planet="budha"]   { background: var(--p-budha-bg);   color: var(--p-budha-mid);   }
.nav-x__card[data-planet="guru"]    { background: var(--p-guru-bg);    color: var(--p-guru-mid);    }
.nav-x__card[data-planet="shukra"]  { background: var(--p-shukra-bg);  color: var(--p-shukra-mid);  }
.nav-x__card[data-planet="shani"]   { background: var(--p-shani-bg);   color: var(--p-shani-mid);   }
.nav-x__card[data-planet="rahu"]    { background: var(--p-rahu-bg);    color: var(--p-rahu-mid);    }
.nav-x__card[data-planet="ketu"]    { background: var(--p-ketu-bg);    color: var(--p-ketu-mid);    }

/* Planet glyph orb */
.nav-x__orb {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.5);
  border: 1.5px solid rgba(255,255,255,0.7);
  backdrop-filter: blur(8px);
  margin-bottom: 10px;
  transition: transform var(--trans-spring), box-shadow var(--trans-ease);
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}
.nav-x__orb-img {
  width: 44px;
  height: 44px;
  object-fit: contain;
  display: block;
}
.nav-x__card:hover .nav-x__orb,
.nav-x__card.is-active .nav-x__orb {
  transform: scale(1.14) rotate(-8deg);
  box-shadow: 0 8px 28px rgba(0,0,0,0.14);
}

.nav-x__card-name {
  font-family: var(--ff-display);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-align: center;
  color: var(--ink);
  margin-bottom: 3px;
  line-height: 1.2;
}
.nav-x__card-en {
  font-family: var(--ff-label);
  font-size: 9px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 500;
  text-align: center;
  color: var(--ink-3);
  opacity: 0.8;
}

/* ============================================================
   DETAIL PANEL
   ============================================================ */
.nav-x__panels {
  position: relative;
  z-index: 1;
  max-width: 1240px;
  margin: 28px auto 0;
  padding: 0 28px;
}
@media (max-width: 580px) { .nav-x__panels { padding: 0 16px; } }

.nav-x__panel {
  display: none;
  border-radius: 32px;
  overflow: hidden;
  background: var(--surface);
  box-shadow: var(--shadow-lg);
}
.nav-x__panel.is-active {
  display: block;
  animation: nv-panel-in 0.58s cubic-bezier(0.25, 1, 0.5, 1) both;
}

@keyframes nv-panel-in {
  from { opacity: 0; transform: translateY(24px) scale(0.975); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}

/* Top accent bar */
.nav-x__panel-accent {
  height: 4px;
}
.nav-x__panel[data-planet="surya"]   .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-surya-bg),  var(--p-surya-mid),  var(--p-surya-deep)); }
.nav-x__panel[data-planet="chandra"] .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-chandra-bg),var(--p-chandra-mid),var(--p-chandra-deep)); }
.nav-x__panel[data-planet="mangal"]  .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-mangal-bg), var(--p-mangal-mid), var(--p-mangal-deep)); }
.nav-x__panel[data-planet="budha"]   .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-budha-bg),  var(--p-budha-mid),  var(--p-budha-deep)); }
.nav-x__panel[data-planet="guru"]    .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-guru-bg),   var(--p-guru-mid),   var(--p-guru-deep)); }
.nav-x__panel[data-planet="shukra"]  .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-shukra-bg), var(--p-shukra-mid), var(--p-shukra-deep)); }
.nav-x__panel[data-planet="shani"]   .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-shani-bg),  var(--p-shani-mid),  var(--p-shani-deep)); }
.nav-x__panel[data-planet="rahu"]    .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-rahu-bg),   var(--p-rahu-mid),   var(--p-rahu-deep)); }
.nav-x__panel[data-planet="ketu"]    .nav-x__panel-accent { background: linear-gradient(90deg,var(--p-ketu-bg),   var(--p-ketu-mid),   var(--p-ketu-deep)); }

/* Panel layout */
.nav-x__panel-inner {
  display: grid;
  grid-template-columns: 320px 1fr;
}
@media (max-width: 860px)  { .nav-x__panel-inner { grid-template-columns: 1fr; } }

/* ── LEFT column ── */
.nav-x__panel-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 48px 36px 48px;
  position: relative;
  overflow: hidden;
}

/* Radial glow bg */
.nav-x__panel-left::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.nav-x__panel[data-planet="surya"]   .nav-x__panel-left { background: var(--p-surya-bg); }
.nav-x__panel[data-planet="surya"]   .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-surya-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="chandra"] .nav-x__panel-left { background: var(--p-chandra-bg); }
.nav-x__panel[data-planet="chandra"] .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-chandra-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="mangal"]  .nav-x__panel-left { background: var(--p-mangal-bg); }
.nav-x__panel[data-planet="mangal"]  .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-mangal-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="budha"]   .nav-x__panel-left { background: var(--p-budha-bg); }
.nav-x__panel[data-planet="budha"]   .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-budha-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="guru"]    .nav-x__panel-left { background: var(--p-guru-bg); }
.nav-x__panel[data-planet="guru"]    .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-guru-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="shukra"]  .nav-x__panel-left { background: var(--p-shukra-bg); }
.nav-x__panel[data-planet="shukra"]  .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-shukra-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="shani"]   .nav-x__panel-left { background: var(--p-shani-bg); }
.nav-x__panel[data-planet="shani"]   .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-shani-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="rahu"]    .nav-x__panel-left { background: var(--p-rahu-bg); }
.nav-x__panel[data-planet="rahu"]    .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-rahu-glow) 0%, transparent 70%); }
.nav-x__panel[data-planet="ketu"]    .nav-x__panel-left { background: var(--p-ketu-bg); }
.nav-x__panel[data-planet="ketu"]    .nav-x__panel-left::before { background: radial-gradient(circle at 50% 40%, var(--p-ketu-glow) 0%, transparent 70%); }

/* Orbital ring decoration */
.nav-x__orbit-ring {
  position: absolute;
  width: 220px;
  height: 220px;
  border-radius: 50%;
  border: 1px dashed rgba(0,0,0,0.08);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: nv-orbit-spin 40s linear infinite;
  pointer-events: none;
}
.nav-x__orbit-ring:nth-child(2) {
  width: 300px;
  height: 300px;
  animation-duration: 65s;
  animation-direction: reverse;
  border-style: dotted;
  opacity: 0.5;
}
@keyframes nv-orbit-spin {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to   { transform: translate(-50%, -50%) rotate(360deg); }
}

/* Large planet image (animated) */
.nav-x__planet-img {
  width: 68px;
  height: 68px;
  object-fit: contain;
  display: block;
  margin-bottom: 14px;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 4px 16px rgba(0,0,0,0.12));
  animation: nv-float 6s ease-in-out infinite;
}
@keyframes nv-float {
  0%,100% { transform: translateY(0px) rotate(0deg); }
  33%      { transform: translateY(-7px) rotate(2deg); }
  66%      { transform: translateY(-4px) rotate(-1.5deg); }
}

/* Product image */
.nav-x__img-wrap {
  position: relative;
  z-index: 1;
  width: 168px;
  height: 168px;
  border-radius: 24px;
  overflow: hidden;
  background: rgba(255,255,255,0.65);
  border: 1px solid rgba(255,255,255,0.9);
  box-shadow: 0 6px 28px rgba(0,0,0,0.10);
  margin-bottom: 22px;
  transition: transform var(--trans-spring), box-shadow var(--trans-ease);
  backdrop-filter: blur(4px);
}
.nav-x__img-wrap:hover {
  transform: translateY(-5px) scale(1.03) rotate(1deg);
  box-shadow: 0 18px 52px rgba(0,0,0,0.16);
}
.nav-x__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.nav-x__img-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56px;
  opacity: 0.2;
}

.nav-x__prod-type {
  font-family: var(--ff-label);
  font-size: 9px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--ink-3);
  margin-bottom: 6px;
  position: relative;
  z-index: 1;
}
.nav-x__prod-name {
  font-family: var(--ff-display);
  font-size: 20px;
  font-weight: 400;
  color: var(--ink);
  letter-spacing: -0.01em;
  text-align: center;
  margin-bottom: 8px;
  line-height: 1.25;
  position: relative;
  z-index: 1;
}
.nav-x__prod-price {
  font-size: 17px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 8px;
  position: relative;
  z-index: 1;
}
.nav-x__prod-compare {
  font-size: 13px;
  font-weight: 400;
  color: var(--ink-3);
  text-decoration: line-through;
}

/* ATC Button */
.nav-x__atc {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 14px 24px;
  border-radius: 999px;
  font-family: var(--ff-body);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: transform var(--trans-spring), box-shadow var(--trans-ease), opacity var(--trans-fast);
  margin-bottom: 10px;
  overflow: hidden;
}
.nav-x__atc::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0);
  transition: background var(--trans-fast);
}
.nav-x__atc:hover:not(:disabled)::after { background: rgba(255,255,255,0.12); }
.nav-x__atc:hover:not(:disabled) {
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.22);
}
.nav-x__atc:active:not(:disabled) { transform: translateY(0px) scale(0.98); }
.nav-x__atc:disabled { opacity: 0.4; cursor: not-allowed; }

/* Per-planet ATC colors */
.nav-x__panel[data-planet="surya"]   .nav-x__atc { background: linear-gradient(135deg,var(--p-surya-mid),  var(--p-surya-deep)); }
.nav-x__panel[data-planet="chandra"] .nav-x__atc { background: linear-gradient(135deg,var(--p-chandra-mid),var(--p-chandra-deep)); }
.nav-x__panel[data-planet="mangal"]  .nav-x__atc { background: linear-gradient(135deg,var(--p-mangal-mid), var(--p-mangal-deep)); }
.nav-x__panel[data-planet="budha"]   .nav-x__atc { background: linear-gradient(135deg,var(--p-budha-mid),  var(--p-budha-deep)); }
.nav-x__panel[data-planet="guru"]    .nav-x__atc { background: linear-gradient(135deg,var(--p-guru-mid),   var(--p-guru-deep)); }
.nav-x__panel[data-planet="shukra"]  .nav-x__atc { background: linear-gradient(135deg,var(--p-shukra-mid), var(--p-shukra-deep)); }
.nav-x__panel[data-planet="shani"]   .nav-x__atc { background: linear-gradient(135deg,var(--p-shani-mid),  var(--p-shani-deep)); }
.nav-x__panel[data-planet="rahu"]    .nav-x__atc { background: linear-gradient(135deg,var(--p-rahu-mid),   var(--p-rahu-deep)); }
.nav-x__panel[data-planet="ketu"]    .nav-x__atc { background: linear-gradient(135deg,var(--p-ketu-mid),   var(--p-ketu-deep)); }

/* View link */
.nav-x__view {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 12px 20px;
  border-radius: 999px;
  border: 1.5px solid rgba(24,24,26,0.14);
  background: rgba(255,255,255,0.7);
  font-family: var(--ff-body);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: transform var(--trans-spring), border-color var(--trans-ease), background var(--trans-ease);
  backdrop-filter: blur(4px);
}
.nav-x__view:hover {
  transform: translateY(-2px);
  border-color: rgba(24,24,26,0.3);
  background: rgba(255,255,255,0.9);
}

/* ── RIGHT column ── */
.nav-x__panel-right {
  padding: 48px 52px;
  display: flex;
  flex-direction: column;
  gap: 30px;
  border-left: 1px solid var(--border);
}
@media (max-width: 860px) {
  .nav-x__panel-right {
    padding: 36px 28px;
    border-left: none;
    border-top: 1px solid var(--border);
    gap: 24px;
  }
}

/* Title block */
.nav-x__panel-title { display: flex; flex-direction: column; gap: 5px; }
.nav-x__panel-num {
  font-family: var(--ff-label);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--ink-4);
}
.nav-x__panel-h {
  font-family: var(--ff-display);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 300;
  color: var(--ink);
  letter-spacing: -0.03em;
  line-height: 1.03;
}
.nav-x__panel-sub {
  font-family: var(--ff-label);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-3);
  opacity: 0.75;
}

/* Description */
.nav-x__desc {
  font-size: 15px;
  line-height: 1.88;
  color: var(--ink-2);
  font-weight: 300;
  padding-left: 20px;
  border-left: 2.5px solid;
}
.nav-x__panel[data-planet="surya"]   .nav-x__desc { border-color: var(--p-surya-mid); }
.nav-x__panel[data-planet="chandra"] .nav-x__desc { border-color: var(--p-chandra-mid); }
.nav-x__panel[data-planet="mangal"]  .nav-x__desc { border-color: var(--p-mangal-mid); }
.nav-x__panel[data-planet="budha"]   .nav-x__desc { border-color: var(--p-budha-mid); }
.nav-x__panel[data-planet="guru"]    .nav-x__desc { border-color: var(--p-guru-mid); }
.nav-x__panel[data-planet="shukra"]  .nav-x__desc { border-color: var(--p-shukra-mid); }
.nav-x__panel[data-planet="shani"]   .nav-x__desc { border-color: var(--p-shani-mid); }
.nav-x__panel[data-planet="rahu"]    .nav-x__desc { border-color: var(--p-rahu-mid); }
.nav-x__panel[data-planet="ketu"]    .nav-x__desc { border-color: var(--p-ketu-mid); }

/* 3-column info grid */
.nav-x__info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 18px;
  overflow: hidden;
}
@media (max-width: 560px) { .nav-x__info-grid { grid-template-columns: 1fr; } }

.nav-x__info-cell { background: var(--surface); padding: 18px 16px; }
.nav-x__info-cell-label {
  font-family: var(--ff-label);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-4);
  display: block;
  margin-bottom: 8px;
}
.nav-x__info-cell--afflicted  .nav-x__info-cell-label { color: #EF4444; }
.nav-x__info-cell--exalted    .nav-x__info-cell-label { color: #10B981; }
.nav-x__info-cell--remedies   .nav-x__info-cell-label { color: #818CF8; }
.nav-x__info-cell-val {
  font-size: 13px;
  line-height: 1.7;
  color: var(--ink-2);
  font-weight: 300;
}

/* Benefit dots */
.nav-x__benefits { display: flex; flex-direction: column; gap: 9px; }
.nav-x__benefits-h {
  font-family: var(--ff-label);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-4);
  margin-bottom: 3px;
}
.nav-x__benefit {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13.5px;
  color: var(--ink-2);
  font-weight: 300;
  line-height: 1.45;
}
.nav-x__benefit-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6px;
