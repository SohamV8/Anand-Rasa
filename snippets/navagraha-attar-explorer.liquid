.nav-x__panel[data-planet="surya"]   .nav-x__benefit-dot { background: var(--p-surya-mid); }
.nav-x__panel[data-planet="chandra"] .nav-x__benefit-dot { background: var(--p-chandra-mid); }
.nav-x__panel[data-planet="mangal"]  .nav-x__benefit-dot { background: var(--p-mangal-mid); }
.nav-x__panel[data-planet="budha"]   .nav-x__benefit-dot { background: var(--p-budha-mid); }
.nav-x__panel[data-planet="guru"]    .nav-x__benefit-dot { background: var(--p-guru-mid); }
.nav-x__panel[data-planet="shukra"]  .nav-x__benefit-dot { background: var(--p-shukra-mid); }
.nav-x__panel[data-planet="shani"]   .nav-x__benefit-dot { background: var(--p-shani-mid); }
.nav-x__panel[data-planet="rahu"]    .nav-x__benefit-dot { background: var(--p-rahu-mid); }
.nav-x__panel[data-planet="ketu"]    .nav-x__benefit-dot { background: var(--p-ketu-mid); }

/* Usage tiles */
.nav-x__usage {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}
@media (max-width: 560px) { .nav-x__usage { grid-template-columns: 1fr 1fr; } }
.nav-x__usage-tile {
  background: var(--bg);
  border-radius: 16px;
  padding: 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  transition: transform var(--trans-spring), box-shadow var(--trans-ease);
}
.nav-x__usage-tile:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
.nav-x__usage-icon { font-size: 22px; line-height: 1; }
.nav-x__usage-label {
  font-family: var(--ff-body);
  font-size: 12px;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 0.02em;
}
.nav-x__usage-val {
  font-size: 11.5px;
  color: var(--ink-3);
  font-weight: 300;
  line-height: 1.45;
}

/* Attribute pills */
.nav-x__attrs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}
.nav-x__attr {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 14px;
  border-radius: 999px;
  font-family: var(--ff-body);
  font-size: 12px;
  font-weight: 500;
  border: 1.5px solid var(--border);
  color: var(--ink);
  background: var(--surface);
  transition: transform var(--trans-fast), box-shadow var(--trans-fast);
}
.nav-x__attr:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); }
.nav-x__attr-label {
  font-family: var(--ff-label);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-4);
  margin-right: 2px;
}

/* ============================================================
   KEYFRAMES
   ============================================================ */
@keyframes nv-rise {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 768px) {
  .nav-x__header { padding: 64px 24px 44px; }
}
@media (max-width: 480px) {
  .nav-x__header { padding: 48px 16px 32px; }
  .nav-x__img-wrap { width: 130px; height: 130px; }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .nav-x *, .nav-x *::before, .nav-x *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
  .nav-x__planet-img { animation: none; }
  .nav-x__orbit-ring   { animation: none; }
}
