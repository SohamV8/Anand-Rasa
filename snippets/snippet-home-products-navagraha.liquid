{%- comment -%} Navagraha — intro + planet cards {%- endcomment -%}
{%- capture ar_nav9_collection_url -%}{% render 'ar-collection-url', handle: 'planet-attars' %}{%- endcapture -%}
{%- liquid
  assign ar_nav9_intro_url = section.settings.nav9_url | strip
  if ar_nav9_intro_url == blank or ar_nav9_intro_url contains 'collections' or ar_nav9_intro_url contains 'shopify://collections'
    assign ar_nav9_intro_url = ar_nav9_collection_url
  endif

  assign ar_pl_collection = collections['planet-attars']
  if ar_pl_collection == blank or ar_pl_collection == empty
    assign ar_pl_collection = collections['planet-attar']
  endif
  if ar_pl_collection == blank or ar_pl_collection == empty
    assign ar_pl_collection = collections['planet']
  endif
-%}
<div class="ar-nav9-wrap">
  <section class="ar-nav9-intro" aria-labelledby="ar-nav9-intro-heading-{{ section.id }}">
    <div class="ar-nav9-intro__in">
      <h2 class="ar-nav9-intro__h" id="ar-nav9-intro-heading-{{ section.id }}">{{ section.settings.nav9_heading | default: 'Navagraha Attars' }}</h2>
      <p class="ar-nav9-intro__p">{{ section.settings.nav9_text | default: 'Inspired by the nine celestial forces, each fragrance is crafted to harmonize your presence with planetary energy.' }}</p>
      <a href="{{ ar_nav9_intro_url }}" class="ar-nav9-intro__btn">Explore Planet Attars</a>
    </div>
  </section>

  {% render 'planet-attar-cards', pl_collection: ar_pl_collection, hide_head: true, pl_home: true, section: section %}
</div>
