{%- comment -%} 6. NAVAGRAHA ATTARS {%- endcomment -%}
{%- capture ar_nav9_collection_url -%}{% render 'ar-collection-url', handle: 'planet-attars' %}{%- endcapture -%}
{%- liquid
  assign ar_nav9_intro_url = section.settings.nav9_url | strip
  if ar_nav9_intro_url == blank or ar_nav9_intro_url contains 'collections' or ar_nav9_intro_url contains 'shopify://collections'
    assign ar_nav9_intro_url = ar_nav9_collection_url
  endif
-%}
<section class="ar-nav9">
  <style>
    #shopify-section-{{ section.id }} .ar-nav9__main { min-height: 100vh; background-color:#FFFFFF ;}
    #shopify-section-{{ section.id }} .ar-nav9__panel { padding: clamp(20px, 4vw, 40px); }
    #shopify-section-{{ section.id }} .ar-nav9__btn.is-active,
    #shopify-section-{{ section.id }} .ar-nav9__btn[aria-pressed="true"] { background-color:#FFFFFF !important; }
    #shopify-section-{{ section.id }} .ar-nav9__pimg {
      width: 100%;
      max-width: min(460px, 96%);
      height: auto;
      max-height: calc(100vh - 180px);
      object-fit: contain;
      background-color:#FFFFFF !important;
      padding: clamp(8px, 1.8vw, 16px);
      margin: 0 auto;
    }
    #shopify-section-{{ section.id }} .ar-nav9__bimg {
      padding: clamp(6px, 1.2vw, 12px);
      margin: clamp(4px, 1vw, 10px);
      width: calc(100% - clamp(8px, 2vw, 20px));
      height: calc(100% - clamp(8px, 2vw, 20px));
    }
    @media (max-width: 1023px) {
      #shopify-section-{{ section.id }} .ar-nav9__main { min-height: 100vh; }
      #shopify-section-{{ section.id }} .ar-nav9__panel { padding: clamp(16px, 5vw, 28px); }
      #shopify-section-{{ section.id }} .ar-nav9__pimg { max-height: min(72vh, 620px); }
    }
  </style>
  {%- liquid
    if collections['planet-attars'] != empty
      assign ar_nav9_fallback = ar_nav9_collection_url
    else
      assign ar_nav9_fallback = routes.collections_url | append: '/planet-attars'
    endif
  -%}
  <div class="ar-nav9__intro">
    <div class="ar-nav9__intro-in">
      <h2 class="ar-nav9__intro-h">{{ section.settings.nav9_heading | default: 'Navagraha Attars' }}</h2>
      <p class="ar-nav9__intro-p">{{ section.settings.nav9_text | default: 'Inspired by the nine celestial forces, each fragrance is crafted to harmonize your presence with planetary energy.' }}</p>
      <a href="{{ ar_nav9_intro_url }}" class="ar-nav9__intro-btn">EXPLORE COLLECTION</a>
    </div>
  </div>
  <div class="ar-nav9__main">
    {%- assign ar_nav9_has_init = false -%}
    {%- assign ar_nav9_init_perfume = nil -%}
    {%- assign ar_nav9_init_desc = '' -%}
    {%- assign ar_nav9_init_url = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'planet' -%}
        {%- unless ar_nav9_has_init -%}
          {%- assign ar_nav9_init_perfume = block.settings.perfume_image -%}
          {%- assign ar_nav9_init_desc = block.settings.description -%}
          {%- assign ar_nav9_init_url = block.settings.url -%}
          {%- assign ar_nav9_has_init = true -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
    <div class="ar-nav9__grid">
      {%- assign ar_nav9_btn_first = true -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'planet' -%}
          {%- assign ar_nav9_attar_image = '' -%}
          {%- assign ar_nav9_card_image = '' -%}
          {%- assign ar_nav9_name_key = block.settings.name | default: '' | downcase | strip -%}
          {%- if ar_nav9_name_key contains 'sun' or ar_nav9_name_key contains 'surya' -%}
            {%- assign ar_nav9_attar_image = 'Planet/surya_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/surya_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'moon' or ar_nav9_name_key contains 'chandra' -%}
            {%- assign ar_nav9_attar_image = 'Planet/chandra_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/moon_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'mars' or ar_nav9_name_key contains 'mangal' -%}
            {%- assign ar_nav9_attar_image = 'Planet/mangal_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/mangal_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'mercury' or ar_nav9_name_key contains 'budh' or ar_nav9_name_key contains 'budha' -%}
            {%- assign ar_nav9_attar_image = 'Planet/budh_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/budh_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'jupiter' or ar_nav9_name_key contains 'guru' -%}
            {%- assign ar_nav9_attar_image = 'Planet/guru_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/guru_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'venus' or ar_nav9_name_key contains 'shukra' -%}
            {%- assign ar_nav9_attar_image = 'Planet/shukra_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/shukra_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'saturn' or ar_nav9_name_key contains 'shani' -%}
            {%- assign ar_nav9_attar_image = 'Planet/shani_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/shani_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'rahu' -%}
            {%- assign ar_nav9_attar_image = 'Planet/rahu_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/rahu_card.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'ketu' -%}
            {%- assign ar_nav9_attar_image = 'Planet/ketu_attar.webp' | asset_url -%}
            {%- assign ar_nav9_card_image = 'Planet/ketu_card.webp' | asset_url -%}
          {%- endif -%}
          {%- liquid
            assign ar_nav9_block_url = block.settings.url | strip
            if ar_nav9_block_url == blank or ar_nav9_block_url contains 'collections' or ar_nav9_block_url contains 'shopify://collections'
              assign ar_nav9_block_url = ar_nav9_collection_url
            endif
          -%}
          <button
            type="button"
            class="ar-nav9__btn{% if ar_nav9_btn_first %} is-active{% endif %}"
            data-img="{%- if ar_nav9_attar_image != blank -%}{{ ar_nav9_attar_image }}{%- endif -%}"
            data-desc="{{ block.settings.description | default: '' | strip_newlines | escape }}"
            data-url="{% if ar_nav9_block_url != blank %}{{ ar_nav9_block_url | escape }}{% endif %}"
            aria-label="{{ block.settings.name | default: 'Planet' | escape }}"
            {{ block.shopify_attributes }}
          >
            {%- if ar_nav9_card_image != blank -%}
              <img src="{{ ar_nav9_card_image }}" alt="{{ block.settings.name | escape }}" width="400" height="400" loading="lazy" class="ar-nav9__bimg">
            {%- endif -%}
          </button>
          {%- assign ar_nav9_btn_first = false -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="ar-nav9__panel">
      {%- assign ar_nav9_init_img = '' -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'planet' -%}
          {%- assign ar_nav9_name_key = block.settings.name | default: '' | downcase | strip -%}
          {%- if ar_nav9_name_key contains 'sun' or ar_nav9_name_key contains 'surya' -%}
            {%- assign ar_nav9_init_img = 'Planet/surya_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'moon' or ar_nav9_name_key contains 'chandra' -%}
            {%- assign ar_nav9_init_img = 'Planet/chandra_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'mars' or ar_nav9_name_key contains 'mangal' -%}
            {%- assign ar_nav9_init_img = 'Planet/mangal_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'mercury' or ar_nav9_name_key contains 'budh' or ar_nav9_name_key contains 'budha' -%}
            {%- assign ar_nav9_init_img = 'Planet/budh_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'jupiter' or ar_nav9_name_key contains 'guru' -%}
            {%- assign ar_nav9_init_img = 'Planet/guru_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'venus' or ar_nav9_name_key contains 'shukra' -%}
            {%- assign ar_nav9_init_img = 'Planet/shukra_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'saturn' or ar_nav9_name_key contains 'shani' -%}
            {%- assign ar_nav9_init_img = 'Planet/shani_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'rahu' -%}
            {%- assign ar_nav9_init_img = 'Planet/rahu_attar.webp' | asset_url -%}
          {%- elsif ar_nav9_name_key contains 'ketu' -%}
            {%- assign ar_nav9_init_img = 'Planet/ketu_attar.webp' | asset_url -%}
          {%- endif -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      <img
        class="ar-nav9__pimg js-ar-nav9-pimg"
        id="ar-pimg-{{ section.id }}"
        width="280"
        height="420"
        alt="{% if ar_nav9_init_perfume != blank %}{{ section.settings.nav9_heading | default: 'Navagraha' | escape }} — selected attar{% else %}Selected planet attar{% endif %}"
        {% if ar_nav9_init_img != blank -%}
          src="{{ ar_nav9_init_img }}"
        {%- endif %}
      >
      <p class="ar-nav9__pdesc js-ar-nav9-pdesc" id="ar-pdesc-{{ section.id }}">{{ ar_nav9_init_desc | escape }}</p>
      <a href="{% if ar_nav9_init_url != blank %}{{ ar_nav9_init_url }}{% else %}{{ ar_nav9_fallback }}{% endif %}" class="ar-nav9__pbtn js-ar-nav9-plink" id="ar-plink-{{ section.id }}" data-fallback-url="{{ ar_nav9_fallback | escape }}">VIEW PRODUCT</a>
    </div>
  </div>
</section>
