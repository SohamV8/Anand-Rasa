{%- comment -%}
  Bestseller image lookup
  -----------------------
  Resolves a product to its corresponding showcase image inside
  /assets/Bestseller/ based on the product's handle/title. Echoes the
  asset filename (e.g. "Bestseller/Kamalini.webp") or empty string if
  no match is found.

  Usage:
    {%- capture bestseller_showcard -%}
      {%- render 'bestseller-image-lookup', bs_product: p -%}
    {%- endcapture -%}
    {%- assign bestseller_showcard = bestseller_showcard | strip -%}

  Required parameter:
    bs_product — a Shopify product object

  Optional:
    bs_mockup_fallback — when true, returns Bestseller/mockup.jpg if no product match
{%- endcomment -%}
{%- liquid
  assign bs_mockup_fallback = bs_mockup_fallback | default: false
  assign title_key = bs_product.title | handleize
  assign handle_key = bs_product.handle | default: title_key
  assign type_key = bs_product.type | default: '' | downcase
  assign img = ''

  assign is_incense_product = false
  if title_key contains 'incense' or handle_key contains 'incense' or type_key contains 'incense' or type_key contains 'agarbatti' or type_key contains 'dhoop'
    assign is_incense_product = true
  endif
-%}
{%- unless is_incense_product -%}
{%- liquid
  comment
  Order matters: place multi-word/compound matches before single-word
  matches so that, for example, "oud-e-azam" doesn't fall through to
  the generic "oud" rule. Do not match jasmine/champa for incense sticks.
  endcomment

  if title_key contains 'kesariya-ishq' or handle_key contains 'kesariya-ishq'
    assign img = 'Bestseller/Kesariya_Ishq.webp'
  elsif title_key contains 'chandan-nandan' or handle_key contains 'chandan-nandan'
    assign img = 'Bestseller/Chandan_Nandan.webp'
  elsif title_key contains 'dev-priya' or handle_key contains 'dev-priya'
    assign img = 'Bestseller/Dev_Priya.webp'
  elsif title_key contains 'oud-e-azam' or handle_key contains 'oud-e-azam'
    assign img = 'Bestseller/Oud-e-Azam.webp'
  elsif title_key contains 'bela-amrit' or handle_key contains 'bela-amrit' or title_key contains 'amrit-bela' or handle_key contains 'amrit-bela'
    assign img = 'Bestseller/Bela_Amrit.webp'
  elsif title_key contains 'rajnigandha' or handle_key contains 'rajnigandha' or title_key contains 'rajni-gandha' or handle_key contains 'rajni-gandha'
    assign img = 'Bestseller/RajniGandha.webp'
  elsif title_key contains 'pushprasa' or handle_key contains 'pushprasa' or title_key contains 'pushp-rasa' or handle_key contains 'pushp-rasa'
    assign img = 'Bestseller/pushprasa.webp'
  elsif title_key contains 'whiteoudh' or handle_key contains 'whiteoudh' or title_key contains 'white-oudh' or handle_key contains 'white-oudh' or title_key contains 'white-oud' or handle_key contains 'white-oud'
    assign img = 'Bestseller/whiteoudh.webp'
  elsif title_key contains 'firdaus' or handle_key contains 'firdaus'
    assign img = 'Bestseller/firdaus_attar.webp'
  elsif title_key contains 'fawakeh' or handle_key contains 'fawakeh'
    assign img = 'Bestseller/Fawakeh_attar.webp'
  elsif title_key contains 'shamama' or handle_key contains 'shamama'
    assign img = 'Bestseller/shamama.webp'
  elsif title_key contains 'gulbadan' or handle_key contains 'gulbadan'
    assign img = 'Bestseller/Gulbadan.webp'
  elsif title_key contains 'kamalini' or handle_key contains 'kamalini'
    assign img = 'Bestseller/Kamalini.webp'
  elsif title_key contains 'kasturi' or handle_key contains 'kasturi'
    assign img = 'Bestseller/Kasturi.webp'
  elsif title_key contains 'velora' or handle_key contains 'velora'
    assign img = 'Bestseller/Velora.webp'
  elsif title_key contains 'mohini' or handle_key contains 'mohini'
    assign img = 'Bestseller/mohini.webp'
  elsif title_key contains 'parijat' or handle_key contains 'parijat'
    assign img = 'Bestseller/parijat.webp'
  elsif title_key contains 'motia' or handle_key contains 'motia'
    assign img = 'Bestseller/motia.webp'
  elsif title_key contains 'kewra' or handle_key contains 'kewra'
    assign img = 'Bestseller/kewra.webp'
  elsif title_key contains 'khus' or handle_key contains 'khus'
    assign img = 'Bestseller/Khus.webp'
  elsif title_key contains 'loban' or handle_key contains 'loban'
    assign img = 'Bestseller/loban.webp'
  elsif title_key contains 'genda' or handle_key contains 'genda'
    assign img = 'Bestseller/Genda.webp'
  elsif title_key contains 'jasmine' or handle_key contains 'jasmine'
    assign img = 'Bestseller/Jasmine.webp'
  elsif title_key contains 'champa' or handle_key contains 'champa'
    assign img = 'Bestseller/champa.webp'
  elsif title_key contains 'heena' or handle_key contains 'heena' or title_key contains 'hina' or handle_key contains 'hina'
    assign img = 'Bestseller/heena.webp'
  elsif title_key contains 'shaahi-oud' or handle_key contains 'shaahi-oud' or title_key contains 'shaahi_oud' or handle_key contains 'shaahi_oud' or title_key contains 'shahi-oud' or handle_key contains 'shahi-oud'
    assign img = 'Bestseller/shaahi_oud.webp'
  elsif title_key contains 'dard-e-disco' or handle_key contains 'dard-e-disco' or title_key contains 'dard-e' or handle_key contains 'dard-e'
    assign img = 'Bestseller/Dard-e-Disco.webp'
  elsif title_key contains 'kala-pathar' or handle_key contains 'kala-pathar' or title_key contains 'kala_pathar' or handle_key contains 'kala_pathar' or title_key contains 'kalapathar' or handle_key contains 'kalapathar'
    assign img = 'Bestseller/Kala_pathar.webp'
  elsif title_key contains 'baazigar' or handle_key contains 'baazigar'
    assign img = 'Bestseller/Baazigar.webp'
  elsif title_key contains 'baaghi' or handle_key contains 'baaghi'
    assign img = 'Bestseller/Baaghi.webp'
  elsif title_key contains 'monarch' or handle_key contains 'monarch'
    assign img = 'Bestseller/Monarch.webp'
  elsif title_key contains 'mirage' or handle_key contains 'mirage'
    assign img = 'Bestseller/Mirage.webp'
  elsif title_key contains 'rangeela' or handle_key contains 'rangeela'
    assign img = 'Bestseller/Rangeela.webp'
  elsif title_key contains 'manmohini' or handle_key contains 'manmohini'
    assign img = 'Bestseller/Manmohini.webp'
  elsif title_key contains 'madhur-sena' or handle_key contains 'madhur-sena' or title_key contains 'madhur_sena' or handle_key contains 'madhur_sena'
    assign img = 'Bestseller/Madhur_Sena.webp'
  elsif title_key contains 'madhavi' or handle_key contains 'madhavi'
    assign img = 'Bestseller/Madhavi.webp'
  elsif title_key contains 'masakali' or handle_key contains 'masakali' or title_key contains 'masa-kali' or handle_key contains 'masa-kali'
    assign img = 'Bestseller/Masakali.webp'
  elsif title_key contains 'menaka' or handle_key contains 'menaka'
    assign img = 'Bestseller/menaka.webp'
  elsif title_key contains 'nag-raaj' or handle_key contains 'nag-raaj' or title_key contains 'nag_raaj' or handle_key contains 'nag_raaj' or title_key contains 'nagraaj' or handle_key contains 'nagraaj' or title_key contains 'nag-raj' or handle_key contains 'nag-raj'
    assign img = 'Bestseller/Nag_raaj.webp'
  elsif title_key contains 'ramta-jogi' or handle_key contains 'ramta-jogi' or title_key contains 'ramta_jogi' or handle_key contains 'ramta_jogi'
    assign img = 'Bestseller/Ramta_jogi.webp'
  elsif title_key contains 'shaam-mastani' or handle_key contains 'shaam-mastani' or title_key contains 'shaam_mastani' or handle_key contains 'shaam_mastani'
    assign img = 'Bestseller/shaam_mastani.webp'
  elsif title_key contains 'mridula' or handle_key contains 'mridula'
    assign img = 'Bestseller/Mridula.webp'
  elsif title_key contains 'malang' or handle_key contains 'malang'
    assign img = 'Bestseller/Malang.webp'
  elsif title_key contains 'oud' or handle_key contains 'oud'
    assign img = 'Bestseller/Oud-e-Azam.webp'
  endif

  if img == '' and bs_mockup_fallback
    assign img = 'Bestseller/mockup.jpg'
  endif

  echo img
-%}
{%- else -%}
{{- '' -}}
{%- endunless -%}
