{%- comment -%}
  Compact luxury collection cards — all collections in a responsive grid.
  Images from theme editor category blocks; URLs via ar-collection-url.
{%- endcomment -%}
{%- liquid
  assign ar_disc_heading = section.settings.disc_heading | default: 'Find Your Fragrance Ritual'
  assign ar_disc_sub = section.settings.disc_subheading | default: 'Curated attars for ritual, balance, and discovery.'

  assign ar_feat_handles = 'planet-attars|zodiac-attars|nakshatra-attars|chakra-attars|stress-relief|love-attar|incense-sticks|giftsets|giftsets|meditation-oils' | split: '|'
  assign ar_feat_titles = 'Planet Attars|Zodiac Attars|Nakshatra Attars|Chakra Attars|Stress Relief Attars|Love Attars|Incense Sticks|Discovery Kits|Gift Sets|Meditation Oils' | split: '|'
  assign ar_feat_matches = 'planet|zodiac|nakshatra|chakra|stress|love|incense|discovery|gift set|meditation' | split: '|'
  assign ar_feat_ctas = 'Explore|Explore|Explore|Explore|Explore|Explore|Explore|Shop|Shop|Explore' | split: '|'
  assign ar_feat_fallbacks = 'PlanetHero.webp|PlanetHero.webp|PlanetHero.webp|chakra.webp|stress.webp|love.webp|incense.jpeg|home.webp|home.webp|chakra.webp' | split: '|'
  assign ar_feat_tones = 'dark|dark|dark|light|dark|dark|dark|dark|dark|dark' | split: '|'
-%}

<section class="ar-disc js-ar-disc" aria-labelledby="ar-disc-heading">
  <header class="ar-disc__hdr">
    <h2 id="ar-disc-heading" class="ar-disc__h">{{ ar_disc_heading | escape }}</h2>
    {%- if ar_disc_sub != blank -%}
      <p class="ar-disc__sub">{{ ar_disc_sub | escape }}</p>
    {%- endif -%}
  </header>

  <div class="ar-disc__list">
    {%- for ar_feat_handle in ar_feat_handles -%}
      {%- liquid
        assign ar_i = forloop.index0
        assign ar_match = ar_feat_matches[ar_i]
        assign ar_title = ar_feat_titles[ar_i]
        assign ar_cta = ar_feat_ctas[ar_i]
        assign ar_fallback = ar_feat_fallbacks[ar_i]
        assign ar_card_tone = ar_feat_tones[ar_i]
        assign ar_delay = ar_i | times: 45

        assign ar_card_image = blank
        assign ar_block_link = blank
        for block in section.blocks
          if block.type == 'category'
            assign ar_bt = block.settings.title | downcase
            assign ar_bl = block.settings.link | default: ''
            assign ar_is_match = false
            if ar_match == 'gift set'
              if ar_bt contains 'gift set' or ar_bt == 'gift sets'
                assign ar_is_match = true
              endif
            elsif ar_match == 'discovery'
              if ar_bt contains 'discovery'
                assign ar_is_match = true
              endif
            elsif ar_bt contains ar_match or ar_bl contains ar_feat_handle
              assign ar_is_match = true
            endif
            if ar_is_match
              if block.settings.image != blank
                assign ar_card_image = block.settings.image
              endif
              assign ar_block_link = block.settings.link | strip
              break
            endif
          endif
        endfor

        capture ar_card_url
          render 'ar-collection-url', handle: ar_feat_handle
        endcapture
        assign ar_card_url = ar_card_url | strip
        if ar_block_link != blank
          if ar_block_link contains 'shopify://collections' or ar_block_link contains '/collections/'
            assign ar_card_url = ar_card_url | default: ar_block_link
          endif
        endif
        if ar_card_url == blank
          assign ar_card_url = routes.collections_url
        endif
      -%}

      <article class="ar-disc__card" style="--ar-disc-delay: {{ ar_delay }}ms;">
        <a
          href="{{ ar_card_url }}"
          class="ar-disc__link ar-disc__link--{{ ar_card_tone }}"
          aria-label="{{ ar_title | escape }} — {{ ar_cta | escape }}"
        >
          <div class="ar-disc__media">
            {%- if ar_card_image != blank -%}
              <img
                class="ar-disc__img"
                src="{{ ar_card_image | image_url: width: 800 }}"
                srcset="{{ ar_card_image | image_url: width: 400 }} 400w, {{ ar_card_image | image_url: width: 600 }} 600w, {{ ar_card_image | image_url: width: 800 }} 800w"
                sizes="(min-width: 1200px) 20vw, (min-width: 768px) 33vw, (min-width: 480px) 50vw, 100vw"
                alt="{{ ar_title | escape }}"
                width="800"
                height="560"
                loading="lazy"
                decoding="async"
              >
            {%- elsif ar_fallback != blank -%}
              <img
                class="ar-disc__img"
                src="{{ ar_fallback | asset_url }}"
                alt=""
                width="800"
                height="560"
                loading="lazy"
                decoding="async"
              >
            {%- else -%}
              <span class="ar-disc__ph" aria-hidden="true"></span>
            {%- endif -%}
            <span class="ar-disc__shade" aria-hidden="true"></span>
          </div>
          <div class="ar-disc__copy">
            <h3 class="ar-disc__title">{{ ar_title | escape }}</h3>
            <span class="ar-disc__btn">{{ ar_cta | escape }}</span>
          </div>
        </a>
      </article>
    {%- endfor -%}
  </div>
</section>
