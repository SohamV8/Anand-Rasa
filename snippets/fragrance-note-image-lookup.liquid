{%- comment -%}
  Maps a fragrance note label → assets/Notes/*.webp
  Usage: {% capture fn_img %}{% render 'fragrance-note-image-lookup', note_name: note_label %}{% endcapture %}
{%- endcomment -%}
{%- liquid
  assign fn_img = ''
  assign n = note_name | downcase | strip
  assign n = n | replace: '–', ' ' | replace: '—', ' ' | replace: '_', ' ' | replace: '-', ' '

  if n contains 'white musk'
    assign fn_img = 'Notes/white musk.webp'
  elsif n contains 'soft smoke' or n contains 'gentle smoke' or n contains 'light smoke'
    assign fn_img = 'Notes/incense.webp'
  elsif n contains 'soft sugar warmth' or n contains 'sugar warmth' or n contains 'soft sugar'
    assign fn_img = 'Notes/Caramel.webp'
  elsif n contains 'combination of many flower' or n contains 'many flowers' or n contains 'many flower' or n contains 'combination of flowers' or n contains 'mixed flowers'
    assign fn_img = 'Notes/jasmine.webp'
  elsif n contains 'white floral' or n contains 'soft white floral' or n contains 'white flower' or n contains 'white blossom' or n contains 'white bloom'
    assign fn_img = 'Notes/jasmine.webp'
  elsif n contains 'floral accord' or n == 'floral' or n == 'florals' or n contains 'floral notes'
    assign fn_img = 'Notes/jasmine.webp'
  elsif n contains 'orange blossom' or n contains 'orange flower' or n contains 'neroli'
    assign fn_img = 'Notes/orange-blossom.webp'
  elsif n contains 'pink pepper'
    assign fn_img = 'Notes/pink_pepper.webp'
  elsif n contains 'black pepper'
    assign fn_img = 'Notes/black_pepper.webp'
  elsif n contains 'cocoa' or n contains 'cacao' or n contains 'cocao' or n contains 'chocolate'
    assign fn_img = 'Notes/chocolate.webp'
  elsif n contains 'passion fruit' or n contains 'passionfruit'
    assign fn_img = 'Notes/Passion_fruit.webp'
  elsif n contains 'mixed berri' or n == 'berries' or n contains 'mixed berries'
    assign fn_img = 'Notes/berries.webp'
  elsif n contains 'raspberry'
    assign fn_img = 'Notes/raspberry.webp'
  elsif n contains 'strawberr'
    assign fn_img = 'Notes/strawberry.webp'
  elsif n contains 'dry fruit' or n contains 'dried fruit'
    assign fn_img = 'Notes/dry_fruits.webp'
  elsif n == 'date' or n == 'dates' or n contains 'dates' or n contains 'date fruit' or n contains 'date palm'
    assign fn_img = 'Notes/dates.webp'
  elsif n contains 'candied fruit' or n contains 'candy fruit' or n contains 'candied' or n contains 'candy' or n contains 'tropical fruit' or n contains 'exotic tropical'
    assign fn_img = 'Notes/candy_fruits.webp'
  elsif n contains 'raat ki rani' or n contains 'rat ki rani' or n contains 'night queen'
    assign fn_img = 'Notes/raat_ki_rani.webp'
  elsif n contains 'myrrh' or n contains 'frankincense'
    assign fn_img = 'Notes/myrrh_frankincense.webp'
  elsif n contains 'oakmoss' or n contains 'oak moss'
    assign fn_img = 'Notes/oakmoss.webp'
  elsif n contains 'tuberose'
    assign fn_img = 'Notes/tuberose.webp'
  elsif n contains 'patchouli'
    assign fn_img = 'Notes/Patchouli.webp'
  elsif n contains 'grapefruit'
    assign fn_img = 'Notes/grapefruit.webp'
  elsif n contains 'bergamot'
    assign fn_img = 'Notes/bergamot.webp'
  elsif n contains 'cedarwood' or n contains 'cedar wood' or n contains 'cedar'
    assign fn_img = 'Notes/cedarwood.webp'
  elsif n contains 'juniper'
    assign fn_img = 'Notes/juniper.webp'
  elsif n contains 'pineapple'
    assign fn_img = 'Notes/pineapple.webp'
  elsif n contains 'cardamom'
    assign fn_img = 'Notes/cardamom.webp'
  elsif n contains 'cinnamon'
    assign fn_img = 'Notes/cinnamon.webp'
  elsif n contains 'nutmeg'
    assign fn_img = 'Notes/nutmeg.webp'
  elsif n contains 'clove'
    assign fn_img = 'Notes/clove.webp'
  elsif n contains 'camphor' or n contains 'kapoor' or n contains 'karpoor'
    assign fn_img = 'Notes/camphor_kapoor.webp'
  elsif n contains 'green herbal' or n contains 'herbaceous' or n contains 'green accord' or n contains 'green notes' or n contains 'fresh herbal' or n contains 'herbal accord' or n contains 'sacred herbal' or n contains 'aromatic herb' or n contains 'herbal' or n contains 'herbs' or n == 'herb'
    assign fn_img = 'Notes/green_herbal.webp'
  elsif n contains 'spice' or n contains 'spicy'
    assign fn_img = 'Notes/spices.webp'
  elsif n contains 'gardenia'
    assign fn_img = 'Notes/Gardenia.webp'
  elsif n contains 'turmeric' or n contains 'kasturi manjal' or n contains 'kasturi manjhal'
    assign fn_img = 'Notes/turmeric.webp'
  elsif n contains 'vetiver'
    assign fn_img = 'Notes/vetiver.webp'
  elsif n contains 'benzoin'
    assign fn_img = 'Notes/benzoin.webp'
  elsif n contains 'coconut'
    assign fn_img = 'Notes/coconut.webp'
  elsif n contains 'almond'
    assign fn_img = 'Notes/almond.webp'
  elsif n contains 'saffron' or n contains 'kesar'
    assign fn_img = 'Notes/Saffron.webp'
  elsif n == 'iris' or n contains 'orris' or n contains 'iris root' or n contains 'iris accord'
    assign fn_img = 'Notes/Saffron.webp'
  elsif n contains 'leather'
    assign fn_img = 'Notes/leather.webp'
  elsif n contains 'tobacco'
    assign fn_img = 'Notes/tobacco.webp'
  elsif n contains 'vanilla'
    assign fn_img = 'Notes/vanilla.webp'
  elsif n contains 'lavender'
    assign fn_img = 'Notes/lavender.webp'
  elsif n contains 'motia' or n contains 'champaca'
    assign fn_img = 'Notes/motia.webp'
  elsif n contains 'jasmine'
    assign fn_img = 'Notes/jasmine.webp'
  elsif n contains 'birch'
    assign fn_img = 'Notes/birch.webp'
  elsif n contains 'coffee'
    assign fn_img = 'Notes/coffee.webp'
  elsif n contains 'praline'
    assign fn_img = 'Notes/praline.webp'
  elsif n contains 'incense' or n contains 'olibanum'
    assign fn_img = 'Notes/incense.webp'
  elsif n contains 'caramel'
    assign fn_img = 'Notes/Caramel.webp'
  elsif n contains 'tonka'
    assign fn_img = 'Notes/tonka.webp'
  elsif n contains 'ginger'
    assign fn_img = 'Notes/ginger.webp'
  elsif n contains 'licorice' or n contains 'liquorice'
    assign fn_img = 'Notes/licorice.webp'
  elsif n contains 'honey'
    assign fn_img = 'Notes/honey.webp'
  elsif n contains 'mango'
    assign fn_img = 'Notes/mango.webp'
  elsif n contains 'peach'
    assign fn_img = 'Notes/peach.webp'
  elsif n contains 'pear'
    assign fn_img = 'Notes/pear.webp'
  elsif n contains 'mint'
    assign fn_img = 'Notes/mint.webp'
  elsif n contains 'lotus'
    assign fn_img = 'Notes/lotus11.webp'
  elsif n contains 'rose' and n contains 'musk'
    assign fn_img = 'Notes/musk.webp'
  elsif n contains 'rose'
    assign fn_img = 'Notes/Rose.webp'
  elsif n contains 'oud' or n contains 'agarwood'
    assign fn_img = 'Notes/oud.webp'
  elsif n contains 'amber'
    assign fn_img = 'Notes/amber.webp'
  elsif n contains 'citrus' or n contains 'lemon' or n contains 'lime' or n contains 'orange' or n contains 'mandarin'
    assign fn_img = 'Notes/citrus.webp'
  elsif n contains 'musk'
    assign fn_img = 'Notes/musk.webp'
  elsif n contains 'grass'
    assign fn_img = 'Notes/grass.webp'
  elsif n contains 'herb'
    assign fn_img = 'Notes/green_herbal.webp'
  elsif n contains 'moss'
    assign fn_img = 'Notes/moss.webp'
  elsif n contains 'wood' or n contains 'woody' or n contains 'sandalwood' or n contains 'sandal'
    assign fn_img = 'Notes/wood.webp'
  elsif n contains 'floral'
    assign fn_img = 'Notes/jasmine.webp'
  endif

  echo fn_img
-%}
