{%- liquid
  assign incense_scope = scope_id | default: 'global'
  assign is_incense_page = false
  if template.suffix contains 'incense'
    assign is_incense_page = true
  endif
  if is_incense_page == false and product.type != blank
    assign incense_type = product.type | downcase
    if incense_type contains 'incense'
      assign is_incense_page = true
    endif
  endif
  if is_incense_page == false and product.handle != blank
    assign incense_handle = product.handle | downcase
    if incense_handle contains 'incense'
      assign is_incense_page = true
    endif
  endif
-%}

{%- if is_incense_page -%}
  <section class="incense-process" id="incense-process-{{ incense_scope | escape }}">
    <div class="incense-process__inner">
      <header class="incense-process__head">
        <h2 class="incense-process__title">The Process of Incense Making</h2>
      </header>

      <div class="incense-process__grid" aria-label="Incense making process steps">
        <article class="incense-process__step">
          <span class="incense-process__icon-slot" aria-hidden="true">1</span>
          <p class="incense-process__text">Flowers are collected from temples.</p>
        </article>
        <article class="incense-process__step">
          <span class="incense-process__icon-slot" aria-hidden="true">2</span>
          <p class="incense-process__text">The flowers are taken for sorting.</p>
        </article>
        <article class="incense-process__step">
          <span class="incense-process__icon-slot" aria-hidden="true">3</span>
          <p class="incense-process__text">They are handpicked and separated carefully.</p>
        </article>
        <article class="incense-process__step">
          <span class="incense-process__icon-slot" aria-hidden="true">4</span>
          <p class="incense-process__text">The dried flowers are turned into powder.</p>
        </article>
        <article class="incense-process__step">
          <span class="incense-process__icon-slot" aria-hidden="true">5</span>
          <p class="incense-process__text">A paste is made to prepare dhoop and incense sticks.</p>
        </article>
        <article class="incense-process__step">
          <span class="incense-process__icon-slot" aria-hidden="true">6</span>
          <p class="incense-process__text">The incense is blended and dipped in pure essential oils.</p>
        </article>
      </div>
    </div>
  </section>

  <style>
    .incense-process {
      margin: 26px auto;
      padding: 66px 26px 60px;
    }
    .incense-process__inner {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 8px;
    }
    .incense-process__head {
      text-align: center;
      margin-bottom: 34px;
    }
    .incense-process__title {
      margin: 0;
      color: #5e2e2e;
      font-family: "Poppins", var(--font-heading-family), var(--font-body-family), sans-serif;
      font-size: clamp(34px, 2.8vw, 52px);
      line-height: 1.1;
      font-weight: 500;
      letter-spacing: -0.015em;
    }
    .incense-process__grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 10px;
      align-items: start;
    }
    @media (max-width: 1100px) {
      .incense-process__grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        row-gap: 18px;
      }
    }
    @media (max-width: 650px) {
      .incense-process {
        margin: 18px auto;
        padding: 48px 16px 44px;
      }
      .incense-process__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    .incense-process__step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      text-align: center;
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.5s cubic-bezier(.22,.61,.36,1), transform 0.5s cubic-bezier(.22,.61,.36,1);
    }
    .incense-process.is-visible .incense-process__step {
      opacity: 1;
      transform: translateY(0);
    }
    .incense-process.is-visible .incense-process__step:nth-child(2) { transition-delay: 0.04s; }
    .incense-process.is-visible .incense-process__step:nth-child(3) { transition-delay: 0.08s; }
    .incense-process.is-visible .incense-process__step:nth-child(4) { transition-delay: 0.12s; }
    .incense-process.is-visible .incense-process__step:nth-child(5) { transition-delay: 0.16s; }
    .incense-process.is-visible .incense-process__step:nth-child(6) { transition-delay: 0.2s; }
    .incense-process__icon-slot {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      border: 1.5px dashed #cfb47f;
      color: #b89252;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: "Poppins", var(--font-body-family), sans-serif;
      font-size: 22px;
      font-weight: 500;
      line-height: 1;
    }
    .incense-process__text {
      margin: 0;
      color: #2f3440;
      font-family: var(--font-body-family);
      font-size: clamp(14px, 1vw, 18px);
      line-height: 1.4;
      font-weight: 400;
      max-width: 230px;
    }
    @media (prefers-reduced-motion: reduce) {
      .incense-process__step {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>

  <script>
    (function () {
      var sectionEl = document.getElementById('incense-process-{{ incense_scope | escape }}');
      if (!sectionEl) return;
      if (!('IntersectionObserver' in window)) {
        sectionEl.classList.add('is-visible');
        return;
      }
      var observer = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          sectionEl.classList.add('is-visible');
          observer.disconnect();
        }
      }, { threshold: 0.2 });
      observer.observe(sectionEl);
    })();
  </script>
{%- endif -%}
