<style>
  .afq {
    margin: clamp(18px, 2vw, 30px) auto 0;
    padding: 0 clamp(12px, 2vw, 20px);
    font-family: var(--font-body-family, system-ui, -apple-system, sans-serif);
  }
  .afq__inner {
    max-width: min(1280px, 100%);
    margin: 0 auto;
    background: #fff;
 
    box-shadow: none;
    padding: clamp(16px, 2.1vw, 24px);
  }
  .afq__eyebrow {
    margin: 0 0 6px;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: #666;
    font-weight: 600;
  }
  .afq__title {
    margin: 0;
    font-size: clamp(20px, 2vw, 30px);
    line-height: 1.18;
    color: #0f0f0f;
    letter-spacing: -0.01em;
  }
  .afq__intro {
    margin: 8px 0 0;
    color: #5a5a5a;
    font-size: 14px;
    line-height: 1.6;
  }
  .afq__list {
    margin-top: 14px;
    display: grid;
    gap: 0;
    border-top: 1px solid #111;
  }
  .afq__item {
    border-bottom: 1px solid #111;
    border-left: 1px solid #111;
    border-right: 1px solid #111;
    border-radius: 0;
    background: #fff;
    overflow: hidden;
  }
  .afq__q {
    position: relative;
    cursor: pointer;
    list-style: none;
    padding: 13px 42px 13px 14px;
    font-size: 14px;
    font-weight: 500;
    color: #101010;
    transition: background-color 0.2s ease;
  }
  .afq__q:hover { background: #f7f7f7; }
  .afq__q::after {
    content: '+';
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 18px;
    line-height: 1;
    color: #444;
  }
  .afq__item[open] .afq__q::after { content: '\2212'; }
  .afq__q::-webkit-details-marker { display: none; }
  .afq__a {
    margin: 0;
    padding: 0 14px 13px;
    color: #4d4d4d;
    font-size: 13px;
    line-height: 1.65;
  }
  @media (max-width: 700px) {
    .afq__inner { padding: 14px; }
    .afq__q { font-size: 13px; padding: 12px 38px 12px 12px; }
    .afq__q::after { right: 12px; }
    .afq__a { font-size: 12.5px; padding: 0 12px 12px; }
  }
</style>
