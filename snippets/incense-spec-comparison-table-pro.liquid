{% assign table_section = section %}
{% if section_ref != blank %}
  {% assign table_section = section_ref %}
{% endif %}

{% assign is_incense_page = false %}
{% if template.suffix contains 'incense' %}
  {% assign is_incense_page = true %}
{% endif %}
{% if is_incense_page == false and product.type != blank %}
  {% assign incense_type = product.type | downcase %}
  {% if incense_type contains 'incense' %}
    {% assign is_incense_page = true %}
  {% endif %}
{% endif %}
{% if is_incense_page == false and product.handle != blank %}
  {% assign incense_handle = product.handle | downcase %}
  {% if incense_handle contains 'incense' %}
    {% assign is_incense_page = true %}
  {% endif %}
{% endif %}

{% if is_incense_page %}
  {% assign compare_feature_1 = table_section.settings.compare_feature_1 | default: 'Clean Burning - Low Smoke' %}
  {% assign compare_feature_2 = table_section.settings.compare_feature_2 | default: 'Natural Ingredients - Chemical & Charcoal Free' %}
  {% assign compare_feature_3 = table_section.settings.compare_feature_3 | default: 'Premium Quality - Handcrafted' %}
  {% assign compare_feature_4 = table_section.settings.compare_feature_4 | default: 'Vedic Fragrance - Authentic Spiritual' %}
  {% assign compare_feature_5 = table_section.settings.compare_feature_5 | default: 'Environment Friendly - Perfect for Daily Pooja' %}

  {% capture incense_yes_mark %}
    <span class="incense-table__seal" aria-hidden="true">
      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
        <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.4"/>
        <path d="m8.5 12 2.2 2.2 4.8-4.8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  {% endcapture %}

  {% capture incense_no_mark %}
    <span class="incense-table__x" aria-hidden="true">×</span>
  {% endcapture %}

  <section class="incense-table" id="incense-table-{{ table_section.id }}">
    <div class="incense-table__card">
      <table class="incense-table__spec">
        <thead>
          <tr>
            <th colspan="2">{{ table_section.settings.spec_table_heading | default: 'Product Specification' }}</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>{{ table_section.settings.spec_label_origin | default: 'Country of Origin' }}</td><td>{{ table_section.settings.spec_origin | default: 'Made in India' }}</td></tr>
          <tr><td>{{ table_section.settings.spec_label_item_form | default: 'Item Form' }}</td><td>{{ table_section.settings.spec_item_form | default: 'Bamboo-less Incense' }}</td></tr>
          <tr><td>{{ table_section.settings.spec_label_item_type | default: 'Item Type' }}</td><td>{{ table_section.settings.spec_item_type | default: 'Eco-friendly, Organic, Meditation, Vedic' }}</td></tr>
          <tr><td>{{ table_section.settings.spec_label_sticks | default: 'Number of Sticks' }}</td><td>{{ table_section.settings.spec_sticks | default: '40' }}</td></tr>
          <tr><td>{{ table_section.settings.spec_label_burn | default: 'Burning Time' }}</td><td>{{ table_section.settings.spec_burn | default: '30+ Minutes' }}</td></tr>
          <tr><td>{{ table_section.settings.spec_label_length | default: 'Length of Stick' }}</td><td>{{ table_section.settings.spec_length | default: '3.5 inches' }}</td></tr>
          {% if table_section.settings.spec_fragrance != blank %}
            <tr><td>{{ table_section.settings.spec_label_fragrance | default: 'Fragrance' }}</td><td>{{ table_section.settings.spec_fragrance }}</td></tr>
          {% endif %}
          {% if table_section.settings.spec_ingredients != blank %}
            <tr><td>{{ table_section.settings.spec_label_ingredients | default: 'Ingredients' }}</td><td>{{ table_section.settings.spec_ingredients }}</td></tr>
          {% endif %}
        </tbody>
      </table>
    </div>

    <div class="incense-table__card">
      <table class="incense-table__compare">
        <thead>
          <tr>
            <th>{{ table_section.settings.compare_col_feature | default: 'Features' }}</th>
            <th>{{ table_section.settings.compare_col_brand | default: 'Anand Rasa' }}</th>
            <th>{{ table_section.settings.compare_col_others | default: 'Others' }}</th>
          </tr>
        </thead>
        <tbody>
          {% if compare_feature_1 != blank %}
            <tr>
              <td>{{ compare_feature_1 }}</td>
              <td>{% if table_section.settings.compare_brand_yes_1 == false %}<span class="incense-table__text">{{ table_section.settings.compare_brand_text_1 | default: '-' }}</span>{% else %}{{ incense_yes_mark }}{% endif %}</td>
              <td>{% if table_section.settings.compare_others_yes_1 %}{{ incense_yes_mark }}{% else %}{{ incense_no_mark }}{% endif %}</td>
            </tr>
          {% endif %}
          {% if compare_feature_2 != blank %}
            <tr>
              <td>{{ compare_feature_2 }}</td>
              <td>{% if table_section.settings.compare_brand_yes_2 == false %}<span class="incense-table__text">{{ table_section.settings.compare_brand_text_2 | default: '-' }}</span>{% else %}{{ incense_yes_mark }}{% endif %}</td>
              <td>{% if table_section.settings.compare_others_yes_2 %}{{ incense_yes_mark }}{% else %}{{ incense_no_mark }}{% endif %}</td>
            </tr>
          {% endif %}
          {% if compare_feature_3 != blank %}
            <tr>
              <td>{{ compare_feature_3 }}</td>
              <td>{% if table_section.settings.compare_brand_yes_3 == false %}<span class="incense-table__text">{{ table_section.settings.compare_brand_text_3 | default: '-' }}</span>{% else %}{{ incense_yes_mark }}{% endif %}</td>
              <td>{% if table_section.settings.compare_others_yes_3 %}{{ incense_yes_mark }}{% else %}{{ incense_no_mark }}{% endif %}</td>
            </tr>
          {% endif %}
          {% if compare_feature_4 != blank %}
            <tr>
              <td>{{ compare_feature_4 }}</td>
              <td>{% if table_section.settings.compare_brand_yes_4 == false %}<span class="incense-table__text">{{ table_section.settings.compare_brand_text_4 | default: '-' }}</span>{% else %}{{ incense_yes_mark }}{% endif %}</td>
              <td>{% if table_section.settings.compare_others_yes_4 %}{{ incense_yes_mark }}{% else %}{{ incense_no_mark }}{% endif %}</td>
            </tr>
          {% endif %}
          {% if compare_feature_5 != blank %}
            <tr>
              <td>{{ compare_feature_5 }}</td>
              <td>{% if table_section.settings.compare_brand_yes_5 == false %}<span class="incense-table__text">{{ table_section.settings.compare_brand_text_5 | default: '-' }}</span>{% else %}{{ incense_yes_mark }}{% endif %}</td>
              <td>{% if table_section.settings.compare_others_yes_5 %}{{ incense_yes_mark }}{% else %}{{ incense_no_mark }}{% endif %}</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  </section>

  <style>
    .incense-table { max-width: 1320px; margin: 0 auto; padding: 74px 28px 94px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: start; }
    @media (max-width: 990px) { .incense-table { grid-template-columns: 1fr; gap: 20px; padding: 58px 18px 74px; } }
    .incense-table__card { border: 1px solid #d7d9de; border-radius: 0; overflow: hidden; background: #f8f8f9; opacity: 0; transform: translateY(10px); transition: opacity .52s cubic-bezier(.22,.61,.36,1), transform .52s cubic-bezier(.22,.61,.36,1); }
    .incense-table.is-ready .incense-table__card { opacity: 1; transform: translateY(0); }
    .incense-table.is-ready .incense-table__card:nth-child(2) { transition-delay: .08s; }
    .incense-table__spec, .incense-table__compare { width: 100%; border-collapse: collapse; table-layout: fixed; font-family: var(--font-body-family); }
    .incense-table__spec th, .incense-table__compare th, .incense-table__spec td, .incense-table__compare td { border-right: 1px solid #e0e1e6; border-bottom: 1px solid #e0e1e6; background: #f7f7f8; }
    .incense-table__spec tr:last-child td, .incense-table__compare tr:last-child td { border-bottom: none; }
    .incense-table__spec th:last-child, .incense-table__compare th:last-child, .incense-table__spec td:last-child, .incense-table__compare td:last-child { border-right: none; }
    .incense-table__spec th { padding: 16px 20px; text-align: left; color: #121212; font-size: 31px; line-height: 1.1; letter-spacing: -.01em; font-weight: 600; font-family: "Poppins", var(--font-heading-family), var(--font-body-family), sans-serif; background: #f7f7f8; }
    .incense-table__spec td { padding: 17px 20px; font-size: 16px; line-height: 1.3; color: #202124; }
    .incense-table__spec td:first-child { width: 52%; font-weight: 400; }
    .incense-table__spec td:last-child { text-align: right; color: #2b2c31; background: #fafafb; }
    .incense-table__compare th { padding: 14px 18px; text-align: center; font-size: 20px; line-height: 1.15; font-weight: 600; font-family: "Poppins", var(--font-heading-family), var(--font-body-family), sans-serif; color: #1a1b1e; background: #f2f2f4; }
    .incense-table__compare th:first-child, .incense-table__compare td:first-child { text-align: left; }
    .incense-table__compare th:first-child { width: 58%; }
    .incense-table__compare td { padding: 19px 18px; font-size: 16px; line-height: 1.33; color: #1e1f24; }
    .incense-table__compare td:nth-child(2), .incense-table__compare td:nth-child(3) { width: 21%; text-align: center; background: #fafafb; }
    .incense-table__seal { display: inline-flex; width: 28px; height: 28px; color: #14161b; vertical-align: middle; }
    .incense-table__seal svg { width: 100%; height: 100%; }
    .incense-table__x { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; font-size: 28px; font-weight: 300; line-height: 1; color: #1a1c21; }
    .incense-table__text { font-size: 16px; color: #565a63; font-weight: 400; }
    .incense-table.is-ready .incense-table__compare tbody tr { animation: incense-row-in .54s cubic-bezier(.22,.61,.36,1) both; }
    .incense-table.is-ready .incense-table__compare tbody tr:nth-child(2) { animation-delay: .03s; }
    .incense-table.is-ready .incense-table__compare tbody tr:nth-child(3) { animation-delay: .06s; }
    .incense-table.is-ready .incense-table__compare tbody tr:nth-child(4) { animation-delay: .09s; }
    .incense-table.is-ready .incense-table__compare tbody tr:nth-child(5) { animation-delay: .12s; }
    @keyframes incense-row-in {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .incense-table__card, .incense-table.is-ready .incense-table__compare tbody tr { transition: none; animation: none; }
      .incense-table__card { opacity: 1; transform: none; }
    }
  </style>

  <script>
    (function () {
      var root = document.getElementById('incense-table-{{ table_section.id }}');
      if (!root) return;
      if (!('IntersectionObserver' in window)) {
        root.classList.add('is-ready');
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          root.classList.add('is-ready');
          io.disconnect();
        }
      }, { threshold: 0.16 });
      io.observe(root);
    })();
  </script>
{% endif %}
