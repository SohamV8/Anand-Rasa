{% doc %}
  Legacy influencer dashboard mock data removed.
  Real partner analytics now load only through the authenticated /pages/partner dashboard.
{% enddoc %}

{%- liquid
  assign inf_handle = page.handle | default: 'partner' | downcase
  assign inf_name = page.title | default: 'Partner'
  assign inf_coupon = ''
  assign inf_instagram = ''
  assign inf_commission_rate = 0
  assign inf_total_orders = blank
  assign inf_revenue = blank
  assign inf_commission = blank
  assign inf_aov = blank
  assign inf_highest = blank
  assign inf_today = blank
  assign inf_monthly = blank
  assign inf_lifetime_commission = blank
  assign inf_monthly_commission = blank
  assign inf_goal_revenue = blank
  assign inf_rank = blank
  assign inf_monthly_rank = blank
  assign inf_top_influencer = ''
  assign inf_referral_url = ''
  assign inf_page_url = shop.url | append: page.url
  assign inf_initials = inf_name | slice: 0, 1 | upcase
-%}
