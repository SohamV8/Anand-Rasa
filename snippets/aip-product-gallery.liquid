{% comment %}
  Luxury product media gallery for AIP PDP layouts.
  Preserves variant image switching via AIPGallery.setActiveIndex (theme-interactions.js).

  Accepts:
  - product: {Object} required
  - show_badges: {Boolean} default true
  - gallery_id: {String} optional unique id suffix
  - side_thumbs_desktop: {Boolean} left thumb column on large screens
{% endcomment %}

{%- liquid
  assign show_badges = show_badges | default: true
  assign gallery_uid = gallery_id | default: product.id
  assign image_count = product.images.size
  assign side_class = ''
  if side_thumbs_desktop
    assign side_class = ' lmg--side-desktop'
  endif
-%}

<div
  class="aip-gallery lmg{{ side_class }}"
  id="aip-gallery-{{ gallery_uid }}"
  data-aip-gallery
  role="region"
  aria-label="{{ 'products.product.media.gallery_viewer' | t | default: 'Product gallery' }}"
>
  <div class="lmg__stage aip-gallery__stage">
    <div class="lmg__hero aip-gallery__main" id="aip-main-img-wrap">
      <span class="lmg__corners" aria-hidden="true"></span>

      {%- for image in product.images -%}
        <img
          src="{{ image | image_url: width: 1800 }}"
          srcset="{{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1800 }} 1800w, {{ image | image_url: width: 2400 }} 2400w"
          sizes="(max-width: 1024px) 100vw, min(660px, 52vw)"
          alt="{{ image.alt | default: product.title | escape }}"
          width="{{ image.width | default: 1200 }}"
          height="{{ image.height | default: 1200 }}"
          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          decoding="async"
          class="lmg__hero-img aip-gallery__main-img{% unless forloop.first %} is-hidden{% endunless %}"
          data-index="{{ forloop.index0 }}"
          id="aip-img-{{ forloop.index0 }}"
        >
      {%- else -%}
        <p class="lmg__empty" style="font-size:13px;color:#9ca3af;">No image</p>
      {%- endfor -%}

      {%- if section != blank -%}
        <div class="aip-gallery__badge">
          {%- assign aip_is_new = false -%}
          {%- if product.tags contains 'new' or product.tags contains 'New' -%}
            {%- assign aip_is_new = true -%}
          {%- endif -%}
          {%- if section.settings.show_new_badge and aip_is_new -%}
            <span class="aip-gallery__tag">{{ section.settings.new_badge_text | default: 'New' }}</span>
          {%- endif -%}
          {%- if section.settings.show_sale_badge and product.compare_at_price > product.price -%}
            {%- assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            <span class="aip-gallery__tag aip-gallery__tag--sale">{{ section.settings.sale_badge_prefix | default: '−' }}{{ savings_pct }}{{ section.settings.sale_badge_suffix | default: '%' }}</span>
          {%- endif -%}
          {%- assign aip_is_bestseller = false -%}
          {%- if product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
            {%- assign aip_is_bestseller = true -%}
          {%- endif -%}
          {%- if section.settings.show_bestseller_badge and aip_is_bestseller -%}
            <span class="aip-gallery__tag aip-gallery__tag--bs">{{ section.settings.bestseller_badge_text | default: 'Bestseller' }}</span>
          {%- endif -%}
        </div>
      {%- elsif show_badges -%}
        <div class="aip-gallery__badge">
          {%- if product.tags contains 'new' or product.tags contains 'New' -%}
            <span class="aip-gallery__tag">New</span>
          {%- endif -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            <span class="aip-gallery__tag aip-gallery__tag--sale">−{{ savings_pct }}%</span>
          {%- endif -%}
          {%- if product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
            <span class="aip-gallery__tag aip-gallery__tag--bs">Bestseller</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if image_count > 0 -%}
        <button type="button" class="aip-gallery__zoom" id="aip-zoom-btn" aria-label="{{ 'products.product.media.open_media' | t | default: 'Enlarge image' }}">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0zm-3-3v6m-3-3h6"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </div>

  {%- if image_count > 1 -%}
    <div class="lmg__thumbs aip-gallery__thumbs-scroll" role="list" aria-label="{{ 'products.product.media.gallery_viewer' | t | default: 'Gallery thumbnails' }}">
      {%- for image in product.images limit: 10 -%}
        <button
          type="button"
          class="lmg__thumb-btn aip-gallery__thumb{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          role="listitem"
          aria-label="{{ 'products.product.media.load_image' | t: index: forloop.index | default: 'View image' | append: ' ' | append: forloop.index }}"
          {% if forloop.first %}
            aria-current="true"
          {% endif %}
        >
          <span class="lmg__thumb-frame">
            <span class="lmg__corners lmg__corners--thumb" aria-hidden="true"></span>
            <img
              src="{{ image | image_url: width: 360 }}"
              alt="{{ image.alt | default: product.title | escape }}"
              width="84"
              height="84"
              loading="lazy"
              decoding="async"
            >
          </span>
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
