{% comment %}
  Navagraha planet attar cards — icon above, product card below (chakra-style).
  Uses assets/Planet/ icons + attar images; products from collection by handle match.
  Optional: pl_collection (explicit collection), hide_head: true (skip duplicate header)
{% endcomment %}

{%- liquid
  assign pl_col = collection
  if pl_collection != blank and pl_collection != empty
    assign pl_col = pl_collection
  endif
  assign pl_hide_head = hide_head | default: false
  assign pl_home = pl_home | default: false
  assign pl_keys = 'surya,chandra,mangal,budha,guru,shukra,shani,rahu,ketu' | split: ','
  assign pl_labels = 'Surya,Chandra,Mangal,Budha,Guru,Shukra,Shani,Rahu,Ketu' | split: ','
  assign pl_icons = 'Planet/sun.webp,Planet/moon.webp,Planet/mars.webp,Planet/Mercury.webp,Planet/Jupiter.webp,Planet/Venus.webp,Planet/Saturn.webp,Planet/Rahu.webp,Planet/Ketu.webp' | split: ','
  assign pl_attars = 'Planet/surya_attar.webp,Planet/chandra_attar.webp,Planet/mangal_attar.webp,Planet/budh_attar.webp,Planet/guru_attar.webp,Planet/shukra_attar.webp,Planet/shani_attar.webp,Planet/rahu_attar.webp,Planet/ketu_attar.webp' | split: ','
  assign pl_match = 'sun,surya|moon,chandra|mars,mangal|mercury,budh,budha|jupiter,guru|venus,shukra|saturn,shani|rahu|ketu' | split: '|'
-%}

<style>
.ar-pl {
  --pl-ink: #1d1d1f;
  --pl-muted: #86868b;
  --pl-fill: #f5f5f7;
  --pl-bg: #ffffff;
  font-family: var(--font-body-family, system-ui, -apple-system, sans-serif);
  -webkit-font-smoothing: antialiased;
  background: var(--pl-bg);
  color: var(--pl-ink);
}
.ar-pl *, .ar-pl *::before, .ar-pl *::after { box-sizing: border-box; margin: 0; padding: 0; }
.ar-pl a { text-decoration: none; color: inherit; }
.ar-pl img { display: block; max-width: 100%; height: auto; }

.ar-pl__head {
  text-align: center;
  max-width: 640px;
  margin: 0 auto;
  padding: 48px 24px 8px;
}
.ar-pl__count {
  font-size: 13px;
  color: var(--pl-muted);
  margin-bottom: 4px;
}
.ar-pl__sub {
  font-size: 15px;
  line-height: 1.65;
  color: var(--pl-muted);
  font-weight: 300;
}

.ar-pl--after-intro .ar-pl__grid {
  padding-top: 16px;
}

.ar-pl__grid {
  max-width: 1280px;
  margin: 0 auto;
  padding: 32px 40px 72px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 36px 28px;
}
@media (max-width: 1024px) {
  .ar-pl__grid { grid-template-columns: repeat(2, 1fr); padding: 28px 24px 60px; gap: 32px 20px; }
}
@media (max-width: 560px) {
  .ar-pl__grid { grid-template-columns: 1fr; gap: 28px; padding: 24px 16px 48px; }
}

.ar-pl__cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
}

.ar-pl__icon-wrap {
  width: 72px;
  height: 72px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ar-pl__icon {
  width: 56px;
  height: 56px;
  object-fit: contain;
}

.ar-pl__label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--pl-muted);
  margin-top: -6px;
}

.ar-pl__card {
  width: 100%;
  max-width: 360px;
  background: #fff;
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 12px 40px rgba(0, 0, 0, 0.08);
  transition: box-shadow 0.3s ease, transform 0.3s ease;
}
.ar-pl__card:hover {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), 0 20px 48px rgba(0, 0, 0, 0.12);
  transform: translateY(-4px);
}

.ar-pl__img-wrap {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--pl-fill);
  overflow: hidden;
  border-radius: 21px 21px 0 0;
}
.ar-pl__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  padding: 12px;
  transition: transform 0.5s ease;
}
.ar-pl__card:hover .ar-pl__img { transform: scale(1.04); }

.ar-pl__name {
  font-size: 16px;
  font-weight: 600;
  line-height: 1.35;
  letter-spacing: -0.022em;
  color: var(--pl-ink);
  padding: 18px 20px 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ar-pl__name:hover { opacity: 0.72; }

.ar-pl__price {
  font-size: 17px;
  font-weight: 600;
  letter-spacing: -0.02em;
  padding: 8px 20px 0;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8px;
}
.ar-pl__compare {
  font-size: 14px;
  font-weight: 400;
  color: var(--pl-muted);
  text-decoration: line-through;
}

.ar-pl__atc {
  box-sizing: border-box;
  width: calc(100% - 40px);
  margin: 16px 20px 20px;
  padding: 13px 18px;
  background: var(--pl-ink);
  color: #f5f5f7;
  border: none;
  border-radius: 980px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  cursor: pointer;
  font-family: inherit;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: background 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
}
.ar-pl__atc:hover:not(:disabled) {
  background: #000;
  transform: translateY(-1px);
}
.ar-pl__atc:disabled {
  background: var(--pl-fill);
  color: var(--pl-muted);
  cursor: not-allowed;
  border: 1px solid rgba(0, 0, 0, 0.06);
}

.ar-pl__empty-slot {
  padding: 24px 20px 28px;
  text-align: center;
  font-size: 13px;
  color: var(--pl-muted);
  line-height: 1.5;
}

/* Homepage — horizontal carousel with side arrows (collection unchanged) */
.ar-pl--home.ar-pl--after-intro { padding-bottom: 0; }
.ar-pl--home .ar-pl__carousel {
  --pl-slide-w: clamp(188px, 22vw, 236px);
  --pl-slide-gap: clamp(14px, 2vw, 22px);
  --pl-pad-x: clamp(16px, 4vw, 48px);
  --pl-nav: clamp(40px, 5vw, 52px);
  position: relative;
  width: 100%;
  max-width: 1360px;
  margin: 0 auto;
  padding: clamp(20px, 3vw, 32px) var(--pl-pad-x) clamp(28px, 4vw, 44px);
}
.ar-pl--home .ar-pl__slider {
  display: grid;
  grid-template-columns: var(--pl-nav) minmax(0, 1fr) var(--pl-nav);
  align-items: center;
  column-gap: clamp(8px, 1.5vw, 16px);
}
.ar-pl--home .ar-pl__nav {
  flex-shrink: 0;
  width: var(--pl-nav);
  height: var(--pl-nav);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  background: #fff;
  color: var(--pl-ink);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
  box-shadow: 0 2px 14px rgba(0, 0, 0, 0.08);
  transition:
    background 0.22s ease,
    color 0.22s ease,
    border-color 0.22s ease,
    transform 0.22s cubic-bezier(0.34, 1.2, 0.64, 1),
    opacity 0.22s ease,
    box-shadow 0.22s ease;
}
.ar-pl--home .ar-pl__nav:hover:not(:disabled) {
  background: var(--pl-ink);
  color: #fff;
  border-color: var(--pl-ink);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14);
  transform: scale(1.05);
}
.ar-pl--home .ar-pl__nav:disabled {
  opacity: 0.32;
  cursor: default;
  box-shadow: none;
}
.ar-pl--home .ar-pl__viewport {
  position: relative;
  min-width: 0;
  overflow: hidden;
}
.ar-pl--home .ar-pl__viewport::before,
.ar-pl--home .ar-pl__viewport::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 28px;
  z-index: 2;
  pointer-events: none;
  transition: opacity 0.25s ease;
}
.ar-pl--home .ar-pl__viewport::before {
  left: 0;
  background: linear-gradient(90deg, #fff 15%, transparent);
}
.ar-pl--home .ar-pl__viewport::after {
  right: 0;
  background: linear-gradient(270deg, #fff 15%, transparent);
}
.ar-pl--home .ar-pl__viewport.is-at-start::before { opacity: 0; }
.ar-pl--home .ar-pl__viewport.is-at-end::after { opacity: 0; }
.ar-pl--home .ar-pl__track {
  display: flex;
  gap: var(--pl-slide-gap);
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior-x: contain;
  scrollbar-width: none;
  padding: 10px 4px 18px;
  margin: 0 -4px;
  scroll-padding-inline: 4px;
}
.ar-pl--home .ar-pl__track::-webkit-scrollbar { display: none; }
.ar-pl--home .ar-pl__track:focus { outline: none; }
.ar-pl--home .ar-pl__track:focus-visible {
  outline: 2px solid var(--pl-ink);
  outline-offset: 3px;
  border-radius: 10px;
}
.ar-pl--home .ar-pl__cell {
  flex: 0 0 var(--pl-slide-w);
  scroll-snap-align: start;
  scroll-snap-stop: always;
  gap: clamp(8px, 1.2vw, 12px);
  transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
}
.ar-pl--home .ar-pl__cell.is-active {
  opacity: 1;
  transform: translateY(0);
}
.ar-pl--home .ar-pl__cell:not(.is-active) {
  opacity: 0.88;
}
.ar-pl--home .ar-pl__progress-wrap {
  max-width: 520px;
  margin: clamp(14px, 2vw, 20px) auto 0;
  padding: 0 4px;
}
.ar-pl--home .ar-pl__progress {
  height: 3px;
  background: rgba(0, 0, 0, 0.08);
  border-radius: 99px;
  overflow: hidden;
}
.ar-pl--home .ar-pl__progress-fill {
  display: block;
  height: 100%;
  width: 0%;
  background: var(--pl-ink);
  border-radius: inherit;
  transition: width 0.3s cubic-bezier(0.25, 1, 0.5, 1);
}
@media (max-width: 720px) {
  .ar-pl--home .ar-pl__carousel {
    --pl-nav: 40px;
    padding-left: clamp(12px, 4vw, 20px);
    padding-right: clamp(12px, 4vw, 20px);
  }
  .ar-pl--home .ar-pl__slider {
    column-gap: 6px;
  }
}
@media (max-width: 480px) {
  .ar-pl--home .ar-pl__slider {
    grid-template-columns: 36px minmax(0, 1fr) 36px;
    column-gap: 4px;
  }
  .ar-pl--home .ar-pl__nav {
    width: 36px;
    height: 36px;
  }
  .ar-pl--home .ar-pl__nav svg {
    width: 16px;
    height: 16px;
  }
}
.ar-pl--home .ar-pl__icon-wrap {
  width: clamp(72px, 12vw, 104px);
  height: clamp(72px, 12vw, 104px);
}
.ar-pl--home .ar-pl__icon {
  width: clamp(64px, 10vw, 92px);
  height: clamp(64px, 10vw, 92px);
}
.ar-pl--home .ar-pl__label { font-size: 10px; margin-top: -4px; }
.ar-pl--home .ar-pl__card {
  width: 100%;
  max-width: none;
  border-radius: 18px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 8px 28px rgba(0, 0, 0, 0.07);
}
.ar-pl--home .ar-pl__card:hover {
  transform: translateY(-3px);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05), 0 14px 36px rgba(0, 0, 0, 0.1);
}
.ar-pl--home .ar-pl__img-wrap {
  aspect-ratio: 4 / 5;
  border-radius: 17px 17px 0 0;
}
.ar-pl--home .ar-pl__img {
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  object-position: center;
  padding: 10px;
}
.ar-pl--home .ar-pl__card:hover .ar-pl__img { transform: none; }
.ar-pl--home .ar-pl__name {
  font-size: 14px;
  padding: 12px 14px 0;
  -webkit-line-clamp: 2;
}
.ar-pl--home .ar-pl__price {
  font-size: 15px;
  padding: 6px 14px 0;
}
.ar-pl--home .ar-pl__compare { font-size: 12px; }
.ar-pl--home .ar-pl__atc {
  width: calc(100% - 28px);
  margin: 12px 14px 14px;
  padding: 11px 14px;
  font-size: 11px;
}
.ar-pl--home .ar-pl__empty-slot {
  padding: 16px 14px 18px;
  font-size: 12px;
}

@media (prefers-reduced-motion: reduce) {
  .ar-pl__card, .ar-pl__img, .ar-pl__atc { transition: none; }
  .ar-pl__card:hover { transform: none; }
  .ar-pl__card:hover .ar-pl__img { transform: none; }
  .ar-pl--home .ar-pl__cell { transition: none; transform: none; opacity: 1; }
  .ar-pl--home .ar-pl__track { scroll-behavior: auto; }
  .ar-pl--home .ar-pl__progress-fill { transition: none; }
  .ar-pl--home .ar-pl__nav { transition: background 0.15s ease, opacity 0.15s ease; }
  .ar-pl--home .ar-pl__nav:hover:not(:disabled) { transform: none; }
}
</style>

<section class="ar-pl{% if pl_hide_head %} ar-pl--after-intro{% endif %}{% if pl_home %} ar-pl--home{% endif %}" aria-label="Navagraha planet attars">
  {%- unless pl_hide_head -%}
  <div class="ar-pl__head">
    {%- if pl_col != blank and pl_col.products_count > 0 -%}
      <p class="ar-pl__count">{{ pl_col.products_count }} attars in this collection</p>
    {%- endif -%}
    {%- if section.settings.planet_cards_subtitle != blank -%}
      <p class="ar-pl__sub">{{ section.settings.planet_cards_subtitle }}</p>
    {%- else -%}
      <p class="ar-pl__sub">Nine celestial attars — each aligned with a Vedic graha. Select your planetary fragrance below.</p>
    {%- endif -%}
  </div>
  {%- endunless -%}

  {%- if pl_home -%}
  <div class="ar-pl__carousel" data-ar-pl-carousel>
    <div class="ar-pl__slider">
      <button type="button" class="ar-pl__nav ar-pl__nav--prev" data-ar-pl-prev aria-label="Previous planet attar" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6"/></svg>
      </button>
      <div class="ar-pl__viewport is-at-start" data-ar-pl-viewport>
        <div class="ar-pl__track" data-ar-pl-track tabindex="0" role="region" aria-roledescription="carousel" aria-label="Navagraha planet attars">
  {%- else -%}
  <div class="ar-pl__grid">
  {%- endif -%}
    {%- for i in (0..8) -%}
      {%- liquid
        assign pk = pl_keys[i]
        assign pl_product = blank
        assign match_terms = pl_match[i] | split: ','

        if pl_col != blank and pl_col.products_count > 0
          for cp in pl_col.products
            assign cp_key = cp.handle | append: ' ' | append: cp.title | downcase
            assign matched = false
            for term in match_terms
              if cp_key contains term
                assign matched = true
                break
              endif
            endfor
            if matched
              assign pl_product = cp
              break
            endif
          endfor
        endif

        if pl_product == blank
          case pk
            when 'surya'
              assign pl_product = all_products['surya-attar']
            when 'chandra'
              assign pl_product = all_products['chandra-attar']
            when 'mangal'
              assign pl_product = all_products['mangal-attar']
            when 'budha'
              assign pl_product = all_products['budha-attar']
              if pl_product == blank
                assign pl_product = all_products['budh-attar']
              endif
            when 'guru'
              assign pl_product = all_products['guru-attar']
            when 'shukra'
              assign pl_product = all_products['shukra-attar']
            when 'shani'
              assign pl_product = all_products['shani-attar']
            when 'rahu'
              assign pl_product = all_products['rahu-attar']
            when 'ketu'
              assign pl_product = all_products['ketu-attar']
          endcase
        endif

        assign pl_img_src = pl_attars[i] | asset_url
        assign pl_img_alt = pl_labels[i] | append: ' attar'
        if pl_product != blank and pl_product != empty
          assign pl_img_alt = pl_product.title
        endif
        unless pl_home
          if pl_product != blank and pl_product.featured_image
            assign pl_img_src = pl_product.featured_image | image_url: width: 720
          endif
        endunless
      -%}

      <article class="ar-pl__cell{% if pl_home and i == 0 %} is-active{% endif %}" id="planet-{{ pk }}"{% if pl_home %} data-ar-pl-slide{% endif %}>
        <div class="ar-pl__icon-wrap">
          <img
            class="ar-pl__icon"
            src="{{ pl_icons[i] | asset_url }}"
            alt="{{ pl_labels[i] }}"
            width="{% if pl_home %}92{% else %}56{% endif %}"
            height="{% if pl_home %}92{% else %}56{% endif %}"
            loading="{% if i < 3 %}eager{% else %}lazy{% endif %}"
            decoding="async"
          >
        </div>
        <span class="ar-pl__label">{{ pl_labels[i] }}</span>

        <div class="ar-pl__card">
          {%- if pl_product != blank and pl_product != empty -%}
            <a href="{{ pl_product.url }}" class="ar-pl__img-wrap">
              <img
                class="ar-pl__img"
                src="{{ pl_img_src }}"
                alt="{{ pl_img_alt | escape }}"
                width="720"
                height="900"
                loading="{% if i < 3 %}eager{% else %}lazy{% endif %}"
                decoding="async"
              >
            </a>
            <a href="{{ pl_product.url }}" class="ar-pl__name">{{ pl_product.title }}</a>
            <div class="ar-pl__price">
              {%- if pl_product.compare_at_price > pl_product.price -%}
                <span class="ar-pl__compare">{{ pl_product.compare_at_price | money }}</span>
              {%- endif -%}
              {{ pl_product.price | money }}
            </div>
            <button
              type="button"
              class="ar-pl__atc js-arc-atc"
              data-id="{{ pl_product.selected_or_first_available_variant.id }}"
              data-name="{{ pl_product.title | escape }}"
              aria-label="Add {{ pl_product.title | escape }} to cart"
              {% unless pl_product.selected_or_first_available_variant.available %}disabled{% endunless %}
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39A2 2 0 0 0 9.62 16h9.76a2 2 0 0 0 1.97-1.67L23 6H6"/></svg>
              Add to Cart
            </button>
          {%- else -%}
            <a href="#planet-{{ pk }}" class="ar-pl__img-wrap">
              <img
                class="ar-pl__img"
                src="{{ pl_img_src }}"
                alt="{{ pl_img_alt | escape }}"
                width="720"
                height="900"
                loading="lazy"
                decoding="async"
              >
            </a>
            <p class="ar-pl__name">{{ pl_labels[i] }} Attar</p>
            <p class="ar-pl__empty-slot">Coming soon — add this product to the Planet Attars collection.</p>
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  {%- if pl_home -%}
        </div>
      </div>
      <button type="button" class="ar-pl__nav ar-pl__nav--next" data-ar-pl-next aria-label="Next planet attar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </div>
    <div class="ar-pl__progress-wrap" aria-hidden="true">
      <div class="ar-pl__progress"><span class="ar-pl__progress-fill" data-ar-pl-progress></span></div>
    </div>
  </div>
  <script>
  (function () {
    'use strict';

    function initPlCarousel(carousel) {
      if (!carousel || carousel.dataset.arPlInit === '1') return;
      carousel.dataset.arPlInit = '1';

      var track = carousel.querySelector('[data-ar-pl-track]');
      var viewport = carousel.querySelector('[data-ar-pl-viewport]');
      var prevBtn = carousel.querySelector('[data-ar-pl-prev]');
      var nextBtn = carousel.querySelector('[data-ar-pl-next]');
      var progressFill = carousel.querySelector('[data-ar-pl-progress]');
      var slides = carousel.querySelectorAll('[data-ar-pl-slide]');
      var count = slides.length;
      if (!track || !count) return;

      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var index = 0;
      var navLock = false;
      var syncTimer = null;
      var rafPending = false;

      function maxIndex() {
        return count - 1;
      }

      function scrollMode() {
        return reduced ? 'auto' : 'smooth';
      }

      function clampIndex(i) {
        return i < 0 ? 0 : i > maxIndex() ? maxIndex() : i;
      }

      function readIndexFromView() {
        var trackRect = track.getBoundingClientRect();
        var anchor = trackRect.left + trackRect.width * 0.5;
        var best = 0;
        var bestDist = Infinity;
        for (var i = 0; i < count; i++) {
          var r = slides[i].getBoundingClientRect();
          var mid = r.left + r.width * 0.5;
          var dist = Math.abs(mid - anchor);
          if (dist < bestDist) {
            bestDist = dist;
            best = i;
          }
        }
        return best;
      }

      function scrollSlideTo(i) {
        var slide = slides[i];
        if (!slide) return;
        var pad = parseFloat(getComputedStyle(track).scrollPaddingInlineStart) || 0;
        var target = Math.max(0, slide.offsetLeft - pad);
        if (typeof track.scrollTo === 'function') {
          track.scrollTo({ left: target, behavior: scrollMode() });
        } else {
          track.scrollLeft = target;
        }
      }

      function goTo(nextIndex, userNav) {
        var i = clampIndex(nextIndex);
        if (userNav && i === index) return;
        index = i;
        navLock = !!userNav;
        scrollSlideTo(i);
        paint();
        if (userNav) {
          window.setTimeout(function () {
            navLock = false;
          }, reduced ? 32 : 420);
        }
      }

      function step(dir) {
        goTo(index + dir, true);
      }

      function paint() {
        var last = maxIndex();
        if (prevBtn) prevBtn.disabled = index <= 0;
        if (nextBtn) nextBtn.disabled = index >= last;
        for (var i = 0; i < count; i++) {
          slides[i].classList.toggle('is-active', i === index);
        }
        if (progressFill) {
          var ratio = last > 0 ? index / last : 0;
          progressFill.style.width = (ratio * 100) + '%';
        }
        if (viewport) {
          viewport.classList.toggle('is-at-start', index <= 0);
          viewport.classList.toggle('is-at-end', index >= last);
        }
      }

      function syncFromScroll() {
        if (navLock) return;
        var seen = readIndexFromView();
        if (seen !== index) {
          index = seen;
          paint();
        } else {
          paint();
        }
      }

      function scheduleSync() {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(function () {
          rafPending = false;
          syncFromScroll();
        });
      }

      function debouncedSync() {
        clearTimeout(syncTimer);
        syncTimer = setTimeout(syncFromScroll, 100);
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          if (prevBtn.disabled) return;
          step(-1);
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          if (nextBtn.disabled) return;
          step(1);
        });
      }

      var hasScrollEnd = 'onscrollend' in document.createElement('div');
      track.addEventListener('scroll', function () {
        scheduleSync();
        if (!hasScrollEnd) debouncedSync();
      }, { passive: true });
      if (hasScrollEnd) {
        track.addEventListener('scrollend', syncFromScroll, { passive: true });
      }

      track.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          step(-1);
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          step(1);
        } else if (e.key === 'Home') {
          e.preventDefault();
          goTo(0, true);
        } else if (e.key === 'End') {
          e.preventDefault();
          goTo(maxIndex(), true);
        }
      });

      if (typeof ResizeObserver !== 'undefined') {
        var ro = new ResizeObserver(scheduleSync);
        ro.observe(track);
      } else {
        window.addEventListener('resize', scheduleSync);
      }

      index = readIndexFromView();
      paint();
    }

    document.querySelectorAll('[data-ar-pl-carousel]').forEach(initPlCarousel);
  })();
  </script>
  {%- else -%}
  </div>
  {%- endif -%}
</section>
