{% liquid
  assign key = handle | downcase | strip
  assign url = ''
  assign contact_fallback_url = pages['contact'].url | default: pages['contact-us'].url | default: routes.root_url
  assign template_suffix = ''

  case key
    when 'about', 'about-us', 'about-anand-rasa'
      assign url = pages['about-us'].url | default: pages['about'].url | default: pages['about-anand-rasa'].url
      assign template_suffix = 'about'
    when 'contact', 'contact-us'
      assign url = pages['contact'].url | default: pages['contact-us'].url
      assign template_suffix = 'contact'
    when 'faq', 'faqs'
      assign url = pages['faq'].url | default: pages['faqs'].url
      if url == blank
        assign url = '/pages/faq'
      endif
    when 'bulk-enquiry', 'bulk-enquiry-form', 'bulk-inquiry'
      assign url = pages['bulk-enquiry-form'].url | default: pages['bulk-enquiry'].url | default: pages['bulk-inquiry'].url
      if url == blank
        assign url = contact_fallback_url
      endif
    when 'find-fragrance', 'find-your-fragrance', 'astro-fragrance-finder', 'custom-perfume', 'custom-perfume-quiz'
      assign url = pages['find-fragrance'].url | default: pages['find-your-fragrance'].url | default: pages['astro-fragrance-finder'].url | default: pages['custom-perfume-quiz'].url | default: pages['custom-perfume'].url
      if url == blank
        assign url = routes.root_url | append: '?view=find-fragrance'
      endif
    when 'vip-club', 'vip'
      assign url = pages['vip-club'].url | default: pages['vip'].url
      if url == blank
        assign url = routes.root_url | append: '?view=vip-club'
      endif
    when 'build-your-box', 'build-your-attar-box', 'attar-box'
      assign url = pages['build-your-box'].url | default: pages['build-your-attar-box'].url
      if url == blank
        assign url = '/pages/build-your-box'
      endif
    when 'build-3-attars'
      assign url = routes.root_url | append: '?view=build-3-attars'
      if pages['build-3-attars'] != blank and pages['build-3-attars'].template_suffix == 'build-3-attars'
        assign url = pages['build-3-attars'].url
      endif
    when 'build-5-attars'
      assign url = routes.root_url | append: '?view=build-5-attars'
      if pages['build-5-attars'] != blank and pages['build-5-attars'].template_suffix == 'build-5-attars'
        assign url = pages['build-5-attars'].url
      endif
    when 'build-4-perfumes'
      assign url = routes.root_url | append: '?view=build-4-perfumes'
      if pages['build-4-perfumes'] != blank and pages['build-4-perfumes'].template_suffix == 'build-4-perfumes'
        assign url = pages['build-4-perfumes'].url
      endif
    when 'astrology-ritual-set'
      assign url = routes.root_url | append: '?view=astrology-ritual-set'
      if pages['astrology-ritual-set'] != blank and pages['astrology-ritual-set'].template_suffix == 'astrology-ritual-set'
        assign url = pages['astrology-ritual-set'].url
      endif
    when 'build-3-incense', 'incense-bundle-offer'
      assign url = routes.root_url | append: '?view=build-3-incense'
      if pages['build-3-incense'] != blank and pages['build-3-incense'].template_suffix == 'build-3-incense'
        assign url = pages['build-3-incense'].url
      endif
    else
      assign url = pages[key].url | default: '/pages/' | append: key
  endcase

  if url == blank and key != blank
    assign url = pages[key].url | default: '/pages/' | append: key
  elsif url == blank
    assign url = routes.root_url
  endif

  if template_suffix != blank and url != blank
    if url contains '?'
      assign url = url | append: '&view=' | append: template_suffix
    else
      assign url = url | append: '?view=' | append: template_suffix
    endif
  endif
%}
{{ url }}
