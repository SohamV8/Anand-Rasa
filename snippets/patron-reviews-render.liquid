{%- liquid
  assign prv_axis = prv_axis | default: 'generic'
  assign prv_product_short = prv_product_short | default: 'this attar'
  assign prv_uid = prv_uid | default: 'prv-block'
  assign prv_short = prv_product_short

  assign prv_title = prv_section_title | default: 'Voices from our fragrance family'
  assign prv_lede = prv_lede | default: 'Real patrons. Different moods. One shared love for slow, soulful scent.'

  capture prv_rows
    render 'prv-data-loader', prv_axis: prv_axis
  endcapture
  assign prv_rows = prv_rows | strip | replace: '{{ prv_short }}', prv_short

  assign prv_fallback_dates = '2 weeks ago,3 weeks ago,1 month ago,6 weeks ago,3 weeks ago,2 months ago' | split: ','
-%}

{%- assign prv_all = prv_rows | split: '~||~' -%}
{%- assign prv_pool_count = prv_all.size -%}
{%- assign prv_day = 'now' | date: '%j' | plus: 0 -%}
{%- assign prv_rand = prv_product_id | default: 17 | plus: prv_day | times: 13 -%}

<section
  class="prv"
  id="{{ prv_uid }}"
  data-prv-section
  aria-labelledby="{{ prv_uid }}-title"
  {{ prv_shopify_attributes }}
>
  <div class="prv__shell">
    <header class="prv__header">
      <h2 class="prv__title" id="{{ prv_uid }}-title" data-prv-reveal>{{ prv_title | escape }}</h2>
      <p class="prv__lede" data-prv-reveal>{{ prv_lede | escape }}</p>
    </header>

    <div class="prv__track-wrap" data-prv-reveal>
      <div
        class="prv__track"
        data-prv-track
        role="list"
        aria-label="Customer reviews"
        tabindex="0"
      >
        {%- for i in (1..6) -%}
          {%- assign prv_step = forloop.index0 | times: 41 | plus: prv_rand -%}
          {%- assign prv_pick = prv_step | modulo: prv_pool_count -%}
          {%- assign prv_row = prv_all[prv_pick] -%}
          {%- assign prv_cols = prv_row | split: '~|~' -%}
          {%- assign prv_name = prv_cols[0] -%}
          {%- assign prv_city = prv_cols[1] -%}
          {%- assign prv_rating = prv_cols[2] | default: '5' -%}
          {%- assign prv_body = prv_cols[3] -%}
          {%- assign prv_tag = prv_cols[4] -%}
          {%- assign prv_ptype = prv_cols[5] -%}
          {%- assign prv_note = prv_cols[6] -%}
          {%- assign prv_initials = prv_cols[7] | default: 'AR' -%}
          {%- assign prv_date = prv_cols[8] -%}
          {%- if prv_date == blank -%}
            {%- assign prv_date = prv_fallback_dates[forloop.index0] -%}
          {%- endif -%}
          {%- assign prv_hue = forloop.index0 | times: 47 | plus: 18 -%}

          <article
            class="prv__card"
            data-prv-card
            role="listitem"
            style="--prv-i: {{ forloop.index0 }}; --prv-hue: {{ prv_hue }}"
          >
            <header class="prv__card-head">
              <div class="prv__person">
                <div class="prv__avatar" aria-hidden="true">
                  <span class="prv__avatar-text">{{ prv_initials }}</span>
                </div>
                <div class="prv__meta">
                  <p class="prv__name">{{ prv_name | escape }}</p>
                  <p class="prv__loc">
                    <span>{{ prv_city | escape }}</span>
                    {%- if prv_date != blank -%}
                      <span class="prv__loc-sep" aria-hidden="true">·</span>
                      <time>{{ prv_date | escape }}</time>
                    {%- endif -%}
                  </p>
                </div>
              </div>
              <div class="prv__rating" role="img" aria-label="{{ prv_rating }} out of 5 stars">
                {%- assign prv_stars = prv_rating | plus: 0 -%}
                {%- for s in (1..5) -%}
                  <svg
                    class="prv__star{% if s > prv_stars %} prv__star--dim{% endif %}"
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    focusable="false"
                  >
                    <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {%- endfor -%}
              </div>
            </header>

            <blockquote class="prv__quote">
              <p>{{ prv_body }}</p>
            </blockquote>

            {%- if prv_product_short != blank or prv_product_thumb != blank -%}
              <div class="prv__purchase">
                {%- if prv_product_thumb != blank -%}
                  <img
                    class="prv__purchase-thumb"
                    src="{{ prv_product_thumb }}"
                    alt=""
                    width="48"
                    height="56"
                    loading="lazy"
                    decoding="async"
                  >
                {%- endif -%}
                <div class="prv__purchase-copy">
                  <span class="prv__purchase-label">Purchased</span>
                  <span class="prv__purchase-name">{{ prv_product_short | escape }}</span>
                </div>
              </div>
            {%- endif -%}

            <footer class="prv__card-foot">
              <span class="prv__verified">
                <svg class="prv__verified-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                Verified Purchase
              </span>
              <ul class="prv__tags" aria-label="Review highlights">
                {%- if prv_tag != blank -%}
                  <li class="prv__tag">{{ prv_tag | escape }}</li>
                {%- endif -%}
                {%- if prv_ptype != blank -%}
                  <li class="prv__tag">{{ prv_ptype | escape }}</li>
                {%- endif -%}
                {%- if prv_note != blank -%}
                  <li class="prv__tag prv__tag--note">{{ prv_note | escape }}</li>
                {%- endif -%}
              </ul>
            </footer>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
