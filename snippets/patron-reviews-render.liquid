{%- assign prv_all = prv_rows | split: '~||~' -%}
{%- assign prv_pool_count = prv_all.size -%}
{%- assign prv_seed = prv_product_id | default: 17 -%}
{%- assign prv_offset = prv_seed | modulo: prv_pool_count -%}

<section
  class="prv"
  id="{{ prv_uid }}"
  data-prv-section
  aria-labelledby="{{ prv_uid }}-title"
  {{ prv_shopify_attributes }}
>
  <div class="prv__shell">
    <header class="prv__header">
      <p class="prv__eyebrow" data-prv-reveal>Patron Reviews</p>
      <h2 class="prv__title" id="{{ prv_uid }}-title" data-prv-reveal>Voices from our fragrance family</h2>
      <p class="prv__lede" data-prv-reveal>Real patrons. Different moods. One shared love for slow, soulful scent.</p>
      <div class="prv__header-rule" data-prv-reveal aria-hidden="true"></div>
    </header>

    <div class="prv__track-wrap" data-prv-reveal>
      <div class="prv__track" data-prv-track role="list" aria-label="Customer reviews">
        {%- for i in (1..6) -%}
          {%- assign prv_pick = i | minus: 1 | plus: prv_offset | modulo: prv_pool_count -%}
          {%- assign prv_row = prv_all[prv_pick] -%}
          {%- assign prv_cols = prv_row | split: '~|~' -%}
          {%- assign prv_name = prv_cols[0] -%}
          {%- assign prv_city = prv_cols[1] -%}
          {%- assign prv_rating = prv_cols[2] | default: '5' -%}
          {%- assign prv_body = prv_cols[3] -%}
          {%- assign prv_tag = prv_cols[4] -%}
          {%- assign prv_ptype = prv_cols[5] -%}
          {%- assign prv_note = prv_cols[6] -%}
          {%- assign prv_initials = prv_cols[7] | default: 'AR' -%}

          <article class="prv__card" data-prv-card role="listitem" style="--prv-i: {{ forloop.index0 }}">
            <div class="prv__card-top">
              <div class="prv__avatar" aria-hidden="true">
                <span class="prv__avatar-text">{{ prv_initials }}</span>
              </div>
              <div class="prv__meta">
                <p class="prv__name">{{ prv_name }}</p>
                <p class="prv__city">{{ prv_city }}</p>
              </div>
              <div class="prv__rating" role="img" aria-label="{{ prv_rating }} out of 5 stars">
                {%- assign prv_stars = prv_rating | plus: 0 -%}
                {%- for s in (1..5) -%}
                  <span class="prv__star{% if s > prv_stars %} prv__star--dim{% endif %}" aria-hidden="true">★</span>
                {%- endfor -%}
              </div>
            </div>

            <blockquote class="prv__quote">
              <p>{{ prv_body }}</p>
            </blockquote>

            <footer class="prv__card-foot">
              <span class="prv__verified">
                <svg class="prv__verified-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Verified Patron
              </span>
              {%- if prv_tag != blank -%}
                <span class="prv__tag">{{ prv_tag }}</span>
              {%- endif -%}
              {%- if prv_note != blank -%}
                <span class="prv__note">Notes: {{ prv_note }}</span>
              {%- endif -%}
              {%- if prv_ptype != blank -%}
                <span class="prv__ptype">{{ prv_ptype }}</span>
              {%- endif -%}
            </footer>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
