{%- comment -%}
  Editorial attar story — italic intro, ✺ divider, detail paragraph.

  Priority: section.settings → product metafields → handle defaults
  Usage: {% render 'attar-product-story', product: product, section: section %}
{%- endcomment -%}

{%- liquid
  assign aps_p = product
  if aps_p == blank
    assign aps_p = story_product
  endif
-%}

{%- if aps_p != blank -%}
  {%- liquid
    assign aps_intro = ''
    assign aps_body = ''
    assign aps_h = aps_p.handle | default: '' | downcase
    assign aps_t = aps_p.title | default: '' | downcase
    assign aps_scope = aps_h | append: '|' | append: aps_t

    if aps_scope contains 'mercury' or aps_scope contains 'budh' or aps_scope contains 'vitpati'
      assign aps_intro = 'The attar of articulate radiance, distilled by hand for seekers of clarity and calm speech.'
      assign aps_body = 'Green cardamom from the Western Ghats. Fresh vetiver root. Light citrus peel and soft woods. A crisp trail for meetings, study, and clear thought—composed to steady the mind without heaviness.'
    elsif aps_scope contains 'surya' or aps_h == 'sun' or aps_scope contains 'sun-energy' or aps_scope contains 'sun-attar'
      assign aps_intro = 'The attar of sovereign radiance, distilled by hand for those who lead with warmth and presence.'
      assign aps_body = 'Kerala turmeric. Aged Mysore sandalwood. Golden spice and sun-warmed resin. Eight-hour luminosity—blessed for mornings when you step forward with confidence.'
    elsif aps_scope contains 'moon' or aps_scope contains 'chandra'
      assign aps_intro = 'The attar of lunar grace, distilled by hand for emotional balance and quiet intuition.'
      assign aps_body = 'White sandalwood. Soft jasmine at dusk. Cool musk and silvered florals. A gentle veil of scent for evening rituals, reflection, and restorative calm.'
    elsif aps_scope contains 'mars' or aps_scope contains 'mangal'
      assign aps_intro = 'The attar of courageous fire, distilled by hand for vitality, focus, and fearless movement.'
      assign aps_body = 'Red spice. Iron-rich resin. Smoky wood and warm pepper. A bold, grounding trail for decisive days—never loud, always intentional.'
    elsif aps_scope contains 'jupiter' or aps_scope contains 'guru'
      assign aps_intro = 'The attar of expansive wisdom, distilled by hand for prosperity, learning, and generous spirit.'
      assign aps_body = 'Sacred frankincense. Rich amber. Temple-grade sandalwood and honeyed balsam. A regal dry-down that lingers through long ceremonies and celebrations.'
    elsif aps_scope contains 'venus' or aps_scope contains 'shukra'
      assign aps_intro = 'The attar of sensual refinement, distilled by hand for beauty, harmony, and magnetic softness.'
      assign aps_body = 'Damascus rose. Creamy sandalwood. Vanilla resin and soft orchid notes. An elegant aura for evenings when grace matters more than volume.'
    elsif aps_scope contains 'saturn' or aps_scope contains 'shani'
      assign aps_intro = 'The attar of disciplined depth, distilled by hand for patience, resilience, and grounded mastery.'
      assign aps_body = 'Aged patchouli. Dark cedar. Mineral smoke and dry vetiver. A serious, slow-unfolding scent for those who value permanence over flash.'
    elsif aps_scope contains 'rahu'
      assign aps_intro = 'The attar of transformative mystery, distilled by hand for bold change and unconventional paths.'
      assign aps_body = 'Dark oud accents. Smoked resin. Spiced florals and shadowed woods. An enigmatic trail—modern, deep, and quietly unforgettable.'
    elsif aps_scope contains 'ketu'
      assign aps_intro = 'The attar of spiritual release, distilled by hand for detachment, insight, and inner pilgrimage.'
      assign aps_body = 'Sacred smoke notes. Ash and sandal. Rare herbs and temple incense memory. A meditative scent that feels older than the day you wear it.'
    elsif aps_scope contains 'aries'
      assign aps_intro = 'The attar of pioneering fire, distilled by hand for the first spark of courage and new beginnings.'
      assign aps_body = 'Cardamom spark. Red musk. Black pepper and charred wood. Electric yet wearable—built for leaders who move before the room notices.'
    elsif aps_scope contains 'taurus' or aps_scope contains 'vrishabha'
      assign aps_intro = 'The attar of earthly luxury, distilled by hand for comfort, devotion, and unhurried beauty.'
      assign aps_body = 'Rose absolute. Mysore sandalwood. Vetiver root and vanilla balsam. Rich on skin, restrained in the air—true Taurus sensuality.'
    elsif aps_scope contains 'gemini'
      assign aps_intro = 'The attar of mercurial charm, distilled by hand for wit, curiosity, and light-footed grace.'
      assign aps_body = 'Bergamot peel. Green herbs. White musk and airy florals. Bright at first, thoughtful in the dry-down—like conversation that stays interesting.'
    elsif aps_scope contains 'cancer'
      assign aps_intro = 'The attar of tidal feeling, distilled by hand for nurture, memory, and protective warmth.'
      assign aps_body = 'Moonlit jasmine. Sea-salt musk. Soft amber and white woods. Intimate and comforting—scent as emotional shelter.'
    elsif aps_scope contains 'leo'
      assign aps_intro = 'The attar of royal warmth, distilled by hand for charisma, creativity, and solar pride.'
      assign aps_body = 'Saffron gold. Resinous amber. Sun-dried florals and cedar throne. A fragrance that enters softly and leaves a golden echo.'
    elsif aps_scope contains 'virgo'
      assign aps_intro = 'The attar of refined clarity, distilled by hand for order, healing, and quiet perfection.'
      assign aps_body = 'Sacred basil. Clean vetiver. Pale iris and herbal resin. Crisp, pure, and grounding—beauty in precision.'
    elsif aps_scope contains 'libra'
      assign aps_intro = 'The attar of harmonious balance, distilled by hand for grace, diplomacy, and aesthetic calm.'
      assign aps_body = 'Pink rose. Soft oud. Powdered musk and sandal cream. Balanced from first breath to last—never sweet, never severe.'
    elsif aps_scope contains 'scorpio'
      assign aps_intro = 'The attar of magnetic depth, distilled by hand for intensity, loyalty, and transformative power.'
      assign aps_body = 'Dark rose. Patchouli smoke. Animalic musk and resinous woods. Seductive without shouting—a private flame.'
    elsif aps_scope contains 'sagittarius'
      assign aps_intro = 'The attar of adventurous spirit, distilled by hand for freedom, faith, and wide horizons.'
      assign aps_body = 'Frankincense trail. Juniper berry. Warm spice and open-air woods. Uplifting and frank—scent for those always leaving town at dawn.'
    elsif aps_scope contains 'capricorn'
      assign aps_intro = 'The attar of enduring ambition, distilled by hand for discipline, legacy, and quiet authority.'
      assign aps_body = 'Dry cedar. Stone moss. Aged labdanum and leathered resin. Structured, mature, and impeccably composed.'
    elsif aps_scope contains 'aquarius'
      assign aps_intro = 'The attar of visionary air, distilled by hand for originality, intellect, and humane rebellion.'
      assign aps_body = 'Cool aldehydic lift. Iris root. Metallic florals and clean woods. Modern, airy, and unmistakably individual.'
    elsif aps_scope contains 'pisces'
      assign aps_intro = 'The attar of dreamwater calm, distilled by hand for compassion, art, and spiritual drift.'
      assign aps_body = 'Water lily. Soft ambergris tone. Incense mist and saline musk. Ethereal on skin—like memory of rain on warm stone.'
    elsif aps_scope contains 'ashwini'
      assign aps_intro = 'The attar of swift healing light, distilled by hand for new paths and rejuvenated beginnings.'
      assign aps_body = 'Fresh herbs. Light resin. Clean musk and dawn florals. Quick, bright opening; gentle, restorative dry-down—Ashwini energy in a bottle.'
    elsif aps_scope contains 'bharani'
      assign aps_intro = 'The attar of creative endurance, distilled by hand for devotion, sensuality, and sacred transformation.'
      assign aps_body = 'Deep rose. Rich ylang. Resinous heart and warm spice. Intense yet refined—beauty that does not apologize.'
    elsif aps_scope contains 'krittika' or aps_scope contains 'kritika'
      assign aps_intro = 'The attar of purifying flame, distilled by hand for courage, truth, and sharp clarity.'
      assign aps_body = 'Saffron fire. Sacred ash notes. Sandal embers and metallic spice. Cleansing, bright, and spiritually awake.'
    elsif aps_scope contains 'rohini'
      assign aps_intro = 'The attar of fertile beauty, distilled by hand for abundance, charm, and creative growth.'
      assign aps_body = 'Night jasmine. Creamy sandal. Honeyed florals and soft musk. Luxurious, magnetic, and deeply feminine in spirit.'
    elsif aps_scope contains 'mrigashira'
      assign aps_intro = 'The attar of searching grace, distilled by hand for curiosity, gentleness, and poetic movement.'
      assign aps_body = 'Green stem. Suede musk. Light florals and woodland air. Restless yet soft—always wandering, never lost.'
    elsif aps_scope contains 'ardra'
      assign aps_intro = 'The attar of storm and renewal, distilled by hand for emotional release and fierce honesty.'
      assign aps_body = 'Rain on stone. Dark florals. Ozone musk and cedar flash. Powerful weather on skin—cleansing, not chaotic.'
    elsif aps_scope contains 'punarvasu'
      assign aps_intro = 'The attar of returning light, distilled by hand for restoration, hope, and second chances.'
      assign aps_body = 'Sacred grass. Soft amber. Morning dew florals and clean resin. Gentle optimism woven through every hour worn.'
    elsif aps_scope contains 'pushya'
      assign aps_intro = 'The attar of nourishing protection, distilled by hand for care, stability, and spiritual food.'
      assign aps_body = 'Temple sandalwood. Milk-soft musk. Honey resin and white florals. The scent of being held—quiet, holy, whole.'
    elsif aps_scope contains 'ashlesha'
      assign aps_intro = 'The attar of hypnotic wisdom, distilled by hand for intuition, mystery, and serpentine calm.'
      assign aps_body = 'Dark jasmine. Cool spice. Smoked woods and mineral musk. Enigmatic, slow, and impossible to ignore up close.'
    elsif aps_scope contains 'magha'
      assign aps_intro = 'The attar of ancestral pride, distilled by hand for lineage, dignity, and royal memory.'
      assign aps_body = 'Royal oud tone. Golden spice. Incense throne and aged woods. Regal without excess—honor worn as scent.'
    elsif aps_scope contains 'phalguni'
      assign aps_intro = 'The attar of celebratory warmth, distilled by hand for joy, union, and creative radiance.'
      assign aps_body = 'Marigold resin. Rose garland. Warm musk and festive spice. Wedding-light in a bottle—generous and golden.'
    elsif aps_scope contains 'hasta'
      assign aps_intro = 'The attar of skilled grace, distilled by hand for craftsmanship, agility, and mindful touch.'
      assign aps_body = 'Pale citrus. Hand-rolled spice. Fine musk and linen woods. Precise, clean, and quietly confident.'
    elsif aps_scope contains 'chitra'
      assign aps_intro = 'The attar of celestial design, distilled by hand for beauty, architecture, and vivid charisma.'
      assign aps_body = 'Bright spice. Jewel-tone florals. Polished woods and crystal musk. Structured brilliance from first dab to dry-down.'
    elsif aps_scope contains 'swati'
      assign aps_intro = 'The attar of independent breeze, distilled by hand for freedom, diplomacy, and balanced breath.'
      assign aps_body = 'Airy florals. Light oud wash. Clean musk and bamboo wood. Moves like wind—present, never heavy.'
    elsif aps_scope contains 'vishakha'
      assign aps_intro = 'The attar of focused triumph, distilled by hand for determination, loyalty, and sacred ambition.'
      assign aps_body = 'Fiery spice. Deep resin. Sandal pillar and dark florals. Single-minded warmth for goals pursued with devotion.'
    elsif aps_scope contains 'anuradha'
      assign aps_intro = 'The attar of devoted friendship, distilled by hand for loyalty, travel, and heartfelt success.'
      assign aps_body = 'Resin path. Soft spice. Mysore sandal and night bloom. Warm, inclusive, and steady through long days.'
    elsif aps_scope contains 'jyeshtha'
      assign aps_intro = 'The attar of protective authority, distilled by hand for senior wisdom and fierce guardianship.'
      assign aps_body = 'Dark patchouli. Iron woods. Sacred smoke and aged musk. Powerful, mature, and unshakeable on the skin.'
    elsif aps_scope contains 'mula'
      assign aps_intro = 'The attar of root truth, distilled by hand for uprooting illusion and finding core knowing.'
      assign aps_body = 'Dry root. Bitter herb. Smoky resin and earth musk. Grounding to the point of revelation—honest and deep.'
    elsif aps_scope contains 'ashadha'
      assign aps_intro = 'The attar of invincible joy, distilled by hand for victory, celebration, and radiant optimism.'
      assign aps_body = 'Festive spice. Sun resin. Garland florals and golden woods. Uplifting energy that feels earned, not borrowed.'
    elsif aps_scope contains 'shravana'
      assign aps_intro = 'The attar of listening wisdom, distilled by hand for learning, mantra, and sacred hearing.'
      assign aps_body = 'Temple incense. Clear sandal. Soft bell-metal musk and water notes. Quiet intelligence you feel before you speak.'
    elsif aps_scope contains 'dhanishtha'
      assign aps_intro = 'The attar of rhythmic abundance, distilled by hand for music, wealth, and celebratory spirit.'
      assign aps_body = 'Copper spice. Resin drum. Warm woods and sparkling musk. Prosperous, lively, and beautifully timed.'
    elsif aps_scope contains 'shatabhisha'
      assign aps_intro = 'The attar of healing secrecy, distilled by hand for solitude, medicine, and starlit repair.'
      assign aps_body = 'Cool herb. Mineral musk. Night rain and distant incense. Mysterious healer’s trail—calm, cool, restorative.'
    elsif aps_scope contains 'bhadrapada'
      assign aps_intro = 'The attar of auspicious depth, distilled by hand for spiritual wealth and composed power.'
      assign aps_body = 'Sacred resin. Dark florals. Sandal foundation and noble musk. Solemn beauty for rituals that matter.'
    elsif aps_scope contains 'revati'
      assign aps_intro = 'The attar of gentle completion, distilled by hand for safe journeys and compassionate endings.'
      assign aps_body = 'Soft musk. Travel spice. Protective florals and moonlit woods. A guardian scent—tender, faithful, calm.'
    elsif aps_scope contains 'muladhara' or aps_scope contains 'root-chakra' or aps_h == 'root'
      assign aps_intro = 'The attar of grounded root, distilled by hand for stability, safety, and embodied presence.'
      assign aps_body = 'Vetiver earth. Cedar root. Patchouli depth and warm resin. Anchoring from the first breath—steady, primal, sure.'
    elsif aps_scope contains 'svadhisthana' or aps_scope contains 'sacral'
      assign aps_intro = 'The attar of creative flow, distilled by hand for pleasure, emotion, and sensual honesty.'
      assign aps_body = 'Orange blossom. Amber warmth. Soft spice and fluid musk. Alive, warm, and unafraid of feeling.'
    elsif aps_scope contains 'manipura' or aps_h == 'solar' or aps_scope contains 'solar-plexus'
      assign aps_intro = 'The attar of solar will, distilled by hand for confidence, digestion of life, and inner fire.'
      assign aps_body = 'Golden spice. Ginger resin. Sun wood and bright balsam. Personal power worn lightly, felt deeply.'
    elsif aps_scope contains 'anahata' or aps_h == 'heart'
      assign aps_intro = 'The attar of open heart, distilled by hand for compassion, forgiveness, and loving courage.'
      assign aps_body = 'Rose heart. Soft frankincense. Green stem and honeyed musk. Tender without weakness—love with backbone.'
    elsif aps_scope contains 'vishuddha' or aps_scope contains 'throat'
      assign aps_intro = 'The attar of truthful voice, distilled by hand for expression, song, and clear communication.'
      assign aps_body = 'Blue chamomile tone. Light herbs. Clean woods and airy musk. Fresh on the throat chakra—honest and bright.'
    elsif aps_scope contains 'ajna' or aps_scope contains 'third-eye'
      assign aps_intro = 'The attar of inner sight, distilled by hand for intuition, focus, and meditative vision.'
      assign aps_body = 'Frankincense veil. Lavender smoke. Sandal mist and cool resin. Clarifying, still, and subtly luminous.'
    elsif aps_scope contains 'sahasrara' or aps_scope contains 'crown'
      assign aps_intro = 'The attar of crown light, distilled by hand for unity, prayer, and transcendent calm.'
      assign aps_body = 'White sandal. Sacred lotus tone. Incense halo and weightless musk. Ethereal finish—scent as quiet blessing.'
    elsif aps_scope contains 'stress' or aps_scope contains 'shanti' or aps_scope contains 'lavender' or aps_scope contains 'muskrose'
      assign aps_intro = 'The attar of restorative calm, distilled by hand for exhale, sleep, and unclenched evenings.'
      assign aps_body = 'Lavender hill. Sandal balm. Soft woods and saline musk. Not sedating—simply kind to a tired nervous system.'
    elsif aps_scope contains 'love' or aps_scope contains 'mohini' or aps_scope contains 'romance'
      assign aps_intro = 'The attar of intimate warmth, distilled by hand for romance, softness, and nearness.'
      assign aps_body = 'Musk rose. Creamy sandal. Vanilla resin and blush florals. Close-skin scent for moments that need tenderness.'
    elsif aps_scope contains 'apsara'
      assign aps_intro = 'The attar of celestial allure, distilled by hand for grace, artistry, and divine femininity.'
      assign aps_body = 'Temple jasmine. Gold amber. Sacred spice and silk musk. Mythic beauty made wearable—light, golden, rare.'
    elsif aps_scope contains 'perfume' or aps_scope contains 'kesar' or aps_scope contains 'chandan'
      assign aps_intro = 'The attar of perfumed heritage, distilled by hand for modern luxury rooted in Indian craft.'
      assign aps_body = 'Saffron thread. Sandal heart. Resin depth and polished musk. Contemporary elegance with ancestral soul.'
    elsif aps_scope contains 'attar' or aps_scope contains 'perfume oil' or aps_scope contains 'fragrance oil'
      assign aps_intro = 'The attar of quiet radiance, distilled by hand for those who wear scent as personal ritual.'
      assign aps_body = 'Premium botanical oils. Traditional deg-bhapka craft. Balanced resin, wood, and floral heart. Long-wearing, skin-close, honestly luxurious.'
    endif

    if section.settings.story_intro != blank
      assign aps_intro = section.settings.story_intro | strip
    endif
    if section.settings.story_detail != blank
      assign aps_body = section.settings.story_detail | strip
    endif

    if aps_intro == blank and aps_p.metafields.custom.story_intro != blank
      assign aps_intro = aps_p.metafields.custom.story_intro.value | default: aps_p.metafields.custom.story_intro | strip
    endif
    if aps_body == blank and aps_p.metafields.custom.story_detail != blank
      assign aps_body = aps_p.metafields.custom.story_detail.value | default: aps_p.metafields.custom.story_detail | strip
    endif
  -%}

  {%- if aps_intro != blank or aps_body != blank -%}
    <div class="ar-story-block" data-attar-story>
      {%- if aps_intro != blank -%}
        <p class="ar-story-intro">{{ aps_intro }}</p>
      {%- endif -%}

      {%- if aps_intro != blank and aps_body != blank -%}
        <div class="ar-divider" aria-hidden="true">
          <span>✺</span>
        </div>
      {%- endif -%}

      {%- if aps_body != blank -%}
        <p class="ar-story-text">{{ aps_body }}</p>
      {%- endif -%}
    </div>

    <style>
      .ar-story-block { margin: 12px 0 18px; }
      .ar-story-intro {
        font-family: Georgia, serif;
        font-style: italic;
        font-size: 16px;
        line-height: 1.5;
        color: #7A654C;
        margin: 0 0 10px;
      }
      .ar-divider {
        position: relative;
        text-align: center;
        margin: 8px 0 10px;
      }
      .ar-divider:before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 50%;
        border-top: 1px solid #D8C08A;
      }
      .ar-divider span {
        position: relative;
        background: #F7F5F0;
        padding: 0 8px;
        color: #C8A03A;
        font-size: 12px;
      }
      .ar-story-text {
        font-family: Georgia, serif;
        font-size: 13px;
        line-height: 1.6;
        color: #6B5A46;
        margin: 0;
      }
      @media screen and (max-width: 749px) {
        .ar-story-intro { font-size: 15px; margin-bottom: 8px; }
        .ar-story-text { font-size: 12px; line-height: 1.55; }
        .ar-divider { margin: 6px 0 8px; }
      }
    </style>
  {%- endif -%}
{%- endif -%}
