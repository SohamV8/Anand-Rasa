{%- comment -%} 8. ZODIAC {%- endcomment -%}
<section class="ar-sc" style="border-top:2px solid #1e2023;">
  <header class="ar-sc__hdr">
    <h2 class="ar-sc__h">{{ section.settings.zc_heading | default: 'ZODIAC' }}</h2>
    <p class="ar-sc__sub">{{ section.settings.zc_sub | default: 'Choose your zodiac fragrance.' }}</p>
  </header>
  <div class="ar-sc__wrap">
    <div class="ar-sc__fade ar-sc__fade-l"></div>
    <div class="ar-sc__fade ar-sc__fade-r"></div>
    <button class="ar-sc__arrow ar-sc__arrow-l js-zc-l" aria-label="Previous">&#8249;</button>
    <button class="ar-sc__arrow ar-sc__arrow-r js-zc-r" aria-label="Next">&#8250;</button>
    <div class="ar-sc__track js-zc-track">
      {%- assign zc = collections[section.settings.zc_collection] -%}
      {%- if zc != blank -%}
        {%- assign zc_bucket_aries = '' -%}
        {%- assign zc_bucket_taurus = '' -%}
        {%- assign zc_bucket_gemini = '' -%}
        {%- assign zc_bucket_cancer = '' -%}
        {%- assign zc_bucket_leo = '' -%}
        {%- assign zc_bucket_virgo = '' -%}
        {%- assign zc_bucket_libra = '' -%}
        {%- assign zc_bucket_scorpio = '' -%}
        {%- assign zc_bucket_sagittarius = '' -%}
        {%- assign zc_bucket_capricorn = '' -%}
        {%- assign zc_bucket_aquarius = '' -%}
        {%- assign zc_bucket_pisces = '' -%}
        {%- assign zc_bucket_rest = '' -%}
        {%- for p in zc.products limit: 12 -%}
          {%- assign p_handle = p.handle | downcase -%}
          {%- assign p_title = p.title | downcase -%}
          {%- assign zc_asset = '' -%}
          {%- if p_handle contains 'aries' -%}
            {%- assign zc_asset = 'Zodiac/aries.webp' -%}
          {%- elsif p_handle contains 'taurus' -%}
            {%- assign zc_asset = 'Zodiac/taurus.webp' -%}
          {%- elsif p_handle contains 'gemini' -%}
            {%- assign zc_asset = 'Zodiac/gemini.webp' -%}
          {%- elsif p_handle contains 'cancer' -%}
            {%- assign zc_asset = 'Zodiac/cancer.webp' -%}
          {%- elsif p_handle contains 'leo' -%}
            {%- assign zc_asset = 'Zodiac/leo.webp' -%}
          {%- elsif p_handle contains 'virgo' -%}
            {%- assign zc_asset = 'Zodiac/virgo.webp' -%}
          {%- elsif p_handle contains 'libra' -%}
            {%- assign zc_asset = 'Zodiac/libra.webp' -%}
          {%- elsif p_handle contains 'scorpio' -%}
            {%- assign zc_asset = 'Zodiac/scorpio.webp' -%}
          {%- elsif p_handle contains 'sagittarius' -%}
            {%- assign zc_asset = 'Zodiac/sagittarius.webp' -%}
          {%- elsif p_handle contains 'capricorn' or p_title contains 'capricorn' -%}
            {%- assign zc_asset = 'Zodiac/capricorn.webp' -%}
          {%- elsif p_handle contains 'aquarius' or p_title contains 'aquarius' -%}
            {%- assign zc_asset = 'Zodiac/aquarius.webp' -%}
          {%- elsif p_handle contains 'pisces' -%}
            {%- assign zc_asset = 'Zodiac/pisces.webp' -%}
          {%- endif -%}
          {%- capture zc_card -%}
            <article class="ar-sc__card">
              <a href="{{ p.url }}" class="ar-sc__link">
                <div class="ar-sc__imgw">
                  {%- if zc_asset != blank -%}
                    <img src="{{ zc_asset | asset_url }}" alt="{{ p.title }}" width="400" height="533" loading="lazy" sizes="(max-width: 640px) 44vw, (max-width: 1024px) 180px, 200px" class="ar-sc__img">
                  {%- elsif p.featured_image -%}
                    <!-- SEO Fix: Zodiac product image optimized with WebP and explicit dimensions -->
                    <picture>
                      <source
                        srcset="{{ p.featured_image | image_url: width: 320, format: 'webp' }} 320w, {{ p.featured_image | image_url: width: 640, format: 'webp' }} 640w"
                        sizes="(max-width: 640px) 44vw, (max-width: 1024px) 180px, 200px"
                        type="image/webp"
                      >
                      <img
                        src="{{ p.featured_image | image_url: width: 640 }}"
                        srcset="{{ p.featured_image | image_url: width: 320 }} 320w, {{ p.featured_image | image_url: width: 640 }} 640w"
                        sizes="(max-width: 640px) 44vw, (max-width: 1024px) 180px, 200px"
                        alt="{{ p.featured_image.alt | default: p.title | append: ' - handcrafted attar - Anandrasa' | escape }}"
                        width="640"
                        height="{{ 640 | divided_by: p.featured_image.aspect_ratio | round }}"
                        loading="lazy"
                        decoding="async"
                        class="ar-sc__img"
                      >
                    </picture>
                  {%- endif -%}
                </div>
                <h3 class="ar-sc__name">{{ p.title }}</h3>
                <p class="ar-sc__type">{{ p.type | default: 'Rashi Rasa' }}</p>
                <p class="ar-sc__price">{{ p.price | money }}</p>
              </a>
            </article>
          {%- endcapture -%}
          {%- if p_handle contains 'aries' -%}
            {%- assign zc_bucket_aries = zc_bucket_aries | append: zc_card -%}
          {%- elsif p_handle contains 'taurus' -%}
            {%- assign zc_bucket_taurus = zc_bucket_taurus | append: zc_card -%}
          {%- elsif p_handle contains 'gemini' -%}
            {%- assign zc_bucket_gemini = zc_bucket_gemini | append: zc_card -%}
          {%- elsif p_handle contains 'cancer' -%}
            {%- assign zc_bucket_cancer = zc_bucket_cancer | append: zc_card -%}
          {%- elsif p_handle contains 'leo' -%}
            {%- assign zc_bucket_leo = zc_bucket_leo | append: zc_card -%}
          {%- elsif p_handle contains 'virgo' -%}
            {%- assign zc_bucket_virgo = zc_bucket_virgo | append: zc_card -%}
          {%- elsif p_handle contains 'libra' -%}
            {%- assign zc_bucket_libra = zc_bucket_libra | append: zc_card -%}
          {%- elsif p_handle contains 'scorpio' -%}
            {%- assign zc_bucket_scorpio = zc_bucket_scorpio | append: zc_card -%}
          {%- elsif p_handle contains 'sagittarius' -%}
            {%- assign zc_bucket_sagittarius = zc_bucket_sagittarius | append: zc_card -%}
          {%- elsif p_handle contains 'capricorn' or p_title contains 'capricorn' -%}
            {%- assign zc_bucket_capricorn = zc_bucket_capricorn | append: zc_card -%}
          {%- elsif p_handle contains 'aquarius' or p_title contains 'aquarius' -%}
            {%- assign zc_bucket_aquarius = zc_bucket_aquarius | append: zc_card -%}
          {%- elsif p_handle contains 'pisces' -%}
            {%- assign zc_bucket_pisces = zc_bucket_pisces | append: zc_card -%}
          {%- else -%}
            {%- assign zc_bucket_rest = zc_bucket_rest | append: zc_card -%}
          {%- endif -%}
        {%- endfor -%}
        {{ zc_bucket_aries }}
        {{ zc_bucket_taurus }}
        {{ zc_bucket_gemini }}
        {{ zc_bucket_cancer }}
        {{ zc_bucket_leo }}
        {{ zc_bucket_virgo }}
        {{ zc_bucket_libra }}
        {{ zc_bucket_scorpio }}
        {{ zc_bucket_sagittarius }}
        {{ zc_bucket_capricorn }}
        {{ zc_bucket_aquarius }}
        {{ zc_bucket_pisces }}
        {{ zc_bucket_rest }}
      {%- else -%}
        <p style="padding:24px;color:#9ca3af;font-family:var(--fb);">Select zodiac collection in Theme Editor.</p>
      {%- endif -%}
    </div>
  </div>
</section>
