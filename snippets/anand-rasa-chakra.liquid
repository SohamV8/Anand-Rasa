{% comment %}
  ANAND RASA — Chakra Attar Section
  sections/anand-rasa-chakra.liquid
  7 chakra bands · pastel Apple UI · product integration
{% endcomment %}

<style>
/* ============================================================
   CHAKRA SECTION — DESIGN SYSTEM
   ============================================================ */
.ar-chakra-wrap {
  --fh: var(--font-heading-family, 'Georgia', serif);
  --fb: var(--font-body-family, system-ui, -apple-system, sans-serif);
  font-family: var(--fb);
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

/* ============================================================
   EACH CHAKRA BAND
   ============================================================ */
.ar-chakra {
  position: relative;
  min-height: 40vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 0;
  overflow: hidden;
  /* entrance: start hidden */
  opacity: 0;
  transform: translateY(32px);
  transition:
    opacity 0.75s cubic-bezier(0.25, 1, 0.5, 1),
    transform 0.75s cubic-bezier(0.25, 1, 0.5, 1);
}

.ar-chakra.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Alternate: odd bands → text left / image right; even → image left / text right */
.ar-chakra:nth-child(even) .ar-chakra__info  { order: 2; }
.ar-chakra:nth-child(even) .ar-chakra__media { order: 1; }

/* ── Subtle noise texture overlay ── */
.ar-chakra::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1;
}

/* ── Individual chakra bg colors (pastel) ── */
.ar-chakra--sahasrara  { background: #E8D8F5; }
.ar-chakra--ajna       { background: #D4CCF0; }
.ar-chakra--vishuddha  { background: #C5E8F0; }
.ar-chakra--anahata    { background: #C8E6C9; }
.ar-chakra--manipura   { background: #FFF3B0; }
.ar-chakra--svadhisthana { background: #FFD9B0; }
.ar-chakra--muladhara  { background: #FFBDBD; }

/* ── Text colors per band ── */
.ar-chakra--sahasrara  { --ck-ink: #3D1D6B; --ck-muted: #7B5AA6; --ck-accent: #9B59B6; }
.ar-chakra--ajna       { --ck-ink: #1A1060; --ck-muted: #5B50A0; --ck-accent: #6C5CE7; }
.ar-chakra--vishuddha  { --ck-ink: #0A3D52; --ck-muted: #3A7A94; --ck-accent: #00B4D8; }
.ar-chakra--anahata    { --ck-ink: #1B4332; --ck-muted: #3A7D5B; --ck-accent: #40916C; }
.ar-chakra--manipura   { --ck-ink: #4A3600; --ck-muted: #8A6D00; --ck-accent: #F4A100; }
.ar-chakra--svadhisthana { --ck-ink: #4A2000; --ck-muted: #8A4500; --ck-accent: #E17D2A; }
.ar-chakra--muladhara  { --ck-ink: #4A0E0E; --ck-muted: #8A2E2E; --ck-accent: #C0392B; }

/* ============================================================
   INFO COLUMN
   ============================================================ */
.ar-chakra__info {
  position: relative;
  z-index: 2;
  padding: 56px 64px 56px 72px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0;
}

/* Number */
.ar-chakra__num {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ck-accent);
  opacity: 0.7;
  margin-bottom: 10px;
  display: block;
}

/* Sanskrit name */
.ar-chakra__sanskrit {
  font-family: var(--fh);
  font-size: clamp(28px, 3.5vw, 52px);
  font-weight: 300;
  color: var(--ck-ink);
  letter-spacing: -0.03em;
  line-height: 1.05;
  margin-bottom: 6px;
}

/* English name */
.ar-chakra__english {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ck-muted);
  margin-bottom: 28px;
}

/* Divider */
.ar-chakra__rule {
  width: 36px;
  height: 1.5px;
  background: var(--ck-accent);
  border: none;
  margin: 0 0 24px;
  opacity: 0.6;
  transform-origin: left;
  transform: scaleX(0);
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1) 0.3s;
}

.ar-chakra.is-visible .ar-chakra__rule { transform: scaleX(1); }

/* Meta grid */
.ar-chakra__meta {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
}

.ar-chakra__meta-row {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 8px;
  align-items: baseline;
}

.ar-chakra__meta-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ck-accent);
  opacity: 0.8;
}

.ar-chakra__meta-val {
  font-size: 14px;
  color: var(--ck-ink);
  font-weight: 400;
  line-height: 1.5;
  opacity: 0.85;
}

/* CTA */
.ar-chakra__cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  background: var(--ck-ink);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  font-family: var(--fb);
  align-self: flex-start;
  transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.ar-chakra__cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.18);
}

.ar-chakra__cta svg { flex-shrink: 0; }

/* ============================================================
   MEDIA COLUMN
   ============================================================ */
.ar-chakra__media {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48px 64px 48px 40px;
  min-height: 40vh;
}

.ar-chakra:nth-child(even) .ar-chakra__media {
  padding: 48px 40px 48px 64px;
}

/* Product card floating container */
.ar-chakra__product {
  position: relative;
  width: 100%;
  max-width: 320px;
  /* Glass card */
  background: rgba(255,255,255,0.55);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255,255,255,0.7);
  border-radius: 24px;
  padding: 24px;
  box-shadow:
    0 4px 6px rgba(0,0,0,0.04),
    0 20px 60px rgba(0,0,0,0.09),
    inset 0 1px 0 rgba(255,255,255,0.6);
  /* Entrance */
  opacity: 0;
  transform: translateX(24px) scale(0.97);
  transition:
    opacity 0.7s cubic-bezier(0.25, 1, 0.5, 1) 0.2s,
    transform 0.7s cubic-bezier(0.25, 1, 0.5, 1) 0.2s,
    box-shadow 0.3s ease;
}

.ar-chakra:nth-child(even) .ar-chakra__product {
  transform: translateX(-24px) scale(0.97);
}

.ar-chakra.is-visible .ar-chakra__product {
  opacity: 1;
  transform: translateX(0) scale(1);
}

.ar-chakra__product:hover {
  box-shadow:
    0 4px 6px rgba(0,0,0,0.04),
    0 28px 72px rgba(0,0,0,0.14),
    inset 0 1px 0 rgba(255,255,255,0.7);
  transform: translateY(-6px) scale(1.01) !important;
}

/* Product image */
.ar-chakra__img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 16px;
  overflow: hidden;
  background: rgba(255,255,255,0.4);
  margin-bottom: 18px;
  position: relative;
}

.ar-chakra__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
}

.ar-chakra__product:hover .ar-chakra__img {
  transform: scale(1.05);
}

.ar-chakra__img-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.3);
}

.ar-chakra__img-ph svg {
  width: 40px;
  height: 40px;
  opacity: 0.3;
  color: var(--ck-ink);
}

/* Product info inside card */
.ar-chakra__prod-name {
  font-family: var(--fh);
  font-size: 17px;
  font-weight: 400;
  color: var(--ck-ink);
  line-height: 1.3;
  letter-spacing: -0.01em;
  margin-bottom: 6px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ar-chakra__prod-price {
  font-size: 15px;
  font-weight: 700;
  color: var(--ck-ink);
  letter-spacing: -0.01em;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.ar-chakra__prod-compare {
  font-size: 12px;
  font-weight: 400;
  color: var(--ck-muted);
  text-decoration: line-through;
  opacity: 0.6;
}

/* Mini ATC */
.ar-chakra__mini-atc {
  width: 100%;
  padding: 11px;
  background: var(--ck-ink);
  color: #fff;
  border: none;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  font-family: var(--fb);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: opacity 0.2s ease, transform 0.2s ease;
  text-decoration: none;
}

.ar-chakra__mini-atc:hover { opacity: 0.85; transform: translateY(-1px); }
.ar-chakra__mini-atc.is-adding { opacity: 0.6; pointer-events: none; }
.ar-chakra__mini-atc.is-added  { background: #1A5C2A; }

/* Placeholder text for no product */
.ar-chakra__no-product {
  font-size: 12px;
  color: var(--ck-muted);
  opacity: 0.6;
  text-align: center;
  padding: 20px;
}

/* ============================================================
   SYMBOL / DECORATION (chakra artwork from /assets)
   ============================================================ */
.ar-chakra__symbol {
  position: absolute;
  bottom: 24px;
  right: 24px;
  width: 96px;
  height: 96px;
  opacity: 0.14;
  line-height: 0;
  pointer-events: none;
  user-select: none;
  z-index: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ar-chakra__symbol img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: blur(0.35px);
}

/* ============================================================
   SECTION HEADER
   ============================================================ */
.ar-chakra-header {
  text-align: center;
  padding: 80px 48px 56px;
  background: #F8F5FF;
  position: relative;
  overflow: hidden;
}

.ar-chakra-header__bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg,
    rgba(232,216,245,0.4) 0%,
    rgba(197,232,240,0.3) 33%,
    rgba(200,230,201,0.3) 60%,
    rgba(255,243,176,0.3) 80%,
    rgba(255,189,189,0.25) 100%
  );
  pointer-events: none;
}

.ar-chakra-header__eyebrow {
  display: block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #9B59B6;
  margin-bottom: 12px;
  opacity: 0;
  animation: ck-up 0.7s ease 0.1s forwards;
}

.ar-chakra-header__title {
  font-family: var(--fh, Georgia, serif);
  font-size: clamp(32px, 5vw, 60px);
  font-weight: 300;
  color: #1A1A2E;
  letter-spacing: -0.03em;
  line-height: 1.08;
  margin-bottom: 16px;
  position: relative;
  opacity: 0;
  animation: ck-up 0.7s ease 0.2s forwards;
}

.ar-chakra-header__sub {
  font-size: 16px;
  color: #5A5A7A;
  line-height: 1.75;
  font-weight: 300;
  max-width: 520px;
  margin: 0 auto;
  position: relative;
  opacity: 0;
  animation: ck-up 0.7s ease 0.3s forwards;
}

/* Rainbow bar */
.ar-chakra-header__rainbow {
  width: 80px;
  height: 3px;
  background: linear-gradient(to right,
    #BF7FDB, #7B68EE, #67C5D5, #6EC46E, #F0D060, #E8A060, #E06060
  );
  border-radius: 999px;
  margin: 24px auto 0;
  opacity: 0;
  animation: ck-up 0.7s ease 0.4s forwards;
}

@keyframes ck-up {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1024px) {
  .ar-chakra__info  { padding: 48px 40px 48px 48px; }
  .ar-chakra__media { padding: 40px 40px 40px 32px; }
  .ar-chakra:nth-child(even) .ar-chakra__media { padding: 40px 32px 40px 40px; }
}

@media (max-width: 768px) {
  .ar-chakra {
    grid-template-columns: 1fr;
    min-height: unset;
  }

  /* Always: text top, product bottom */
  .ar-chakra:nth-child(even) .ar-chakra__info  { order: 1; }
  .ar-chakra:nth-child(even) .ar-chakra__media { order: 2; }

  .ar-chakra__info  { padding: 40px 28px 20px; }
  .ar-chakra__media { padding: 16px 28px 40px; min-height: unset; }
  .ar-chakra:nth-child(even) .ar-chakra__media { padding: 16px 28px 40px; }

  .ar-chakra__product { max-width: 100%; }
  .ar-chakra__sanskrit { font-size: 36px; }
  .ar-chakra-header { padding: 60px 24px 40px; }
}

@media (max-width: 480px) {
  .ar-chakra__info { padding: 32px 20px 16px; }
  .ar-chakra__media { padding: 12px 20px 32px; }
  .ar-chakra__symbol { width: 72px; height: 72px; bottom: 16px; right: 16px; }
}
</style>

{%- comment -%} ── SECTION HEADER ── {%- endcomment -%}
<div class="ar-chakra-header" role="banner">
  <div class="ar-chakra-header__bg" aria-hidden="true"></div>
  <span class="ar-chakra-header__eyebrow">{{ section.settings.eyebrow | default: 'The Seven Centres of Life' }}</span>
  <h2 class="ar-chakra-header__title">{{ section.settings.title | default: 'Chakra Attar Collection' }}</h2>
  <p class="ar-chakra-header__sub">{{ section.settings.subtitle | default: 'Seven sacred attars — one for each energy centre. Each fragrance is crafted to resonate with a specific chakra, supporting balance, clarity, and deep presence.' }}</p>
  <div class="ar-chakra-header__rainbow" aria-hidden="true"></div>
</div>

{%- comment -%} ── CHAKRA BANDS ── {%- endcomment -%}
<div class="ar-chakra-wrap" role="region" aria-label="Chakra Attar Collection">

  {%- assign chakras = '7,6,5,4,3,2,1' | split: ',' -%}
  {%- assign ck_names    = 'sahasrara,ajna,vishuddha,anahata,manipura,svadhisthana,muladhara' | split: ',' -%}
  {%- assign ck_english  = 'Crown Chakra,Third Eye Chakra,Throat Chakra,Heart Chakra,Solar Plexus Chakra,Sacral Chakra,Root Chakra' | split: ',' -%}
  {%- comment -%} WEBP symbols in /assets/Chakra — same order as ck_names (crown → root) {%- endcomment -%}
  {%- assign ck_symbol_assets = 'Chakra/Sahasrara.webp,Chakra/Ajna.webp,Chakra/Vishuddha.webp,Chakra/Anahata.webp,Chakra/Manipura.webp,Chakra/Svadhisthana.webp,Chakra/Muladhara.webp' | split: ',' -%}
  {%- assign ck_numbers  = '07,06,05,04,03,02,01' | split: ',' -%}

  {%- for idx in (0..6) -%}
    {%- assign ck_key    = ck_names[idx] -%}
    {%- assign ck_eng    = ck_english[idx] -%}
    {%- assign ck_sym_asset = ck_symbol_assets[idx] -%}
    {%- assign ck_num    = ck_numbers[idx] -%}

    {%- assign q_sanskrit = 'name_' | append: ck_key -%}
    {%- assign q_essence  = 'essence_' | append: ck_key -%}
    {%- assign q_mantra   = 'mantra_' | append: ck_key -%}
    {%- assign q_element  = 'element_' | append: ck_key -%}
    {%- assign q_benefit  = 'benefit_' | append: ck_key -%}
    {%- assign q_product  = 'product_' | append: ck_key -%}
    {%- assign q_url      = 'url_' | append: ck_key -%}

    {%- assign ck_display = section.settings[q_sanskrit] | default: ck_key | upcase -%}
    {%- assign ck_essence = section.settings[q_essence] -%}
    {%- assign ck_mantra  = section.settings[q_mantra] -%}
    {%- assign ck_element = section.settings[q_element] -%}
    {%- assign ck_benefit = section.settings[q_benefit] -%}
    {%- assign ck_product = section.settings[q_product] -%}
    {%- assign ck_url     = section.settings[q_url] -%}

    {%- if ck_product == blank and collection != blank and collection.products_count > 0 -%}
      {%- for cp in collection.products -%}
        {%- assign cp_handle = cp.handle | downcase -%}
        {%- case ck_key -%}
          {%- when 'muladhara' -%}
            {%- if cp_handle contains 'muladhara' or cp_handle contains 'root-chakra' or cp_handle contains 'root' -%}
              {%- assign ck_product = cp -%}
              {%- break -%}
            {%- endif -%}
          {%- when 'svadhisthana' -%}
            {%- if cp_handle contains 'svadhisthana' or cp_handle contains 'swadhisthana' or cp_handle contains 'sacral-chakra' or cp_handle contains 'sacral' -%}
              {%- assign ck_product = cp -%}
              {%- break -%}
            {%- endif -%}
          {%- when 'manipura' -%}
            {%- if cp_handle contains 'manipura' or cp_handle contains 'solar-plexus-chakra' or cp_handle contains 'solar-plexus' -%}
              {%- assign ck_product = cp -%}
              {%- break -%}
            {%- endif -%}
          {%- when 'anahata' -%}
            {%- if cp_handle contains 'anahata' or cp_handle contains 'heart-chakra' or cp_handle contains 'heart' -%}
              {%- assign ck_product = cp -%}
              {%- break -%}
            {%- endif -%}
          {%- when 'vishuddha' -%}
            {%- if cp_handle contains 'vishuddha' or cp_handle contains 'vishudha' or cp_handle contains 'throat-chakra' or cp_handle contains 'throat' -%}
              {%- assign ck_product = cp -%}
              {%- break -%}
            {%- endif -%}
          {%- when 'ajna' -%}
            {%- if cp_handle contains 'ajna' or cp_handle contains 'agya' or cp_handle contains 'third-eye-chakra' or cp_handle contains 'third-eye' -%}
              {%- assign ck_product = cp -%}
              {%- break -%}
            {%- endif -%}
          {%- when 'sahasrara' -%}
            {%- if cp_handle contains 'sahasrara' or cp_handle contains 'crown-chakra' or cp_handle contains 'crown' -%}
              {%- assign ck_product = cp -%}
              {%- break -%}
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if ck_product == blank -%}
      {%- assign ck_fallback_handle = ck_key | append: '-attar' -%}
      {%- assign ck_product = all_products[ck_fallback_handle] -%}
    {%- endif -%}

    <article
      class="ar-chakra ar-chakra--{{ ck_key }}"
      aria-label="{{ ck_display }} — {{ ck_eng }}"
      data-chakra="{{ ck_key }}"
      itemscope
      itemtype="https://schema.org/Thing"
    >
      <meta itemprop="name" content="{{ ck_display }} — {{ ck_eng }}">

      {%- comment -%} ── INFO COLUMN ── {%- endcomment -%}
      <div class="ar-chakra__info">
        <span class="ar-chakra__num">{{ ck_num }}</span>
        <h3 class="ar-chakra__sanskrit">{{ ck_display }}</h3>
        <p class="ar-chakra__english">{{ ck_eng }}</p>
        <hr class="ar-chakra__rule" aria-hidden="true">

        <div class="ar-chakra__meta">
          {%- if ck_essence != blank -%}
            <div class="ar-chakra__meta-row">
              <span class="ar-chakra__meta-label">Essence</span>
              <span class="ar-chakra__meta-val">{{ ck_essence }}</span>
            </div>
          {%- endif -%}
          {%- if ck_mantra != blank -%}
            <div class="ar-chakra__meta-row">
              <span class="ar-chakra__meta-label">Bij Mantra</span>
              <span class="ar-chakra__meta-val">{{ ck_mantra }}</span>
            </div>
          {%- endif -%}
          {%- if ck_element != blank -%}
            <div class="ar-chakra__meta-row">
              <span class="ar-chakra__meta-label">Element</span>
              <span class="ar-chakra__meta-val">{{ ck_element }}</span>
            </div>
          {%- endif -%}
          {%- if ck_benefit != blank -%}
            <div class="ar-chakra__meta-row">
              <span class="ar-chakra__meta-label">Benefits</span>
              <span class="ar-chakra__meta-val">{{ ck_benefit }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- if ck_product != blank and ck_product != empty -%}
          <a href="{{ ck_product.url }}" class="ar-chakra__cta" aria-label="View {{ ck_display }} Attar">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            View Attar
          </a>
        {%- elsif ck_url != blank -%}
          <a href="{{ ck_url }}" class="ar-chakra__cta">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            View Attar
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} ── MEDIA / PRODUCT COLUMN ── {%- endcomment -%}
      <div class="ar-chakra__media">
        <div class="ar-chakra__product">

          {%- if ck_product != blank and ck_product != empty -%}

            <a href="{{ ck_product.url }}" class="ar-chakra__img-wrap" aria-label="{{ ck_product.title | escape }}">
              {%- if ck_product.featured_image -%}
                <img
                  class="ar-chakra__img"
                  src="{{ ck_product.featured_image | image_url: width: 600 }}"
                  alt="{{ ck_product.featured_image.alt | default: ck_product.title | escape }}"
                  width="600"
                  height="600"
                  loading="lazy"
                  decoding="async"
                >
              {%- else -%}
                <div class="ar-chakra__img-ph" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
              {%- endif -%}
            </a>

            <a href="{{ ck_product.url }}" class="ar-chakra__prod-name" style="display:block;text-decoration:none;color:inherit;">
              {{ ck_product.title }}
            </a>

            <div class="ar-chakra__prod-price">
              {%- if ck_product.compare_at_price > ck_product.price -%}
                <span class="ar-chakra__prod-compare">{{ ck_product.compare_at_price | money }}</span>
              {%- endif -%}
              {{ ck_product.price | money }}
            </div>

            {%- if ck_product.available -%}
              <button
                type="button"
                class="ar-chakra__mini-atc js-ck-atc"
                data-id="{{ ck_product.variants.first.id }}"
                aria-label="Add {{ ck_product.title | escape }} to cart"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39A2 2 0 0 0 9.62 16h9.76a2 2 0 0 0 1.97-1.67L23 6H6"/></svg>
                <span>Add to Cart</span>
              </button>
            {%- else -%}
              <span class="ar-chakra__mini-atc" style="opacity:0.4;cursor:not-allowed;">Sold Out</span>
            {%- endif -%}

          {%- else -%}
            <div class="ar-chakra__img-wrap" aria-hidden="true">
              <div class="ar-chakra__img-ph">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            </div>
            <p class="ar-chakra__prod-name">{{ ck_display }} Attar</p>
            <p class="ar-chakra__no-product">Assign product in Theme Editor</p>
          {%- endif -%}

        </div>
      </div>

      <span class="ar-chakra__symbol" aria-hidden="true">
        <img
          src="{{ ck_sym_asset | asset_url }}"
          alt=""
          width="96"
          height="96"
          loading="lazy"
          decoding="async"
        >
      </span>

    </article>
  {%- endfor -%}

</div>


<script>
(function () {
  'use strict';

  /* ── Scroll-triggered entrance ── */
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.ar-chakra').forEach(function (el) {
      io.observe(el);
    });
  } else {
    /* Fallback: show all */
    document.querySelectorAll('.ar-chakra').forEach(function (el) {
      el.classList.add('is-visible');
    });
  }

  /* ── Add to Cart ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.js-ck-atc');
    if (!btn) return;
    e.preventDefault();

    var id   = parseInt(btn.dataset.id, 10);
    var span = btn.querySelector('span');
    var orig = span ? span.textContent : 'Add to Cart';

    if (!id) return;
    btn.classList.add('is-adding');
    if (span) span.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: id, quantity: 1 })
    })
    .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
    .then(function () {
      btn.classList.remove('is-adding');
      btn.classList.add('is-added');
      if (span) span.textContent = '✓ Added';
      document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
      setTimeout(function () {
        btn.classList.remove('is-added');
        if (span) span.textContent = orig;
      }, 2200);
    })
    .catch(function () {
      btn.classList.remove('is-adding');
      if (span) span.textContent = orig;
    });
  });

})();
</script>
