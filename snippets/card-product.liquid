{% comment %}
  Modern collection product card — exact match to reference design.
  Includes: auto-slide images, badges, wishlist, stars, price, ATC button.
{% endcomment %}

{%- unless skip_styles -%}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
  {{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign first_image    = card_product.featured_media
    assign image_count    = 0
    assign image_urls     = ''
    assign product_tags   = card_product.tags | join: ',' | downcase

    assign rating_value   = 5
    if card_product.metafields.reviews.rating.value.rating
      assign rating_value = card_product.metafields.reviews.rating.value.rating
    endif
    assign rating_count   = card_product.metafields.reviews.rating_count | default: 0
    assign rounded_rating = rating_value | round

    assign badge_text  = blank
    assign badge_class = blank
    if product_tags contains 'bestseller'
      assign badge_text  = 'BESTSELLER'
      assign badge_class = 'is-bestseller'
    elsif product_tags contains 'new'
      assign badge_text  = 'NEW'
      assign badge_class = 'is-new'
    elsif product_tags contains 'limited'
      assign badge_text  = 'LIMITED'
      assign badge_class = 'is-limited'
    elsif card_product.compare_at_price > card_product.price
      assign badge_text  = 'SALE'
      assign badge_class = 'is-sale'
    endif
  -%}

  {%- for media_item in card_product.media -%}
    {%- if media_item.media_type == 'image' -%}
      {%- assign image_count = image_count | plus: 1 -%}
      {%- if image_count == 1 and first_image == blank -%}
        {%- assign first_image = media_item -%}
      {%- endif -%}
      {%- capture image_urls -%}{{ image_urls }}{% if image_urls != blank %},{% endif %}{{ media_item | image_url: width: 600 }}{%- endcapture -%}
    {%- endif -%}
  {%- endfor -%}

  {%- liquid
    assign qty_rules = false
    assign qv = card_product.selected_or_first_available_variant
    if qv.quantity_rule.min > 1 or qv.quantity_rule.max != null or qv.quantity_rule.increment > 1
      assign qty_rules = true
    endif
    assign _has_variants = false
    if card_product.variants_count > 1
      assign _has_variants = true
    endif
    assign _needs_quick_add = false
    if quick_add == 'standard' and _has_variants
      assign _needs_quick_add = true
    endif
    if quick_add == 'standard' and qty_rules
      assign _needs_quick_add = true
    endif
    assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id
  -%}

  <div
    class="card-wrapper product-card-wrapper ar-cw"
    style="--card-i: {{ card_index | default: 0 }}"
  >
    <article
      class="ar-card"
      data-product-card
      data-card-index="{{ card_index | default: 0 }}"
      data-images="{{ image_urls | escape }}"
      data-image-count="{{ image_count }}"
    >

      {%- comment -%} ── IMAGE BLOCK ── {%- endcomment -%}
      <div class="ar-card__media">
        <a
          href="{{ card_product.url }}"
          class="ar-card__media-link"
          tabindex="-1"
          aria-label="{{ card_product.title | escape }}"
        >
          {%- if first_image -%}
            <!-- SEO Fix: Product card responsive image with WebP source and explicit dimensions -->
            <picture>
              <source
                srcset="{{ first_image | image_url: width: 400, format: 'webp' }} 400w, {{ first_image | image_url: width: 800, format: 'webp' }} 800w"
                sizes="(min-width: 990px) 25vw, 50vw"
                type="image/webp"
              >
              <img
                class="ar-card__img"
                src="{{ first_image | image_url: width: 800 }}"
                srcset="{{ first_image | image_url: width: 400 }} 400w, {{ first_image | image_url: width: 800 }} 800w"
                sizes="(min-width: 990px) 25vw, 50vw"
                alt="{{ first_image.alt | default: card_product.title | append: ' - handcrafted attar - Anandrasa' | escape }}"
                loading="{% if card_index == 0 %}eager{% else %}lazy{% endif %}"
                {% if card_index == 0 %}fetchpriority="high"{% endif %}
                width="800"
                height="{{ 800 | divided_by: first_image.aspect_ratio | round }}"
                decoding="async"
              >
            </picture>
          {%- else -%}
            <div class="ar-card__img-ph"></div>
          {%- endif -%}
        </a>

        {%- if badge_text != blank -%}
          <span class="ar-card__badge {{ badge_class }}">{{ badge_text }}</span>
        {%- endif -%}

        <button
          type="button"
          class="ar-card__wish"
          aria-label="Add {{ card_product.title | escape }} to wishlist"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 20.727 3.818 12.545A5.5 5.5 0 1 1 11.6 4.763l.4.4.4-.4a5.5 5.5 0 0 1 7.778 7.782L12 20.727Z"/>
          </svg>
        </button>

        {%- if image_count > 1 -%}
          <div class="ar-card__dots" aria-hidden="true">
            {%- for i in (1..image_count) -%}
              <span class="ar-card__dot{% if forloop.first %} is-on{% endif %}"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── BODY BLOCK ── {%- endcomment -%}
      <div class="ar-card__body">

        <h3 class="ar-card__title">
          <a href="{{ card_product.url }}" class="ar-card__title-link">
            {{ card_product.title | escape }}
          </a>
        </h3>

        <div class="ar-card__rating" aria-label="{{ rating_value }} out of 5 stars">
          <span class="ar-card__stars" aria-hidden="true">
            {%- for star in (1..5) -%}
              <svg class="ar-star{% if star <= rounded_rating %} is-on{% endif %}" viewBox="0 0 24 24" aria-hidden="true">
                <path d="m12 2.6 2.97 6.02 6.64.97-4.8 4.68 1.13 6.61L12 17.73l-5.94 3.13 1.13-6.61-4.8-4.68 6.64-.97L12 2.6Z"/>
              </svg>
            {%- endfor -%}
          </span>
          {%- if rating_count > 0 -%}
            <span class="ar-card__rc">({{ rating_count }})</span>
          {%- endif -%}
        </div>

        <div class="ar-card__price">
          {%- if card_product.compare_at_price > card_product.price -%}
            <span class="ar-card__price-old">{{ card_product.compare_at_price | money }}</span>
            <span class="ar-card__price-sale">{{ card_product.price | money }}</span>
          {%- else -%}
            <span class="ar-card__price-reg">{{ card_product.price | money }}</span>
          {%- endif -%}
        </div>

        <div class="ar-card__atc">
          {%- if card_product.available == false -%}
            <button type="button" class="ar-card__btn is-sold" disabled>SOLD OUT</button>

          {%- elsif _needs_quick_add -%}
            <modal-opener data-modal="#QuickAdd-{{ card_product.id }}">
              <button
                id="{{ product_form_id }}-submit"
                type="button"
                name="add"
                class="ar-card__btn"
                aria-haspopup="dialog"
                aria-labelledby="{{ product_form_id }}-submit"
                data-product-url="{{ card_product.url }}"
              >ADD TO CART</button>
            </modal-opener>
            <quick-add-modal id="QuickAdd-{{ card_product.id }}" class="quick-add-modal">
              <div
                role="dialog"
                aria-label="{{ 'products.product.choose_product_options' | t: product_name: card_product.title | escape }}"
                aria-modal="true"
                class="quick-add-modal__content global-settings-popup"
                tabindex="-1"
              >
                <button
                  id="ModalClose-{{ card_product.id }}"
                  type="button"
                  class="quick-add-modal__toggle"
                  aria-label="{{ 'accessibility.close' | t }}"
                >
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </button>
                <div id="QuickAddInfo-{{ card_product.id }}" class="quick-add-modal__content-info"></div>
              </div>
            </quick-add-modal>

          {%- elsif quick_add == 'standard' -%}
            <product-form data-section-id="{{ section.id }}">
              {%- form 'product',
                card_product,
                id: product_form_id,
                class: 'form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
                <input
                  type="hidden"
                  name="id"
                  value="{{ card_product.selected_or_first_available_variant.id }}"
                  class="product-variant-id"
                  {% if card_product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                >
                <button
                  id="{{ product_form_id }}-submit"
                  type="submit"
                  name="add"
                  class="ar-card__btn"
                  aria-live="polite"
                  data-sold-out-message="true"
                  {% if card_product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                >
                  <span>ADD TO CART</span>
                  <span class="sold-out-message hidden">SOLD OUT</span>
                  {%- render 'loading-spinner' -%}
                </button>
              {%- endform -%}
            </product-form>

          {%- else -%}
            <a href="{{ card_product.url }}" class="ar-card__btn">ADD TO CART</a>
          {%- endif -%}
        </div>

      </div>
    </article>
  </div>

{%- else -%}
  <div class="card-wrapper product-card-wrapper ar-cw">
    <div class="ar-card ar-card--ph">
      <div class="ar-card__media"></div>
      <div class="ar-card__body">
        <h3 class="ar-card__title">{{ 'onboarding.product_title' | t }}</h3>
      </div>
    </div>
  </div>
{%- endif -%}


<style>
/* ============================================================
   AR PRODUCT CARD — Full Design System
   ============================================================ */

/* ── Entrance Animation ── */
@keyframes ar-card-in {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

.ar-cw {
  animation: ar-card-in 0.55s ease both;
  animation-delay: calc(var(--card-i, 0) * 60ms);
}

/* ── Card Shell ── */
.ar-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid #EBEBEB;
  border-radius: 0;                    /* sharp edges */
  overflow: hidden;
  transition: box-shadow 0.28s ease, transform 0.28s ease;
}

.ar-card:hover {
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.09);
  transform: translateY(-3px);
}

/* ── Image Block ── */
.ar-card__media {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #F7F3EC;
  flex-shrink: 0;
}

.ar-card__media-link {
  display: block;
  width: 100%;
  height: 100%;
}

.ar-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.55s cubic-bezier(0.25, 1, 0.5, 1),
              opacity 0.3s ease;
}

.ar-card:hover .ar-card__img {
  transform: scale(1.03);
}

.ar-card__img-ph {
  width: 100%;
  height: 100%;
  background: #EDE8DF;
}

/* ── Badge ── */
.ar-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  z-index: 2;
  padding: 5px 11px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
  line-height: 1;
  pointer-events: none;
}
.ar-card__badge.is-bestseller { background: #1A1A1A; }
.ar-card__badge.is-new        { background: #2E7D32; }
.ar-card__badge.is-limited    { background: #6B3FA0; }
.ar-card__badge.is-sale       { background: #C62828; }

/* ── Wishlist ── */
.ar-card__wish {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 2;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #888;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  transition: color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  padding: 0;
}

.ar-card__wish:hover {
  color: #E8799A;
  background: #FFF0F4;
  transform: scale(1.08);
}

.ar-card__wish svg {
  display: block;
  pointer-events: none;
}

/* ── Image Dots ── */
.ar-card__dots {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 5px;
  z-index: 2;
  pointer-events: none;
}

.ar-card__dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  transition: background 0.25s ease, transform 0.25s ease;
}

.ar-card__dot.is-on {
  background: #fff;
  transform: scale(1.25);
}

/* ── Body ── */
.ar-card__body {
  padding: 16px 16px 0;
  background: #fff;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

/* ── Title ── */
.ar-card__title {
  margin: 0;
  font-size: 15px;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ar-card__title-link {
  color: #1A1A1A;
  text-decoration: none;
  display: block;
}

.ar-card__title-link:hover {
  color: #1A1A1A;
  text-decoration: none;
}

/* ── Stars ── */
.ar-card__rating {
  display: flex;
  align-items: center;
  gap: 6px;
}

.ar-card__stars {
  display: flex;
  gap: 2px;
  align-items: center;
}

.ar-star {
  width: 14px;
  height: 14px;
  fill: #DDD;
  flex-shrink: 0;
}

.ar-star.is-on {
  fill: #F5A623;
}

.ar-card__rc {
  font-size: 12px;
  color: #999;
  line-height: 1;
}

/* ── Price ── */
.ar-card__price {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}

.ar-card__price-reg {
  font-size: 17px;
  font-weight: 800;
  color: #1A1A1A;
}

.ar-card__price-old {
  font-size: 13px;
  font-weight: 400;
  color: #ADADAD;
  text-decoration: line-through;
}

.ar-card__price-sale {
  font-size: 17px;
  font-weight: 800;
  color: #C8873A;
}

/* ── ATC Button ── */
.ar-card__atc {
  margin-top: auto;
  padding: 14px 0 16px;
}

.ar-card__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 14px;
  background: #fff;
  color: #1A1A1A;
  border: 1.5px solid #1A1A1A;
  border-radius: 0;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  font-family: inherit;
  line-height: 1;
  transition: background 0.22s ease, color 0.22s ease;
  position: relative;
  overflow: hidden;
}

.ar-card__btn:hover:not(:disabled) {
  background: #1A1A1A;
  color: #fff;
}

.ar-card__btn.is-sold,
.ar-card__btn:disabled {
  background: #F5F5F5;
  color: #BBBBBB;
  border-color: #E0E0E0;
  cursor: not-allowed;
}

/* ── Placeholder ── */
.ar-card--ph .ar-card__media {
  aspect-ratio: 1 / 1;
  background: #EEEBE4;
}

/* ── Responsive ── */
@media (max-width: 480px) {
  .ar-card__body   { padding: 12px 12px 0; }
  .ar-card__title  { font-size: 14px; }
  .ar-card__price-reg,
  .ar-card__price-sale { font-size: 15px; }
  .ar-card__btn    { font-size: 11px; padding: 12px; }
}
</style>


<script>
/* ── Auto-slide images on hover ──────────────────────────── */
(function () {
  'use strict';

  function initCard(card) {
    var rawUrls  = card.dataset.images || '';
    var count    = parseInt(card.dataset.imageCount, 10) || 0;
    if (count < 2 || !rawUrls) return;

    var img     = card.querySelector('.ar-card__img');
    var dots    = Array.from(card.querySelectorAll('.ar-card__dot'));
    if (!img) return;

    var urls    = rawUrls.split(',');
    var current = 0;
    var timer   = null;

    /* pre-load secondary images on first hover */
    var preloaded = false;
    function preload() {
      if (preloaded) return;
      preloaded = true;
      urls.forEach(function (u, i) {
        if (i === 0) return;
        var pi = new Image();
        pi.src = (u.startsWith('//') ? 'https:' : '') + u;
      });
    }

    function show(idx) {
      current = idx;
      var src = urls[idx];
      img.src = src.startsWith('//') ? 'https:' + src : src;
      dots.forEach(function (d, i) {
        d.classList.toggle('is-on', i === idx);
      });
    }

    function next() {
      show((current + 1) % urls.length);
    }

    card.addEventListener('mouseenter', function () {
      preload();
      timer = setInterval(next, 2500);
    });

    card.addEventListener('mouseleave', function () {
      clearInterval(timer);
      timer = null;
      show(0);
    });
  }

  /* Use IntersectionObserver so off-screen cards don't fire */
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        initCard(entry.target);
        io.unobserve(entry.target);
      }
    });
  }, { rootMargin: '200px' });

  function attachAll() {
    document.querySelectorAll('[data-product-card]:not([data-slide-ready])').forEach(function (c) {
      c.dataset.slideReady = '1';
      io.observe(c);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachAll);
  } else {
    attachAll();
  }

  /* Re-run when Shopify re-renders sections (theme editor) */
  document.addEventListener('shopify:section:load', attachAll);
})();
</script>
