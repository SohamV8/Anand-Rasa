{% comment %}
  Modern collection product card — exact match to reference design.
  Includes: auto-slide images, badges, wishlist, stars, price, ATC button.
{% endcomment %}

{%- unless skip_styles -%}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
  {{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign first_image    = card_product.featured_media
    assign image_count    = 0
    assign image_urls     = ''
    assign product_tags   = card_product.tags | join: ',' | downcase

    comment
      Anand Rasa — map Planet & Zodiac products to local asset thumbnails.
      Detect by handle + title so it works wherever this card is rendered.
    endcomment
    assign ar_card_asset_img = ''
    assign ar_card_key = card_product.handle | append: ' ' | append: card_product.title | downcase

    if ar_card_key contains 'sun' or ar_card_key contains 'surya'
      assign ar_card_asset_img = 'Planet/surya_attar.webp' | asset_url
    elsif ar_card_key contains 'moon' or ar_card_key contains 'chandra'
      assign ar_card_asset_img = 'Planet/chandra_attar.webp' | asset_url
    elsif ar_card_key contains 'mars' or ar_card_key contains 'mangal'
      assign ar_card_asset_img = 'Planet/mangal_attar.webp' | asset_url
    elsif ar_card_key contains 'mercury' or ar_card_key contains 'budh'
      assign ar_card_asset_img = 'Planet/budh_attar.webp' | asset_url
    elsif ar_card_key contains 'jupiter' or ar_card_key contains 'guru'
      assign ar_card_asset_img = 'Planet/guru_attar.webp' | asset_url
    elsif ar_card_key contains 'venus' or ar_card_key contains 'shukra'
      assign ar_card_asset_img = 'Planet/shukra_attar.webp' | asset_url
    elsif ar_card_key contains 'saturn' or ar_card_key contains 'shani'
      assign ar_card_asset_img = 'Planet/shani_attar.webp' | asset_url
    elsif ar_card_key contains 'rahu'
      assign ar_card_asset_img = 'Planet/rahu_attar.webp' | asset_url
    elsif ar_card_key contains 'ketu'
      assign ar_card_asset_img = 'Planet/ketu_attar.webp' | asset_url
    elsif ar_card_key contains 'aries' or ar_card_key contains 'mesha'
      assign ar_card_asset_img = 'Zodiac/aries.webp' | asset_url
    elsif ar_card_key contains 'taurus' or ar_card_key contains 'vrishabha'
      assign ar_card_asset_img = 'Zodiac/taurus.webp' | asset_url
    elsif ar_card_key contains 'gemini' or ar_card_key contains 'mithuna'
      assign ar_card_asset_img = 'Zodiac/gemini.webp' | asset_url
    elsif ar_card_key contains 'cancer' or ar_card_key contains 'karka'
      assign ar_card_asset_img = 'Zodiac/cancer.webp' | asset_url
    elsif ar_card_key contains 'leo' or ar_card_key contains 'simha'
      assign ar_card_asset_img = 'Zodiac/leo.webp' | asset_url
    elsif ar_card_key contains 'virgo' or ar_card_key contains 'kanya'
      assign ar_card_asset_img = 'Zodiac/virgo.webp' | asset_url
    elsif ar_card_key contains 'libra' or ar_card_key contains 'tula'
      assign ar_card_asset_img = 'Zodiac/libra.webp' | asset_url
    elsif ar_card_key contains 'scorpio' or ar_card_key contains 'vrischika'
      assign ar_card_asset_img = 'Zodiac/scorpio.webp' | asset_url
    elsif ar_card_key contains 'sagittarius' or ar_card_key contains 'dhanu'
      assign ar_card_asset_img = 'Zodiac/sagittarius.webp' | asset_url
    elsif ar_card_key contains 'capricorn' or ar_card_key contains 'makara'
      assign ar_card_asset_img = 'Zodiac/capricorn.webp' | asset_url
    elsif ar_card_key contains 'aquarius' or ar_card_key contains 'kumbha'
      assign ar_card_asset_img = 'Zodiac/aquarius.webp' | asset_url
    elsif ar_card_key contains 'pisces' or ar_card_key contains 'meena'
      assign ar_card_asset_img = 'Zodiac/pisces.webp' | asset_url
    endif

    comment
      Bestseller showcase images from /assets/Bestseller/ (shared lookup).
    endcomment
    assign ar_card_bestseller_img = ''
    assign ar_card_nakshatra_img = ''
    assign ar_card_incense_img = ''

    capture ar_card_img_alt
      render 'image-seo-alt', seo_product: card_product, img_context: 'card'
    endcapture
    assign ar_card_img_alt = ar_card_img_alt | strip
    capture ar_card_img_alt_hover
      render 'image-seo-alt', seo_product: card_product, img_context: 'hover'
    endcapture
    assign ar_card_img_alt_hover = ar_card_img_alt_hover | strip
  -%}

  {%- capture ar_ck_lookup -%}
    {%- render 'chakra-image-lookup', ck_product: card_product -%}
  {%- endcapture -%}
  {%- assign ar_ck_lookup = ar_ck_lookup | strip -%}
  {%- if ar_card_asset_img == blank and ar_ck_lookup != blank -%}
    {%- assign ar_card_asset_img = ar_ck_lookup | asset_url -%}
  {%- endif -%}

  {%- capture ar_nk_lookup -%}
    {%- render 'nakshatra-image-lookup', nk_product: card_product -%}
  {%- endcapture -%}
  {%- assign ar_nk_lookup = ar_nk_lookup | strip -%}
  {%- if ar_card_asset_img == blank and ar_nk_lookup != blank -%}
    {%- assign ar_card_nakshatra_img = ar_nk_lookup | asset_url -%}
  {%- endif -%}

  {%- capture ar_inc_lookup -%}
    {%- render 'incense-image-lookup', inc_product: card_product -%}
  {%- endcapture -%}
  {%- assign ar_inc_lookup = ar_inc_lookup | strip -%}
  {%- if ar_card_asset_img == blank and ar_card_nakshatra_img == blank and ar_inc_lookup != blank -%}
    {%- assign ar_card_incense_img = ar_inc_lookup | asset_url -%}
  {%- endif -%}

  {%- capture ar_bs_lookup -%}
    {%- render 'bestseller-image-lookup', bs_product: card_product -%}
  {%- endcapture -%}
  {%- assign ar_bs_lookup = ar_bs_lookup | strip -%}
  {%- if ar_card_asset_img == blank and ar_card_nakshatra_img == blank and ar_card_incense_img == blank and ar_bs_lookup != blank -%}
    {%- assign ar_card_bestseller_img = ar_bs_lookup | asset_url -%}
  {%- endif -%}

  {%- for media_item in card_product.media -%}
    {%- if media_item.media_type == 'image' -%}
      {%- assign image_count = image_count | plus: 1 -%}
      {%- if image_count == 1 and first_image == blank -%}
        {%- assign first_image = media_item -%}
      {%- endif -%}
      {%- capture image_urls -%}{{ image_urls }}{% if image_urls != blank %},{% endif %}{{ media_item | image_url: width: 600 }}{%- endcapture -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if ar_card_asset_img != blank or ar_card_nakshatra_img != blank or ar_card_incense_img != blank or ar_card_bestseller_img != blank -%}
    {%- assign image_count = 0 -%}
    {%- assign image_urls = '' -%}
  {%- endif -%}

  {%- liquid
    assign qty_rules = false
    assign qv = card_product.selected_or_first_available_variant
    if qv.quantity_rule.min > 1 or qv.quantity_rule.max != null or qv.quantity_rule.increment > 1
      assign qty_rules = true
    endif
    assign _has_variants = false
    if card_product.variants_count > 1
      assign _has_variants = true
    endif
    assign _needs_quick_add = false
    if quick_add == 'standard' and _has_variants
      assign _needs_quick_add = true
    endif
    if quick_add == 'standard' and qty_rules
      assign _needs_quick_add = true
    endif
    assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id
  -%}

  <div
    class="card-wrapper product-card-wrapper ar-cw"
    style="--card-i: {{ card_index | default: 0 }}"
  >
    <article
      class="ar-card"
      data-product-card
      data-card-index="{{ card_index | default: 0 }}"
      data-images="{{ image_urls | escape }}"
      data-image-count="{{ image_count }}"
    >

      {%- comment -%} ── IMAGE BLOCK ── {%- endcomment -%}
      <div class="ar-card__media{% if ar_card_asset_img != blank or ar_card_nakshatra_img != blank or ar_card_incense_img != blank or ar_card_bestseller_img != blank %} ar-card__media--contain{% endif %}">
        <a
          href="{{ card_product.url }}"
          class="ar-card__media-link"
          tabindex="-1"
          aria-label="{{ ar_card_img_alt | escape }}"
          title="{{ card_product.title | escape }}"
        >
          {%- if ar_card_asset_img != blank -%}
            <img
              class="ar-card__img ar-card__img--contain"
              src="{{ ar_card_asset_img }}"
              alt="{{ ar_card_img_alt | escape }}"
              title="{{ card_product.title | escape }}"
              loading="{% if card_index == 0 %}eager{% else %}lazy{% endif %}"
              {% if card_index == 0 %}fetchpriority="high"{% endif %}
              decoding="async"
            >
          {%- elsif ar_card_nakshatra_img != blank -%}
            <img
              class="ar-card__img ar-card__img--contain"
              src="{{ ar_card_nakshatra_img }}"
              alt="{{ ar_card_img_alt | escape }}"
              title="{{ card_product.title | escape }}"
              loading="{% if card_index == 0 %}eager{% else %}lazy{% endif %}"
              {% if card_index == 0 %}fetchpriority="high"{% endif %}
              decoding="async"
            >
          {%- elsif ar_card_incense_img != blank -%}
            <img
              class="ar-card__img ar-card__img--contain"
              src="{{ ar_card_incense_img }}"
              alt="{{ ar_card_img_alt | escape }}"
              title="{{ card_product.title | escape }}"
              loading="{% if card_index == 0 %}eager{% else %}lazy{% endif %}"
              {% if card_index == 0 %}fetchpriority="high"{% endif %}
              decoding="async"
            >
          {%- elsif ar_card_bestseller_img != blank -%}
            <img
              class="ar-card__img ar-card__img--contain"
              src="{{ ar_card_bestseller_img }}"
              alt="{{ ar_card_img_alt | escape }}"
              title="{{ card_product.title | escape }}"
              loading="{% if card_index == 0 %}eager{% else %}lazy{% endif %}"
              {% if card_index == 0 %}fetchpriority="high"{% endif %}
              decoding="async"
            >
          {%- elsif first_image -%}
            <!-- SEO Fix: Product card responsive image with WebP source and explicit dimensions -->
            <picture>
              <source
                srcset="{{ first_image | image_url: width: 400, format: 'webp' }} 400w, {{ first_image | image_url: width: 800, format: 'webp' }} 800w"
                sizes="(min-width: 990px) 25vw, 50vw"
                type="image/webp"
              >
              <img
                class="ar-card__img"
                src="{{ first_image | image_url: width: 800 }}"
                srcset="{{ first_image | image_url: width: 400 }} 400w, {{ first_image | image_url: width: 800 }} 800w"
                sizes="(min-width: 990px) 25vw, 50vw"
                alt="{{ first_image.alt | default: ar_card_img_alt | escape }}"
                title="{{ card_product.title | escape }}"
                loading="{% if card_index == 0 %}eager{% else %}lazy{% endif %}"
                {% if card_index == 0 %}fetchpriority="high"{% endif %}
                width="800"
                height="{{ 800 | divided_by: first_image.aspect_ratio | round }}"
                decoding="async"
              >
            </picture>
          {%- else -%}
            <div class="ar-card__img-ph"></div>
          {%- endif -%}
        </a>

      </div>

      {%- comment -%} ── BODY BLOCK ── {%- endcomment -%}
      <div class="ar-card__body">
        {%- liquid
          assign ar_raw_notes = ''
          assign ar_main_notes = ''
          assign ar_note_count = 0
          assign ar_product_type = card_product.type | default: 'Attar'
          assign ar_product_type_key = ar_product_type | downcase
          assign ar_display_category = 'Attar'

          if ar_product_type_key contains 'incense' or ar_product_type_key contains 'agarbatti'
            assign ar_display_category = 'Incense Stick'
          elsif ar_product_type_key contains 'perfume'
            assign ar_display_category = 'Perfume'
          endif

          assign ar_notes_source_1 = card_product.metafields.custom.main_notes.value | default: ''
          assign ar_notes_source_2 = card_product.metafields.custom.top_notes.value | default: ''
          assign ar_notes_source_3 = card_product.metafields.custom.heart_notes.value | default: ''
          assign ar_notes_source_4 = card_product.metafields.custom.base_notes.value | default: ''

          if ar_notes_source_1 != blank
            assign ar_raw_notes = ar_notes_source_1
          elsif ar_notes_source_2 != blank
            assign ar_raw_notes = ar_notes_source_2
            if ar_notes_source_3 != blank
              assign ar_raw_notes = ar_raw_notes | append: ', ' | append: ar_notes_source_3
            endif
            if ar_notes_source_4 != blank
              assign ar_raw_notes = ar_raw_notes | append: ', ' | append: ar_notes_source_4
            endif
          endif

          assign ar_raw_notes = ar_raw_notes | replace: ' · ', ', ' | replace: ' & ', ', ' | replace: ' and ', ', ' | replace: ' / ', ', ' | replace: ';', ',' | strip
        -%}

        <h3 class="ar-card__title">
          <a href="{{ card_product.url }}" class="ar-card__title-link">
            {{ card_product.title | escape }}
          </a>
        </h3>

        {%- if ar_raw_notes != blank -%}
          {%- assign ar_note_items = ar_raw_notes | split: ',' -%}
          {%- for ar_note in ar_note_items -%}
            {%- assign ar_note_clean = ar_note | strip -%}
            {%- if ar_note_clean != blank and ar_note_count < 3 -%}
              {%- if ar_main_notes != blank -%}
                {%- assign ar_main_notes = ar_main_notes | append: ' • ' -%}
              {%- endif -%}
              {%- assign ar_main_notes = ar_main_notes | append: ar_note_clean -%}
              {%- assign ar_note_count = ar_note_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if ar_main_notes != blank -%}
            <p class="ar-card__notes">{{ ar_main_notes | escape }}</p>
          {%- endif -%}
        {%- endif -%}

        <p class="ar-card__category">{{ ar_display_category }}</p>

        <div class="ar-card__price">
          {%- if card_product.compare_at_price > card_product.price -%}
            <span class="ar-card__price-old">{{ card_product.compare_at_price | money }}</span>
            <span class="ar-card__price-sale">{{ card_product.price | money }}</span>
          {%- else -%}
            <span class="ar-card__price-reg">{{ card_product.price | money }}</span>
          {%- endif -%}
        </div>

      </div>
    </article>
  </div>

{%- else -%}
  <div class="card-wrapper product-card-wrapper ar-cw">
    <div class="ar-card ar-card--ph">
      <div class="ar-card__media"></div>
      <div class="ar-card__body">
        <h3 class="ar-card__title">{{ 'onboarding.product_title' | t }}</h3>
      </div>
    </div>
  </div>
{%- endif -%}


<style>
/* Minimal Luxury Collection Card */
@keyframes ar-card-in {
  from { opacity: 0; transform: translate3d(0, 18px, 0); }
  to   { opacity: 1; transform: translate3d(0, 0, 0); }
}

.ar-cw {
  animation: ar-card-in 0.45s ease both;
  animation-delay: calc(var(--card-i, 0) * 45ms);
}

.ar-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #fff;
  border: 1px solid #ece8df;
  transition: transform 0.26s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.26s ease;
}

.ar-card:hover {
  transform: translate3d(0, -2px, 0);
  box-shadow: 0 8px 24px rgba(17, 24, 39, 0.08);
}

.ar-card__media {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #fff;
}

.ar-card__media-link {
  display: block;
  width: 100%;
  height: 100%;
}

.ar-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.ar-card:hover .ar-card__img {
  transform: scale3d(1.02, 1.02, 1);
}

.ar-card__media--contain .ar-card__media-link {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ar-card__img--contain {
  width: auto;
  height: auto;
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.ar-card__img-ph {
  width: 100%;
  height: 100%;
  background: #f5f2ec;
}

.ar-card__body {
  display: flex;
  flex-direction: column;
  gap: 7px;
  padding: 14px 14px 16px;
  flex: 1;
}

.ar-card__title {
  margin: 0;
  font-size: 15px;
  font-weight: 650;
  letter-spacing: -0.01em;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ar-card__title-link {
  color: #1a1a1a;
  text-decoration: none;
}

.ar-card__notes {
  margin: 0;
  font-size: 12.5px;
  line-height: 1.5;
  color: #6b7280;
  font-weight: 400;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ar-card__category {
  margin: 0;
  font-size: 10.5px;
  line-height: 1.3;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #8b6f47;
  font-weight: 600;
}

.ar-card__price {
  margin-top: 3px;
  display: flex;
  align-items: baseline;
  gap: 7px;
  flex-wrap: wrap;
}

.ar-card__price-reg,
.ar-card__price-sale {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #1a1a1a;
}

.ar-card__price-old {
  font-size: 12px;
  color: #9ca3af;
  text-decoration: line-through;
}

.ar-card--ph .ar-card__media {
  aspect-ratio: 1 / 1;
}

@media (max-width: 480px) {
  .ar-card__body { padding: 12px; gap: 6px; }
  .ar-card__title { font-size: 14px; }
  .ar-card__notes { font-size: 12px; }
  .ar-card__category { font-size: 10px; }
  .ar-card__price-reg,
  .ar-card__price-sale { font-size: 15px; }
}

@media (prefers-reduced-motion: reduce) {
  .ar-cw,
  .ar-card,
  .ar-card__img {
    animation: none !important;
    transition: none !important;
    transform: none !important;
  }
}
</style>
