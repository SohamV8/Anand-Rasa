{%- comment -%}
  Inline SVG icons for Attar Ritual Guide.
  @param icon {string} lotus | bowl | droplet | sparkle | shirt | drop-ring | clock | flask | hands | skin-drop
{%- endcomment -%}

{%- case icon -%}
  {%- when 'bowl' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 14c0 3.3 2.7 6 6 6s6-2.7 6-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M5 14h14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M8 10c1.5-2.5 3.5-4 4-4s2.5 1.5 4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M10 6.5c.4-.8 1-1.5 2-1.5s1.6.7 2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
  {%- when 'droplet' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 4c3 4.5 5 7.5 5 10.5a5 5 0 11-10 0C7 11.5 9 8.5 12 4z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
  {%- when 'sparkle' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l1 3.5L16.5 7.5 13 8.5 12 12l-1-3.5L7.5 7.5 11 6.5 12 3z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M18 13l.8 2.5L21.5 16l-2.7.5L18 19l-.8-2.5L14.5 16l2.7-.5L18 13z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/></svg>
  {%- when 'shirt' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 4l-3 3v2l3 1.5V20h6V10.5L18 9V7l-3-3-3 2-3-2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
  {%- when 'drop-ring' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.3"/><path d="M12 8.5c1.8 2.5 3 4.2 3 5.8a3 3 0 11-6 0c0-1.6 1.2-3.3 3-5.8z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
  {%- when 'clock' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="13" r="7.5" stroke="currentColor" stroke-width="1.3"/><path d="M12 9.5V13l2.5 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M9 4.5h6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
  {%- when 'flask' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M10 3h4v5l4.5 8.5a2.5 2.5 0 01-2.2 3.5H7.7a2.5 2.5 0 01-2.2-3.5L10 8V3z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M9 14h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
  {%- when 'hands' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 11V8.5a1.5 1.5 0 013 0V11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M11 11V7.5a1.5 1.5 0 013 0V12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M14 12V8.5a1.5 1.5 0 013 0v6.5a5 5 0 01-5 5H10a5 5 0 01-5-5v-3a1.5 1.5 0 013 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'skin-drop' -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 14c0-2.5 2.5-5 5-7 2.5 2 5 4.5 5 7a5 5 0 11-10 0z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M5 19c1.2.8 2.6 1.2 4 1.2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3c-1.5 2-3 4.5-3 7a3 3 0 006 0c0-2.5-1.5-5-3-7z" stroke="currentColor" stroke-width="1.4"/><path d="M8 17c1.2 1.5 2.6 2 4 2s2.8-.5 4-2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M7 20h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
{%- endcase -%}
