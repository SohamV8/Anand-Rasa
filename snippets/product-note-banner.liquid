{%- comment -%}
  Fragrance notes pyramid — above note banner and recommendations.
  Rendered from product-note-banner.liquid on product pages.

  Usage:
    {% render 'product-note-banner', product: product %}
{%- endcomment -%}
{%- liquid
  assign pnb_product = product
  if pnb_product == blank
    assign pnb_product = banner_product
  endif
  if pnb_product == blank
    assign pnb_product = nb_product
  endif
-%}
{%- if pnb_product != blank -%}
  {% render 'fragrance-notes', product: pnb_product %}

  {%- capture pnb_asset -%}{%- render 'note-banner-lookup', nb_product: pnb_product -%}{%- endcapture -%}
  {%- assign pnb_asset = pnb_asset | strip -%}
  {%- unless pnb_asset contains 'NoteBanner/' -%}
    {%- assign pnb_asset = '' -%}
  {%- endunless -%}

  {%- if pnb_asset != blank -%}
    {%- liquid
      assign pnb_id = pnb_product.id
      assign pnb_title = pnb_product.title | escape
      assign pnb_alt = pnb_title | append: ' fragrance notes'
      assign pnb_src = pnb_asset | asset_url
    -%}

    {%- if pnb_src != blank -%}
      <section
        id="pnb-{{ pnb_id }}"
        class="pnb pnb--bleed"
        aria-label="{{ pnb_title }} fragrance notes"
      >
        <picture class="pnb__picture">
          <img
            src="{{ pnb_src }}"
            alt="{{ pnb_alt | escape }}"
            width="3840"
            height="1600"
            loading="lazy"
            decoding="async"
            class="pnb__img"
          >
        </picture>
      </section>

      <style>
        #pnb-{{ pnb_id }}.pnb--bleed {
          display: block;
          width: 100%;
          max-width: 100%;
          margin: clamp(32px, 5vw, 64px) 0 clamp(40px, 6vw, 80px);
          padding: 0;
          background: #fff;
          overflow-x: clip;
          box-sizing: border-box;
          clear: both;
        }

        #pnb-{{ pnb_id }} .pnb__picture {
          display: block;
          width: 100%;
          margin: 0;
          padding: 0;
          line-height: 0;
        }

        #pnb-{{ pnb_id }} .pnb__img {
          display: block;
          width: 100%;
          height: auto;
          max-width: 100%;
          margin: 0 auto;
          object-fit: contain;
          object-position: center center;
        }

        @media (max-width: 749px) {
          #pnb-{{ pnb_id }}.pnb--bleed {
            margin-top: 28px;
            margin-bottom: 36px;
          }
        }
      </style>
    {%- endif -%}
  {%- endif -%}
{%- endif -%}
