<section class="ar-vt">
  <div class="ar-vt__inner">

    <!-- HEADER -->
    <div class="ar-vt__header">
      <h2 class="ar-vt__heading">
        {{ heading | default: "Real Experiences" }}
      </h2>
      <p class="ar-vt__sub">
        {{ subheading | default: "Authentic moments from our customers." }}
      </p>
    </div>

    <!-- SLIDER -->
    <div class="ar-vt__wrapper">
      <div class="ar-vt__track" id="arVTTrack">

        {% for video in videos %}
          <div class="ar-vt__slide">

            <div class="ar-vt__video-box">
              <video
                class="ar-vt__video"
                src="{{ video.url }}"
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            </div>

            <div class="ar-vt__meta">
              <p class="ar-vt__name">{{ video.name }}</p>
            </div>

          </div>
        {% endfor %}

      </div>
    </div>

  </div>
</section>


<style>

/* SECTION */
.ar-vt {
  padding: 120px 0;
  background: #f8f8f7;
}

.ar-vt__inner {
  max-width: 1400px;
  margin: auto;
  padding: 0 24px;
}

/* HEADER */
.ar-vt__header {
  text-align: center;
  margin-bottom: 60px;
}

.ar-vt__heading {
  font-size: 42px;
  font-weight: 500;
}

.ar-vt__sub {
  color: #6b7280;
}

/* SLIDER */
.ar-vt__wrapper {
  position: relative;
  overflow: hidden;
}

.ar-vt__track {
  display: flex;
  gap: 24px;
  will-change: transform;
}

/* SLIDE */
.ar-vt__slide {
  flex: 0 0 auto;
  width: 280px;
}

/* VIDEO */
.ar-vt__video-box {
  width: 100%;
  height: 500px;
  border-radius: 20px;
  overflow: hidden;
  background: #000;
}

.ar-vt__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: translateZ(0);
}

/* META */
.ar-vt__meta {
  text-align: center;
  margin-top: 10px;
}

/* FADE EDGES */
.ar-vt__wrapper::before,
.ar-vt__wrapper::after {
  content: "";
  position: absolute;
  top: 0;
  width: 80px;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.ar-vt__wrapper::before {
  left: 0;
  background: linear-gradient(to right, #f8f8f7, transparent);
}

.ar-vt__wrapper::after {
  right: 0;
  background: linear-gradient(to left, #f8f8f7, transparent);
}

/* RESPONSIVE */
@media(max-width:768px){
  .ar-vt__slide { width: 220px; }
  .ar-vt__video-box { height: 420px; }
}

</style>


<script>
document.addEventListener("DOMContentLoaded", () => {

  const track = document.getElementById("arVTTrack");
  if (!track) return;

  const slides = track.children;
  const speed = 0.4; // smooth speed
  let scroll = 0;

  // CLONE for infinite loop
  track.innerHTML += track.innerHTML;

  function autoScroll() {
    scroll += speed;
    track.style.transform = `translateX(-${scroll}px)`;

    if (scroll >= track.scrollWidth / 2) {
      scroll = 0;
    }

    requestAnimationFrame(autoScroll);
  }

  autoScroll();

  // VIDEO PLAY CONTROL (center active)
  const videos = track.querySelectorAll("video");

  function updateVideos() {
    const center = window.innerWidth / 2;

    videos.forEach(video => {
      const rect = video.getBoundingClientRect();
      const videoCenter = rect.left + rect.width / 2;

      if (Math.abs(center - videoCenter) < 120) {
        video.play().catch(()=>{});
      } else {
        video.pause();
      }
    });
  }

  setInterval(updateVideos, 300);

});
</script>