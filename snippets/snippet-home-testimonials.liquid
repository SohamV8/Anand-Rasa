{%- liquid
  assign text_testimonials = section.blocks | where: 'type', 'testimonial'
  assign video_testimonials = section.blocks | where: 'type', 'video_testimonial'
-%}

{%- if text_testimonials.size > 0 -%}
  <section class="ar-tst">
    <div class="ar-tst__inner">
      <div class="ar-tst__hdr">
        <h2 class="ar-tst__h">{{ section.settings.tst_heading | default: 'What Our Customers Say' }}</h2>
        <div class="ar-tst__div"></div>
        <p class="ar-tst__sub">{{ section.settings.tst_sub | default: 'Real people. Real experiences.' }}</p>
      </div>

      <div class="ar-tst__track js-tst-track">
        {%- for block in text_testimonials -%}
          <article class="ar-tst__card" {{ block.shopify_attributes }}>
            {%- assign rating = block.settings.rating | default: 5 -%}
            <div class="ar-tst__stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                <span class="ar-tst__star{% if i <= rating %} on{% endif %}">&#9733;</span>
              {%- endfor -%}
            </div>
            <p class="ar-tst__quote">"{{ block.settings.quote }}"</p>
            <div class="ar-tst__author">
              <p class="ar-tst__name">{{ block.settings.name }}</p>
              <p class="ar-tst__loc">{{ block.settings.location }}</p>
            </div>
          </article>
        {%- endfor -%}
      </div>

      <div class="ar-tst__dots" id="ar-tst-dots"></div>
    </div>
  </section>
{%- endif -%}

{%- if video_testimonials.size > 0 -%}
  <section class="ar-vtm">
    <div class="ar-vtm__inner">
      <div class="ar-vtm__header">
        <h2 class="ar-vtm__h">{{ section.settings.vtm_heading | default: 'Video Testimonials' }}</h2>
        <div class="ar-vtm__divider"></div>
        <p class="ar-vtm__sub">{{ section.settings.vtm_sub | default: 'Real people. Real experiences.' }}</p>
      </div>

      <div class="ar-vtm__grid">
        {%- for block in video_testimonials -%}
          {%- assign v = block.settings.video -%}
          {%- assign v_url = block.settings.video_url | strip -%}
          <article class="ar-vtm__card" {{ block.shopify_attributes }}>
            <div class="ar-vtm__video-wrap">
              {%- if v != blank -%}
                {{
                  v
                  | video_tag:
                    class: 'ar-vtm__video',
                    image_size: '540x960',
                    autoplay: true,
                    loop: true,
                    muted: true,
                    controls: false,
                    playsinline: true
                }}
              {%- elsif v_url != blank -%}
                <video
                  class="ar-vtm__video"
                  src="{{ v_url }}"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                ></video>
              {%- else -%}
                <div class="ar-vtm__video ar-vtm__ph">Upload a portrait video</div>
              {%- endif -%}
              {%- if v != blank or v_url != blank -%}
                <button type="button" class="ar-vtm__mute-btn js-vtm-mute-btn is-muted" aria-label="Unmute video" data-muted="true">
                  <span class="ar-vtm__icon ar-vtm__icon--muted" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                      <line x1="23" y1="9" x2="17" y2="15"></line>
                      <line x1="17" y1="9" x2="23" y2="15"></line>
                    </svg>
                  </span>
                  <span class="ar-vtm__icon ar-vtm__icon--unmuted" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                      <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                      <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
                    </svg>
                  </span>
                </button>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

<script>
  (function () {
    var root = document.currentScript && document.currentScript.parentElement;
    if (!root) return;

    var videos = root.querySelectorAll('.ar-vtm__video-wrap video');
    videos.forEach(function (video) {
      video.muted = true;
      video.setAttribute('muted', 'muted');
      var p = video.play();
      if (p && typeof p.catch === 'function') p.catch(function () {});
    });

    root.querySelectorAll('.js-vtm-mute-btn').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        var wrap = btn.closest('.ar-vtm__video-wrap');
        if (!wrap) return;
        var video = wrap.querySelector('video');
        if (!video) return;

        var mutedNow = !video.muted;
        video.muted = mutedNow;
        btn.setAttribute('data-muted', mutedNow ? 'true' : 'false');
        btn.classList.toggle('is-muted', mutedNow);
        btn.setAttribute('aria-label', mutedNow ? 'Unmute video' : 'Mute video');
      });
    });
  })();
</script>