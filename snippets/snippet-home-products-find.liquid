{%- liquid
  assign cf_uid = uid | default: 'discover-fragrance' | handleize

  assign find_heading = find_heading | default: 'Discover the fragrance written in your stars.'
  assign find_text = find_text | default: 'Our astrology fragrance finder reveals the attar aligned with your zodiac, planet, and Nakshatra energy.'
  assign find_url = find_url | strip
  if find_url == blank
    assign find_url = routes.root_url | append: '?view=find-fragrance'
  endif
  assign find_btn = find_btn | default: 'Find Your Fragrance'

  if section != blank
    if section.settings.find_heading != blank
      assign find_heading = section.settings.find_heading
    endif
    if section.settings.find_text != blank
      assign find_text = section.settings.find_text
    endif
    if section.settings.find_btn != blank
      assign find_btn = section.settings.find_btn
    endif
    if section.settings.find_url != blank
      assign find_url = section.settings.find_url
    endif
  endif
-%}

{{ 'hero-vanta.css' | asset_url | stylesheet_tag }}

<section
  class="hero-vanta"
  id="hero-vanta-{{ cf_uid }}"
  aria-labelledby="hero-vanta-title-{{ cf_uid }}"
>
  <div class="hero-vanta__content">
    <h2 class="hero-vanta__title" id="hero-vanta-title-{{ cf_uid }}">{{ find_heading }}</h2>
    <p class="hero-vanta__desc">{{ find_text }}</p>
    <a href="{{ find_url }}" class="hero-vanta__cta">{{ find_btn }}</a>
  </div>
</section>

{%- comment -%} Perf: WebGL hero stack deferred (was render-blocking script_tag). hero-vanta.js lazy-inits via IntersectionObserver on window load, so defer keeps visuals identical while unblocking HTML parse / LCP. {%- endcomment -%}
<script src="{{ 'three.min.js' | asset_url }}" defer></script>
<script src="{{ 'vanta.clouds.min.js' | asset_url }}" defer></script>
<script src="{{ 'hero-vanta.js' | asset_url }}" defer></script>
