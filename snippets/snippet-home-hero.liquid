{%- comment -%} 1. HERO {%- endcomment -%}
<section class="ar-hero">
  <div class="ar-hero__in">

    <!-- LEFT -->
    <div class="ar-hero__left">
      <p class="ar-hero__ey">
        {{ section.settings.hero_eyebrow | default: 'ANAND RAS' }}
      </p>

      <h1 class="ar-hero__h1">
        {%- if section.settings.hero_headline != blank -%}
          {{ section.settings.hero_headline | newline_to_br }}
        {%- else -%}
          Perfume for your<br>soul
        {%- endif -%}
      </h1>

      <p class="ar-hero__p">
        {{ section.settings.hero_body | default: 'Modern luxury attars crafted through timeless distillation. Pure oils, calm presence, and minimal elegance designed for everyday ritual.' }}
      </p>

      <div class="ar-hero__cta">
        <a href="{{ section.settings.hero_btn1_url | default: routes.all_products_collection_url }}" class="ar-hero__btn1">
          {{ section.settings.hero_btn1_label | default: 'Shop Now' }}
        </a>

        <a href="{{ section.settings.hero_btn2_url | default: routes.collections_url }}" class="ar-hero__btn2">
          {{ section.settings.hero_btn2_label | default: 'Explore Collections' }}
        </a>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="ar-hero__right">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 2400 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 1200 }} 1200w,
                  {{ section.settings.hero_image | image_url: width: 1800 }} 1800w,
                  {{ section.settings.hero_image | image_url: width: 2400 }} 2400w"
          sizes="(min-width:1024px) 55vw, 100vw"
          alt="{{ section.settings.hero_image.alt | default: section.settings.hero_headline | default: shop.name | escape }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="ar-hero__img"
        >
      {%- else -%}
        <div class="ar-hero__ph">Upload hero image in Theme Editor</div>
      {%- endif -%}
    </div>

  </div>
</section>

<style>

/* =========================
   HERO BASE
========================= */

.ar-hero {
  background: #fff;
  overflow: hidden;
  display: flex;
  align-items: center;
  margin: 0;
  padding: 0;
}

/* =========================
   LAYOUT
========================= */

.ar-hero__in {
  max-width: 1480px;
  width: 100%;
  margin: 0 auto;

  /* 🔥 FIXED TOP SPACE */
  padding: 0 clamp(28px, 8vw, 120px) clamp(48px, 6vw, 80px);

  display: grid;
  grid-template-columns: 1.1fr 1fr;
  align-items: center;

  gap: clamp(60px, 6vw, 100px);
  min-height: 85vh;
}

/* =========================
   LEFT CONTENT
========================= */

.ar-hero__left {
  max-width: 640px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.ar-hero__ey {
  font-size: 12px;
  letter-spacing: 0.35em;
  color: #8a8a8a;
  margin: 0;
}

.ar-hero__h1 {
  font-size: clamp(3rem, 6vw, 5rem);
  line-height: 1.05;
  font-weight: 500;
  letter-spacing: -0.02em;
  color: #111;
  margin: 0;
}

/* 🔥 BETTER TEXT BREATHING */
.ar-hero__p {
  font-size: 18px;
  line-height: 1.8;
  color: #555;
  max-width: 520px;
  margin-top: 8px;
}

/* =========================
   CTA
========================= */

.ar-hero__cta {
  display: flex;
  gap: 16px;
  margin-top: 24px;
}

.ar-hero__btn1 {
  padding: 14px 28px;
  border-radius: 999px;
  border: 1px solid #ddd;
  font-size: 14px;
  transition: all 0.3s ease;
}

.ar-hero__btn1:hover {
  background: #111;
  color: #fff;
}

.ar-hero__btn2 {
  font-size: 16px;
  color: #555;
  text-decoration: none;
}

/* =========================
   IMAGE SIDE (MAJOR FIX)
========================= */

.ar-hero__right {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.ar-hero__img {
  width: 120%;
  max-width: 820px;
  height: auto;
  object-fit: contain;
}

/* =========================
   RESPONSIVE
========================= */

@media (max-width: 1024px) {
  .ar-hero__in {
    grid-template-columns: 1fr;
    text-align: center;
    padding: 40px 24px;
  }

  .ar-hero__left {
    margin: 0 auto;
    align-items: center;
  }

  .ar-hero__cta {
    justify-content: center;
  }

  .ar-hero__right {
    justify-content: center;
  }

  .ar-hero__img {
    width: 100%;
    max-width: 520px;
  }
}

@media (max-width: 640px) {
  .ar-hero__h1 {
    font-size: 38px;
  }

  .ar-hero__p {
    font-size: 16px;
  }
}

</style>