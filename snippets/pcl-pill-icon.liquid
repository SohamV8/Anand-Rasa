{%- comment -%}
  Premium collections — category pill icons
  @param icon {string} bestsellers | astrology | attars | perfumes | incense | gift-sets
{%- endcomment -%}
{%- case icon -%}
  {%- when 'bestsellers' -%}
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 2l2.2 4.5 5 .7-3.6 3.5.9 5L10 13.8 5.5 15.7l.9-5L2.8 7.2l5-.7L10 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
  {%- when 'astrology' -%}
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.2"/><path d="M10 3v2M10 15v2M3 10h2M15 10h2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
  {%- when 'attars' -%}
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 3c-1.5 2.5-4 4-4 7a4 4 0 008 0c0-3-2.5-4.5-4-7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M10 9v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
  {%- when 'perfumes' -%}
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M8 4h4v2H8V4zM7 6h6l1 12H6L7 6z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><ellipse cx="10" cy="6" rx="3" ry="1" stroke="currentColor" stroke-width="1.2"/></svg>
  {%- when 'incense' -%}
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 16V8M8 16h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M10 8c-1-2-1-3.5 0-5M10 8c1-2 1-3.5 0-5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.7"/></svg>
  {%- when 'gift-sets' -%}
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><rect x="3" y="8" width="14" height="9" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M10 8v9M3 11h14" stroke="currentColor" stroke-width="1.2"/><path d="M10 8c-2 0-3.5-1-3.5-2.5S8 3 10 3s3.5 1 3.5 2.5S12 8 10 8z" stroke="currentColor" stroke-width="1.2"/></svg>
  {%- else -%}
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.3"/></svg>
{%- endcase -%}
