{% comment %}
  ANAND RASA — Love Attar · Floating Petals Section
  sections/anand-rasa-love-attar.liquid
  Upper border (border1.webp) + Floating petals + Content + Lower border (border.webp)
{% endcomment %}

{%- liquid
  assign petal_srcs = 'love/1.webp,love/2.webp,love/3.webp,love/4.webp,love/5.webp,love/6.webp' | split: ','
  assign petal_count = 28
-%}

<style>
/* ============================================================
   SECTION TOKENS
   ============================================================ */
.ar-love {
  --fh: var(--font-heading-family, 'Georgia', serif);
  --fb: var(--font-body-family, system-ui, -apple-system, sans-serif);
  --pink:      #E8799A;
  --pink-deep: #C0395A;
  --gold:      #B8943A;
  --ink:       #1A1A1A;
  --ink-2:     #4A4A4A;
  --ink-3:     #888888;
  --bg:        #FFF8F0;
  --white:     #FFFFFF;
  --trans:     0.3s cubic-bezier(0.25,1,0.5,1);
  font-family: var(--fb);
  -webkit-font-smoothing: antialiased;
}
.ar-love *, .ar-love *::before, .ar-love *::after { box-sizing: border-box; margin: 0; padding: 0; }
.ar-love a { text-decoration: none; color: inherit; }
.ar-love img { display: block; max-width: 100%; }
.ar-love button { font-family: var(--fb); cursor: pointer; border: none; }

/* ============================================================
   PETAL ANIMATIONS — each petal gets a unique keyframe
   Generated via JS; CSS handles the base float pattern
   ============================================================ */
@keyframes ar-petal-fall {
  0%   { transform: translateY(-12%) rotate(0deg)   translateX(0px); opacity: 0; }
  5%   { opacity: 0.88; }
  50%  { opacity: 0.80; }
  95%  { opacity: 0.72; }
  100% { transform: translateY(115%) rotate(360deg) translateX(0px); opacity: 0; }
}

/* ============================================================
   TOP BORDER
   ============================================================ */
.ar-love__border-top {
  position: relative;
  z-index: 10;
  width: 100%;
  line-height: 0;
}
.ar-love__border-top img {
  width: 100%;
  height: auto;
  object-fit: contain;
  display: block;
}

/* ============================================================
   MAIN CONTENT SHELL — yellow-warm bg matching original
   ============================================================ */
.ar-love__shell {
  position: relative;
  background: #FFF8F0;
  overflow: hidden;
  /* top/bottom gradient fades — match original yellow fade */
}
.ar-love__shell::before,
.ar-love__shell::after {
  content: '';
  position: absolute;
  inset-x: 0;
  height: 100px;
  z-index: 30;
  pointer-events: none;
}
.ar-love__shell::before {
  top: 0;
  background: linear-gradient(180deg, #FFF8F0 0%, rgba(255,248,240,0) 100%);
}
.ar-love__shell::after {
  bottom: 0;
  background: linear-gradient(0deg, #FFF8F0 0%, rgba(255,248,240,0) 100%);
}

/* ============================================================
   PETALS CANVAS — absolutely covers the shell
   ============================================================ */
.ar-love__petals {
  position: absolute;
  inset: 0;
  z-index: 20;
  overflow: hidden;
  pointer-events: none;
  contain: layout paint;
}

.ar-love__petal {
  position: absolute;
  top: -18%;
  pointer-events: none;
  user-select: none;
  will-change: transform, opacity;
  transform-origin: center center;
}

.ar-love__petal img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  pointer-events: none;
  user-select: none;
}

/* ============================================================
   INNER CONTENT — sits above petals (z-index: 40)
   ============================================================ */
.ar-love__content {
  position: relative;
  z-index: 40;
  max-width: 1200px;
  margin: 0 auto;
  padding: 80px 48px 96px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

/* ── Section header ── */
.ar-love__header {
  text-align: center;
  margin-bottom: 60px;
}

.ar-love__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--pink);
  margin-bottom: 14px;
}
.ar-love__eyebrow::before,
.ar-love__eyebrow::after {
  content: ''; width: 28px; height: 1px;
  background: currentColor; opacity: 0.5;
}

.ar-love__title {
  font-family: var(--fh);
  font-size: clamp(34px, 5vw, 64px);
  font-weight: 300;
  color: var(--ink);
  letter-spacing: -0.04em;
  line-height: 1.05;
  margin-bottom: 16px;
}
.ar-love__title em { font-style: italic; font-weight: 400; color: var(--pink-deep); }

.ar-love__sub {
  font-size: 16px;
  color: var(--ink-3);
  line-height: 1.8;
  font-weight: 300;
  max-width: 560px;
  margin: 0 auto 24px;
}

/* Gold decorative rule */
.ar-love__rule {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}
.ar-love__rule-line {
  width: 48px; height: 1px;
  background: linear-gradient(to right, transparent, var(--gold));
}
.ar-love__rule-line:last-child {
  background: linear-gradient(to left, transparent, var(--gold));
}
.ar-love__rule-rose { font-size: 18px; }

/* ── Product grid ── */
.ar-love__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  width: 100%;
  margin-bottom: 60px;
}
@media (max-width: 900px) { .ar-love__grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 560px) { .ar-love__grid { grid-template-columns: 1fr; gap: 16px; } }

/* Product card */
.ar-love__card {
  background: rgba(255,255,255,0.7);
  border: 1px solid rgba(232,121,154,0.15);
  border-radius: 24px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 4px 24px rgba(232,121,154,0.08);
  transition: transform var(--trans), box-shadow var(--trans);
}
.ar-love__card:hover {
  transform: translateY(-6px) scale(1.01);
  box-shadow: 0 16px 48px rgba(232,121,154,0.18);
}

.ar-love__card-img {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: rgba(255,220,235,0.2);
  position: relative;
}
.ar-love__card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.25,1,0.5,1);
}
.ar-love__card:hover .ar-love__card-img img { transform: scale(1.05); }

.ar-love__card-badge {
  position: absolute;
  top: 12px; left: 12px;
  padding: 5px 12px;
  background: var(--pink);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 4px;
}

.ar-love__card-body { padding: 20px 20px 0; flex: 1; display: flex; flex-direction: column; gap: 5px; }
.ar-love__card-type { font-size: 10px; text-transform: uppercase; letter-spacing: 0.18em; font-weight: 600; color: var(--pink); }
.ar-love__card-name { font-family: var(--fh); font-size: 18px; font-weight: 400; color: var(--ink); line-height: 1.3; letter-spacing: -0.01em; }
.ar-love__card-desc { font-size: 13px; color: var(--ink-3); font-weight: 300; line-height: 1.55; font-style: italic; }
.ar-love__card-price-row { display: flex; align-items: baseline; gap: 8px; margin-top: 8px; }
.ar-love__card-price { font-size: 17px; font-weight: 700; color: var(--ink); }
.ar-love__card-compare { font-size: 13px; color: #ADADAD; text-decoration: line-through; }

.ar-love__card-foot { padding: 16px 20px 20px; }
.ar-love__card-btn {
  width: 100%; padding: 13px;
  border-radius: 999px;
  background: var(--pink);
  color: #fff;
  font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
  display: flex; align-items: center; justify-content: center; gap: 7px;
  transition: background var(--trans), transform 0.2s ease, box-shadow 0.2s ease;
  cursor: pointer;
}
.ar-love__card-btn:hover:not(:disabled) {
  background: var(--pink-deep);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(192,57,90,0.3);
}
.ar-love__card-btn:disabled { background: #DDD; color: #999; cursor: not-allowed; }
.ar-love__card-btn.is-added { background: #2E7D52; }

/* ── Story / Brand Block ── */
.ar-love__story {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  width: 100%;
  margin-bottom: 60px;
  background: rgba(255,255,255,0.6);
  border: 1px solid rgba(232,121,154,0.12);
  border-radius: 28px;
  padding: 48px 52px;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
@media (max-width: 768px) {
  .ar-love__story { grid-template-columns: 1fr; padding: 36px 28px; gap: 32px; }
}

.ar-love__story-img-wrap {
  aspect-ratio: 4/3;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(232,121,154,0.15);
}
.ar-love__story-img-wrap img { width: 100%; height: 100%; object-fit: cover; }

.ar-love__story-label {
  font-size: 10px; font-weight: 700; letter-spacing: 0.28em;
  text-transform: uppercase; color: var(--pink); display: block; margin-bottom: 14px;
}
.ar-love__story-h {
  font-family: var(--fh);
  font-size: clamp(24px, 3vw, 38px); font-weight: 300; color: var(--ink);
  letter-spacing: -0.025em; line-height: 1.15; margin-bottom: 18px;
}
.ar-love__story-p {
  font-size: 15px; line-height: 1.85; color: var(--ink-2); font-weight: 300;
  margin-bottom: 28px;
}
.ar-love__story-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 28px; border-radius: 999px;
  background: var(--pink); color: #fff;
  font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none;
  transition: background var(--trans), transform 0.2s ease;
}
.ar-love__story-btn:hover { background: var(--pink-deep); transform: translateY(-2px); }

/* ── Notes / Feature row ── */
.ar-love__notes {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  width: 100%;
}
@media (max-width: 768px) { .ar-love__notes { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 420px) { .ar-love__notes { grid-template-columns: 1fr; } }

.ar-love__note {
  background: rgba(255,255,255,0.65);
  border: 1px solid rgba(232,121,154,0.12);
  border-radius: 20px;
  padding: 24px 20px;
  text-align: center;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transition: transform var(--trans), box-shadow var(--trans);
}
.ar-love__note:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(232,121,154,0.14); }
.ar-love__note-icon { font-size: 28px; margin-bottom: 10px; }
.ar-love__note-title { font-size: 13px; font-weight: 700; color: var(--ink); margin-bottom: 6px; letter-spacing: -0.01em; }
.ar-love__note-val   { font-size: 12px; color: var(--ink-3); font-weight: 300; line-height: 1.5; }

/* ============================================================
   BOTTOM BORDER
   ============================================================ */
.ar-love__border-bot {
  position: relative; z-index: 10;
  width: 100%; line-height: 0;
}
.ar-love__border-bot img {
  width: 100%; height: auto; object-fit: contain; display: block;
}

/* ============================================================
   ENTRANCE ANIMATIONS
   ============================================================ */
@keyframes ar-love-up {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.ar-love__header { opacity: 0; animation: ar-love-up 0.7s ease 0.1s forwards; }
.ar-love__grid   { opacity: 0; animation: ar-love-up 0.7s ease 0.25s forwards; }
.ar-love__story  { opacity: 0; animation: ar-love-up 0.7s ease 0.35s forwards; }
.ar-love__notes  { opacity: 0; animation: ar-love-up 0.7s ease 0.45s forwards; }

@media (prefers-reduced-motion: reduce) {
  .ar-love *, .ar-love *::before, .ar-love *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
  .ar-love__petal { display: none !important; }
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 768px) {
  .ar-love__content { padding: 60px 24px 72px; }
}
@media (max-width: 480px) {
  .ar-love__content { padding: 48px 16px 60px; }
}
</style>

<div class="ar-love" role="region" aria-label="Love Attar Collection">

  {%- comment -%} ── TOP BORDER ── {%- endcomment -%}
  <div class="ar-love__border-top">
    {% if section.settings.border_top != blank %}
      <img
        src="{{ section.settings.border_top | image_url: width: 1920 }}"
        alt=""
        loading="eager"
        decoding="async"
        aria-hidden="true"
      >
    {% else %}
      <img
        src="{{ 'love/border1.webp' | asset_url }}"
        alt=""
        loading="eager"
        decoding="async"
        aria-hidden="true"
      >
    {% endif %}
  </div>

  {%- comment -%} ── MAIN SHELL ── {%- endcomment -%}
  <div class="ar-love__shell">

    {%- comment -%} ── PETALS LAYER ── {%- endcomment -%}
    <div class="ar-love__petals js-ar-petals" aria-hidden="true"></div>

    {%- comment -%} ── INNER CONTENT ── {%- endcomment -%}
    <div class="ar-love__content">

      {%- comment -%} HEADER {%- endcomment -%}
      <header class="ar-love__header">
        <span class="ar-love__eyebrow">{{ section.settings.eyebrow | default: 'Pure Love Collection' }}</span>
        <h2 class="ar-love__title">{{ section.settings.title | default: 'Attars <em>for the Heart</em>' }}</h2>
        <p class="ar-love__sub">{{ section.settings.subtitle | default: 'Rare botanical attars crafted for love — to attract it, honour it, deepen it. Each drop carries the essence of flowers that have spoken love since antiquity.' }}</p>
        <div class="ar-love__rule" aria-hidden="true">
          <span class="ar-love__rule-line"></span>
          <span class="ar-love__rule-rose">🌹</span>
          <span class="ar-love__rule-line"></span>
        </div>
      </header>

      {%- comment -%} STORY BLOCK {%- endcomment -%}
      {%- if section.settings.story_title != blank -%}
        <div class="ar-love__story">
          <div class="ar-love__story-img-wrap">
            {%- if section.settings.story_image != blank -%}
              <img
                src="{{ section.settings.story_image | image_url: width: 900 }}"
                alt="{{ section.settings.story_title | escape }}"
                width="900" height="675"
                loading="lazy" decoding="async"
              >
            {%- endif -%}
          </div>
          <div>
            <span class="ar-love__story-label">{{ section.settings.story_label | default: 'The Story of Love Attar' }}</span>
            <h3 class="ar-love__story-h">{{ section.settings.story_title }}</h3>
            <p class="ar-love__story-p">{{ section.settings.story_text | default: 'Long before perfume was bottled and branded, love had its own fragrance — distilled in rose fields at dawn, carried in clay vials across empires. Our Love Attar is that fragrance, returned to you.' }}</p>
            {%- if section.settings.story_url != blank -%}
              <a href="{{ section.settings.story_url }}" class="ar-love__story-btn">
                {{ section.settings.story_btn | default: 'Read the Story' }}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} FEATURE NOTES {%- endcomment -%}
      <div class="ar-love__notes" role="list">
        <div class="ar-love__note" role="listitem">
          <div class="ar-love__note-icon">🌹</div>
          <p class="ar-love__note-title">Pure Rose Absolute</p>
          <p class="ar-love__note-val">Extracted from 10,000 roses per bottle — the most expensive botanical in perfumery</p>
        </div>
        <div class="ar-love__note" role="listitem">
          <div class="ar-love__note-icon">🕯️</div>
          <p class="ar-love__note-title">Zero Synthetics</p>
          <p class="ar-love__note-val">No alcohol, no artificial fixatives — only pure botanical essences in aged sandalwood base</p>
        </div>
        <div class="ar-love__note" role="listitem">
          <div class="ar-love__note-icon">⏱️</div>
          <p class="ar-love__note-title">All-Day Longevity</p>
          <p class="ar-love__note-val">A single drop lasts 8–12 hours, deepening and evolving on warm skin throughout the day</p>
        </div>
        <div class="ar-love__note" role="listitem">
          <div class="ar-love__note-icon">🫙</div>
          <p class="ar-love__note-title">Hand-Distilled</p>
          <p class="ar-love__note-val">Small-batch hydrodistillation in Kannauj — the same method used for over 500 years</p>
        </div>
      </div>

    </div>
  </div>

  {%- comment -%} ── BOTTOM BORDER ── {%- endcomment -%}
  <div class="ar-love__border-bot">
    {% if section.settings.border_bottom != blank %}
      <img
        src="{{ section.settings.border_bottom | image_url: width: 1920 }}"
        alt=""
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      >
    {% else %}
      <img
        src="{{ 'love/border.webp' | asset_url }}"
        alt=""
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      >
    {% endif %}
  </div>

</div>

<script>
(function () {
  'use strict';

  /* ============================================================
     FLOATING PETALS — pure Vanilla JS, mirrors framer-motion logic
     ============================================================ */
  var PETAL_SRCS = [
    {{ 'love/1.webp' | asset_url | json }},
    {{ 'love/2.webp' | asset_url | json }},
    {{ 'love/3.webp' | asset_url | json }},
    {{ 'love/4.webp' | asset_url | json }},
    {{ 'love/5.webp' | asset_url | json }},
    {{ 'love/6.webp' | asset_url | json }}
  ];

  var PETAL_COUNT = 28;

  function rand(min, max) { return min + Math.random() * (max - min); }
  function randInt(min, max) { return Math.round(rand(min, max)); }

  function buildPetals() {
    var container = document.querySelector('.js-ar-petals');
    if (!container) return;

    var frag = document.createDocumentFragment();

    for (var i = 0; i < PETAL_COUNT; i++) {
      var src      = PETAL_SRCS[i % PETAL_SRCS.length];
      var size     = randInt(80, 160);   // px — big petals
      var left     = Math.min(96, Math.max(4, rand(2, 98)));
      var delay    = rand(0, 8);         // s
      var duration = rand(16, 36);       // s
      var sway     = rand(12, 70);       // px horizontal sway amplitude
      var rotate   = randInt(0, 360);    // initial rotation deg

      /* Create petal wrapper */
      var el = document.createElement('div');
      el.className = 'ar-love__petal';
      el.style.cssText = [
        'position:absolute',
        'top:-18%',
        'left:' + left + '%',
        'width:' + size + 'px',
        'height:' + size + 'px',
        'pointer-events:none',
        'will-change:transform',
        'transform-origin:center center',
        'opacity:0'
      ].join(';');

      /* Create unique keyframe name */
      var kfName = 'ar-petal-' + i;
      injectKeyframe(kfName, rotate, sway);

      el.style.animation = [
        kfName + ' ' + duration + 's ' + delay + 's infinite linear'
      ].join('');

      /* Image */
      var img = document.createElement('img');
      img.src = src;
      img.alt = '';
      img.width = size;
      img.height = size;
      img.style.cssText = 'width:100%;height:100%;object-fit:contain;pointer-events:none;user-select:none;';
      img.setAttribute('draggable', 'false');
      img.loading = 'lazy';

      el.appendChild(img);
      frag.appendChild(el);
    }

    container.appendChild(frag);
  }

  /* Inject a unique @keyframes per petal into the page <style> */
  var kfSheet;
  function getSheet() {
    if (kfSheet) return kfSheet;
    var style = document.createElement('style');
    document.head.appendChild(style);
    kfSheet = style.sheet;
    return kfSheet;
  }

  function injectKeyframe(name, rotate, sway) {
    var sheet = getSheet();
    var rule = [
      '@keyframes ' + name + ' {',
        '0%   { opacity:0;    transform: translateY(-18%) translateX(0px)           rotate(' + (rotate - 40) + 'deg); }',
        '4%   { opacity:0.88; }',
        '25%  { transform: translateY(25%)  translateX(' + sway + 'px)              rotate(' + (rotate + 60) + 'deg); opacity:0.82; }',
        '50%  { transform: translateY(55%)  translateX(' + (-sway * 0.6) + 'px)     rotate(' + (rotate + 150) + 'deg); opacity:0.76; }',
        '75%  { transform: translateY(82%)  translateX(' + (sway * 0.8) + 'px)      rotate(' + (rotate + 260) + 'deg); opacity:0.68; }',
        '96%  { opacity:0.5; }',
        '100% { opacity:0;    transform: translateY(118%) translateX(0px)            rotate(' + (rotate + 360) + 'deg); }',
      '}'
    ].join('\n');

    try { sheet.insertRule(rule, sheet.cssRules.length); } catch (e) { /* ignore */ }
  }

  /* ── Add to Cart ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.js-love-atc');
    if (!btn) return;
    e.preventDefault();

    var id   = parseInt(btn.dataset.id, 10);
    var span = btn.querySelector('span');
    var orig = span ? span.textContent : 'Add to Cart';
    if (!id) return;

    btn.disabled = true;
    if (span) span.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: id, quantity: 1 })
    })
    .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
    .then(function () {
      btn.classList.add('is-added');
      if (span) span.textContent = '✓ Added';
      document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
      setTimeout(function () {
        btn.disabled = false;
        btn.classList.remove('is-added');
        if (span) span.textContent = orig;
      }, 2400);
    })
    .catch(function () {
      btn.disabled = false;
      if (span) span.textContent = orig;
    });
  });

  /* Init petals after DOM ready */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', buildPetals);
  } else {
    buildPetals();
  }

  /* Re-init on Shopify section reload (theme editor) */
  document.addEventListener('shopify:section:load', function () {
    var c = document.querySelector('.js-ar-petals');
    if (c) { c.innerHTML = ''; buildPetals(); }
  });

})();
</script>
