{%- comment -%}
  Ingredient cards for a note tier (Top / Heart / Base).
  Usage: {% render 'fragrance-note-cards', notes_text: fn_top, tier: 'top' %}
{%- endcomment -%}
{%- if notes_text != blank -%}
  {%- liquid
    assign fnc_raw = notes_text | replace: ' · ', ', ' | replace: ' & ', ', ' | replace: ' and ', ', ' | replace: ' / ', ', ' | replace: ';', ','
    assign fnc_list = fnc_raw | split: ','
  -%}
  <div class="ar-fn__cards" role="list">
    {%- for note in fnc_list -%}
      {%- assign fnc_label = note | strip -%}
      {%- if fnc_label != blank -%}
        {%- capture fnc_img -%}{%- render 'fragrance-note-image-lookup', note_name: fnc_label -%}{%- endcapture -%}
        {%- assign fnc_img = fnc_img | strip -%}
        <div class="ar-fn__card{% if fnc_img == blank %} ar-fn__card--text{% endif %}" role="listitem" tabindex="0" style="--ar-fn-card-i: {{ forloop.index0 }};">
          {%- if fnc_img != blank -%}
            <figure class="ar-fn__card-media">
              <span class="ar-fn__card-glow" aria-hidden="true"></span>
              <img
                class="ar-fn__card-img"
                src="{{ fnc_img | asset_url }}"
                alt="{{ fnc_label | escape }}"
                width="160"
                height="160"
                loading="lazy"
                decoding="async"
              >
            </figure>
          {%- endif -%}
          <p class="ar-fn__card-name">{{ fnc_label | escape }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}
