{%- comment -%}
  BreadcrumbList JSON-LD for key templates (no visible UI change).
{%- endcomment -%}
{%- liquid
  assign ar_root_item = request.origin | append: routes.root_url
-%}
{%- if request.page_type == 'product' and product != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ shop.name | json }},
          "item": {{ ar_root_item | json }}
        }
        {%- if product.collections.first -%}
        ,
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ product.collections.first.title | json }},
          "item": {{ request.origin | append: product.collections.first.url | json }}
        }
        {%- endif -%}
        ,
        {
          "@type": "ListItem",
          "position": {% if product.collections.first %}3{% else %}2{% endif %},
          "name": {{ product.title | json }},
          "item": {{ request.origin | append: product.url | json }}
        }
      ]
    }
  </script>
{%- elsif request.page_type == 'collection' and collection != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ shop.name | json }},
          "item": {{ ar_root_item | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ request.origin | append: collection.url | json }}
        }
      ]
    }
  </script>
{%- elsif request.page_type == 'blog' and blog != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ shop.name | json }},
          "item": {{ ar_root_item | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | json }},
          "item": {{ request.origin | append: blog.url | json }}
        }
      ]
    }
  </script>
{%- elsif request.page_type == 'article' and article != blank and blog != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ shop.name | json }},
          "item": {{ ar_root_item | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | json }},
          "item": {{ request.origin | append: blog.url | json }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ article.title | json }},
          "item": {{ request.origin | append: article.url | json }}
        }
      ]
    }
  </script>
{%- endif -%}
