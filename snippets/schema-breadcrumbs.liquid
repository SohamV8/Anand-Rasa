{%- comment -%}
  BreadcrumbList JSON-LD for key templates (no visible UI change).
{%- endcomment -%}
{%- liquid
  assign ar_root_item = request.origin | append: routes.root_url
-%}
{%- if request.page_type == 'product' and product != blank -%}
  {%- liquid
    assign ar_product_collection = collection
    if ar_product_collection == blank
      assign ar_product_collection = product.collections.first
    endif
  -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Homepage",
          "item": {{ ar_root_item | json }}
        }
        {%- if ar_product_collection -%}
        ,
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ ar_product_collection.title | json }},
          "item": {{ request.origin | append: ar_product_collection.url | json }}
        }
        {%- endif -%}
        ,
        {
          "@type": "ListItem",
          "position": {% if ar_product_collection %}3{% else %}2{% endif %},
          "name": {{ product.title | json }},
          "item": {{ request.origin | append: product.url | json }}
        }
      ]
    }
  </script>
{%- elsif request.page_type == 'collection' and collection != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Homepage",
          "item": {{ ar_root_item | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ request.origin | append: collection.url | json }}
        }
      ]
    }
  </script>
{%- elsif request.page_type == 'blog' and blog != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Homepage",
          "item": {{ ar_root_item | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | json }},
          "item": {{ request.origin | append: blog.url | json }}
        }
      ]
    }
  </script>
{%- elsif request.page_type == 'page' and page != blank and page.handle == 'faq' and template.suffix == 'faq' -%}
  {%- capture ar_faq_breadcrumb_url -%}{% render 'ar-faq-url', absolute: true %}{%- endcapture -%}
  {%- assign ar_faq_breadcrumb_url = ar_faq_breadcrumb_url | strip -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Homepage",
          "item": {{ ar_root_item | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ page.title | default: 'Frequently Asked Questions' | json }},
          "item": {{ ar_faq_breadcrumb_url | json }}
        }
      ]
    }
  </script>
{%- elsif request.page_type == 'article' and article != blank and blog != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Homepage",
          "item": {{ ar_root_item | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | json }},
          "item": {{ request.origin | append: blog.url | json }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ article.title | json }},
          "item": {{ request.origin | append: article.url | json }}
        }
      ]
    }
  </script>
{%- endif -%}
