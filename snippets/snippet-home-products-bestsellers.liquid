{%- comment -%} 3. BESTSELLERS {%- endcomment -%}
<section class="ar-best">
  <header class="ar-best__hdr">
    <h2 class="ar-best__h">{{ section.settings.bs_heading | default: 'Bestsellers' }}</h2>
    <p class="ar-best__sub">{{ section.settings.bs_sub | default: 'Our most loved attars.' }}</p>
  </header>
  <div class="ar-best__wrap">
    <div class="ar-best__fade ar-best__fade-l"></div>
    <div class="ar-best__fade ar-best__fade-r"></div>
    <button class="ar-best__arrow ar-best__arrow-l js-best-l" aria-label="Previous">&#8249;</button>
    <button class="ar-best__arrow ar-best__arrow-r js-best-r" aria-label="Next">&#8250;</button>
    <div class="ar-best__track js-best-track">
      {%- assign bs = collections[section.settings.bs_collection] -%}
      {%- if bs != blank -%}
        {%- for p in bs.products -%}
          {%- capture bestseller_showcard -%}{%- render 'bestseller-image-lookup', bs_product: p -%}{%- endcapture -%}
          {%- assign bestseller_showcard = bestseller_showcard | strip -%}
          <article class="ar-best__card">
            <a href="{{ p.url }}" class="ar-best__link">
              <div class="ar-best__imgw">
                {%- if p.tags contains 'bestseller' or p.tags contains 'Bestseller' -%}<span class="ar-best__badge">BESTSELLER</span>
                {%- elsif p.tags contains 'new' or p.tags contains 'New' -%}<span class="ar-best__badge">NEW</span>
                {%- elsif p.tags contains 'limited' -%}<span class="ar-best__badge">LIMITED</span>
                {%- elsif p.compare_at_price > p.price -%}<span class="ar-best__badge">SALE</span>{%- endif -%}
                {%- if bestseller_showcard != blank -%}
                  <img src="{{ bestseller_showcard | asset_url }}" alt="{{ p.title | escape }}" width="600" height="800" loading="lazy" class="ar-best__img">
                {%- elsif p.featured_image -%}
                  <!-- SEO Fix: Homepage featured product image optimized with WebP and explicit dimensions -->
                  <picture>
                    <source
                      srcset="{{ p.featured_image | image_url: width: 400, format: 'webp' }} 400w, {{ p.featured_image | image_url: width: 800, format: 'webp' }} 800w"
                      sizes="(min-width: 1024px) 20vw, 45vw"
                      type="image/webp"
                    >
                    <img
                      src="{{ p.featured_image | image_url: width: 800 }}"
                      srcset="{{ p.featured_image | image_url: width: 400 }} 400w, {{ p.featured_image | image_url: width: 800 }} 800w"
                      sizes="(min-width: 1024px) 20vw, 45vw"
                      alt="{{ p.featured_image.alt | default: p.title | append: ' - handcrafted attar - Anandrasa' | escape }}"
                      width="800"
                      height="{{ 800 | divided_by: p.featured_image.aspect_ratio | round }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      {% if forloop.first %}fetchpriority="high"{% endif %}
                      decoding="async"
                      class="ar-best__img"
                    >
                  </picture>
                {%- endif -%}
              </div>
              <h3 class="ar-best__name">{{ p.title }}</h3>
              <p class="ar-best__type">{{ p.type | default: 'Attar' }}</p>
              <div class="ar-best__price-row">
                {%- if p.compare_at_price > p.price -%}<span class="ar-best__price-old">{{ p.compare_at_price | money }}</span>{%- endif -%}
                <span class="ar-best__price">{{ p.price | money }}</span>
              </div>
            </a>
          </article>
        {%- endfor -%}
      {%- else -%}
        <p style="padding:24px;color:#9ca3af;font-family:var(--fb);">Select a collection in Theme Editor &rarr; Bestsellers.</p>
      {%- endif -%}
    </div>
  </div>
</section>
