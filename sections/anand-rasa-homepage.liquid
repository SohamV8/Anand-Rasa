<div class="ar-hp">
  {% render 'snippet-home-hero', section: section %}
  {% render 'snippet-home-collections', section: section %}
  {% render 'snippet-home-products', section: section %}
  {%- liquid
    assign heading = section.settings.bp_heading
    assign idx = 0
    for ar_bp_block in section.blocks
      if ar_bp_block.type == 'philosophy_card'
        if idx == 0
          assign card_title_1 = ar_bp_block.settings.title
          assign card_text_1 = ar_bp_block.settings.text
        elsif idx == 1
          assign card_title_2 = ar_bp_block.settings.title
          assign card_text_2 = ar_bp_block.settings.text
        elsif idx == 2
          assign card_title_3 = ar_bp_block.settings.title
          assign card_text_3 = ar_bp_block.settings.text
        elsif idx == 3
          assign card_title_4 = ar_bp_block.settings.title
          assign card_text_4 = ar_bp_block.settings.text
        endif
        assign idx = idx | plus: 1
      endif
    endfor
    assign combo_image = ''
    assign combo_image_srcset = ''
    assign combo_image_width = 1400
    assign combo_image_height = 1050
    if section.settings.combo_image != blank
      assign combo_image = section.settings.combo_image | image_url: width: 1400
      assign combo_image_width = section.settings.combo_image.width | default: 1400
      assign combo_image_height = section.settings.combo_image.height | default: 1050
      assign combo_src_700 = section.settings.combo_image | image_url: width: 700
      assign combo_src_1050 = section.settings.combo_image | image_url: width: 1050
      assign combo_src_1400 = section.settings.combo_image | image_url: width: 1400
      assign combo_image_srcset = combo_src_700 | append: ' 700w, ' | append: combo_src_1050 | append: ' 1050w, ' | append: combo_src_1400 | append: ' 1400w'
    elsif section.settings.combo_image_url != blank
      assign combo_image = section.settings.combo_image_url
    else
      assign combo_image = 'wooden_attar_box.webp' | asset_url
    endif
    capture ar_gift_sets_url
      render 'ar-collection-url', handle: 'gift-sets'
    endcapture
    assign ar_gift_sets_url = ar_gift_sets_url | strip
    if ar_gift_sets_url == blank or ar_gift_sets_url == routes.collections_url
      assign ar_gift_sets_url = '/collections/gift-set?view=gift-sets'
    endif
    assign combo_eyebrow = section.settings.combo_eyebrow
    assign combo_heading = section.settings.combo_heading
    assign combo_text = section.settings.combo_text
    assign combo_note = section.settings.combo_note
    assign combo_url = section.settings.combo_url
    assign combo_btn = section.settings.combo_btn
    assign story_heading = section.settings.pure_heading
    assign story_text = section.settings.pure_text
    assign story_url = section.settings.pure_url
    assign story_btn = section.settings.pure_btn
  -%}
