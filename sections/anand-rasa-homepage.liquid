  .ar-best__img { position:absolute; inset:0; width:100%; height:100%; object-fit:contain; transition:transform .5s; }
  .ar-best__link:hover .ar-best__img { transform:scale(1.05); }
  .ar-best__badge { position:absolute; top:8px; left:0; font-size:10px; font-weight:700; letter-spacing:.06em; padding:4px 10px; border-radius:3px; background:#1e2023; color:#fff; z-index:5; }
  .ar-best__name  { margin-top:20px; font-family:var(--fh); font-size:clamp(14px,1.5vw,18px); letter-spacing:.04em; color:#1e2023; }
  .ar-best__type  { margin-top:4px; font-size:10px; text-transform:uppercase; letter-spacing:.18em; color:#9ca3af; }
  .ar-best__price-row { margin-top:8px; display:flex; align-items:center; justify-content:center; gap:8px; }
  .ar-best__price-old { font-size:12px; color:#9ca3af; text-decoration:line-through; }
  .ar-best__price { font-size:14px; font-weight:600; color:#1e2023; }

  /* ── PHILOSOPHY ── */
  .ar-bp { background:#fff; width:100%; padding:64px 0 80px; font-family:'Poppins',sans-serif; }
  .ar-bp__in { max-width:1300px; margin:0 auto; padding:0 20px; }
  .ar-bp__h { font-size:clamp(36px,5vw,64px); font-weight:700; letter-spacing:-.025em; line-height:1.15; color:#141414; text-align:center; max-width:28ch; margin:0 auto 48px; opacity:0; transform:translateY(16px); transition:opacity .6s ease,transform .6s ease; }
  .ar-bp__h.ar-vis { opacity:1; transform:translateY(0); }
  .ar-bp__grid { display:grid; grid-template-columns:1fr; gap:24px; }
  @media(min-width:640px){ .ar-bp__grid { grid-template-columns:1fr 1fr; } }
  @media(min-width:1024px){ .ar-bp__grid { grid-template-columns:repeat(4,1fr); } }
  .ar-bp__root { position:relative; opacity:0; transform:translateY(28px); transition:opacity .65s ease,transform .65s ease; }
  .ar-bp__root.ar-vis { opacity:1; transform:translateY(0); }
  .ar-bp__shadow { position:absolute; inset:0; border-radius:22px; background:#e8a0bd; transform:translate(7px,8px); transition:transform .38s ease; pointer-events:none; z-index:0; }
  .ar-bp__root:hover .ar-bp__shadow { transform:translate(10px,11px); }
  .ar-bp__card { position:relative; z-index:1; display:flex; flex-direction:column; gap:16px; background:#fff; border:1.5px solid #252525; border-radius:22px; padding:22px 22px 26px; transition:transform .38s ease; }
  .ar-bp__root:hover .ar-bp__card { transform:translateY(-4px); }
  .ar-bp__pill { display:inline-block; background:#e8a0bd; border:1.5px solid #252525; border-radius:999px; padding:7px 16px; font-size:12.5px; font-weight:600; line-height:1.4; color:#141414; text-align:center; max-width:100%; word-break:break-word; }
  .ar-bp__body { font-size:14px; font-weight:400; line-height:1.78; color:#3c3c3c; }

  /* ── FIND ── */
  .ar-find { position:relative; width:100%; height:70vh; overflow:hidden; background:#000; display:flex; align-items:center; justify-content:center; font-family:var(--fb); }
  .ar-find__bg { position:absolute; inset:0; background:radial-gradient(ellipse at 60% 50%,rgba(225,0,255,.25) 0%,transparent 70%),radial-gradient(ellipse at 30% 60%,rgba(247,247,247,.1) 0%,transparent 60%); animation:arGlow 8s ease-in-out infinite alternate; }
  .ar-find__con { position:relative; z-index:10; text-align:center; padding:0 24px; max-width:768px; }
  .ar-find__h { font-size:clamp(24px,4vw,48px); font-weight:600; line-height:1.2; color:#fff; margin-bottom:20px; }
  .ar-find__p { font-size:14px; line-height:1.75; color:rgba(255,255,255,.85); margin-bottom:32px; }
  .ar-find__btn { display:inline-block; border:1.5px solid rgba(255,255,255,.85); padding:14px 36px; font-family:var(--fb); font-size:11px; font-weight:500; letter-spacing:.2em; text-transform:uppercase; color:#ffffff !important; background:transparent; transition:background .3s,color .3s; }
  .ar-find__btn:hover { background:#ffffff; color:#000000 !important; }

  /* ── BLOG ── */
  .ar-blog { background:#fff; padding:64px 0 80px; border-top:2px solid #1e2023; font-family:var(--fb); }
  .ar-blog__hdr { max-width:768px; margin:0 auto 48px; padding:0 24px; text-align:center; }
  .ar-blog__h { font-family:var(--fh); font-size:clamp(22px,3vw,36px); letter-spacing:.04em; color:#1e2023; margin-bottom:12px; }
  .ar-blog__div { width:48px; height:2px; background:rgba(0,0,0,.6); margin:0 auto; }
  .ar-blog__track { max-width:1280px; margin:0 auto; padding:0 24px; display:grid; grid-template-columns:1fr; gap:40px; }
  @media(min-width:640px){ .ar-blog__track { grid-template-columns:repeat(2,1fr); } }
  @media(min-width:1024px){ .ar-blog__track { grid-template-columns:repeat(3,1fr); } }
  .ar-blog__link { display:block; }
  .ar-blog__imgw { position:relative; aspect-ratio:4/3; overflow:hidden; background:#f3f4f6; }
  .ar-blog__img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition:transform .7s ease; }
  .ar-blog__link:hover .ar-blog__img { transform:scale(1.03); }
  .ar-blog__ph { position:absolute; inset:0; background:#e5e7eb; }
  .ar-blog__date { margin-top:16px; font-size:11px; text-transform:uppercase; letter-spacing:.16em; color:#6b7280; }
  .ar-blog__title { margin-top:8px; font-family:var(--fh); font-size:18px; color:#1e2023; transition:opacity .2s; }
  .ar-blog__link:hover .ar-blog__title { opacity:.8; }
  .ar-blog__exc { margin-top:8px; font-size:13px; line-height:1.6; color:#4b5563; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .ar-blog__cta { display:inline-block; margin-top:16px; font-size:11px; letter-spacing:.12em; border-bottom:1px solid #1e2023; padding-bottom:2px; color:#1e2023; }

  /* ── INCENSE BANNER ── */
  .ar-incense { display:block; width:100%; overflow:hidden; cursor:pointer; line-height:0; position:relative; }
  .ar-incense img { width:100%; height:auto; display:block; transition:transform .6s ease; object-fit:cover; }
  .ar-incense:hover img { transform:scale(1.02); }
  .ar-incense-ph { width:100%; padding:60px 24px; background:#fce4ec; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; font-family:var(--fb); text-align:center; }

  /* ── INCENSE PRODUCTS ── */
  .ar-inc { background:#f5f0e8; padding:60px 0 72px; font-family:var(--fb); }
  .ar-inc__inner { max-width:1400px; margin:0 auto; padding:0 48px; }
  @media(max-width:768px){ .ar-inc__inner { padding:0 20px; } }
  .ar-inc__h { font-family:'Poppins',sans-serif; font-size:clamp(24px,3vw,40px); font-weight:700; color:#1e2023; text-align:center; margin-bottom:40px; letter-spacing:-.02em; }
  .ar-inc__wrap { position:relative; }
  .ar-inc__arrow { position:absolute; top:40%; z-index:20; transform:translateY(-50%); width:36px; height:36px; border-radius:50%; border:1px solid rgba(30,32,35,.2); background:rgba(255,255,255,.9); cursor:pointer; font-size:18px; display:flex; align-items:center; justify-content:center; transition:background .3s,color .3s; }
  .ar-inc__arrow:hover { background:#1e2023; color:#fff; }
  .ar-inc__arrow-l { left:8px; } .ar-inc__arrow-r { right:8px; }
  .ar-inc__track { display:flex; gap:32px; overflow-x:auto; padding:0 24px; scroll-snap-type:x mandatory; scrollbar-width:none; }
  .ar-inc__track::-webkit-scrollbar { display:none; }
  .ar-inc__card { min-width:200px; max-width:240px; flex-shrink:0; scroll-snap-align:start; text-align:center; position:relative; }
  .ar-inc__link { display:block; text-decoration:none; }
  .ar-inc__imgw { position:relative; aspect-ratio:3/4; width:160px; margin:0 auto; overflow:hidden; }
  @media(min-width:640px){ .ar-inc__imgw { width:180px; } }
  .ar-inc__img { position:absolute; inset:0; width:100%; height:100%; object-fit:contain; transition:transform .5s; }
  .ar-inc__link:hover .ar-inc__img { transform:scale(1.05); }
  .ar-inc__badge { position:absolute; top:8px; left:0; font-size:10px; font-weight:700; letter-spacing:.06em; padding:4px 10px; border-radius:3px; background:#1e2023; color:#fff; z-index:5; }
  .ar-inc__name  { margin-top:16px; font-family:var(--fh); font-size:clamp(14px,1.5vw,18px); letter-spacing:.04em; color:#1e2023; }
  .ar-inc__type  { margin-top:4px; font-size:10px; text-transform:uppercase; letter-spacing:.18em; color:#9ca3af; }
  .ar-inc__price-row { margin-top:8px; display:flex; align-items:center; justify-content:center; gap:8px; }
  .ar-inc__price-old { font-size:12px; color:#9ca3af; text-decoration:line-through; }
  .ar-inc__price { font-size:14px; font-weight:600; color:#1e2023; }

  /* ── VIDEO TESTIMONIALS ── */
  .ar-vtm { background:#fff; padding:80px 0; font-family:var(--fb); border-top:1px solid rgba(30,32,35,.08); }
  .ar-vtm__inner { max-width:1280px; margin:0 auto; padding:0 32px; }
  .ar-vtm__header { text-align:center; margin-bottom:52px; }
  .ar-vtm__h { font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(28px,3.5vw,48px); font-weight:400; color:#1e2023; margin-bottom:14px; letter-spacing:-.01em; }
  .ar-vtm__divider { width:40px; height:2px; background:#1e2023; margin:0 auto 14px; }
  .ar-vtm__sub { font-size:14px; color:#6b7280; font-weight:300; }
  .ar-vtm__grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; }
  @media(max-width:900px){ .ar-vtm__grid { grid-template-columns:repeat(2,1fr); } }
  @media(max-width:580px){ .ar-vtm__grid { grid-template-columns:1fr; } }
  .ar-vtm__card { background:#faf9f7; border:1px solid rgba(30,32,35,.08); border-radius:12px; overflow:hidden; transition:transform .3s ease,box-shadow .3s ease; }
  .ar-vtm__card:hover { transform:translateY(-4px); box-shadow:0 20px 48px rgba(0,0,0,.09); }
  .ar-vtm__video-wrap { position:relative; aspect-ratio:9/16; max-height:380px; overflow:hidden; background:#0a0a0a; cursor:pointer; }
  .ar-vtm__video { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; }
  .ar-vtm__ph { display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,.4); font-size:13px; }
  .ar-vtm__play { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,.28); transition:background .3s; }
  .ar-vtm__video-wrap:hover .ar-vtm__play { background:rgba(0,0,0,.45); }
  .ar-vtm__info { padding:20px 20px 24px; }
  .ar-vtm__stars { display:flex; gap:3px; margin-bottom:10px; }
  .ar-vtm__star { font-size:14px; color:#d1d5db; }
  .ar-vtm__star.on { color:#f59e0b; }
  .ar-vtm__quote { font-family:'Cormorant Garamond',Georgia,serif; font-size:16px; line-height:1.65; color:#374151; margin-bottom:14px; font-style:italic; }
  .ar-vtm__name { font-size:13px; font-weight:600; color:#1e2023; letter-spacing:.02em; margin:0; }
  .ar-vtm__loc { font-size:12px; color:#9ca3af; margin:3px 0 0; }
</style>

<div class="ar-hp">

  {%- comment -%} 1. HERO {%- endcomment -%}
  <section class="ar-hero">
    <div class="ar-hero__in">
      <div class="ar-hero__left">
        <p class="ar-hero__ey">{{ section.settings.hero_eyebrow | default: 'ANAND RAS' }}</p>
        <h1 class="ar-hero__h1">{{ section.settings.hero_headline | default: 'Perfume for your soul' }}</h1>
        <p class="ar-hero__p">{{ section.settings.hero_body | default: 'Modern luxury attars crafted through timeless distillation. Pure oils, calm presence, and minimal elegance designed for everyday ritual.' }}</p>
        <div class="ar-hero__cta">
          <a href="{{ section.settings.hero_btn1_url | default: '/collections/all' }}" class="ar-hero__btn1">{{ section.settings.hero_btn1_label | default: 'Shop Now' }}</a>
          <a href="{{ section.settings.hero_btn2_url | default: '/collections' }}" class="ar-hero__btn2">{{ section.settings.hero_btn2_label | default: 'Explore Collections' }}</a>
        </div>
      </div>
      <div class="ar-hero__right">
        {%- if section.settings.hero_image != blank -%}
          <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ section.settings.hero_image.alt | default: 'Anand Rasa' }}" width="{{ section.settings.hero_image.width }}" height="{{ section.settings.hero_image.height }}" loading="eager" class="ar-hero__img">
        {%- else -%}
          <div class="ar-hero__ph">Upload hero image in Theme Editor</div>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} 2. CATEGORY GRID {%- endcomment -%}
  <section class="ar-cat">
    <div class="ar-cat__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <a href="{{ block.settings.link }}" class="ar-cat__item" {{ block.shopify_attributes }}>
            <div class="ar-cat__wrap">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" width="800" height="533" loading="lazy" class="ar-cat__img">
              {%- else -%}
                <div class="ar-cat__ph">Upload image</div>
              {%- endif -%}
              <div class="ar-cat__ov"></div>
              <div class="ar-cat__txt">
                <h3 class="ar-cat__title">{{ block.settings.title }}</h3>
                <span class="ar-cat__cta">Explore</span>
              </div>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>

  {%- comment -%} 3. BESTSELLERS {%- endcomment -%}
  <section class="ar-best">
    <header class="ar-best__hdr">
      <h2 class="ar-best__h">{{ section.settings.bs_heading | default: 'Bestsellers' }}</h2>
      <p class="ar-best__sub">{{ section.settings.bs_sub | default: 'Our most loved attars.' }}</p>
    </header>
    <div class="ar-best__wrap">
      <div class="ar-best__fade ar-best__fade-l"></div>
      <div class="ar-best__fade ar-best__fade-r"></div>
      <button class="ar-best__arrow ar-best__arrow-l js-best-l" aria-label="Previous">&#8249;</button>
      <button class="ar-best__arrow ar-best__arrow-r js-best-r" aria-label="Next">&#8250;</button>
      <div class="ar-best__track js-best-track">
        {%- assign bs = collections[section.settings.bs_collection] -%}
        {%- if bs != blank -%}
          {%- for p in bs.products limit: section.settings.bs_limit -%}
            <article class="ar-best__card">
              <a href="{{ p.url }}" class="ar-best__link">
                <div class="ar-best__imgw">
                  {%- if p.tags contains 'bestseller' or p.tags contains 'Bestseller' -%}<span class="ar-best__badge">BESTSELLER</span>
                  {%- elsif p.tags contains 'new' or p.tags contains 'New' -%}<span class="ar-best__badge">NEW</span>
                  {%- elsif p.tags contains 'limited' -%}<span class="ar-best__badge">LIMITED</span>
                  {%- elsif p.compare_at_price > p.price -%}<span class="ar-best__badge">SALE</span>{%- endif -%}
                  {%- if p.featured_image -%}
                    <img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.featured_image.alt | default: p.title }}" width="400" height="533" loading="lazy" class="ar-best__img">
                  {%- endif -%}
                </div>
                <h3 class="ar-best__name">{{ p.title }}</h3>
                <p class="ar-best__type">{{ p.type | default: 'Attar' }}</p>
                <div class="ar-best__price-row">
                  {%- if p.compare_at_price > p.price -%}<span class="ar-best__price-old">{{ p.compare_at_price | money }}</span>{%- endif -%}
                  <span class="ar-best__price">{{ p.price | money }}</span>
                </div>
              </a>
            </article>
          {%- endfor -%}
        {%- else -%}
          <p style="padding:24px;color:#9ca3af;font-family:var(--fb);">Select a collection in Theme Editor &rarr; Bestsellers.</p>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} 4. SHOP TRIO {%- endcomment -%}
  <section class="ar-trio">
    <div class="ar-trio__grid">
      <div class="ar-trio__left">
        <a href="{{ section.settings.t1_url | default: '/collections/incense' }}" class="ar-trio__card">
          {%- if section.settings.t1_image != blank -%}<img src="{{ section.settings.t1_image | image_url: width: 1200 }}" alt="{{ section.settings.t1_image.alt | default: 'Incense Sticks' }}" width="1200" height="800" loading="lazy" class="ar-trio__img">{%- else -%}<div class="ar-trio__ph">Upload image</div>{%- endif -%}
          <div class="ar-trio__ov"></div>
          <div class="ar-trio__cta-wrap"><span class="ar-trio__cta">{{ section.settings.t1_label | default: 'Shop Now' }}</span></div>
        </a>
      </div>
      <div class="ar-trio__right">
        <a href="{{ section.settings.t2_url | default: '/collections/stress' }}" class="ar-trio__card">
          {%- if section.settings.t2_image != blank -%}<img src="{{ section.settings.t2_image | image_url: width: 800 }}" alt="{{ section.settings.t2_image.alt | default: 'Stress Relief' }}" width="800" height="600" loading="lazy" class="ar-trio__img">{%- else -%}<div class="ar-trio__ph">Upload image</div>{%- endif -%}
          <div class="ar-trio__ov"></div>
          <div class="ar-trio__cta-wrap"><span class="ar-trio__cta">{{ section.settings.t2_label | default: 'Shop Now' }}</span></div>
        </a>
        <a href="{{ section.settings.t3_url | default: '/collections/love-attar' }}" class="ar-trio__card">
          {%- if section.settings.t3_image != blank -%}<img src="{{ section.settings.t3_image | image_url: width: 800 }}" alt="{{ section.settings.t3_image.alt | default: 'Love Attars' }}" width="800" height="600" loading="lazy" class="ar-trio__img">{%- else -%}<div class="ar-trio__ph">Upload image</div>{%- endif -%}
          <div class="ar-trio__ov"></div>
          <div class="ar-trio__cta-wrap"><span class="ar-trio__cta">{{ section.settings.t3_label | default: 'Shop Now' }}</span></div>
        </a>
      </div>
    </div>
  </section>

  {%- comment -%} 5. DISCOVER THE FRAGRANCE {%- endcomment -%}
  <section class="ar-find">
    <div class="ar-find__bg"></div>
    <div class="ar-find__con">
      <h2 class="ar-find__h">{{ section.settings.find_heading | default: 'Discover the fragrance written in your stars.' }}</h2>
      <p class="ar-find__p">{{ section.settings.find_text | default: 'Our astrology fragrance finder reveals the attar aligned with your zodiac, planet, and Nakshatra energy.' }}</p>
      <a href="{{ section.settings.find_url | default: '/pages/find-fragrance' }}" class="ar-find__btn">{{ section.settings.find_btn | default: 'Find Your Fragrance' }}</a>
    </div>
  </section>

  {%- comment -%} 6. NAVAGRAHA ATTARS {%- endcomment -%}
  <section class="ar-nav9">
    <div class="ar-nav9__intro">
      <div class="ar-nav9__intro-in">
        <h2 class="ar-nav9__intro-h">{{ section.settings.nav9_heading | default: 'Navagraha Attars' }}</h2>
        <p class="ar-nav9__intro-p">{{ section.settings.nav9_text | default: 'Inspired by the nine celestial forces, each fragrance is crafted to harmonize your presence with planetary energy.' }}</p>
        <a href="{{ section.settings.nav9_url | default: '/collections/planets' }}" class="ar-nav9__intro-btn">EXPLORE COLLECTION</a>
      </div>
    </div>
    <div class="ar-nav9__main">
      {%- assign ar_nav9_has_init = false -%}
      {%- assign ar_nav9_init_perfume = nil -%}
      {%- assign ar_nav9_init_desc = '' -%}
      {%- assign ar_nav9_init_url = '' -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'planet' -%}
          {%- unless ar_nav9_has_init -%}
            {%- assign ar_nav9_init_perfume = block.settings.perfume_image -%}
            {%- assign ar_nav9_init_desc = block.settings.description -%}
            {%- assign ar_nav9_init_url = block.settings.url -%}
            {%- assign ar_nav9_has_init = true -%}
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
      <div class="ar-nav9__grid">
        {%- assign ar_nav9_btn_first = true -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'planet' -%}
            <button
              type="button"
              class="ar-nav9__btn{% if ar_nav9_btn_first %} is-active{% endif %}"
              data-img="{%- if block.settings.perfume_image != blank -%}{{ block.settings.perfume_image | image_url: width: 600 }}{%- endif -%}"
              data-desc="{{ block.settings.description | default: '' | strip_newlines | escape }}"
              data-url="{% if block.settings.url != blank %}{{ block.settings.url | escape }}{% endif %}"
              aria-label="{{ block.settings.name | default: 'Planet' | escape }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.planet_image != blank -%}
                <img src="{{ block.settings.planet_image | image_url: width: 400 }}" alt="{{ block.settings.name | escape }}" width="400" height="400" loading="lazy" class="ar-nav9__bimg">
              {%- endif -%}
            </button>
            {%- assign ar_nav9_btn_first = false -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="ar-nav9__panel">
        <img
          class="ar-nav9__pimg js-ar-nav9-pimg"
          id="ar-pimg-{{ section.id }}"
          width="280"
          height="420"
          alt="{% if ar_nav9_init_perfume != blank %}{{ section.settings.nav9_heading | default: 'Navagraha' | escape }} — selected attar{% else %}Selected planet attar{% endif %}"
          {% if ar_nav9_init_perfume != blank -%}
            src="{{ ar_nav9_init_perfume | image_url: width: 600 }}"
          {%- endif %}
        >
