<script>
(function(){
  'use strict';

  var tg = document.querySelector('.js-ar-trust');
  if(tg) new IntersectionObserver(function(e){ if(e[0].isIntersecting) tg.classList.add('ar-vis'); },{threshold:.15}).observe(tg);

  function carousel(track, left, right){
    if(!track) return;
    function sc(d){ track.scrollBy({left:d*(track.clientWidth*(window.innerWidth<640?.7:.8)),behavior:'smooth'}); }
    if(left)  left.addEventListener('click',  function(){ sc(-1); });
    if(right) right.addEventListener('click', function(){ sc(1); });
  }

  carousel(document.querySelector('.js-best-track'), document.querySelector('.js-best-l'), document.querySelector('.js-best-r'));
  carousel(document.querySelector('.js-zc-track'), document.querySelector('.js-zc-l'), document.querySelector('.js-zc-r'));
  carousel(document.querySelector('.js-inc-track'), document.querySelector('.js-inc-l'), document.querySelector('.js-inc-r'));

  document.querySelectorAll('.ar-nav9').forEach(function(nav9){
    var pbtns = nav9.querySelectorAll('.ar-nav9__btn');
    var pImg  = nav9.querySelector('.js-ar-nav9-pimg');
    var pDesc = nav9.querySelector('.js-ar-nav9-pdesc');
    var pLink = nav9.querySelector('.js-ar-nav9-plink');
    if (!pbtns.length) return;

    function activate(btn){
      pbtns.forEach(function(b){ b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      var img = btn.getAttribute('data-img') || '';
      var desc = btn.getAttribute('data-desc') || '';
      var url = btn.getAttribute('data-url') || '';
      if (pImg) {
        if (img) {
          pImg.src = img;
          pImg.alt = btn.getAttribute('aria-label') || 'Selected planet attar';
        } else {
          pImg.removeAttribute('src');
          pImg.alt = '';
        }
      }
      if (pDesc) pDesc.textContent = desc;
      if (pLink) {
        pLink.href = url || '#';
        if (url) pLink.removeAttribute('aria-disabled');
        else pLink.setAttribute('aria-disabled', 'true');
      }
    }

    activate(pbtns[0]);
    pbtns.forEach(function(b){
      b.addEventListener('click', function(){ activate(b); });
    });
  });

  var bp = document.querySelector('.js-ar-bp');
  if(bp) new IntersectionObserver(function(e){
    if(e[0].isIntersecting){
      var h = bp.querySelector('.js-ar-bp-h');
      if(h) h.classList.add('ar-vis');
      bp.querySelectorAll('.js-ar-bp-card').forEach(function(c){ c.classList.add('ar-vis'); });
    }
  },{threshold:.12}).observe(bp);

  document.querySelectorAll('.js-vtm-wrap').forEach(function(wrap){
    wrap.addEventListener('click', function(){
      var video = wrap.querySelector('video');
      var play  = wrap.querySelector('.js-vtm-play');
      if(!video) return;
      if(video.paused){ video.muted=false; video.play(); if(play) play.style.display='none'; }
      else { video.pause(); if(play) play.style.display='flex'; }
    });
  });

  // Testimonial dot navigation
  (function(){
    var track = document.querySelector('.js-tst-track');
    var dotsEl = document.getElementById('ar-tst-dots');
    if (!track || !dotsEl) return;
    var cards = Array.from(track.querySelectorAll('.ar-tst__card'));
    if (!cards.length) return;
    var dots = cards.map(function(_, i) {
      var d = document.createElement('button');
      d.className = 'ar-tst__dot' + (i === 0 ? ' is-active' : '');
      d.setAttribute('aria-label', 'Review ' + (i+1));
      d.addEventListener('click', function() {
        track.scrollTo({ left: cards[i].offsetLeft - 32, behavior: 'smooth' });
      });
      dotsEl.appendChild(d);
      return d;
    });
    track.addEventListener('scroll', function() {
      var mid = track.scrollLeft + track.clientWidth / 2;
      var closest = 0, minD = Infinity;
      cards.forEach(function(card, i) {
        var d = Math.abs(card.offsetLeft + card.offsetWidth / 2 - mid);
        if (d < minD) { minD = d; closest = i; }
      });
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === closest); });
    }, { passive: true });
  })();

})();
</script>

