  .ar-hero__p  { font-family:'Jost', sans-serif; font-size:15px; line-height:1.75; color:#4b5563; margin-bottom:40px; max-width:440px; font-weight:300; }
  .ar-hero__cta { display:flex; align-items:center; gap:24px; flex-wrap:wrap; }
  .ar-hero__btn1 { display:inline-flex; align-items:center; justify-content:center; padding:13px 32px; background:#ffffff; color:#1a1a18; font-family:var(--fb); font-size:13px; font-weight:600; letter-spacing:.04em; border:1.8px solid #1a1a18; border-radius:100px; transition:background .25s,color .25s; }
