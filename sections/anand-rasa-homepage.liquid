{% comment %}
  ANAND RASA - Homepage
  sections/anand-rasa-homepage.liquid
{% endcomment %}

<style>
  .ar-hp *, .ar-hp *::before, .ar-hp *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .ar-hp { --ink: #1e2023; --fh: var(--font-heading-family); --fb: var(--font-body-family); }
  .ar-hp img, .ar-hp video { max-width: 100%; display: block; }
  .ar-hp a { color: inherit; text-decoration: none; }

  @keyframes arUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
  @keyframes arIn { from { opacity:0; } to { opacity:1; } }
  @keyframes arGlow { from { transform:scale(1); } to { transform:scale(1.08) rotate(2deg); } }

  /* ── HERO ── (styles in snippets/snippet-home-hero.liquid) */

  /* ── TRUST BAR ── */
  .ar-trust { background:#fff; padding:56px 24px; font-family:var(--fb); }
  .ar-trust__grid { list-style:none; display:grid; grid-template-columns:repeat(2,1fr); gap:48px 24px; text-align:center; max-width:1280px; margin:0 auto; }
  @media(min-width:1024px){ .ar-trust__grid { grid-template-columns:repeat(4,1fr); } }
  .ar-trust__item { display:flex; flex-direction:column; align-items:center; opacity:0; transform:translateY(20px); transition:opacity .7s ease,transform .7s ease; }
  .ar-trust__grid.ar-vis .ar-trust__item { opacity:1; transform:translateY(0); }
  .ar-trust__icon { width:64px; height:64px; object-fit:contain; filter:grayscale(1); margin-bottom:16px; transition:transform .5s; }
  .ar-trust__item:hover .ar-trust__icon { transform:scale(1.05); }
  .ar-trust__ph { width:64px; height:64px; background:#f3f4f6; border-radius:50%; margin-bottom:16px; }
  .ar-trust__lbl { font-size:14px; line-height:1.5; color:#4b5563; max-width:200px; }

  /* ── FRAGRANCE DISCOVERY (minimal luxury cards) ── */
  .ar-disc {
    --ar-disc-ink: #141210;
    --ar-disc-muted: #5c554c;
    background: #fff;
    padding: clamp(48px, 6vw, 96px) clamp(20px, 4vw, 48px);
    font-family: var(--fb);
    color: var(--ar-disc-ink);
  }
  .ar-disc__hdr {
    max-width: 48rem;
    margin: 0 auto clamp(36px, 5vw, 56px);
    text-align: center;
  }
  .ar-disc__h {
    font-family: 'Poppins', var(--font-heading-family);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0;
    color: var(--ar-disc-ink);
  }
  .ar-disc__sub {
    margin: clamp(14px, 2vw, 20px) auto 0;
    font-family: 'Poppins', var(--font-heading-family);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    line-height: 1.55;
    color: var(--ar-disc-muted);
    max-width: 40rem;
  }
  .ar-disc__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0;
  }
  @media (min-width: 640px) {
    .ar-disc__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
  }
  @media (min-width: 900px) {
    .ar-disc__list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }
  }
  @media (min-width: 1200px) {
    .ar-disc__list {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 16px;
    }
  }
  .ar-disc__card {
    margin: 0;
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .js-ar-disc .ar-disc__card {
      opacity: 0;
      transform: translate3d(0, 20px, 0);
      transition:
        opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
        transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      transition-delay: var(--ar-disc-delay, 0ms);
    }
    .js-ar-disc.ar-disc--vis .ar-disc__card {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }
  .ar-disc__link {
    display: block;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    -webkit-tap-highlight-color: transparent;
    box-shadow: 0 2px 10px rgba(20, 18, 16, 0.07);
    transition: box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ar-disc__link:focus-visible {
    outline: 2px solid var(--ar-disc-ink);
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ar-disc__link:hover,
    .ar-disc__link:focus-visible {
      box-shadow:
        0 4px 16px rgba(20, 18, 16, 0.1),
        0 20px 48px rgba(20, 18, 16, 0.12);
    }
  }
  .ar-disc__media {
    position: relative;
    aspect-ratio: 4 / 3;
    min-height: 0;
    background: linear-gradient(135deg, #2a2622 0%, #141210 100%);
    isolation: isolate;
  }
  .ar-disc__img,
  .ar-disc__ph {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    transform: translateZ(0);
    transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ar-disc__ph {
    display: block;
    background: linear-gradient(120deg, #3d3832 0%, #1a1816 50%, #0d0c0b 100%);
  }
  .ar-disc__shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(6, 5, 4, 0.92) 0%,
      rgba(6, 5, 4, 0.55) 38%,
      rgba(6, 5, 4, 0.2) 68%,
      rgba(6, 5, 4, 0.08) 100%
    );
    transition: opacity 0.45s ease;
  }
  .ar-disc__link--light .ar-disc__shade {
    background: linear-gradient(
      to top,
      rgba(255, 255, 255, 0.96) 0%,
      rgba(255, 255, 255, 0.72) 42%,
      rgba(255, 255, 255, 0.25) 72%,
      transparent 100%
    );
  }
  @media (prefers-reduced-motion: no-preference) {
    .ar-disc__link:hover .ar-disc__img,
    .ar-disc__link:focus-visible .ar-disc__img {
      transform: scale3d(1.035, 1.035, 1);
    }
    .ar-disc__link:hover .ar-disc__shade,
    .ar-disc__link:focus-visible .ar-disc__shade {
      opacity: 0.92;
    }
  }
  .ar-disc__copy {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    gap: 0;
    padding: 10px 12px 12px;
    pointer-events: none;
  }
  .ar-disc__link--dark .ar-disc__title {
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.45);
  }
  .ar-disc__link--light .ar-disc__title {
    color: var(--ar-disc-ink);
    text-shadow: none;
  }
  .ar-disc__title {
    font-family: 'Poppins', var(--font-heading-family);
    font-size: clamp(0.75rem, 2vw, 0.9375rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0;
    text-wrap: balance;
  }
  .ar-disc__btn {
    display: inline-flex;
    align-items: center;
    margin-top: 8px;
    padding: 5px 10px;
    border-radius: 999px;
    font-family: 'Poppins', var(--font-heading-family);
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    background: transparent;
    transition:
      background 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      color 0.35s ease;
  }
  @media (min-width: 900px) {
    .ar-disc__copy { padding: 12px 14px 14px; }
    .ar-disc__title { font-size: 0.9375rem; }
    .ar-disc__btn {
      margin-top: 10px;
      padding: 6px 12px;
      font-size: 0.625rem;
    }
  }
  .ar-disc__link--dark .ar-disc__btn {
    border: 1.5px solid rgba(255, 255, 255, 0.85);
    color: #fff;
  }
  .ar-disc__link--light .ar-disc__btn {
    border: 1.5px solid var(--ar-disc-ink);
    color: var(--ar-disc-ink);
  }
  @media (prefers-reduced-motion: no-preference) {
    .ar-disc__link--dark:hover .ar-disc__btn,
    .ar-disc__link--dark:focus-visible .ar-disc__btn {
      background: rgba(255, 255, 255, 0.14);
      border-color: #fff;
    }
    .ar-disc__link--light:hover .ar-disc__btn,
    .ar-disc__link--light:focus-visible .ar-disc__btn {
      background: var(--ar-disc-ink);
      border-color: var(--ar-disc-ink);
      color: #fff;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ar-disc__img,
    .ar-disc__shade,
    .ar-disc__btn,
    .ar-disc__link { transition: none; }
  }

  /* ── SHOWCASE ── */
  .ar-sc { background:#fff; padding:64px 0; border-bottom:2px solid #1e2023; font-family:var(--fb); }
  .ar-sc__hdr { max-width:896px; margin:0 auto 48px; padding:0 24px; text-align:center; }
  .ar-sc__h { font-family:var(--fh); font-size:clamp(22px,3vw,36px); letter-spacing:.05em; color:#1e2023; }
  .ar-sc__sub { font-size:14px; color:#6b7280; margin-top:12px; }
  .ar-sc__wrap { position:relative; }
  .ar-sc__fade { pointer-events:none; position:absolute; top:0; height:100%; width:24px; z-index:10; }
  .ar-sc__fade-l { left:0; background:linear-gradient(to right,#fff,transparent); }
  .ar-sc__fade-r { right:0; background:linear-gradient(to left,#fff,transparent); }
  .ar-sc__arrow { position:absolute; top:50%; z-index:20; transform:translateY(-50%); width:36px; height:36px; border-radius:50%; border:1px solid rgba(30,32,35,.2); background:rgba(255,255,255,.9); cursor:pointer; font-size:18px; line-height:1; display:flex; align-items:center; justify-content:center; transition:background .3s,color .3s; }
  .ar-sc__arrow:hover { background:#1e2023; color:#fff; }
  .ar-sc__arrow-l { left:8px; } .ar-sc__arrow-r { right:8px; }
  .ar-sc__track { display:flex; gap:32px; overflow-x:auto; padding:0 24px; scroll-snap-type:x mandatory; scrollbar-width:none; }
  .ar-sc__track::-webkit-scrollbar { display:none; }
  .ar-sc__card { min-width:200px; max-width:240px; flex-shrink:0; scroll-snap-align:start; text-align:center; }
  .ar-sc__link { display:block; }
  .ar-sc__imgw { position:relative; aspect-ratio:3/4; width:160px; margin:0 auto; overflow:hidden; }
  @media(min-width:640px){ .ar-sc__imgw { width:180px; } }
  .ar-sc__img { position:absolute; inset:0; width:100%; height:100%; object-fit:contain; transition:transform .5s ease; }
  .ar-sc__link:hover .ar-sc__img { transform:scale(1.05); }
  .ar-sc__name  { margin-top:20px; font-family:var(--fh); font-size:clamp(14px,1.5vw,18px); letter-spacing:.04em; color:#1e2023; }
  .ar-sc__type  { margin-top:4px; font-size:10px; text-transform:uppercase; letter-spacing:.18em; color:#9ca3af; }
  .ar-sc__desc  { margin-top:8px; font-size:13px; line-height:1.6; color:#4b5563; }
  .ar-sc__price { margin-top:12px; font-size:13px; font-weight:500; color:#1e2023; }

  /* ── NAVAGRAHA ── */
  .ar-nav9-wrap { background:#fff; border:none; font-family:var(--fb); overflow-x:clip; }
  .ar-nav9-wrap .ar-pl { border:none; overflow-x:clip; }
  .ar-nav9-wrap .ar-pl__card { border:none; }
  .ar-nav9-intro { display:flex; align-items:center; justify-content:center; min-height:28vh; padding:48px 24px 24px; border-bottom:none; }
  .ar-nav9-intro__in { max-width:672px; text-align:center; }
  .ar-nav9-intro__h { font-family:var(--fh); font-size:clamp(24px,3vw,36px); color:#1e2023; margin-bottom:16px; }
  .ar-nav9-intro__p { font-size:14px; line-height:1.75; color:#4b5563; margin-bottom:24px; }
  .ar-nav9-intro__btn { display:inline-block; border:2px solid #1e2023; padding:8px 24px; font-size:11px; letter-spacing:.18em; color:#1e2023; font-family:var(--fb); transition:background .3s,color .3s; text-decoration:none; }
  .ar-nav9-intro__btn:hover { background:#1e2023; color:#fff; }

  /* ── ZODIAC HERO ── */
  .ar-zh { background:#0a0a0a; overflow:hidden; font-family:var(--fb); }
  .ar-zh__in { max-width:1440px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; align-items:center; min-height:600px; }
  @media(max-width:900px){ .ar-zh__in { grid-template-columns:1fr; } }
  .ar-zh__left { padding:80px 64px; }
  @media(max-width:900px){ .ar-zh__left { padding:60px 24px 32px; } }
  .ar-zh__h { font-family: var(--font-heading-family); font-size:clamp(42px,5vw,76px); font-weight:400; line-height:1.12; color:#ffffff; margin-bottom:28px; letter-spacing:-.01em; }
  .ar-zh__p { font-size:15px; line-height:1.8; color:rgba(255,255,255,.75); max-width:480px; margin-bottom:44px; font-weight:300; }
  .ar-zh__btn { display:inline-block; border:1.5px solid rgba(255,255,255,.85); padding:16px 36px; font-family:var(--fb); font-size:11px; font-weight:500; letter-spacing:.22em; text-transform:uppercase; color:#ffffff !important; background:transparent; transition:background .3s,color .3s; }
  .ar-zh__btn:hover { background:#ffffff; color:#0a0a0a !important; }
  .ar-zh__right { position:relative; width:100%; height:100%; min-height:500px; overflow:hidden; }
  @media(max-width:900px){ .ar-zh__right { min-height:360px; } }
  .ar-zh__media { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center center; display:block; }
  .ar-zh__ph { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,.3); font-size:13px; font-family:var(--fb); text-align:center; padding:24px; }

  /* ── SHOP TRIO ── */
  .ar-trio { background:#fff; font-family:var(--fb); }
  .ar-trio__grid { display:grid; grid-template-columns:1fr; }
  @media(min-width:768px){ .ar-trio__grid { grid-template-columns:1fr 1fr; } }
  .ar-trio__left { height:420px; }
  @media(min-width:768px){ .ar-trio__left { height:600px; } }
  .ar-trio__right { display:grid; grid-template-rows:1fr 1fr; height:420px; }
  @media(min-width:768px){ .ar-trio__right { height:600px; } }
  .ar-trio__card { display:block; position:relative; width:100%; height:100%; overflow:hidden; border:2px solid #1e2023; }
  .ar-trio__img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition:transform .7s ease; }
  .ar-trio__card:hover .ar-trio__img { transform:scale(1.05); }
  .ar-trio__ov { position:absolute; inset:0; background:rgba(0,0,0,0); transition:background .5s; }
  .ar-trio__card:hover .ar-trio__ov { background:rgba(0,0,0,.1); }
  .ar-trio__cta-wrap { position:absolute; bottom:24px; left:24px; z-index:2; }
  .ar-trio__cta {
    display:inline-block;
    border:2px solid #000;
    border-radius:0;
    padding:8px 24px;
    font-size:12px;
    letter-spacing:.18em;
    color:#000;
    background:rgba(255,255,255,.14);
    backdrop-filter:blur(14px) saturate(160%);
    -webkit-backdrop-filter:blur(14px) saturate(160%);
    box-shadow:0 4px 20px rgba(0,0,0,.15), inset 0 1px 0 rgba(255,255,255,.4);
    transition:background .4s cubic-bezier(0.25,0.1,0.25,1),
      border-color .4s cubic-bezier(0.25,0.1,0.25,1),
      color .4s cubic-bezier(0.25,0.1,0.25,1),
      box-shadow .4s cubic-bezier(0.25,0.1,0.25,1);
  }
  .ar-trio__card:hover .ar-trio__cta,
  .ar-trio__card:focus-visible .ar-trio__cta {
    background:rgba(255,255,255,.26);
    border-color:#000;
    color:#000;
    box-shadow:0 8px 28px rgba(0,0,0,.2), inset 0 1px 0 rgba(255,255,255,.55);
  }
  .ar-trio__card:has(.ar-trio__ph) .ar-trio__cta {
    border:2px solid rgba(30,32,35,.35);
    color:#1e2023;
    background:rgba(255,255,255,.5);
    box-shadow:0 4px 16px rgba(30,32,35,.08), inset 0 1px 0 rgba(255,255,255,.7);
  }
  .ar-trio__card:has(.ar-trio__ph):hover .ar-trio__cta,
  .ar-trio__card:has(.ar-trio__ph):focus-visible .ar-trio__cta {
    background:rgba(255,255,255,.72);
    border-color:rgba(30,32,35,.55);
    color:#111;
    box-shadow:0 8px 24px rgba(30,32,35,.12), inset 0 1px 0 #fff;
  }
  .ar-trio__ph { position:absolute; inset:0; background:#e5e7eb; display:flex; align-items:center; justify-content:center; color:#9ca3af; font-size:12px; font-family:var(--fb); }

  /* ── PURE ATTAR ── */
  .ar-pure { position:relative; width:100%; min-height:460px; overflow:hidden; display:flex; align-items:center; justify-content:center; font-family:var(--fb); background:#050010; background-image:radial-gradient(ellipse at 20% 50%,rgba(140,0,255,0.35) 0%,transparent 55%),radial-gradient(ellipse at 80% 30%,rgba(225,0,255,0.25) 0%,transparent 50%),radial-gradient(ellipse at 60% 80%,rgba(80,0,180,0.3) 0%,transparent 45%); padding:100px 24px; }
  .ar-pure__con { position:relative; z-index:10; max-width:680px; text-align:center; }
  .ar-pure__h { font-family: var(--font-heading-family); font-size:clamp(32px,4.5vw,60px); font-weight:300; color:#fff; margin-bottom:20px; letter-spacing:-.01em; }
  .ar-pure__p { font-size:15px; line-height:1.8; color:rgba(255,255,255,.75); margin-bottom:36px; font-weight:300; max-width:520px; margin-left:auto; margin-right:auto; }

  /* ── COMBO ── */
  .ar-combo { background:#fff; border-bottom:2px solid rgba(30,32,35,.1); font-family:var(--fb); }
  .ar-combo__in { max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr; align-items:center; gap:40px; padding:64px 24px; }
  @media(min-width:768px){ .ar-combo__in { grid-template-columns:1fr 1fr; gap:64px; } }
  .ar-combo__imgw { position:relative; aspect-ratio:4/3; max-width:560px; margin:0 auto; background:#f3f4f6; overflow:hidden; }
  .ar-combo__img { position:absolute; inset:0; width:100%; height:100%; object-fit:contain; display:block; }
  .ar-combo__ph { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; color:#9ca3af; font-size:13px; font-family:var(--fb); text-align:center; padding:24px; }
  .ar-combo__con { text-align:center; }
  @media(min-width:768px){ .ar-combo__con { text-align:left; } }
  .ar-combo__h { font-family:var(--fh); font-size:clamp(24px,3vw,36px); letter-spacing:.04em; color:#1e2023; margin-bottom:20px; }
  .ar-combo__p { font-size:14px; line-height:1.75; color:#4b5563; max-width:448px; margin:0 auto 32px; }
  @media(min-width:768px){ .ar-combo__p { margin:0 0 32px; } }
  .ar-combo__btn { display:inline-block; border:1px solid #1e2023; padding:12px 32px; font-size:11px; letter-spacing:.2em; color:#1e2023; transition:background .3s,color .3s; }
  .ar-combo__btn:hover { background:#1e2023; color:#fff; }

  /* ── TEXT TESTIMONIALS ── */
  .ar-tst { background:#faf9f7; padding:80px 0; font-family:var(--fb); border-top:1px solid rgba(30,32,35,.08); }
  .ar-tst__inner { max-width:1200px; margin:0 auto; padding:0 32px; }
  .ar-tst__hdr { text-align:center; margin-bottom:52px; }
  .ar-tst__h { font-family: var(--font-heading-family); font-size:clamp(28px,3.5vw,46px); font-weight:400; color:#1e2023; margin-bottom:12px; letter-spacing:-.01em; }
  .ar-tst__div { width:40px; height:2px; background:#1e2023; margin:0 auto 14px; }
  .ar-tst__sub { font-size:14px; color:#6b7280; font-weight:300; }
  .ar-tst__track { display:flex; gap:24px; overflow-x:auto; scroll-snap-type:x mandatory; scrollbar-width:none; padding:4px 2px 20px; }
  .ar-tst__track::-webkit-scrollbar { display:none; }
  .ar-tst__card { min-width:300px; max-width:360px; flex-shrink:0; scroll-snap-align:start; background:#fff; border:1px solid rgba(30,32,35,.08); border-radius:16px; padding:32px 28px; display:flex; flex-direction:column; gap:16px; transition:box-shadow .3s,transform .3s; }
  .ar-tst__card:hover { box-shadow:0 12px 40px rgba(0,0,0,.08); transform:translateY(-3px); }
  .ar-tst__stars { display:flex; gap:3px; }
  .ar-tst__star { font-size:16px; color:#e5e7eb; }
  .ar-tst__star.on { color:#f59e0b; }
  .ar-tst__quote { font-family: var(--font-heading-family); font-size:17px; line-height:1.7; color:#374151; font-style:italic; flex:1; }
  .ar-tst__author { border-top:1px solid rgba(30,32,35,.06); padding-top:14px; }
  .ar-tst__name { font-size:13px; font-weight:600; color:#1e2023; }
  .ar-tst__loc { font-size:13px; color:#9ca3af; }
