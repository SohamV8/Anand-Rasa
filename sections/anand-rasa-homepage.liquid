                when 'Incense Sticks'
                  assign ar_cat_handle = 'incense-sticks'
                when 'Discovery Kit'
                  assign ar_cat_handle = 'gift-sets'
              endcase
              if ar_cat_handle != blank and collections[ar_cat_handle] != empty
                assign ar_cat_href = collections[ar_cat_handle].url
              elsif ar_cat_handle != blank
                assign ar_cat_href = routes.collections_url | append: '/' | append: ar_cat_handle
              else
                assign ar_cat_href = routes.collections_url
              endif
            endif
          -%}
