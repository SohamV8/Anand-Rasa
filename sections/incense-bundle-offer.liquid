{% comment %}
  ANAND RASA — Incense Bundle Offer Page
  sections/incense-bundle-offer.liquid

  A standalone offer page where the customer picks any 3 incense sticks
  for a fixed bundle price (default ₹599). When the bundle is complete the
  customer hits "Add Bundle to Cart" — all 3 variants are added in a single
  /cart/add.js call, and the configured discount code is auto-applied via
  the /discount/{code}?redirect=/cart Shopify URL.

  Notes for the merchant:
  - Set the source collection in the Theme Editor (default handle: incense).
  - Create a Shopify discount (e.g. "BUY3FOR599") that applies when 3 items
    from the collection are in the cart, OR a fixed-amount code that brings
    3 items down to ₹599. Then enter that code in the section settings.
{% endcomment %}

{%- liquid
  assign coll_handle  = section.settings.bundle_collection | default: 'incense-stick'
  assign bundle_coll  = collections[coll_handle]
  assign bundle_size  = section.settings.bundle_size       | default: 3
  assign bundle_price = section.settings.bundle_price_text | default: '₹599'
  assign disc_code    = section.settings.discount_code     | default: 'BUY3FOR599'
  assign offer_mins   = section.settings.offer_minutes     | default: 60
  assign hero_eyebrow = section.settings.hero_eyebrow      | default: 'Special Discount'
  assign hero_title   = section.settings.hero_title        | default: 'Buy any 3'
  assign hero_sub     = section.settings.hero_sub          | default: 'Hand-picked incense sticks, crafted from pure botanicals. Mix any three fragrances and treat your space — or your loved ones — to a sacred ritual.'
  assign cta_pick     = section.settings.cta_pick          | default: 'Pick Your 3 Fragrances'
  assign cta_add      = section.settings.cta_add           | default: 'Add Bundle to Cart'
  assign cta_clear    = section.settings.cta_clear         | default: 'Clear Selection'
-%}

<style>
/* ============================================================
   ANAND RASA — Incense Bundle Offer
   Scoped under .arb to avoid theme collisions.
   ============================================================ */
.arb {
  --arb-ink:     #0F0F0F;
  --arb-ink-2:   #3A3A3A;
  --arb-ink-3:   #7A7A7A;
  --arb-ink-4:   #ADADAD;
  --arb-bg:      #FAF7F1;
  --arb-bg-2:    #F2EBDB;
  --arb-card:    #FFFFFF;
  --arb-gold:    #B8943A;
  --arb-gold-2:  #D4AB5A;
  --arb-gold-tint: #FFF6E1;
  --arb-rose:    #C45A78;
  --arb-success: #1A5C2A;
  --arb-border:  #E8E2D2;
  --arb-radius:  18px;
  --arb-trans:   0.32s cubic-bezier(0.25, 1, 0.5, 1);
  --arb-fh: var(--font-heading-family, Georgia, serif);
  --arb-fb: var(--font-body-family, system-ui, -apple-system, "Segoe UI", sans-serif);

  font-family: var(--arb-fb);
  color: var(--arb-ink);
  background: var(--arb-bg);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
.arb *, .arb *::before, .arb *::after { box-sizing: border-box; }
.arb img { display: block; max-width: 100%; }
.arb a { text-decoration: none; color: inherit; }

/* ============================================================
   ANIMATIONS
   ============================================================ */
@keyframes arb-up   { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
@keyframes arb-fade { from { opacity: 0; } to { opacity: 1; } }
@keyframes arb-pop  { 0% { transform: scale(0.6); opacity: 0; } 60% { transform: scale(1.08); opacity: 1; } 100% { transform: scale(1); } }
@keyframes arb-line { from { transform: scaleX(0); } to { transform: scaleX(1); } }
@keyframes arb-blob {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33%      { transform: translate(40px, -30px) scale(1.06); }
  66%      { transform: translate(-30px, 40px) scale(0.95); }
}
@keyframes arb-shimmer {
  0%   { background-position: -100% 0; }
  100% { background-position: 200% 0; }
}
@keyframes arb-bounce {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-4px); }
}

@media (prefers-reduced-motion: reduce) {
  .arb *, .arb *::before, .arb *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}

/* ============================================================
   HERO
   ============================================================ */
.arb-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #FAF7F1 0%, #F2EBDB 100%);
  padding: clamp(48px, 7vw, 96px) clamp(20px, 5vw, 64px) clamp(56px, 8vw, 110px);
  isolation: isolate;
}

.arb-hero__blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  opacity: 0.55;
  z-index: 0;
  pointer-events: none;
  animation: arb-blob 18s ease-in-out infinite;
}
.arb-hero__blob--gold {
  width: 420px;
  height: 420px;
  top: -120px;
  right: -80px;
  background: radial-gradient(circle, var(--arb-gold-2) 0%, transparent 70%);
}
.arb-hero__blob--rose {
  width: 380px;
  height: 380px;
  bottom: -160px;
  left: -100px;
  background: radial-gradient(circle, #F2C7A8 0%, transparent 70%);
  animation-duration: 22s;
  animation-direction: reverse;
}

.arb-hero__inner {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  align-items: center;
  gap: 56px;
}

.arb-hero__copy {
  animation: arb-up 0.8s cubic-bezier(0.25, 1, 0.5, 1) both;
}

.arb-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--arb-gold);
  background: var(--arb-gold-tint);
  padding: 7px 14px;
  border-radius: 999px;
  margin-bottom: 18px;
}
.arb-hero__eyebrow::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--arb-gold);
  box-shadow: 0 0 10px var(--arb-gold);
}

.arb-hero__title {
  font-family: var(--arb-fh);
  font-weight: 400;
  font-size: clamp(40px, 6vw, 84px);
  line-height: 1.02;
  letter-spacing: -0.03em;
  color: var(--arb-ink);
  margin: 0 0 14px;
}
.arb-hero__title-em {
  font-style: italic;
  color: var(--arb-gold);
  position: relative;
  display: inline-block;
}
.arb-hero__title-em::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  bottom: 4%;
  height: 8px;
  background: var(--arb-gold-tint);
  z-index: -1;
  border-radius: 4px;
  transform: scaleX(0);
  transform-origin: left;
  animation: arb-line 0.8s ease 0.6s forwards;
}

.arb-hero__price {
  display: flex;
  align-items: baseline;
  gap: 14px;
  margin: 4px 0 22px;
  font-family: var(--arb-fh);
}
.arb-hero__price-now {
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--arb-ink);
}
.arb-hero__price-tag {
  font-family: var(--arb-fb);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #fff;
  background: var(--arb-rose);
  padding: 6px 12px;
  border-radius: 6px;
  align-self: center;
}

.arb-hero__sub {
  font-size: 16px;
  line-height: 1.7;
  color: var(--arb-ink-3);
  max-width: 520px;
  margin: 0 0 28px;
  font-weight: 300;
}

.arb-hero__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
}

.arb-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 16px 28px;
  font-family: var(--arb-fb);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  line-height: 1;
  border-radius: 999px;
  border: 1.5px solid transparent;
  cursor: pointer;
  transition: background var(--arb-trans), color var(--arb-trans),
              border-color var(--arb-trans), transform 0.2s ease,
              box-shadow var(--arb-trans);
  text-decoration: none;
}
.arb-btn--primary {
  background: var(--arb-ink);
  color: #fff;
}
.arb-btn--primary:hover {
  background: var(--arb-gold);
  transform: translateY(-2px);
  box-shadow: 0 14px 32px rgba(184, 148, 58, 0.32);
}
.arb-btn--ghost {
  background: transparent;
  color: var(--arb-ink);
  border-color: var(--arb-ink);
}
.arb-btn--ghost:hover {
  background: var(--arb-ink);
  color: #fff;
}
.arb-btn:disabled {
  background: #E8E2D2;
  color: var(--arb-ink-4);
  border-color: #E8E2D2;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.arb-btn-arrow {
  display: inline-block;
  transition: transform 0.3s ease;
}
.arb-btn:hover .arb-btn-arrow { transform: translateX(4px); }

/* Countdown */
.arb-hero__visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: arb-fade 0.9s ease 0.2s both;
}

.arb-count {
  width: 100%;
  max-width: 380px;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,0.7);
  border-radius: 24px;
  padding: 28px 28px 24px;
  box-shadow: 0 24px 60px rgba(15,15,15,0.10);
  text-align: center;
}
.arb-count__label {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--arb-rose);
  margin: 0 0 16px;
}
.arb-count__row {
  display: flex;
  justify-content: center;
  gap: 10px;
}
.arb-count__cell {
  flex: 1;
  background: var(--arb-ink);
  color: #fff;
  border-radius: 12px;
  padding: 14px 8px 10px;
  position: relative;
  overflow: hidden;
}
.arb-count__cell::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(255,255,255,0.06);
}
.arb-count__num {
  font-family: var(--arb-fh);
  font-size: 36px;
  font-weight: 400;
  line-height: 1;
  letter-spacing: -0.02em;
  display: block;
}
.arb-count__unit {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-top: 6px;
  display: block;
  color: rgba(255,255,255,0.6);
}
.arb-count__hint {
  margin-top: 14px;
  font-size: 11px;
  color: var(--arb-ink-3);
  font-style: italic;
}
.arb-count.is-expired .arb-count__cell { background: #999; }

@media (max-width: 880px) {
  .arb-hero__inner {
    grid-template-columns: 1fr;
    gap: 36px;
    text-align: center;
  }
  .arb-hero__copy { margin: 0 auto; }
  .arb-hero__eyebrow,
  .arb-hero__btns,
  .arb-hero__price { justify-content: center; }
  .arb-hero__sub { margin-left: auto; margin-right: auto; }
}

/* ============================================================
   STEPS
   ============================================================ */
.arb-steps {
  background: #fff;
  border-bottom: 1px solid var(--arb-border);
}
.arb-steps__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 28px clamp(20px, 5vw, 64px);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.arb-step {
  display: flex;
  align-items: center;
  gap: 14px;
  opacity: 0;
  animation: arb-up 0.6s ease both;
}
.arb-step:nth-child(1) { animation-delay: 0.1s; }
.arb-step:nth-child(2) { animation-delay: 0.2s; }
.arb-step:nth-child(3) { animation-delay: 0.3s; }
.arb-step__num {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--arb-gold-tint);
  color: var(--arb-gold);
  display: grid;
  place-items: center;
  font-family: var(--arb-fh);
  font-size: 16px;
  font-weight: 700;
  border: 1.5px solid var(--arb-gold);
}
.arb-step__txt {
  font-size: 13px;
  color: var(--arb-ink-2);
  line-height: 1.5;
}
.arb-step__txt strong {
  display: block;
  color: var(--arb-ink);
  font-weight: 700;
  font-size: 14px;
  margin-bottom: 2px;
}
@media (max-width: 720px) {
  .arb-steps__inner { grid-template-columns: 1fr; gap: 14px; padding: 22px 20px; }
}

/* ============================================================
   PICKER HEADER
   ============================================================ */
.arb-pickhead {
  max-width: 1200px;
  margin: 0 auto;
  padding: clamp(48px, 6vw, 80px) clamp(20px, 5vw, 64px) 24px;
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
}
.arb-pickhead__title {
  font-family: var(--arb-fh);
  font-size: clamp(28px, 3.5vw, 44px);
  line-height: 1.1;
  font-weight: 400;
  letter-spacing: -0.02em;
  margin: 0;
}
.arb-pickhead__rule {
  display: block;
  width: 56px;
  height: 1.5px;
  background: var(--arb-gold);
  margin-top: 14px;
  transform-origin: left;
  animation: arb-line 0.7s ease 0.3s both;
}

.arb-pickhead__counter {
  font-family: var(--arb-fb);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--arb-ink-2);
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
  background: var(--arb-card);
  border: 1px solid var(--arb-border);
  border-radius: 999px;
  box-shadow: 0 6px 18px rgba(15,15,15,0.04);
}
.arb-pickhead__counter strong {
  font-family: var(--arb-fh);
  font-size: 22px;
  font-weight: 400;
  color: var(--arb-gold);
  line-height: 1;
}

/* ============================================================
   PRODUCT GRID
   ============================================================ */
.arb-grid {
  max-width: 1200px;
  margin: 0 auto;
  padding: 16px clamp(20px, 5vw, 64px) clamp(140px, 14vw, 200px);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 22px;
}
@media (max-width: 1100px) { .arb-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 820px)  { .arb-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; } }
@media (max-width: 460px)  { .arb-grid { grid-template-columns: 1fr; padding-bottom: 180px; } }

.arb-card {
  position: relative;
  background: var(--arb-card);
  border: 1.5px solid var(--arb-border);
  border-radius: var(--arb-radius);
  overflow: hidden;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  transition: border-color var(--arb-trans), box-shadow var(--arb-trans),
              transform 0.25s ease;
  opacity: 0;
  transform: translateY(28px);
  animation: arb-up 0.6s cubic-bezier(0.25,1,0.5,1) both;
  animation-delay: calc(var(--ci, 0) * 70ms + 0.15s);
  -webkit-tap-highlight-color: transparent;
  font-family: inherit;
  text-align: left;
  color: inherit;
  padding: 0;
}
.arb-card:focus-visible {
  outline: none;
  border-color: var(--arb-gold);
  box-shadow: 0 0 0 3px rgba(184,148,58,0.25);
}
.arb-card:hover:not(.is-disabled) {
  border-color: var(--arb-ink-4);
  box-shadow: 0 18px 40px rgba(15,15,15,0.10);
  transform: translateY(-3px);
}

.arb-card.is-selected {
  border-color: var(--arb-gold);
  box-shadow: 0 18px 40px rgba(184, 148, 58, 0.22), inset 0 0 0 1.5px var(--arb-gold);
  background: linear-gradient(180deg, #FFF8E8 0%, #FFFFFF 60%);
}

.arb-card.is-disabled {
  opacity: 0.45;
  cursor: not-allowed;
  filter: grayscale(0.4);
}

.arb-card__media {
  position: relative;
  aspect-ratio: 1 / 1;
  background: #F7F2E6;
  overflow: hidden;
}

.arb-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s cubic-bezier(0.25,1,0.5,1);
}
.arb-card:hover:not(.is-disabled) .arb-card__img { transform: scale(1.06); }

.arb-card__media-ph {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  font-size: 32px;
  color: var(--arb-ink-4);
  background: linear-gradient(135deg, #F7F2E6 0%, #EFE7D2 100%);
}

.arb-card__check {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 2;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.92);
  border: 1.5px solid var(--arb-border);
  display: grid;
  place-items: center;
  color: transparent;
  transition: background var(--arb-trans), color var(--arb-trans),
              border-color var(--arb-trans), transform var(--arb-trans);
  backdrop-filter: blur(4px);
}
.arb-card.is-selected .arb-card__check {
  background: var(--arb-gold);
  border-color: var(--arb-gold);
  color: #fff;
  animation: arb-pop 0.45s cubic-bezier(0.25,1.5,0.5,1) both;
}

.arb-card__rank {
  position: absolute;
  top: 12px;
  left: 12px;
  z-index: 2;
  background: var(--arb-ink);
  color: #fff;
  font-family: var(--arb-fh);
  font-weight: 400;
  font-size: 13px;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  opacity: 0;
  transform: scale(0.6);
  transition: opacity var(--arb-trans), transform var(--arb-trans);
}
.arb-card.is-selected .arb-card__rank {
  opacity: 1;
  transform: scale(1);
}

.arb-card__body {
  padding: 14px 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}
.arb-card__type {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: var(--arb-gold);
  text-transform: uppercase;
}
.arb-card__name {
  font-family: var(--arb-fh);
  font-weight: 400;
  font-size: 17px;
  line-height: 1.25;
  letter-spacing: -0.01em;
  color: var(--arb-ink);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.arb-card__tag {
  margin-top: 4px;
  font-size: 12px;
  color: var(--arb-ink-3);
  font-style: italic;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.arb-card__price-row {
  margin-top: 8px;
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.arb-card__price {
  font-size: 14px;
  font-weight: 700;
  color: var(--arb-ink);
}
.arb-card__compare {
  font-size: 12px;
  color: var(--arb-ink-4);
  text-decoration: line-through;
}

.arb-card__hint {
  margin-top: 10px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--arb-gold);
  display: flex;
  align-items: center;
  gap: 6px;
}
.arb-card.is-selected .arb-card__hint { color: var(--arb-success); }

/* ============================================================
   STICKY BUNDLE BAR
   ============================================================ */
.arb-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 60;
  background: rgba(15,15,15,0.96);
  color: #fff;
  border-top: 1px solid rgba(255,255,255,0.08);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transform: translateY(100%);
  transition: transform 0.45s cubic-bezier(0.25, 1, 0.5, 1);
  box-shadow: 0 -16px 40px rgba(0,0,0,0.18);
}
.arb-bar.is-visible { transform: translateY(0); }

.arb-bar__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 16px clamp(20px, 5vw, 48px);
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 24px;
}

.arb-bar__progress {
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-width: 0;
}

.arb-bar__progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}

.arb-bar__label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  display: inline-flex;
  align-items: center;
  gap: 10px;
}
.arb-bar__label strong {
  font-family: var(--arb-fh);
  font-weight: 400;
  font-size: 22px;
  letter-spacing: -0.02em;
  color: #fff;
  text-transform: none;
}

.arb-bar__price {
  font-family: var(--arb-fb);
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  display: inline-flex;
  align-items: baseline;
  gap: 8px;
}
.arb-bar__price strong {
  font-family: var(--arb-fh);
  font-weight: 400;
  font-size: 22px;
  letter-spacing: -0.02em;
  color: var(--arb-gold-2);
}

.arb-bar__track {
  position: relative;
  height: 4px;
  background: rgba(255,255,255,0.10);
  border-radius: 999px;
  overflow: hidden;
}
.arb-bar__fill {
  position: absolute;
  inset: 0;
  width: 0;
  background: linear-gradient(90deg, var(--arb-gold-2), var(--arb-gold));
  border-radius: 999px;
  transition: width 0.45s cubic-bezier(0.25, 1, 0.5, 1);
}
.arb-bar__fill::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  background-size: 200% 100%;
  animation: arb-shimmer 2.4s linear infinite;
}

.arb-bar__actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.arb-bar__clear {
  background: transparent;
  border: 1.5px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.85);
  font-family: var(--arb-fb);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 13px 18px;
  border-radius: 999px;
  cursor: pointer;
  transition: background var(--arb-trans), border-color var(--arb-trans);
}
.arb-bar__clear:hover {
  background: rgba(255,255,255,0.10);
  border-color: rgba(255,255,255,0.5);
}

.arb-bar__add {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 28px;
  background: var(--arb-gold);
  color: #fff;
  font-family: var(--arb-fb);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  overflow: hidden;
  transition: background var(--arb-trans), transform 0.2s ease,
              box-shadow var(--arb-trans);
}
.arb-bar__add:not(:disabled):hover {
  background: #fff;
  color: var(--arb-ink);
  transform: translateY(-2px);
  box-shadow: 0 14px 32px rgba(212, 171, 90, 0.5);
}
.arb-bar__add:not(:disabled):hover .arb-bar__add-icon {
  background: var(--arb-gold);
  color: #fff;
  transform: translateX(3px);
}
.arb-bar__add:disabled {
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.5);
  cursor: not-allowed;
}
.arb-bar__add-icon {
  display: inline-flex;
  width: 22px;
  height: 22px;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.20);
  color: #fff;
  transition: background var(--arb-trans), color var(--arb-trans), transform var(--arb-trans);
}
.arb-bar__add.is-loading .arb-bar__add-text { opacity: 0.4; }
.arb-bar__add.is-loading::before {
  content: '';
  position: absolute;
  width: 16px; height: 16px;
  top: 50%; left: 50%;
  margin: -8px 0 0 -8px;
  border-radius: 50%;
  border: 2px solid #fff;
  border-right-color: transparent;
  animation: arb-spin 0.7s linear infinite;
}
@keyframes arb-spin { to { transform: rotate(360deg); } }

.arb-bar__add.is-success {
  background: var(--arb-success);
  color: #fff;
}
.arb-bar__add.is-success .arb-bar__add-icon {
  background: rgba(255,255,255,0.2);
}

@media (max-width: 720px) {
  .arb-bar__inner {
    grid-template-columns: 1fr;
    gap: 12px;
    padding: 14px 16px;
  }
  .arb-bar__actions { justify-content: space-between; width: 100%; }
  .arb-bar__add {
    flex: 1;
    justify-content: center;
    padding: 14px 16px;
    font-size: 11px;
    letter-spacing: 0.12em;
  }
  .arb-bar__clear { padding: 12px 14px; }
  .arb-bar__label strong, .arb-bar__price strong { font-size: 18px; }
}

/* ============================================================
   TOAST
   ============================================================ */
.arb-toast {
  position: fixed;
  top: 24px;
  left: 50%;
  transform: translate(-50%, -120%);
  z-index: 80;
  background: var(--arb-ink);
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.02em;
  padding: 12px 20px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 12px 30px rgba(15,15,15,0.25);
  transition: transform 0.45s cubic-bezier(0.25, 1.5, 0.5, 1);
  pointer-events: none;
}
.arb-toast.is-visible { transform: translate(-50%, 0); }
.arb-toast.is-error   { background: #B0271A; }

/* ============================================================
   EMPTY STATE
   ============================================================ */
.arb-empty {
  max-width: 720px;
  margin: 0 auto;
  padding: 80px 24px 120px;
  text-align: center;
  color: var(--arb-ink-3);
}
.arb-empty h2 {
  font-family: var(--arb-fh);
  font-weight: 400;
  color: var(--arb-ink);
  font-size: 28px;
  margin: 0 0 10px;
}
</style>

<div class="arb" data-section-id="{{ section.id }}">
  {%- comment -%} ── HERO ── {%- endcomment -%}
  <section class="arb-hero" aria-labelledby="arb-hero-title">
    <span class="arb-hero__blob arb-hero__blob--gold" aria-hidden="true"></span>
    <span class="arb-hero__blob arb-hero__blob--rose" aria-hidden="true"></span>

    <div class="arb-hero__inner">
      <div class="arb-hero__copy">
        <span class="arb-hero__eyebrow">{{ hero_eyebrow }}</span>

        <h1 id="arb-hero-title" class="arb-hero__title">
          {{ hero_title }}
          <span class="arb-hero__title-em">incense sticks</span>
        </h1>

        <div class="arb-hero__price">
          <span class="arb-hero__price-now">for {{ bundle_price }}</span>
          <span class="arb-hero__price-tag">save up to 35%</span>
        </div>

        <p class="arb-hero__sub">{{ hero_sub }}</p>

        <div class="arb-hero__btns">
          <a href="#arb-picker" class="arb-btn arb-btn--primary">
            {{ cta_pick }}
            <span class="arb-btn-arrow">→</span>
          </a>
          {%- if section.settings.cta_secondary_text != blank and section.settings.cta_secondary_url != blank -%}
            <a href="{{ section.settings.cta_secondary_url }}" class="arb-btn arb-btn--ghost">
              {{ section.settings.cta_secondary_text }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="arb-hero__visual">
        <div
          class="arb-count"
          data-arb-countdown
          data-minutes="{{ offer_mins }}"
          role="timer"
          aria-live="polite"
        >
          <p class="arb-count__label">Offer ends in</p>
          <div class="arb-count__row">
            <div class="arb-count__cell">
              <span class="arb-count__num" data-unit="hours">00</span>
              <span class="arb-count__unit">Hrs</span>
            </div>
            <div class="arb-count__cell">
              <span class="arb-count__num" data-unit="minutes">00</span>
              <span class="arb-count__unit">Min</span>
            </div>
            <div class="arb-count__cell">
              <span class="arb-count__num" data-unit="seconds">00</span>
              <span class="arb-count__unit">Sec</span>
            </div>
          </div>
          <p class="arb-count__hint">Hand-blended fragrances · Free gift wrapping</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── HOW IT WORKS ── {%- endcomment -%}
  <section class="arb-steps" aria-label="How the bundle works">
    <div class="arb-steps__inner">
      <div class="arb-step">
        <span class="arb-step__num">1</span>
        <span class="arb-step__txt">
          <strong>Pick {{ bundle_size }} fragrances</strong>
          Tap any incense stick below to add it to your bundle.
        </span>
      </div>
      <div class="arb-step">
        <span class="arb-step__num">2</span>
        <span class="arb-step__txt">
          <strong>Bundle locks at {{ bundle_price }}</strong>
          Discount is auto-applied at checkout — no code needed.
        </span>
      </div>
      <div class="arb-step">
        <span class="arb-step__num">3</span>
        <span class="arb-step__txt">
          <strong>Free shipping</strong>
          Delivered fresh from our Indian workshop, packed with care.
        </span>
      </div>
    </div>
  </section>

  {%- comment -%} ── PICKER ── {%- endcomment -%}
  <header class="arb-pickhead" id="arb-picker">
    <div>
      <h2 class="arb-pickhead__title">Choose your three fragrances</h2>
      <span class="arb-pickhead__rule" aria-hidden="true"></span>
    </div>
    <span class="arb-pickhead__counter" aria-live="polite">
      <strong data-arb-counter>0</strong>
      <span>/ {{ bundle_size }} selected</span>
    </span>
  </header>

  {%- if bundle_coll != blank and bundle_coll.products.size > 0 -%}
    <main class="arb-grid" id="arb-grid" data-bundle-size="{{ bundle_size }}">
      {%- for p in bundle_coll.products limit: 24 -%}
        {%- liquid
          assign v = p.selected_or_first_available_variant
          assign tag = p.metafields.custom.tagline | metafield_text
          if tag == blank and p.description != blank
            assign tag = p.description | strip_html | truncate: 80
          endif
        -%}
        {%- if v != blank and v.available -%}
          <button
            type="button"
            class="arb-card"
            style="--ci: {{ forloop.index0 }};"
            data-arb-card
            data-variant-id="{{ v.id }}"
            data-product-id="{{ p.id }}"
            data-title="{{ p.title | escape }}"
            aria-pressed="false"
            aria-label="Add {{ p.title | escape }} to bundle"
          >
            <div class="arb-card__media">
              <span class="arb-card__check" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              <span class="arb-card__rank" data-arb-rank aria-hidden="true"></span>

              {%- if p.featured_image != blank -%}
                <img
                  src="{{ p.featured_image | image_url: width: 600 }}"
                  srcset="
                    {{ p.featured_image | image_url: width: 400 }} 400w,
                    {{ p.featured_image | image_url: width: 700 }} 700w,
                    {{ p.featured_image | image_url: width: 900 }} 900w
                  "
                  sizes="(min-width: 1100px) 280px, (min-width: 820px) 32vw, (min-width: 460px) 47vw, 92vw"
                  alt="{{ p.featured_image.alt | default: p.title | escape }}"
                  width="600"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="arb-card__img"
                >
              {%- else -%}
                <div class="arb-card__media-ph" aria-hidden="true">✦</div>
              {%- endif -%}
            </div>

            <div class="arb-card__body">
              {%- if p.type != blank -%}
                <span class="arb-card__type">{{ p.type }}</span>
              {%- endif -%}
              <h3 class="arb-card__name">{{ p.title }}</h3>
              {%- if tag != blank -%}
                <p class="arb-card__tag">{{ tag }}</p>
              {%- endif -%}

              <div class="arb-card__price-row">
                <span class="arb-card__price">{{ p.price | money }}</span>
                {%- if p.compare_at_price > p.price -%}
                  <span class="arb-card__compare">{{ p.compare_at_price | money }}</span>
                {%- endif -%}
              </div>

              <span class="arb-card__hint" data-arb-hint>
                <span data-arb-hint-add>Tap to add</span>
                <span data-arb-hint-on hidden>✓ In your bundle</span>
              </span>
            </div>
          </button>
        {%- endif -%}
      {%- endfor -%}
    </main>
  {%- else -%}
    <div class="arb-empty">
      <h2>Bundle is being prepared</h2>
      <p>No products available yet. Please check back shortly, or browse the
        <a href="/collections/{{ coll_handle }}" style="color: var(--arb-gold); text-decoration: underline;">incense collection</a>.</p>
    </div>
  {%- endif -%}

  {%- comment -%} ── STICKY BAR ── {%- endcomment -%}
  <div class="arb-bar" data-arb-bar role="region" aria-label="Bundle progress">
    <div class="arb-bar__inner">
      <div class="arb-bar__progress">
        <div class="arb-bar__progress-row">
          <span class="arb-bar__label">
            Your bundle:
            <strong>
              <span data-arb-counter-bar>0</span> / {{ bundle_size }}
            </strong>
          </span>
          <span class="arb-bar__price">
            Bundle total: <strong>{{ bundle_price }}</strong>
          </span>
        </div>
        <div class="arb-bar__track" aria-hidden="true">
          <span class="arb-bar__fill" data-arb-fill></span>
        </div>
      </div>
      <div class="arb-bar__actions">
        <button type="button" class="arb-bar__clear" data-arb-clear>
          {{ cta_clear }}
        </button>
        <button type="button" class="arb-bar__add" data-arb-add disabled>
          <span class="arb-bar__add-text" data-arb-add-text>{{ cta_add }}</span>
          <span class="arb-bar__add-icon" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} ── TOAST ── {%- endcomment -%}
  <div class="arb-toast" data-arb-toast role="status" aria-live="polite"></div>
</div>

<script>
(function () {
  'use strict';

  var root = document.querySelector('.arb[data-section-id="{{ section.id }}"]');
  if (!root) return;

  /* ── COUNTDOWN ─────────────────────────────────────── */
  (function () {
    var el = root.querySelector('[data-arb-countdown]');
    if (!el) return;

    var minutes = parseInt(el.getAttribute('data-minutes'), 10) || 60;
    var key = 'arb_offer_end_v1_{{ section.id }}';
    var stored = parseInt(window.sessionStorage ? sessionStorage.getItem(key) : 0, 10);
    var now = Date.now();
    var endTs;

    if (stored && stored > now) {
      endTs = stored;
    } else {
      endTs = now + (minutes * 60 * 1000);
      try { if (window.sessionStorage) sessionStorage.setItem(key, String(endTs)); } catch (e) {}
    }

    var hEl = el.querySelector('[data-unit="hours"]');
    var mEl = el.querySelector('[data-unit="minutes"]');
    var sEl = el.querySelector('[data-unit="seconds"]');

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function tick() {
      var diff = endTs - Date.now();
      if (diff <= 0) {
        if (hEl) hEl.textContent = '00';
        if (mEl) mEl.textContent = '00';
        if (sEl) sEl.textContent = '00';
        el.classList.add('is-expired');
        clearInterval(timer);
        return;
      }
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      if (hEl) hEl.textContent = pad(h);
      if (mEl) mEl.textContent = pad(m);
      if (sEl) sEl.textContent = pad(s);
    }

    tick();
    var timer = setInterval(tick, 1000);
  })();

  /* ── BUNDLE PICKER ─────────────────────────────────── */
  var grid = root.querySelector('#arb-grid');
  if (!grid) return;

  var bundleSize = parseInt(grid.getAttribute('data-bundle-size'), 10) || 3;
  var cards      = Array.prototype.slice.call(grid.querySelectorAll('[data-arb-card]'));
  var bar        = root.querySelector('[data-arb-bar]');
  var fill       = root.querySelector('[data-arb-fill]');
  var counterEls = root.querySelectorAll('[data-arb-counter], [data-arb-counter-bar]');
  var addBtn     = root.querySelector('[data-arb-add]');
  var addText    = root.querySelector('[data-arb-add-text]');
  var clearBtn   = root.querySelector('[data-arb-clear]');
  var toast      = root.querySelector('[data-arb-toast]');

  var DISCOUNT_CODE = {{ disc_code | json }};

  /* selected: array of variantIds in selection order */
  var selected = [];

  function renderState() {
    cards.forEach(function (card) {
      var vid = card.getAttribute('data-variant-id');
      var idx = selected.indexOf(vid);
      var rankEl = card.querySelector('[data-arb-rank]');
      var hintAdd = card.querySelector('[data-arb-hint-add]');
      var hintOn  = card.querySelector('[data-arb-hint-on]');

      if (idx > -1) {
        card.classList.add('is-selected');
        card.classList.remove('is-disabled');
        card.setAttribute('aria-pressed', 'true');
        if (rankEl) rankEl.textContent = (idx + 1);
        if (hintAdd) hintAdd.hidden = true;
        if (hintOn)  hintOn.hidden  = false;
      } else {
        card.classList.remove('is-selected');
        card.setAttribute('aria-pressed', 'false');
        if (rankEl) rankEl.textContent = '';
        if (hintAdd) hintAdd.hidden = false;
        if (hintOn)  hintOn.hidden  = true;

        if (selected.length >= bundleSize) {
          card.classList.add('is-disabled');
        } else {
          card.classList.remove('is-disabled');
        }
      }
    });

    counterEls.forEach(function (el) { el.textContent = String(selected.length); });
    if (fill) fill.style.width = (Math.min(selected.length, bundleSize) / bundleSize * 100) + '%';

    if (bar) {
      if (selected.length > 0) bar.classList.add('is-visible');
      else bar.classList.remove('is-visible');
    }

    if (addBtn) {
      if (selected.length === bundleSize) {
        addBtn.disabled = false;
        if (addText) addText.textContent = '{{ cta_add | escape }}';
      } else {
        addBtn.disabled = true;
        if (addText) {
          var remaining = bundleSize - selected.length;
          addText.textContent = 'Pick ' + remaining + ' more fragrance' + (remaining === 1 ? '' : 's');
        }
      }
    }
  }

  function showToast(msg, isError) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.toggle('is-error', !!isError);
    toast.classList.add('is-visible');
    clearTimeout(toast._t);
    toast._t = setTimeout(function () {
      toast.classList.remove('is-visible');
    }, 2400);
  }

  cards.forEach(function (card) {
    card.addEventListener('click', function () {
      var vid = card.getAttribute('data-variant-id');
      var title = card.getAttribute('data-title') || 'Fragrance';
      var idx = selected.indexOf(vid);

      if (idx > -1) {
        selected.splice(idx, 1);
        renderState();
        return;
      }

      if (selected.length >= bundleSize) {
        showToast('Bundle full — remove one to swap fragrances.', true);
        return;
      }

      selected.push(vid);
      renderState();
      showToast('Added "' + title + '" to your bundle.');
    });
  });

  if (clearBtn) {
    clearBtn.addEventListener('click', function () {
      if (selected.length === 0) return;
      selected = [];
      renderState();
      showToast('Bundle cleared.');
    });
  }

  /* ── SUBMIT BUNDLE ─────────────────────────────────── */
  if (addBtn) {
    addBtn.addEventListener('click', function () {
      if (selected.length !== bundleSize || addBtn.disabled) return;

      addBtn.disabled = true;
      addBtn.classList.add('is-loading');
      if (addText) addText.textContent = 'Adding...';

      var items = selected.map(function (id) {
        return { id: parseInt(id, 10), quantity: 1 };
      });

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ items: items })
      })
        .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
        .then(function (result) {
          if (!result.ok) {
            var msg = (result.data && (result.data.description || result.data.message)) || 'Could not add bundle to cart.';
            throw new Error(msg);
          }

          addBtn.classList.remove('is-loading');
          addBtn.classList.add('is-success');
          if (addText) addText.textContent = 'Bundle added — opening cart...';

          /* publish update to refresh cart drawer/bubble if Dawn-style PubSub is present */
          try {
            if (window.PUB_SUB_EVENTS && typeof publish === 'function') {
              publish(window.PUB_SUB_EVENTS.cartUpdate, {
                source: 'incense-bundle-offer',
                productVariantId: items[0].id,
                cartData: result.data
              });
            }
          } catch (e) { /* no-op */ }

          /* clear stored countdown so it resets after a successful purchase flow */
          try { sessionStorage.removeItem('arb_offer_end_v1_{{ section.id }}'); } catch (e) {}

          var redirect = '/cart';
          if (DISCOUNT_CODE && DISCOUNT_CODE.length) {
            redirect = '/discount/' + encodeURIComponent(DISCOUNT_CODE) + '?redirect=' + encodeURIComponent('/cart');
          }
          setTimeout(function () { window.location.href = redirect; }, 450);
        })
        .catch(function (err) {
          addBtn.classList.remove('is-loading');
          addBtn.disabled = false;
          if (addText) addText.textContent = '{{ cta_add | escape }}';
          showToast(err.message || 'Something went wrong. Please try again.', true);
        });
    });
  }

  renderState();
})();
</script>

{%- schema -%}
{
  "name": "Incense Bundle Offer",
  "settings": [
    { "type": "header", "content": "Bundle" },
    {
      "type": "collection",
      "id": "bundle_collection",
      "label": "Bundle source collection",
      "info": "Products shown to the customer to pick from."
    },
    {
      "type": "range",
      "id": "bundle_size",
      "label": "Items in bundle",
      "min": 2, "max": 6, "step": 1, "default": 3
    },
    {
      "type": "text",
      "id": "bundle_price_text",
      "label": "Displayed bundle price",
      "default": "₹599"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount code to auto-apply",
      "info": "After 'Add Bundle to Cart', the customer is sent to /discount/{code}?redirect=/cart so the discount is auto-applied. Leave empty to skip.",
      "default": "BUY3FOR599"
    },
    {
      "type": "range",
      "id": "offer_minutes",
      "label": "Offer countdown (minutes)",
      "min": 5, "max": 240, "step": 5, "default": 60
    },

    { "type": "header", "content": "Hero" },
    { "type": "text",     "id": "hero_eyebrow", "label": "Eyebrow",  "default": "Special Discount" },
    { "type": "text",     "id": "hero_title",   "label": "Heading",  "default": "Buy any 3" },
    { "type": "textarea", "id": "hero_sub",     "label": "Sub-heading",
      "default": "Hand-picked incense sticks, crafted from pure botanicals. Mix any three fragrances and treat your space — or your loved ones — to a sacred ritual." },

    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "cta_pick",  "label": "Hero primary CTA", "default": "Pick Your 3 Fragrances" },
    { "type": "text", "id": "cta_secondary_text", "label": "Hero secondary CTA text" },
