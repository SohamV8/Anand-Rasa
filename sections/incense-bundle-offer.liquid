{% comment %}
  Build Your Incense Box — flagship bundle builder.
  Template: build-3-incense | View: ?view=build-3-incense
{% endcomment %}

{%- liquid
  assign bundle_coll = section.settings.bundle_collection
  assign bundle_fallback_handles = 'incense-sticks,incense-stick,incense' | split: ','
  if bundle_coll == blank or bundle_coll.products_count == 0
    for bundle_h in bundle_fallback_handles
      assign bundle_h_clean = bundle_h | strip
      if collections[bundle_h_clean] != blank and collections[bundle_h_clean].products_count > 0
        assign bundle_coll = collections[bundle_h_clean]
        break
      endif
    endfor
  endif

  assign bundle_size = section.settings.bundle_size | default: 3
  assign bundle_price = section.settings.bundle_price_text | default: '₹600'
  assign disc_code = section.settings.discount_code | default: 'BUY3FOR600'
  assign cta_add = section.settings.cta_add | default: 'Add Bundle to Cart'
  assign cta_clear = section.settings.cta_clear | default: 'Clear'
  assign default_burn = section.settings.default_burn_time | default: '45–60 minutes'

  assign hero_eyebrow = section.settings.hero_eyebrow | default: 'BUILD YOUR INCENSE BOX'
  assign hero_title = section.settings.hero_title | default: 'Choose Your Daily Ritual.'
  assign hero_sub = section.settings.hero_sub | default: 'Create your own incense collection from our handcrafted blends inspired by Indian temples, nature and tradition.'
  assign hero_cta = section.settings.cta_pick | default: 'Start Building'
  assign hero_secondary = section.settings.hero_secondary | default: 'Choose Any 3 Packs'
-%}

{% render 'build-box-incense-assets', part: 'styles' %}

<div
  class="bib"
  data-bib-root
  data-section-id="{{ section.id }}"
  id="build-incense-box"
>
  <script type="application/json" data-bib-config>
    {
      "bundleSize": {{ bundle_size }},
      "bundlePrice": {{ bundle_price | json }},
      "discountCode": {{ disc_code | json }},
      "ctaAdd": {{ cta_add | json }},
      "ctaClear": {{ cta_clear | json }},
      "moneyFormat": {{ shop.money_format | json }}
    }
  </script>

  {%- comment -%} ── HERO ── {%- endcomment -%}
  <header class="bib-hero" data-bib-reveal>
    <div class="bib-hero__grid">
      <div class="bib-hero__visual">
        <div class="bib-hero__frame" aria-hidden="true">
          {%- if section.settings.hero_image != blank -%}
            <img
              class="bib-hero__img"
              src="{{ section.settings.hero_image | image_url: width: 1200 }}"
              srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w"
              sizes="(min-width: 900px) 52vw, (min-width: 600px) 80vw, 94vw"
              alt="{{ section.settings.hero_image.alt | default: 'Handcrafted Anand Rasa incense sticks' | escape }}"
              width="1200"
              height="1200"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            >
          {%- else -%}
            <img
              class="bib-hero__img"
              src="{{ 'incense/incense_collection.webp' | asset_url }}"
              alt="Handcrafted Anand Rasa incense sticks"
              width="1200"
              height="1200"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            >
          {%- endif -%}
        </div>
      </div>
      <div class="bib-hero__copy">
        <p class="bib-hero__eyebrow">{{ hero_eyebrow }}</p>
        <h1 class="bib-hero__title">{{ hero_title }}</h1>
        <p class="bib-hero__sub">{{ hero_sub }}</p>
        <ul class="bib-hero__features" aria-label="Product highlights">
          <li>Natural Ingredients</li>
          <li>Low Smoke</li>
          <li>Long Burning</li>
          <li>Made In India</li>
        </ul>
        <div class="bib-hero__ctas">
          <a href="#bib-grid" class="bib-btn bib-btn--primary">{{ hero_cta | default: 'Start Building' }}</a>
          <span class="bib-hero__offer">{{ hero_secondary }} · <strong>{{ bundle_price }}</strong></span>
        </div>
      </div>
    </div>
  </header>

  {%- comment -%} ── TRUST ── {%- endcomment -%}
  <section class="bib-trust" aria-label="Why trust Anand Rasa incense" data-bib-reveal>
    <div class="bib-wrap">
      <ul class="bib-trust__list">
        <li><span class="bib-trust__icon">{% render 'incense-box-landing-icon', icon: 'leaf' %}</span>Natural Ingredients</li>
        <li><span class="bib-trust__icon">{% render 'incense-box-landing-icon', icon: 'craft' %}</span>Handcrafted</li>
        <li><span class="bib-trust__icon">{% render 'incense-box-landing-icon', icon: 'smoke' %}</span>Low Smoke</li>
        <li><span class="bib-trust__icon">{% render 'incense-box-landing-icon', icon: 'temple' %}</span>Temple Inspired</li>
        <li><span class="bib-trust__icon">{% render 'incense-box-landing-icon', icon: 'craft' %}</span>Made In India</li>
        <li><span class="bib-trust__icon">{% render 'incense-box-landing-icon', icon: 'clock' %}</span>Long Lasting</li>
      </ul>
    </div>
  </section>

  {%- comment -%} ── PRODUCT GRID ── {%- endcomment -%}
  <section class="bib-grid-section bib-section" id="bib-grid" aria-labelledby="bib-grid-heading" data-bib-reveal>
    <div class="bib-wrap">
      <header class="bib-section__head">
        <h2 id="bib-grid-heading" class="bib-section__title">Choose Your Fragrances</h2>
        <p class="bib-section__sub">Handcrafted incense · Pick any {{ bundle_size }} · Bundle {{ bundle_price }}</p>
      </header>

      {%- if bundle_coll != blank and bundle_coll.products_count > 0 -%}
        <div class="bib-grid" data-bib-grid data-bundle-size="{{ bundle_size }}">
          {%- for p in bundle_coll.products -%}
            {% render 'incense-box-product-card', product: p, index: forloop.index0, default_burn_time: default_burn %}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="bib-empty">
          <h2>Bundle is being prepared</h2>
          <p>Please check back shortly, or <a href="{% render 'ar-collection-url', handle: 'incense-sticks' %}">browse incense sticks</a>.</p>
        </div>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} ── HOW TO USE ── {%- endcomment -%}
  <section class="bib-how bib-section" aria-labelledby="bib-how-heading" data-bib-reveal>
    <div class="bib-wrap">
      <h2 id="bib-how-heading" class="bib-section__title">How to Use</h2>
      <div class="bib-how__grid">
        <article class="bib-how__card">
          <span class="bib-how__icon">{% render 'incense-box-landing-icon', icon: 'flame' %}</span>
          <h3>Light incense</h3>
          <p>Hold the tip to a flame until it glows, then blow gently to release the aroma.</p>
        </article>
        <article class="bib-how__card">
          <span class="bib-how__icon">{% render 'incense-box-landing-icon', icon: 'safe' %}</span>
          <h3>Place safely</h3>
          <p>Use a heat-resistant holder in a ventilated space, away from fabrics and drafts.</p>
        </article>
        <article class="bib-how__card">
          <span class="bib-how__icon">{% render 'incense-box-landing-icon', icon: 'relax' %}</span>
          <h3>Relax and enjoy</h3>
          <p>Let the fragrance settle. Breathe slowly and enjoy your quiet ritual.</p>
        </article>
      </div>
    </div>
  </section>

  {%- comment -%} ── WHY ── {%- endcomment -%}
  <section class="bib-why bib-section" aria-labelledby="bib-why-heading" data-bib-reveal>
    <div class="bib-wrap">
      <h2 id="bib-why-heading" class="bib-section__title">Why Our Incense</h2>
      <p class="bib-why__seo bib-sr-focus">Low smoke incense · Made in India · Handcrafted incense sticks</p>
      <div class="bib-why__grid">
        <article class="bib-why__card" data-bib-reveal style="--bib-i: 0;">
          <span class="bib-why__icon">{% render 'incense-box-landing-icon', icon: 'leaf' %}</span>
          <h3>Natural Ingredients</h3>
          <p>Botanicals and essential oils — mindful, clean, everyday ritual.</p>
        </article>
        <article class="bib-why__card" data-bib-reveal style="--bib-i: 1;">
          <span class="bib-why__icon">{% render 'incense-box-landing-icon', icon: 'smoke' %}</span>
          <h3>Low Smoke</h3>
          <p>A gentler burn for your home, your breath, your peace.</p>
        </article>
        <article class="bib-why__card" data-bib-reveal style="--bib-i: 2;">
          <span class="bib-why__icon">{% render 'incense-box-landing-icon', icon: 'craft' %}</span>
          <h3>Handcrafted</h3>
          <p>Made by artisans who carry forward generations of craft.</p>
        </article>
        <article class="bib-why__card" data-bib-reveal style="--bib-i: 3;">
          <span class="bib-why__icon">{% render 'incense-box-landing-icon', icon: 'temple' %}</span>
          <h3>Temple Inspired</h3>
          <p>Fragrances rooted in Indian devotional tradition.</p>
        </article>
      </div>
    </div>
  </section>

  {%- comment -%} ── CUSTOMER LOVE ── {%- endcomment -%}
  {%- liquid
    assign bib_review_rows = "My morning pooja feels complete now.~|~Priya~|~Mumbai||Ghar mein lagate hi smell settle ho jati hai — zyada heavy nahi.~|~Pooja~|~Indore||धूप जैसी भारी धुआँ नहीं — हल्की खुशबू, टिकती भी है।~|~रीता~|~Jaipur||Clean burn — meri mummy ne bola yehi dubara mangwana.~|~Divya~|~Vadodara||Perfect for meditation after work.~|~Kavya~|~Bangalore||Shaam ki chai ke saath — habit ban gayi hai.~|~Rahul~|~Jaipur" | split: '||'
  -%}
  <section class="bib-reviews bib-section" aria-labelledby="bib-reviews-heading" data-bib-reveal>
    <div class="bib-wrap">
      <header class="bib-reviews__head">
        <div>
          <h2 id="bib-reviews-heading" class="bib-section__title">Customer Love</h2>
          <p class="bib-reviews__rating"><span aria-hidden="true">★★★★★</span> 4.9/5 · Verified buyers</p>
        </div>
      </header>
      <div class="bib-reviews__viewport" role="region" aria-label="Customer reviews">
        <div class="bib-reviews__track">
          {%- for bib_review_copy in (1..2) -%}
            <div class="bib-reviews__group"{% if bib_review_copy == 2 %} aria-hidden="true"{% endif %}>
              {%- for row in bib_review_rows -%}
                {%- assign bib_parts = row | split: '~|~' -%}
                <blockquote class="bib-reviews__card">
                  <p{% if bib_parts[0] contains '।' or bib_parts[0] contains 'ह' %} lang="hi"{% endif %}>{{ bib_parts[0] }}</p>
                  <cite>{{ bib_parts[1] }}, {{ bib_parts[2] }}</cite>
                </blockquote>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── PERFECT FOR ── {%- endcomment -%}
  <section class="bib-perfect bib-section" aria-labelledby="bib-perfect-heading" data-bib-reveal>
    <div class="bib-wrap">
      <h2 id="bib-perfect-heading" class="bib-section__title">Perfect For</h2>
      <ul class="bib-perfect__grid">
        <li><span class="bib-perfect__icon">{% render 'incense-box-landing-icon', icon: 'gift' %}</span>Gifting</li>
        <li><span class="bib-perfect__icon">{% render 'incense-box-landing-icon', icon: 'meditate' %}</span>Meditation</li>
        <li><span class="bib-perfect__icon">{% render 'incense-box-landing-icon', icon: 'pooja' %}</span>Pooja</li>
        <li><span class="bib-perfect__icon">{% render 'incense-box-landing-icon', icon: 'yoga' %}</span>Yoga</li>
        <li><span class="bib-perfect__icon">{% render 'incense-box-landing-icon', icon: 'ritual' %}</span>Daily rituals</li>
      </ul>
    </div>
  </section>

  {% render 'incense-box-modal' %}

  {%- comment -%} ── STICKY FOOTER ── {%- endcomment -%}
  <footer class="bib-dock" data-bib-dock role="region" aria-label="Your incense box">
    <div class="bib-dock__inner">
      <div class="bib-dock__selected" data-bib-dock-items aria-live="polite"></div>
      <div class="bib-dock__meta">
        <span class="bib-dock__count"><span data-bib-dock-counter>0</span>/{{ bundle_size }} packs</span>
        <span class="bib-dock__remain" data-bib-dock-remain>Pick {{ bundle_size }} fragrances</span>
        <span class="bib-dock__price">Bundle <strong>{{ bundle_price }}</strong></span>
      </div>
      <div class="bib-dock__actions">
        <button type="button" class="bib-dock__clear" data-bib-clear>{{ cta_clear }}</button>
        <button type="button" class="bib-dock__checkout" data-bib-checkout disabled>
          <span data-bib-checkout-text>{{ cta_add }}</span>
        </button>
      </div>
    </div>
  </footer>

  <div class="bib-toast" data-bib-toast role="status" aria-live="polite"></div>
</div>

{% render 'build-box-incense-assets', part: 'scripts' %}

{% schema %}
{
  "name": "Build Your Incense Box",
  "tag": "section",
  "class": "section-build-incense-box",
  "settings": [
    { "type": "header", "content": "Bundle" },
    {
      "type": "collection",
      "id": "bundle_collection",
      "label": "Incense collection"
    },
    {
      "type": "range",
      "id": "bundle_size",
      "label": "Packs in bundle",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "bundle_price_text",
      "label": "Bundle price display",
      "default": "₹600"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount code",
      "default": "BUY3FOR600",
      "info": "Auto-applied after add to cart via /discount/{code}?redirect=/cart"
    },
    {
      "type": "text",
      "id": "default_burn_time",
      "label": "Default burn time (modal)",
      "default": "45–60 minutes"
    },
    { "type": "header", "content": "Hero" },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Defaults to incense collection artwork. object-fit: contain — never crops."
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow",
      "default": "BUILD YOUR INCENSE BOX"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Heading",
      "default": "Choose Your Daily Ritual."
    },
    {
      "type": "textarea",
      "id": "hero_sub",
      "label": "Subheading",
      "default": "Create your own incense collection from our handcrafted blends inspired by Indian temples, nature and tradition."
    },
    {
      "type": "text",
      "id": "hero_secondary",
      "label": "Offer line",
      "default": "Choose Any 3 Packs"
    },
    { "type": "header", "content": "Buttons" },
    {
      "type": "text",
      "id": "cta_pick",
      "label": "Hero CTA",
      "default": "Start Building"
    },
    {
      "type": "text",
      "id": "cta_add",
      "label": "Checkout button",
      "default": "Add Bundle to Cart"
    },
    {
      "type": "text",
      "id": "cta_clear",
      "label": "Clear button",
      "default": "Clear"
    }
  ],
  "presets": [{ "name": "Build Your Incense Box" }]
}
{% endschema %}
