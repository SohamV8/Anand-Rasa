{% comment %}
  Anand Rasa — Bestseller Collection Hero
  Use on collection.bestseller template only.
{% endcomment %}

{%- liquid
  assign bsh_id = section.id
  assign bsh_heading = section.settings.heading | default: collection.title | default: 'Bestsellers'
  assign bsh_subheading = section.settings.subheading | default: 'Our most loved attars and fragrances—handpicked from across Anand Rasa for depth, longevity, and everyday ritual.'
  assign bsh_support = section.settings.supporting_text | default: 'Customer favorites you can trust, from signature attars to calming blends loved again and again.'
-%}

<style>
  #shopify-section-{{ bsh_id }} .bsh {
    --bsh-bg: {{ section.settings.bg_color | default: '#FFFFFF' }};
    --bsh-ink: #1A1A1A;
    --bsh-ink-2: #4A4540;
    --bsh-ink-3: #7A746C;
    --bsh-gold: #B8943A;
    --bsh-ease: cubic-bezier(0.25, 1, 0.5, 1);
    --bsh-font-h: var(--font-heading-family, 'Cormorant Garamond', Georgia, serif);
    --bsh-font-b: var(--font-body-family, 'Poppins', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
    background: var(--bsh-bg);
    font-family: var(--bsh-font-b);
    color: var(--bsh-ink);
  }

  #shopify-section-{{ bsh_id }} .bsh__inner {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 96px) clamp(24px, 5vw, 48px) clamp(48px, 7vw, 72px);
    text-align: center;
  }

  #shopify-section-{{ bsh_id }} .bsh__eyebrow {
    display: block;
    margin: 0 0 18px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--bsh-gold);
    opacity: 0;
    transform: translateY(14px);
    animation: bsh-up 0.7s var(--bsh-ease) 0.05s forwards;
  }

  #shopify-section-{{ bsh_id }} .bsh__title {
    margin: 0;
    font-family: var(--bsh-font-h);
    font-size: clamp(32px, 4.8vw, 56px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--bsh-ink);
    opacity: 0;
    transform: translateY(18px);
    animation: bsh-up 0.75s var(--bsh-ease) 0.12s forwards;
  }

  #shopify-section-{{ bsh_id }} .bsh__rule {
    display: block;
    width: 48px;
    height: 1.5px;
    margin: clamp(22px, 3vw, 28px) auto;
    background: linear-gradient(90deg, transparent, var(--bsh-gold) 20%, var(--bsh-gold) 80%, transparent);
    border-radius: 999px;
    transform: scaleX(0);
    animation: bsh-line 0.8s var(--bsh-ease) 0.28s forwards;
  }

  #shopify-section-{{ bsh_id }} .bsh__lead {
    margin: 0 auto;
    max-width: 640px;
    font-size: clamp(15px, 1.65vw, 18px);
    line-height: 1.8;
    font-weight: 300;
    color: var(--bsh-ink-2);
    letter-spacing: 0.01em;
    opacity: 0;
    transform: translateY(16px);
    animation: bsh-up 0.75s var(--bsh-ease) 0.34s forwards;
  }

  #shopify-section-{{ bsh_id }} .bsh__support {
    margin: clamp(20px, 3vw, 28px) auto 0;
    max-width: 560px;
    font-size: clamp(13px, 1.35vw, 15px);
    line-height: 1.7;
    font-weight: 300;
    color: var(--bsh-ink-3);
    opacity: 0;
    transform: translateY(14px);
    animation: bsh-up 0.75s var(--bsh-ease) 0.46s forwards;
  }

  @keyframes bsh-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bsh-line {
    to {
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ bsh_id }} .bsh__eyebrow,
    #shopify-section-{{ bsh_id }} .bsh__title,
    #shopify-section-{{ bsh_id }} .bsh__rule,
    #shopify-section-{{ bsh_id }} .bsh__lead,
    #shopify-section-{{ bsh_id }} .bsh__support {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

<header class="bsh" id="bsh-{{ bsh_id }}">
  <div class="bsh__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="bsh__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h1 class="bsh__title">{{ bsh_heading | escape }}</h1>

    <span class="bsh__rule" aria-hidden="true"></span>

    <p class="bsh__lead">{{ bsh_subheading }}</p>

    {%- if bsh_support != blank -%}
      <p class="bsh__support">{{ bsh_support }}</p>
    {%- endif -%}
  </div>
</header>

{% schema %}
{
  "name": "Bestseller Hero",
  "tag": "section",
  "class": "section-bestseller-hero",
  "settings": [
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Anand Rasa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H1)",
      "default": "Bestsellers"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our most loved attars and fragrances—handpicked from across Anand Rasa for depth, longevity, and everyday ritual."
    },
    {
      "type": "textarea",
      "id": "supporting_text",
      "label": "Supporting text",
      "default": "Customer favorites you can trust, from signature attars to calming blends loved again and again."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Bestseller Hero"
    }
  ]
}
{% endschema %}
