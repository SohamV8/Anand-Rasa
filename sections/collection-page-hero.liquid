{% comment %}
  Anand Rasa — minimal collection page hero (Bestsellers-style).
  Pair with collection sections using layout_mode: products_only.
{% endcomment %}

{%- liquid
  assign cph_id = section.id
  assign cph_heading = section.settings.heading | default: collection.title
  assign cph_subheading = section.settings.subheading
  assign cph_support = section.settings.supporting_text
-%}

<style>
  #shopify-section-{{ cph_id }} .cph {
    --cph-bg: {{ section.settings.bg_color | default: '#FFFFFF' }};
    --cph-ink: #1A1A1A;
    --cph-ink-2: #4A4540;
    --cph-ink-3: #7A746C;
    --cph-gold: #B8943A;
    --cph-ease: cubic-bezier(0.25, 1, 0.5, 1);
    --cph-font-h: var(--font-heading-family, 'Cormorant Garamond', Georgia, serif);
    --cph-font-b: var(--font-body-family, 'Poppins', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
    background: var(--cph-bg);
    font-family: var(--cph-font-b);
    color: var(--cph-ink);
  }

  #shopify-section-{{ cph_id }} .cph__inner {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 96px) clamp(24px, 5vw, 48px) clamp(48px, 7vw, 72px);
    text-align: center;
  }

  #shopify-section-{{ cph_id }} .cph__eyebrow {
    display: block;
    margin: 0 0 18px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cph-gold);
    opacity: 0;
    transform: translateY(14px);
    animation: cph-up 0.7s var(--cph-ease) 0.05s forwards;
  }

  #shopify-section-{{ cph_id }} .cph__title {
    margin: 0;
    font-family: var(--cph-font-h);
    font-size: clamp(32px, 4.8vw, 56px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--cph-ink);
    opacity: 0;
    transform: translateY(18px);
    animation: cph-up 0.75s var(--cph-ease) 0.12s forwards;
  }

  #shopify-section-{{ cph_id }} .cph__rule {
    display: block;
    width: 48px;
    height: 1.5px;
    margin: clamp(22px, 3vw, 28px) auto;
    background: linear-gradient(90deg, transparent, var(--cph-gold) 20%, var(--cph-gold) 80%, transparent);
    border-radius: 999px;
    transform: scaleX(0);
    animation: cph-line 0.8s var(--cph-ease) 0.28s forwards;
  }

  #shopify-section-{{ cph_id }} .cph__lead {
    margin: 0 auto;
    max-width: 640px;
    font-size: clamp(15px, 1.65vw, 18px);
    line-height: 1.8;
    font-weight: 300;
    color: var(--cph-ink-2);
    letter-spacing: 0.01em;
    opacity: 0;
    transform: translateY(16px);
    animation: cph-up 0.75s var(--cph-ease) 0.34s forwards;
  }

  #shopify-section-{{ cph_id }} .cph__support {
    margin: clamp(20px, 3vw, 28px) auto 0;
    max-width: 560px;
    font-size: clamp(13px, 1.35vw, 15px);
    line-height: 1.7;
    font-weight: 300;
    color: var(--cph-ink-3);
    opacity: 0;
    transform: translateY(14px);
    animation: cph-up 0.75s var(--cph-ease) 0.46s forwards;
  }

  @keyframes cph-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes cph-line {
    to {
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ cph_id }} .cph__eyebrow,
    #shopify-section-{{ cph_id }} .cph__title,
    #shopify-section-{{ cph_id }} .cph__rule,
    #shopify-section-{{ cph_id }} .cph__lead,
    #shopify-section-{{ cph_id }} .cph__support {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

<header class="cph" id="cph-{{ cph_id }}">
  <div class="cph__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="cph__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h1 class="cph__title">{{ cph_heading | escape }}</h1>

    <span class="cph__rule" aria-hidden="true"></span>

    {%- if cph_subheading != blank -%}
      <p class="cph__lead">{{ cph_subheading }}</p>
    {%- endif -%}

    {%- if cph_support != blank -%}
      <p class="cph__support">{{ cph_support }}</p>
    {%- endif -%}
  </div>
</header>

{% schema %}
{
  "name": "Collection Page Hero",
  "tag": "section",
  "class": "section-collection-page-hero",
  "settings": [
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Anand Rasa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H1)",
      "default": "Collection"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "supporting_text",
      "label": "Supporting text"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Collection Page Hero"
    }
  ]
}
{% endschema %}
