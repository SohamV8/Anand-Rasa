{%- comment -%}
  Anand Rasa — Enterprise FAQ Page
  templates/page.faq.json → sections/main-faq.liquid
{%- endcomment -%}

{%- liquid
  assign arf_heading = section.settings.heading | default: 'Frequently Asked Questions'
  assign arf_subtext = section.settings.subtext | default: 'Clear answers about our handcrafted attars, incense, orders, and spiritual fragrance collections.'
  capture arf_schema_url
    render 'ar-faq-url', absolute: true
  endcapture
  assign arf_schema_url = arf_schema_url | strip
  assign arf_contact_url = pages['contact'].url | default: pages['contact-us'].url
  if arf_contact_url == blank
    capture arf_contact_url
      render 'ar-page-url', handle: 'contact'
    endcapture
    assign arf_contact_url = arf_contact_url | strip
  endif
-%}

<style>
  .arf {
    --arf-ink: #0a0a0a;
    --arf-ink-2: #3a3a3a;
    --arf-ink-3: #6b6b6b;
    --arf-border: #e5e5e5;
    --arf-bg: #ffffff;
    --arf-surface: #fafafa;
    --arf-gold: #b8943a;
    --arf-ease: cubic-bezier(0.25, 1, 0.5, 1);
    --arf-fh: var(--font-heading-family, Georgia, serif);
    --arf-fb: var(--font-body-family, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
    font-family: var(--arf-fb);
    background: var(--arf-bg);
    color: var(--arf-ink);
    -webkit-font-smoothing: antialiased;
  }

  .arf *, .arf *::before, .arf *::after { box-sizing: border-box; }

  .arf__wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(48px, 8vw, 96px) clamp(20px, 5vw, 48px) clamp(64px, 10vw, 112px);
  }

  .arf__header {
    margin-bottom: clamp(40px, 6vw, 56px);
    padding-bottom: 32px;
    border-bottom: 1px solid var(--arf-border);
  }

  .arf__eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--arf-ink-3);
    margin-bottom: 14px;
  }

  .arf__title {
    font-family: var(--arf-fh);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--arf-ink);
    margin: 0 0 16px;
  }

  .arf__sub {
    font-size: clamp(15px, 1.8vw, 17px);
    line-height: 1.65;
    color: var(--arf-ink-3);
    font-weight: 400;
    max-width: 52ch;
    margin: 0;
  }

  .arf__cat {
    font-family: var(--arf-fh);
    font-size: clamp(13px, 1.5vw, 15px);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--arf-ink);
    margin: 40px 0 16px;
    padding-top: 8px;
  }

  .arf__cat:first-of-type { margin-top: 0; }

  .arf__group {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--arf-border);
  }

  .arf__details {
    border-bottom: 1px solid var(--arf-border);
  }

  .arf__summary {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 20px 0;
    margin: 0;
    cursor: pointer;
    list-style: none;
    font-family: inherit;
    color: var(--arf-ink);
    transition: color 0.2s var(--arf-ease);
  }

  .arf__summary::-webkit-details-marker,
  .arf__summary::marker {
    display: none;
    content: '';
  }

  .arf__summary:hover,
  .arf__summary:focus-visible {
    color: var(--arf-ink-2);
    outline: none;
  }

  .arf__details[open] > .arf__summary {
    color: var(--arf-ink);
  }

  .arf__summary:focus-visible {
    box-shadow: inset 0 0 0 2px var(--arf-ink);
    border-radius: 2px;
  }

  .arf__q {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.01em;
    flex: 1;
    padding-top: 2px;
  }

  .arf__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-top: 4px;
    position: relative;
    color: var(--arf-ink-3);
    transition: transform 0.25s var(--arf-ease), color 0.2s var(--arf-ease);
  }

  .arf__icon::before,
  .arf__icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .arf__icon::before { width: 12px; height: 1.5px; }
  .arf__icon::after { width: 1.5px; height: 12px; transition: opacity 0.2s var(--arf-ease); }

  .arf__details[open] .arf__icon::after { opacity: 0; }
  .arf__details[open] .arf__icon { transform: rotate(45deg); color: var(--arf-ink); }

  .arf__answer {
    margin: 0;
    padding: 0 0 22px;
    font-size: 15px;
    line-height: 1.7;
    color: var(--arf-ink-2);
    font-weight: 400;
    max-width: 62ch;
  }

  .arf__details[open] .arf__answer {
    animation: arf-reveal 0.3s var(--arf-ease);
  }

  @keyframes arf-reveal {
    from { opacity: 0.6; }
    to { opacity: 1; }
  }

  .arf__answer a {
    color: var(--arf-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }

  .arf__answer a:hover { opacity: 0.65; }

  .arf__foot {
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid var(--arf-border);
    font-size: 14px;
    line-height: 1.6;
    color: var(--arf-ink-3);
    text-align: center;
  }

  .arf__foot a {
    color: var(--arf-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .arf__icon,
    .arf__icon::after,
    .arf__details[open] .arf__answer { animation: none; transition: none; }
  }

  @media (max-width: 600px) {
    .arf__summary { padding: 18px 0; gap: 16px; }
    .arf__q { font-size: 14px; }
    .arf__answer { font-size: 14px; padding-bottom: 18px; }
  }
</style>

{%- comment -%} FAQPage JSON-LD — must match visible Q&A {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "name": {{ arf_heading | json }},
  "description": {{ arf_subtext | strip_html | json }},
  "url": {{ arf_schema_url | json }},
  "mainEntity": [
    {%- assign arf_schema_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'question' and block.settings.question != blank and block.settings.answer != blank -%}
        {%- if arf_schema_count > 0 -%},{%- endif -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }
        {%- assign arf_schema_count = arf_schema_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>

<section
  class="arf"
  id="arf-{{ section.id }}"
  aria-labelledby="arf-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="arf__wrap">
    <header class="arf__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="arf__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="arf__title" id="arf-title-{{ section.id }}">{{ arf_heading }}</h1>
      {%- if arf_subtext != blank -%}
        <p class="arf__sub">{{ arf_subtext }}</p>
      {%- endif -%}
    </header>

    <div class="arf__body">
      {%- assign arf_group_open = false -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            {%- if arf_group_open -%}
              </section>
              {%- assign arf_group_open = false -%}
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h2 class="arf__cat" {{ block.shopify_attributes }}>{{ block.settings.title }}</h2>
            {%- endif -%}

          {%- when 'question' -%}
            {%- if block.settings.question != blank and block.settings.answer != blank -%}
              {%- unless arf_group_open -%}
                <section class="arf__group" aria-label="FAQ items">
                {%- assign arf_group_open = true -%}
              {%- endunless -%}
              {%- assign arf_item_id = 'arf-item-' | append: section.id | append: '-' | append: block.id -%}
              <details class="arf__details" id="{{ arf_item_id }}" {{ block.shopify_attributes }}>
                <summary class="arf__summary" id="{{ arf_item_id }}-summary">
                  <span class="arf__q">{{ block.settings.question }}</span>
                  <span class="arf__icon" aria-hidden="true"></span>
                </summary>
                <div class="arf__answer" id="{{ arf_item_id }}-answer">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
      {%- if arf_group_open -%}
        </section>
      {%- endif -%}
    </div>

    {%- if section.settings.show_contact_note -%}
      <p class="arf__foot">
        {{ section.settings.contact_note | default: 'Still have a question?' }}
        {%- if arf_contact_url != blank -%}
          <a href="{{ arf_contact_url }}">{{ section.settings.contact_link_label | default: 'Contact our team' }}</a>
        {%- endif -%}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ Page",
  "tag": "section",
  "class": "section-faq-page",
  "settings": [
    {
      "type": "header",
      "content": "Page header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Help Centre"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page title (H1)",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Introduction",
      "default": "Clear answers about our handcrafted attars, incense, orders, and spiritual fragrance collections."
    },
    {
      "type": "header",
      "content": "Footer note"
    },
    {
      "type": "checkbox",
      "id": "show_contact_note",
      "label": "Show contact note",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_note",
      "label": "Contact note",
      "default": "Still have a question?"
    },
    {
      "type": "text",
      "id": "contact_link_label",
      "label": "Contact link label",
      "default": "Contact our team"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Section heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Category"
        }
      ]
    },
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page"
    }
  ],
  "enabled_on": {
    "templates": ["page", "index"]
  }
}
{% endschema %}
