{% render 'planet-product-base', section: section, product: product %}

{% schema %}
{
  "name": "Sun Energy Attar",
  "settings": [
    { "type": "header", "content": "Brand & hero — Sun Energy" },
    { "type": "text", "id": "brand_text", "label": "Brand line (above title)", "default": "ANAND RAS" },
    { "type": "text", "id": "product_label", "label": "Product label (hidden in new layout; optional SEO)", "default": "Sun Energy Attar" },
    { "type": "textarea", "id": "short_description", "label": "Short description (below title)", "info": "Shown under the product title. Quantity appears above Add to cart. Overrides the short line when set.", "default": "A radiant attar crafted for confidence, leadership, and authority — uplifting your presence with solar vitality." },
