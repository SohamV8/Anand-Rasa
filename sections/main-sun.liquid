    { "type": "range", "id": "rating", "label": "Star rating (display)", "min": 1, "max": 5, "step": 1, "default": 5 },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "0" },
    { "type": "checkbox", "id": "show_buy_now", "label": "Show Buy Now button", "default": true },
    { "type": "text", "id": "trust_1", "label": "Trust line 1 — Sun", "default": "Confident expression" },
    { "type": "text", "id": "trust_2", "label": "Trust line 2 — Sun", "default": "Leadership energy" },
    { "type": "text", "id": "trust_3", "label": "Trust line 3 — Sun", "default": "Solar vitality" },
    { "type": "header", "content": "Info strip (3 columns) — Sun Energy" },
    { "type": "text", "id": "strip_col1", "label": "Column 1 — Description", "default": "Confidence and authority" },
    { "type": "text", "id": "strip_col2", "label": "Column 2 — Details", "default": "A luminous aroma to support power, vitality, and success in your daily path." },
    { "type": "text", "id": "strip_col3", "label": "Column 3 — Category", "default": "Planet Energy Attar" },
    { "type": "header", "content": "Why choose section — Sun Energy" },
    { "type": "text", "id": "why_heading", "label": "Heading", "default": "Why Choose Sun Energy Attar" },
    { "type": "textarea", "id": "why_sub", "label": "Subheading", "default": "Crafted to support confidence, leadership, and authority for a bold and successful mindset." },
    { "type": "header", "content": "Specifications table — Sun Energy" },
    { "type": "text", "id": "spec_origin", "label": "Country of Origin", "default": "India" },
    { "type": "text", "id": "spec_item_form", "label": "Item Form", "default": "Luxury Attar" },
    { "type": "text", "id": "spec_item_type", "label": "Focus", "default": "Power, Vitality, Success" },
    { "type": "text", "id": "spec_sticks", "label": "Ideal for", "default": "Leadership roles, confidence rituals, and high-impact days" },
    { "type": "text", "id": "spec_burn", "label": "Longevity", "default": "Long-lasting radiant presence" },
    { "type": "text", "id": "spec_length", "label": "Application", "default": "Dab on pulse points each morning" },
    { "type": "text", "id": "spec_fragrance", "label": "Fragrance (optional row)", "default": "Warm citrus • golden spice • soft woods" },
    { "type": "text", "id": "spec_ingredients", "label": "Key ingredients (optional row)", "default": "Natural resins, essential oils, premium aromatic botanicals" },
    { "type": "header", "content": "Recommended products — Sun Energy" },
    { "type": "collection", "id": "related_collection", "label": "Collection" },
    { "type": "text", "id": "related_heading", "label": "Heading", "default": "You May Also Like" },
    { "type": "text", "id": "related_sub", "label": "Subheading", "default": "More planetary aromas for your ritual" }
  ],
  "presets": [{ "name": "Sun Energy Attar" }],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
