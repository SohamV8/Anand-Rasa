{{ 'about-us-brand-story.css' | asset_url | stylesheet_tag }}

<div class="section-{{ section.id }}-padding isolate">
  {%- render 'about-us-brand-story',
    title: section.settings.title,
    subtitle: section.settings.subtitle,
    body: section.settings.body,
    logo_alt: section.settings.logo_alt
  %}
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .section-{{ section.id }}-padding {
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .section-{{ section.id }}-padding {
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "About brand story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "Anand Rasa"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "About Us"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Crafting fragrances rooted in tradition, devotion, and timeless luxury."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Story",
      "default": "<p>Anand Rasa was born from a simple belief: fragrance is not just scent — it is identity, devotion, and cosmic connection. We are India's astrology-inspired fragrance house, handcrafting luxury alcohol-free attars, zodiac perfume oils, planet fragrances, agarbatti, and spiritual incense rooted in Vedic tradition. Every bottle carries the intention of its celestial alignment — from the fiery confidence of a Mars attar to the serene calm of a Moon fragrance. Our perfumers blend rare natural ingredients using time-honoured distillation methods, creating skin-close aromas designed for meditation, pooja, and daily ritual. Based in Gurugram, Haryana, we honour the ancient Indian art of attar-making while bringing it to a modern, design-conscious audience.</p>"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "About brand story"
    }
  ]
}
{% endschema %}
