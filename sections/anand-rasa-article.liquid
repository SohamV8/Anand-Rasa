{% comment %}
  ANAND RASA — Single Blog Post (Article) Page
  Install:
  1. Edit Code → sections/ → Add new section → name: anand-rasa-article → paste → Save
  2. Edit Code → templates/ → Add new template → type: article → name: default
     Replace content with:
     {
       "sections": { "main": { "type": "anand-rasa-article", "settings": {} } },
       "order": ["main"]
     }
{% endcomment %}

<style>
  .ar-art *, .ar-art *::before, .ar-art *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .ar-art { font-family: var(--font-body-family); background: linear-gradient(180deg, #f5f1ea 0%, #faf9f7 32%, #faf9f7 100%); color: #1e2023; min-height: 100vh; }
  .ar-art a { color: inherit; }
  .ar-art img { display: block; max-width: 100%; }

  .aa-page { max-width: 1180px; margin: 0 auto; }

  /* ── FRAMED HERO (image card + title below) — editable in theme settings ── */
  .aa-hero--framed { padding: 32px 20px 0; }
  .aa-hero--framed .aa-hero__back { color: #9ca3af; margin-bottom: 24px; }
  .aa-hero--framed .aa-hero__back:hover { color: #1e2023; }
  .aa-framed-media { max-width: var(--aa-framed-max, 880px); margin: 0 auto 36px; }
  .aa-framed-media--narrow { --aa-framed-max: 720px; }
  .aa-framed-media--medium { --aa-framed-max: 880px; }
  .aa-framed-media--wide { --aa-framed-max: 1040px; }
  .aa-framed-media__inner {
    position: relative;
    border-radius: var(--aa-framed-radius, 16px);
    overflow: hidden;
    background: #e8e4dc;
    box-shadow: 0 20px 60px rgba(30, 32, 35, 0.1), 0 4px 16px rgba(30, 32, 35, 0.06);
  }
  .aa-framed-media__ratio { position: relative; width: 100%; }
  .aa-framed-media__ratio--16-10 { aspect-ratio: 16 / 10; }
  .aa-framed-media__ratio--3-2 { aspect-ratio: 3 / 2; }
  .aa-framed-media__ratio--4-5 { aspect-ratio: 4 / 5; max-height: min(72vh, 640px); }
  .aa-framed-media__ratio--1-1 { aspect-ratio: 1 / 1; max-height: min(70vh, 720px); }
  .aa-framed-media__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .aa-framed-intro { text-align: center; max-width: 760px; margin: 0 auto; padding: 0 8px 8px; }
  .aa-framed-intro .aa-hero__tags { justify-content: center; }
  .aa-framed-intro .aa-hero__title { color: #1a1a18; }
  .aa-framed-intro .aa-hero__meta { justify-content: center; border-bottom: none; padding-bottom: 0; }

  /* ── FULL-BLEED HERO (title on image) ── */
  .aa-feature { position: relative; margin: 0; border-radius: 0 0 18px 18px; overflow: hidden; box-shadow: 0 24px 80px rgba(30, 32, 35, 0.12); }
  @media (min-width: 1200px) { .aa-feature { margin: 0 8px; border-radius: 0 0 22px 22px; } }
  .aa-feature__media { position: relative; aspect-ratio: 21 / 9; min-height: 260px; max-height: 68vh; background: #1a1814; }
  @media (max-width: 700px) { .aa-feature__media { aspect-ratio: 3 / 4; max-height: none; min-height: 320px; } }
  .aa-feature__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .aa-feature__scrim { position: absolute; inset: 0; pointer-events: none; transition: opacity 0.2s; }
  .aa-feature--no-overlay .aa-feature__scrim { opacity: 0 !important; }
  .aa-feature__inner { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: clamp(24px, 5vw, 52px); z-index: 2; }
  .aa-feature__back { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255, 255, 255, 0.8); text-decoration: none; margin-bottom: 18px; transition: color 0.2s; align-self: flex-start; }
  .aa-feature__back:hover { color: #fff; }
  .aa-feature__back svg { width: 14px; height: 14px; flex-shrink: 0; }
  .aa-feature__tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .aa-feature__tag { font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #e8d5a8; }
  .aa-feature__tag + .aa-feature__tag::before { content: '·'; margin-right: 8px; color: rgba(255, 255, 255, 0.35); }
  .aa-feature__title { font-family: var(--font-heading-family); font-size: clamp(1.85rem, 5vw, 3.15rem); font-weight: 400; line-height: 1.12; color: #fff; letter-spacing: -0.02em; margin-bottom: 16px; max-width: 920px; text-shadow: 0 2px 28px rgba(0, 0, 0, 0.4); }
  .aa-feature__meta { display: flex; align-items: center; flex-wrap: wrap; gap: 14px 18px; color: rgba(255, 255, 255, 0.88); font-size: 13px; }
  .aa-feature__author { display: flex; align-items: center; gap: 10px; }
  .aa-feature__author-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.35); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; color: #fff; overflow: hidden; flex-shrink: 0; }
  .aa-feature__dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(255, 255, 255, 0.35); }
  .aa-feature__date, .aa-feature__read { color: rgba(255, 255, 255, 0.72); }

  /* ── TEXT-ONLY HERO (no image) ── */
  .aa-hero { padding: clamp(48px, 8vw, 88px) 24px 48px; text-align: center; max-width: 820px; margin: 0 auto; }
  .aa-hero--text { position: relative; }
  .aa-hero--text::after { content: ''; display: block; width: 48px; height: 2px; background: linear-gradient(90deg, transparent, #c9a96e, transparent); margin: 0 auto 28px; border-radius: 2px; }
  .aa-hero__back { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #9ca3af; text-decoration: none; margin-bottom: 28px; transition: color 0.2s; }
  .aa-hero__back:hover { color: #1e2023; }
  .aa-hero__back svg { width: 14px; height: 14px; }
  .aa-hero__tags { display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .aa-hero__tag { font-size: 10px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: #c9a96e; }
  .aa-hero__tag + .aa-hero__tag::before { content: '·'; margin-right: 8px; color: #d1d5db; }
  .aa-hero__title { font-family: var(--font-heading-family); font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 400; line-height: 1.12; color: #1a1a18; letter-spacing: -0.02em; margin-bottom: 24px; }
  .aa-hero__meta { display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap; padding-bottom: 8px; }
  .aa-hero__author { display: flex; align-items: center; gap: 10px; }
  .aa-hero__author-avatar { width: 40px; height: 40px; border-radius: 50%; background: #1e2023; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; color: #fff; overflow: hidden; flex-shrink: 0; }
  .aa-hero__author-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .aa-hero__author-name { font-size: 13px; font-weight: 500; color: #1e2023; }
  .aa-hero__dot { width: 3px; height: 3px; background: #d1d5db; border-radius: 50%; }
  .aa-hero__date { font-size: 13px; color: #9ca3af; }
  .aa-hero__read-time { font-size: 13px; color: #9ca3af; }

  /* ── ARTICLE BODY ── */
  .aa-body { display: grid; grid-template-columns: minmax(0, 1fr) 280px; gap: 48px; max-width: 1180px; margin: 0 auto; padding: clamp(40px, 5vw, 64px) 24px 72px; align-items: start; }
  @media (max-width: 900px) { .aa-body { grid-template-columns: 1fr; gap: 40px; } }

  /* Article content */
  .aa-content {
    max-width: 720px;
    background: #fff;
    border-radius: 16px;
    padding: clamp(28px, 4vw, 44px) clamp(22px, 3vw, 40px) 40px;
    border: 1px solid rgba(30, 32, 35, 0.06);
    box-shadow: 0 4px 40px rgba(30, 32, 35, 0.06);
  }
  .aa-content__text { font-size: 18px; line-height: 1.92; color: #3d4349; font-weight: 300; }
  @media (min-width: 700px) {
    .aa-content__text > p:first-of-type:first-child::first-letter {
      font-family: var(--font-heading-family);
      font-size: 3.25rem;
      line-height: 1;
      float: left;
      margin: 0.08em 12px 0 0;
      color: #1a1a18;
      font-weight: 400;
    }
  }
  .aa-content__text h2 { font-family:var(--font-heading-family); font-size:clamp(24px,3vw,36px); font-weight:400; color:#1a1a18; margin:48px 0 20px; letter-spacing:-.01em; line-height:1.2; }
  .aa-content__text h3 { font-family:var(--font-heading-family); font-size:clamp(20px,2.5vw,28px); font-weight:400; color:#1a1a18; margin:36px 0 16px; line-height:1.3; }
  .aa-content__text p { margin-bottom:24px; }
  .aa-content__text strong { font-weight:600; color:#1e2023; }
  .aa-content__text em { font-style:italic; }
  .aa-content__text a { color:#c9a96e; text-decoration:underline; text-underline-offset:3px; }
  .aa-content__text blockquote { border-left:3px solid #c9a96e; padding:8px 0 8px 24px; margin:32px 0; font-family:var(--font-heading-family); font-size:22px; font-style:italic; color:#1a1a18; line-height:1.5; font-weight:400; }
  .aa-content__text ul, .aa-content__text ol { padding-left:24px; margin-bottom:24px; }
  .aa-content__text li { margin-bottom:8px; line-height:1.75; }
  .aa-content__text img { width:100%; border-radius:4px; margin:32px 0; }
  .aa-content__text hr { border:none; border-top:1px solid rgba(30,32,35,.1); margin:40px 0; }

  /* Tags + share footer */
  .aa-footer { margin-top:48px; padding-top:32px; border-top:1px solid rgba(30,32,35,.1); display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:20px; }
  .aa-tags { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .aa-tags__label { font-size:11px; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:#9ca3af; }
  .aa-tag { font-size:11px; padding:5px 14px; border:1px solid rgba(30,32,35,.15); color:#6b7280; border-radius:100px; text-decoration:none; transition:all .2s; }
  .aa-tag:hover { background:#1e2023; color:#fff; border-color:#1e2023; }
  .aa-share { display:flex; align-items:center; gap:10px; }
  .aa-share__label { font-size:11px; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:#9ca3af; }
  .aa-share-btn { width:36px; height:36px; border:1px solid rgba(30,32,35,.15); display:flex; align-items:center; justify-content:center; color:#6b7280; text-decoration:none; transition:all .2s; font-size:12px; font-weight:600; border-radius:50%; }
  .aa-share-btn:hover { background:#1e2023; color:#fff; border-color:#1e2023; }

  /* ── SIDEBAR ── */
  .aa-sidebar { display: flex; flex-direction: column; gap: 24px; position: sticky; top: 24px; }
  .aa-widget { background: #fff; border: 1px solid rgba(30, 32, 35, 0.08); padding: 22px; border-radius: 14px; box-shadow: 0 2px 24px rgba(30, 32, 35, 0.04); }
  .aa-widget__title { font-size:10px; font-weight:600; letter-spacing:.18em; text-transform:uppercase; color:#9ca3af; display:block; margin-bottom:18px; }

  /* TOC */
  .aa-toc { display:flex; flex-direction:column; gap:10px; }
  .aa-toc__item { font-size:13px; color:#6b7280; text-decoration:none; padding-left:12px; border-left:2px solid transparent; transition:all .2s; line-height:1.4; }
  .aa-toc__item:hover, .aa-toc__item.is-active { color:#1e2023; border-left-color:#c9a96e; }

  /* Related posts */
  .aa-related-item { display:flex; gap:12px; align-items:flex-start; padding:12px 0; border-bottom:1px solid rgba(30,32,35,.06); text-decoration:none; }
  .aa-related-item:first-child { padding-top:0; }
  .aa-related-item:last-child { border-bottom:none; }
  .aa-related-thumb { width:64px; height:48px; flex-shrink:0; overflow:hidden; position:relative; background:#e5e7eb; }
  .aa-related-thumb img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition:transform .4s; }
  .aa-related-item:hover .aa-related-thumb img { transform:scale(1.06); }
  .aa-related-title { font-family:var(--font-heading-family); font-size:14px; line-height:1.35; color:#1a1a18; margin-bottom:5px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; transition:opacity .2s; }
  .aa-related-item:hover .aa-related-title { opacity:.7; }
  .aa-related-date { font-size:11px; color:#9ca3af; }

  .aa-newsletter {
    background: linear-gradient(145deg, #1a1814 0%, #2a2420 100%);
    border-radius: 14px;
    padding: 26px 22px;
    border: 1px solid rgba(201, 169, 110, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }
  .aa-newsletter__title { font-family: var(--font-heading-family); font-size: 1.35rem; font-weight: 400; color: #fff; margin-bottom: 10px; line-height: 1.3; }
  .aa-newsletter__text { font-size: 12px; color: rgba(255, 255, 255, 0.55); margin-bottom: 18px; line-height: 1.65; font-weight: 300; }
  .aa-newsletter__input { width: 100%; padding: 11px 14px; background: rgba(255, 255, 255, 0.07); border: 1px solid rgba(255, 255, 255, 0.14); color: #fff; font-size: 13px; margin-bottom: 10px; outline: none; border-radius: 8px; }
  .aa-newsletter__input::placeholder { color: rgba(255, 255, 255, 0.35); }
  .aa-newsletter__btn {
    width: 100%;
    padding: 12px;
    background: #c9a96e;
    color: #1a1814;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .aa-newsletter__btn:hover { background: #d4b77d; transform: translateY(-1px); }

  /* ── PREV / NEXT NAV ── */
  .aa-prevnext { max-width: 1180px; margin: 0 auto; padding: 0 24px 72px; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 580px) { .aa-prevnext { grid-template-columns: 1fr; } }
  .aa-prevnext__item {
    background: #fff;
    padding: 28px 24px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: box-shadow 0.25s, transform 0.2s;
    border-radius: 14px;
    border: 1px solid rgba(30, 32, 35, 0.08);
    box-shadow: 0 2px 20px rgba(30, 32, 35, 0.04);
  }
  .aa-prevnext__item:hover { box-shadow: 0 12px 40px rgba(30, 32, 35, 0.1); transform: translateY(-2px); }
  .aa-prevnext__item--next { text-align: right; }
  .aa-prevnext__dir { font-size: 10px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: #9ca3af; display: flex; align-items: center; gap: 6px; }
  .aa-prevnext__item--next .aa-prevnext__dir { justify-content: flex-end; }
  .aa-prevnext__title { font-family: var(--font-heading-family); font-size: 1.15rem; font-weight: 400; color: #1a1a18; line-height: 1.35; transition: color 0.2s; }
  .aa-prevnext__item:hover .aa-prevnext__title { color: #c9a96e; }
</style>

<div class="ar-art">

  <div class="aa-page">
  {%- liquid
    assign featured_img = article.image
    if featured_img == blank and section.settings.fallback_featured_image != blank
      assign featured_img = section.settings.fallback_featured_image
    endif
    assign layout = section.settings.featured_layout | default: 'framed'
    assign overlay_op = section.settings.overlay_strength | default: 55 | times: 0.01
    assign overlay_deep = section.settings.overlay_strength | default: 55 | times: 0.01 | plus: 0.1
    if overlay_deep > 1
      assign overlay_deep = 1
    endif
  -%}
  {%- if layout != 'text_only' and featured_img != blank and layout == 'full_bleed' -%}
    <header class="aa-feature{% unless section.settings.full_bleed_overlay %} aa-feature--no-overlay{% endunless %}" aria-label="{{ article.title }}">
      <div class="aa-feature__media">
        <img
          src="{{ featured_img | image_url: width: 2000 }}"
          alt="{{ featured_img.alt | default: article.title }}"
          width="{{ featured_img.width | default: 2000 }}"
          height="{{ featured_img.height | default: 857 }}"
          loading="eager"
          class="aa-feature__img"
        >
        {%- if section.settings.full_bleed_overlay -%}
          <div class="aa-feature__scrim" aria-hidden="true" style="background: linear-gradient(180deg, rgba(15,14,12,0.15) 0%, rgba(15,14,12,{{ overlay_op }}) 50%, rgba(15,14,12,{{ overlay_deep }}) 100%);"></div>
        {%- endif -%}
      </div>
      <div class="aa-feature__inner">
        <a href="{{ blog.url }}" class="aa-feature__back">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Back to {{ blog.title | default: 'Journal' }}
        </a>
        {%- if article.tags.size > 0 -%}
          <div class="aa-feature__tags">
            {%- for tag in article.tags -%}
              <span class="aa-feature__tag">{{ tag }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <h1 class="aa-feature__title">{{ article.title }}</h1>
        <div class="aa-feature__meta">
          <div class="aa-feature__author">
            <div class="aa-feature__author-avatar" aria-hidden="true">
              {%- if article.author contains ' ' -%}
                {{ article.author | split: ' ' | first | slice: 0 }}{{ article.author | split: ' ' | last | slice: 0 }}
              {%- else -%}
                {{ article.author | slice: 0, 2 | upcase }}
              {%- endif -%}
            </div>
            <span>{{ article.author }}</span>
          </div>
          <span class="aa-feature__dot" aria-hidden="true"></span>
          <span class="aa-feature__date">{{ article.published_at | date: '%B %d, %Y' }}</span>
          <span class="aa-feature__dot" aria-hidden="true"></span>
          <span class="aa-feature__read">{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
        </div>
      </div>
    </header>
  {%- elsif layout != 'text_only' and featured_img != blank and layout == 'framed' -%}
    <header class="aa-hero aa-hero--framed" aria-label="{{ article.title }}">
      <a href="{{ blog.url }}" class="aa-hero__back">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to {{ blog.title | default: 'Journal' }}
      </a>
      <div class="aa-framed-media aa-framed-media--{{ section.settings.framed_width | default: 'medium' }}" style="--aa-framed-radius: {{ section.settings.framed_radius | default: 16 }}px;">
        <div class="aa-framed-media__inner">
          <div class="aa-framed-media__ratio aa-framed-media__ratio--{{ section.settings.framed_ratio | default: '16-10' }}">
            <img
              src="{{ featured_img | image_url: width: 2000 }}"
              alt="{{ featured_img.alt | default: article.title }}"
              width="{{ featured_img.width | default: 1600 }}"
              height="{{ featured_img.height | default: 1000 }}"
              loading="eager"
              class="aa-framed-media__img"
            >
          </div>
        </div>
      </div>
      <div class="aa-framed-intro">
        {%- if article.tags.size > 0 -%}
          <div class="aa-hero__tags">
            {%- for tag in article.tags -%}
              <span class="aa-hero__tag">{{ tag }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <h1 class="aa-hero__title">{{ article.title }}</h1>
        <div class="aa-hero__meta">
          <div class="aa-hero__author">
            <div class="aa-hero__author-avatar" aria-hidden="true">
              {%- if article.author contains ' ' -%}
                {{ article.author | split: ' ' | first | slice: 0 }}{{ article.author | split: ' ' | last | slice: 0 }}
              {%- else -%}
                {{ article.author | slice: 0, 2 | upcase }}
              {%- endif -%}
            </div>
            <span class="aa-hero__author-name">{{ article.author }}</span>
          </div>
          <span class="aa-hero__dot" aria-hidden="true"></span>
          <span class="aa-hero__date">{{ article.published_at | date: '%B %d, %Y' }}</span>
          <span class="aa-hero__dot" aria-hidden="true"></span>
          <span class="aa-hero__read-time">{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
        </div>
      </div>
    </header>
  {%- else -%}
    <header class="aa-hero aa-hero--text">
      <a href="{{ blog.url }}" class="aa-hero__back">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to {{ blog.title | default: 'Journal' }}
      </a>
      {%- if article.tags.size > 0 -%}
        <div class="aa-hero__tags">
          {%- for tag in article.tags -%}
            <span class="aa-hero__tag">{{ tag }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}
      <h1 class="aa-hero__title">{{ article.title }}</h1>
      <div class="aa-hero__meta">
        <div class="aa-hero__author">
          <div class="aa-hero__author-avatar" aria-hidden="true">
            {%- if article.author contains ' ' -%}
              {{ article.author | split: ' ' | first | slice: 0 }}{{ article.author | split: ' ' | last | slice: 0 }}
            {%- else -%}
              {{ article.author | slice: 0, 2 | upcase }}
            {%- endif -%}
          </div>
          <span class="aa-hero__author-name">{{ article.author }}</span>
        </div>
        <span class="aa-hero__dot" aria-hidden="true"></span>
        <span class="aa-hero__date">{{ article.published_at | date: '%B %d, %Y' }}</span>
        <span class="aa-hero__dot" aria-hidden="true"></span>
        <span class="aa-hero__read-time">{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
      </div>
    </header>
  {%- endif -%}

  {%- comment -%} BODY: content + sidebar {%- endcomment -%}
  <div class="aa-body">

    {%- comment -%} LEFT — article content {%- endcomment -%}
    <div class="aa-content">
      <div class="aa-content__text">
        {{ article.content }}
      </div>

      {%- comment -%} Tags + share {%- endcomment -%}
      <div class="aa-footer">
        {%- if article.tags.size > 0 -%}
          <div class="aa-tags">
            <span class="aa-tags__label">Tags</span>
            {%- for tag in article.tags -%}
              <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="aa-tag">{{ tag }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <div class="aa-share">
          <span class="aa-share__label">Share</span>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" class="aa-share-btn" aria-label="Share on Twitter">X</a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" class="aa-share-btn" aria-label="Share on Facebook">f</a>
          <a href="https://api.whatsapp.com/send?text={{ article.title | url_encode }}%20{{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" class="aa-share-btn" aria-label="Share on WhatsApp">W</a>
        </div>
      </div>
    </div>

    {%- comment -%} SIDEBAR {%- endcomment -%}
    <aside class="aa-sidebar">

      {%- comment -%} Table of contents (auto-built from h2 headings) {%- endcomment -%}
      <div class="aa-widget" id="aa-toc-widget" style="display:none">
        <span class="aa-widget__title">In This Article</span>
        <nav class="aa-toc" id="aa-toc"></nav>
      </div>

      {%- comment -%} Related posts {%- endcomment -%}
      {%- if blog.articles.size > 1 -%}
        <div class="aa-widget">
          <span class="aa-widget__title">More Articles</span>
          {%- for a in blog.articles limit: 4 -%}
            {%- unless a.id == article.id -%}
              <a href="{{ a.url }}" class="aa-related-item">
                <div class="aa-related-thumb">
                  {%- if a.image -%}
                    <img src="{{ a.image | image_url: width: 200 }}" alt="{{ a.title }}" width="64" height="48" loading="lazy">
                  {%- endif -%}
                </div>
                <div>
                  <p class="aa-related-title">{{ a.title }}</p>
                  <span class="aa-related-date">{{ a.published_at | date: '%b %d, %Y' }}</span>
                </div>
              </a>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Newsletter (visual only — connect to app in theme settings if needed) {%- endcomment -%}
      <div class="aa-newsletter">
        <h3 class="aa-newsletter__title">The Scent Letter</h3>
        <p class="aa-newsletter__text">Monthly stories on fragrance, ritual, and the art of presence.</p>
        <input type="email" class="aa-newsletter__input" placeholder="Your email" autocomplete="email">
        <button type="button" class="aa-newsletter__btn">Subscribe</button>
      </div>

    </aside>
  </div>

  {%- comment -%} PREV / NEXT {%- endcomment -%}
  <div class="aa-prevnext">
    {%- if blog.previous_article -%}
      <a href="{{ blog.previous_article.url }}" class="aa-prevnext__item">
        <span class="aa-prevnext__dir">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Previous
        </span>
        <span class="aa-prevnext__title">{{ blog.previous_article.title }}</span>
      </a>
    {%- else -%}
      <div></div>
    {%- endif -%}
    {%- if blog.next_article -%}
      <a href="{{ blog.next_article.url }}" class="aa-prevnext__item aa-prevnext__item--next">
        <span class="aa-prevnext__dir">
          Next
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </span>
        <span class="aa-prevnext__title">{{ blog.next_article.title }}</span>
      </a>
    {%- else -%}
      <div></div>
    {%- endif -%}
  </div>

  </div>

</div>

<script>
(function(){
  // Auto Table of Contents from h2 tags in article
  var content = document.querySelector('.aa-content__text');
  var tocEl   = document.getElementById('aa-toc');
  var tocWidget = document.getElementById('aa-toc-widget');
  if(content && tocEl){
    var headings = content.querySelectorAll('h2');
    if(headings.length >= 2){
      headings.forEach(function(h, i){
        var id = 'aa-h-' + i;
        h.id = id;
        var a = document.createElement('a');
        a.href = '#' + id;
        a.className = 'aa-toc__item';
        a.textContent = h.textContent;
        a.addEventListener('click', function(e){
          e.preventDefault();
          document.getElementById(id).scrollIntoView({ behavior:'smooth', block:'start' });
        });
        tocEl.appendChild(a);
      });
      if(tocWidget) tocWidget.style.display = 'block';

      // Highlight active TOC item on scroll
      var items = tocEl.querySelectorAll('.aa-toc__item');
      window.addEventListener('scroll', function(){
        var scrollY = window.scrollY + 100;
        headings.forEach(function(h, i){
          if(h.offsetTop <= scrollY){
            items.forEach(function(a){ a.classList.remove('is-active'); });
            if(items[i]) items[i].classList.add('is-active');
          }
        });
      }, { passive:true });
    }
  }
})();
</script>

{%- if article != blank -%}
  <script type="application/ld+json">
    {{ article | structured_data }}
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Article Page",
  "settings": [
    {
      "type": "header",
      "content": "Featured image"
    },
    {
      "type": "paragraph",
      "content": "The article’s own featured image is used first. Add a fallback below for posts without one."
    },
    {
      "type": "select",
      "id": "featured_layout",
      "label": "Layout",
      "options": [
        { "value": "framed", "label": "Framed — image card, title below (recommended)" },
        { "value": "full_bleed", "label": "Full width — text on image" },
        { "value": "text_only", "label": "Title only — hide featured image" }
      ],
      "default": "framed"
    },
    {
      "type": "image_picker",
      "id": "fallback_featured_image",
      "label": "Fallback image (if article has no image)"
    },
    {
      "type": "header",
      "content": "Framed layout"
    },
    {
      "type": "select",
      "id": "framed_width",
      "label": "Image width",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "medium", "label": "Medium" },
        { "value": "wide", "label": "Wide" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "framed_radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Corner radius",
      "default": 16
    },
    {
      "type": "select",
      "id": "framed_ratio",
      "label": "Image shape",
      "options": [
        { "value": "16-10", "label": "Landscape 16:10" },
        { "value": "3-2", "label": "Landscape 3:2" },
        { "value": "4-5", "label": "Portrait 4:5" },
        { "value": "1-1", "label": "Square 1:1" }
      ],
      "default": "16-10"
    },
    {
      "type": "header",
      "content": "Full-width layout"
    },
    {
      "type": "checkbox",
      "id": "full_bleed_overlay",
      "label": "Dark gradient overlay (for text readability)",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_strength",
      "min": 35,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay depth",
      "default": 55
    }
  ],
  "presets": [{ "name": "Article Page" }]
}
{% endschema %}
