{%- liquid
  assign cpq_uid = section.id
  assign cpq_contact_id = 'cpq-contact-' | append: cpq_uid
  assign cpq_form_posted = false
-%}

<section
  class="cpq section-{{ section.id }}-padding"
  id="cpq-{{ cpq_uid }}"
  data-cpq-quiz
  aria-labelledby="cpq-title-{{ cpq_uid }}"
>
  <div class="cpq__cosmos" aria-hidden="true">
    {%- for i in (1..28) -%}
      <span class="cpq__star" style="--cpq-sx: {{ i | times: 37 | modulo: 100 }}%; --cpq-sy: {{ i | times: 53 | modulo: 100 }}%; --cpq-sd: {{ i | times: 0.7 | modulo: 5 | plus: 3 }}s;"></span>
    {%- endfor -%}
  </div>
  <div class="cpq__ambient" aria-hidden="true">
    <span class="cpq__glow cpq__glow--1"></span>
    <span class="cpq__glow cpq__glow--2"></span>
    <span class="cpq__grain"></span>
  </div>

  <div class="cpq__shell">
    {%- form 'contact', id: cpq_contact_id, class: 'cpq__shopify-form' -%}

      {%- if form.posted_successfully? -%}
        {%- assign cpq_form_posted = true -%}
        <div class="cpq__success" data-cpq-success tabindex="-1" role="status" aria-labelledby="cpq-success-title-{{ cpq_uid }}">
          <div class="cpq__success-icon" aria-hidden="true">
            <svg class="cpq__success-check" viewBox="0 0 52 52" focusable="false">
              <circle class="cpq__success-circle" cx="26" cy="26" r="24" fill="none"/>
              <path class="cpq__success-path" fill="none" d="M14 27l8 8 16-18"/>
            </svg>
          </div>
          <p class="cpq__success-eyebrow">✦ Anand Rasa</p>
          <h2 class="cpq__success-title" id="cpq-success-title-{{ cpq_uid }}">
            {{ section.settings.success_heading | default: 'Thank You' }}
          </h2>
          <p class="cpq__success-sub">
            {{ section.settings.success_subheading | default: 'Your personalised fragrance consultation has been received.' }}
          </p>
          <div class="cpq__success-divider" aria-hidden="true"></div>
          <p class="cpq__success-body">
            {{ section.settings.success_body | default: 'Our fragrance specialists will carefully review your preferences and contact you with curated attar recommendations crafted around your taste, mood, and fragrance profile.' }}
          </p>
          <p class="cpq__success-foot">
            {{ section.settings.success_footnote | default: 'Thank you for choosing Anand Rasa.' }}
          </p>
          {%- if section.settings.collection_link != blank -%}
            <a class="cpq__btn cpq__btn--ghost cpq__success-cta" href="{{ section.settings.collection_link }}">Explore our attars</a>
          {%- endif -%}
        </div>
      {%- else -%}

      {%- if form.errors -%}
        <div class="cpq__form-errors" data-cpq-form-errors role="alert">
          <p class="cpq__form-errors-title">{{ 'templates.contact.form.error_heading' | t }}</p>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <input type="hidden" name="contact[tags]" value="custom-perfume-quiz,attar-consultation">
      <input type="hidden" name="contact[form_type]" value="Custom Perfume Consultation">
      <input type="hidden" name="contact[fragrance_type]" value="" data-cpq-contact-field="fragranceType">
      <input type="hidden" name="contact[purpose]" value="" data-cpq-contact-field="purpose">
      <input type="hidden" name="contact[mood]" value="" data-cpq-contact-field="mood">
      <input type="hidden" name="contact[fragrance_families]" value="" data-cpq-contact-field="families">
      <input type="hidden" name="contact[zodiac]" value="" data-cpq-contact-field="zodiac">
      <input type="hidden" name="contact[planet]" value="" data-cpq-contact-field="planet">
      <input type="hidden" name="contact[nakshatra]" value="" data-cpq-contact-field="nakshatra">
      <input type="hidden" name="contact[intensity]" value="" data-cpq-contact-field="intensity">
      <input type="hidden" name="contact[date_of_birth]" value="" data-cpq-contact-field="dob">
      <input type="hidden" name="contact[birth_time]" value="" data-cpq-contact-field="birthTime">
      <input type="hidden" name="contact[birth_place]" value="" data-cpq-contact-field="birthLocation">
      <textarea class="cpq__body-hidden" name="contact[body]" data-cpq-contact-field="body" tabindex="-1" aria-hidden="true"></textarea>

      <div class="cpq__consultation" data-cpq-consultation>
    <header class="cpq__header">
      <p class="cpq__badge">✦ {{ section.settings.eyebrow | default: 'Anand Rasa' }}</p>
      <h1 class="cpq__title" id="cpq-title-{{ cpq_uid }}">
        {{ section.settings.heading | default: 'Personalised fragrance consultation' }}
      </h1>
      <p class="cpq__lead">
        {{ section.settings.subheading | default: 'Share your preferences with our fragrance specialists for a curated attar consultation — crafted around your taste, mood, and fragrance profile.' }}
      </p>
      <div class="cpq__progress" role="progressbar" aria-valuemin="1" aria-valuemax="7" aria-valuenow="1" aria-label="Quiz progress" id="cpq-progress-{{ cpq_uid }}">
        <div class="cpq__progress-track">
          <div class="cpq__progress-fill" data-cpq-progress-fill style="width:14.3%"></div>
        </div>
        <p class="cpq__progress-label"><span data-cpq-step-label>Step 1</span> <span class="cpq__progress-total">of 7</span></p>
      </div>
    </header>

    {%- if section.settings.show_trust -%}
      <ul class="cpq__trust" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_badge' -%}
            <li class="cpq__trust-item" {{ block.shopify_attributes }}>{{ block.settings.label }}</li>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.blocks.size == 0 -%}
          <li class="cpq__trust-item"><span class="cpq__trust-dot" aria-hidden="true"></span>Alcohol-free attars</li>
          <li class="cpq__trust-item"><span class="cpq__trust-dot" aria-hidden="true"></span>Handcrafted in India</li>
          <li class="cpq__trust-item"><span class="cpq__trust-dot" aria-hidden="true"></span>Natural perfume oils</li>
          <li class="cpq__trust-item"><span class="cpq__trust-dot" aria-hidden="true"></span>Long-lasting wear</li>
          <li class="cpq__trust-item"><span class="cpq__trust-dot" aria-hidden="true"></span>Astrology-guided</li>
        {%- endif -%}
      </ul>
    {%- endif -%}

    <div class="cpq__form" data-cpq-form role="group" aria-label="Personalised attar consultation">
      <div class="cpq__steps-viewport" data-cpq-steps-viewport>
      <div class="cpq__steps" data-cpq-steps>
        {%- comment -%} Step 1 {%- endcomment -%}
        <fieldset class="cpq__step is-active" data-cpq-step="1">
          <legend class="cpq__step-title">Begin your consultation</legend>
          <p class="cpq__step-sub">Tell us how to reach you. Your responses are sent securely to our team — never in the page URL.</p>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-name-{{ cpq_uid }}">Name <span class="cpq__opt">(optional)</span></label>
            <input class="cpq__input" id="cpq-name-{{ cpq_uid }}" type="text" name="contact[name]" autocomplete="name" placeholder="Your name" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
          </div>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-email-{{ cpq_uid }}">
              Email <span class="cpq__req" aria-hidden="true">*</span>
            </label>
            <input
              class="cpq__input"
              id="cpq-email-{{ cpq_uid }}"
              type="email"
              name="contact[email]"
              autocomplete="email"
              spellcheck="false"
              autocapitalize="off"
              required
              placeholder="you@example.com"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
            >
          </div>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-phone-{{ cpq_uid }}">Phone <span class="cpq__opt">(optional)</span></label>
            <input
              class="cpq__input"
              id="cpq-phone-{{ cpq_uid }}"
              type="tel"
              name="contact[phone]"
              autocomplete="tel"
              inputmode="tel"
              placeholder="+91 …"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            >
          </div>
        </fieldset>

        {%- comment -%} Step 2 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="2" hidden>
          <legend class="cpq__step-title">Attar or perfume oil</legend>
          <p class="cpq__step-sub">Choose the format you prefer.</p>
          <div class="cpq__choices cpq__choices--2" data-cpq-group="fragranceType" data-cpq-required>
            {%- assign cpq_types = 'Attar|attar,Perfume oil|perfume-oil' | split: ',' -%}
            {%- for cpq_t in cpq_types -%}
              {%- assign cpq_tp = cpq_t | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_tp[1] }}" aria-pressed="false">{{ cpq_tp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 3 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="3" hidden>
          <legend class="cpq__step-title">When you wear it</legend>
          <p class="cpq__step-sub">Pick what fits your routine.</p>
          <div class="cpq__choices cpq__choices--3" data-cpq-group="purpose" data-cpq-required>
            {%- assign cpq_purposes = 'Everyday|daily,Work|office,Sports|sports,Meditation|meditation,Stress relief|stress,Spiritual|spiritual,Gift|gifting,Special event|special' | split: ',' -%}
            {%- for cpq_p in cpq_purposes -%}
              {%- assign cpq_pp = cpq_p | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_pp[1] }}" aria-pressed="false">{{ cpq_pp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 4 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="4" hidden>
          <legend class="cpq__step-title">Your mood</legend>
          <p class="cpq__step-sub">How should your fragrance feel?</p>
          <div class="cpq__choices cpq__choices--2" data-cpq-group="mood" data-cpq-required>
            {%- assign cpq_moods = 'Calm|calm,Happy|happy,Fresh|fresh,Warm|warm,Romantic|romantic,Bold|bold,Relaxed|relaxed,Confident|confident' | split: ',' -%}
            {%- for cpq_m in cpq_moods -%}
              {%- assign cpq_mp = cpq_m | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_mp[1] }}" aria-pressed="false">{{ cpq_mp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 5 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="5" hidden>
          <legend class="cpq__step-title">Signature notes</legend>
          <p class="cpq__step-sub">Choose the fragrance families that feel instinctively right — floral, woody, oud, spice, and more.</p>
          <div class="cpq__choices cpq__choices--3" data-cpq-group="families" data-cpq-required data-cpq-multi>
            {%- assign cpq_families = 'Rose|rose,Lavender|lavender,Sandalwood|sandalwood,Jasmine|jasmine,Mogra|mogra,Oud|oud,Vetiver|vetiver,Musk|musk,Amber|amber,Saffron|saffron,Citrus|citrus,Floral|floral,Woody|woody,Herbal|herbal' | split: ',' -%}
            {%- for cpq_f in cpq_families -%}
              {%- assign cpq_fp = cpq_f | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_fp[1] }}" aria-pressed="false">{{ cpq_fp[0] }}</button>
            {%- endfor -%}
          </div>
          <p class="cpq__hint">Select one or more families.</p>
        </fieldset>

        {%- comment -%} Step 6 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="6" hidden>
          <legend class="cpq__step-title">Cosmic alignment</legend>
          <p class="cpq__step-sub">Optional — share zodiac, planet, nakshatra, and birth details to refine your consultation.</p>
          <div class="cpq__astro-grid">
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-zodiac-{{ cpq_uid }}">Zodiac sign</label>
              <select class="cpq__select" id="cpq-zodiac-{{ cpq_uid }}" name="zodiac" data-cpq-field="zodiac">
                <option value="">Prefer not to say</option>
                <option value="aries">Aries (Mesh)</option>
                <option value="taurus">Taurus (Vrishabh)</option>
                <option value="gemini">Gemini (Mithun)</option>
                <option value="cancer">Cancer (Kark)</option>
                <option value="leo">Leo (Simha)</option>
                <option value="virgo">Virgo (Kanya)</option>
                <option value="libra">Libra (Tula)</option>
                <option value="scorpio">Scorpio (Vrishchik)</option>
                <option value="sagittarius">Sagittarius (Dhanu)</option>
                <option value="capricorn">Capricorn (Makar)</option>
                <option value="aquarius">Aquarius (Kumbh)</option>
                <option value="pisces">Pisces (Meen)</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-planet-{{ cpq_uid }}">Planet</label>
              <select class="cpq__select" id="cpq-planet-{{ cpq_uid }}" name="planet" data-cpq-field="planet">
                <option value="">Prefer not to say</option>
                <option value="surya">Sun (Surya)</option>
                <option value="chandra">Moon (Chandra)</option>
                <option value="mangal">Mars (Mangal)</option>
                <option value="budh">Mercury (Budh)</option>
                <option value="guru">Jupiter (Guru)</option>
                <option value="shukra">Venus (Shukra)</option>
                <option value="shani">Saturn (Shani)</option>
                <option value="rahu">Rahu</option>
                <option value="ketu">Ketu</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-nakshatra-{{ cpq_uid }}">Nakshatra</label>
              <select class="cpq__select" id="cpq-nakshatra-{{ cpq_uid }}" name="nakshatra" data-cpq-field="nakshatra">
                <option value="">Prefer not to say</option>
                <option value="ashwini">Ashwini</option>
                <option value="bharani">Bharani</option>
                <option value="krittika">Krittika</option>
                <option value="rohini">Rohini</option>
                <option value="mrigashira">Mrigashira</option>
                <option value="ardra">Ardra</option>
                <option value="punarvasu">Punarvasu</option>
                <option value="pushya">Pushya</option>
                <option value="ashlesha">Ashlesha</option>
                <option value="magha">Magha</option>
                <option value="phalguni">Phalguni</option>
                <option value="hasta">Hasta</option>
                <option value="chitra">Chitra</option>
                <option value="swati">Swati</option>
                <option value="vishakha">Vishakha</option>
                <option value="anuradha">Anuradha</option>
                <option value="jyeshtha">Jyeshtha</option>
                <option value="mula">Mula</option>
                <option value="ashadha">Ashadha</option>
                <option value="shravana">Shravana</option>
                <option value="dhanishtha">Dhanishtha</option>
                <option value="shatabhisha">Shatabhisha</option>
                <option value="bhadrapada">Bhadrapada</option>
                <option value="revati">Revati</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-dob-{{ cpq_uid }}">Date of birth <span class="cpq__opt">(optional)</span></label>
              <input class="cpq__input" id="cpq-dob-{{ cpq_uid }}" name="dob" type="date" data-cpq-field="dob" autocomplete="bday">
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-time-{{ cpq_uid }}">Time of birth <span class="cpq__opt">(optional)</span></label>
              <input class="cpq__input" id="cpq-time-{{ cpq_uid }}" name="birth_time" type="time" data-cpq-field="birthTime" autocomplete="off">
            </div>
            <div class="cpq__field cpq__field--full">
              <label class="cpq__label" for="cpq-location-{{ cpq_uid }}">Place of birth <span class="cpq__opt">(optional)</span></label>
              <input class="cpq__input" id="cpq-location-{{ cpq_uid }}" name="birth_location" type="text" data-cpq-field="birthLocation" placeholder="e.g. Mumbai, Delhi, Jaipur" autocomplete="address-level2">
            </div>
          </div>
        </fieldset>

        {%- comment -%} Step 7 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="7" hidden>
          <legend class="cpq__step-title">Strength</legend>
          <p class="cpq__step-sub">Light, medium, or strong on skin?</p>
          <div class="cpq__pills" data-cpq-group="intensity" data-cpq-required>
            <button type="button" class="cpq__pill" data-cpq-value="light" aria-pressed="false">Light</button>
            <button type="button" class="cpq__pill" data-cpq-value="medium" aria-pressed="false">Medium</button>
            <button type="button" class="cpq__pill" data-cpq-value="strong" aria-pressed="false">Strong</button>
          </div>
        </fieldset>

      </div>
      </div>

      <div class="cpq__nav" data-cpq-nav>
        <button type="button" class="cpq__btn cpq__btn--ghost" data-cpq-back hidden>Back</button>
        <button type="button" class="cpq__btn cpq__btn--primary" data-cpq-next>Continue</button>
        <button type="submit" class="cpq__btn cpq__btn--primary" data-cpq-submit hidden>
          {{ section.settings.contact_submit_label | default: 'Submit' }}
        </button>
      </div>
    </div>
      </div>

      {%- endif -%}
    {%- endform -%}

    {%- unless cpq_form_posted -%}
    {%- if section.settings.show_how -%}
      <section class="cpq__how" aria-labelledby="cpq-how-{{ cpq_uid }}">
        <h2 class="cpq__how-title" id="cpq-how-{{ cpq_uid }}">{{ section.settings.how_title | default: 'Your consultation journey' }}</h2>
        <ol class="cpq__how-list">
          <li><strong>Share your preferences</strong> — mood, intention, signature notes, and optional birth details for zodiac or nakshatra attars.</li>
          <li><strong>Our specialists review</strong> your preferences with care and intention.</li>
          <li><strong>We contact you</strong> with curated attar recommendations tailored to your profile.</li>
        </ol>
      </section>
    {%- endif -%}

    {%- if section.settings.show_faq -%}
      <section class="cpq__faq" aria-labelledby="cpq-faq-{{ cpq_uid }}">
        <h2 class="cpq__faq-title" id="cpq-faq-{{ cpq_uid }}">{{ section.settings.faq_title | default: 'Attar consultation — frequently asked' }}</h2>
        <div class="cpq__faq-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              <details class="cpq__faq-item" {{ block.shopify_attributes }}>
                <summary class="cpq__faq-q">{{ block.settings.question }}</summary>
                <div class="cpq__faq-a rte">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
          {%- assign cpq_faq_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              {%- assign cpq_faq_count = cpq_faq_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if cpq_faq_count == 0 -%}
            <details class="cpq__faq-item" open>
              <summary class="cpq__faq-q">What is this personalised attar consultation?</summary>
              <div class="cpq__faq-a"><p>This consultation captures your fragrance preferences and optional cosmic details. Our team reviews your submission and follows up with personalised attar guidance from Anand Rasa.</p></div>
            </details>
            <details class="cpq__faq-item">
              <summary class="cpq__faq-q">Are these alcohol-free natural perfume oils?</summary>
              <div class="cpq__faq-a"><p>Yes. Our attars are concentrated, alcohol-free perfume oils designed for intimate, long-lasting wear on skin.</p></div>
            </details>
            <details class="cpq__faq-item">
              <summary class="cpq__faq-q">Can I use zodiac or birth details?</summary>
              <div class="cpq__faq-a"><p>Yes. Optional zodiac, planet, nakshatra, date, time, and place of birth help surface zodiac attars, planet attars, and nakshatra attars that resonate with your profile.</p></div>
            </details>
          {%- endif -%}
        </div>
      </section>
    {%- endif -%}
    {%- endunless -%}
  </div>
</section>

<style>
  #cpq-{{ cpq_uid }} {
    --cpq-deep: #1a0a2e;
    --cpq-ink: #1e2023;
    --cpq-muted: #6b7280;
    --cpq-surface: #faf7f2;
    --cpq-card: #fffdf8;
    --cpq-gold: #b8860b;
    --cpq-gold-mid: #d4a843;
    --cpq-gold-light: #f5e6c0;
    --cpq-border: rgba(184, 134, 11, 0.18);
    position: relative;
    overflow: hidden;
    background: var(--cpq-surface);
    color: var(--cpq-ink);
    font-family: var(--font-body-family, system-ui, sans-serif);
  }
  #cpq-{{ cpq_uid }}.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media (min-width: 750px) {
    #cpq-{{ cpq_uid }}.section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #cpq-{{ cpq_uid }} .cpq__cosmos {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  #cpq-{{ cpq_uid }} .cpq__star {
    position: absolute;
    left: var(--cpq-sx);
    top: var(--cpq-sy);
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: var(--cpq-gold);
    opacity: 0.2;
    animation: cpqTwinkle var(--cpq-sd) ease-in-out infinite alternate;
  }
  @keyframes cpqTwinkle {
    from { opacity: 0.08; transform: scale(0.8); }
    to { opacity: 0.35; transform: scale(1.2); }
  }
  #cpq-{{ cpq_uid }} .cpq__shell {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 48px) clamp(16px, 3vw, 24px);
  }
  #cpq-{{ cpq_uid }}.cpq--success .cpq__shell {
    max-width: 640px;
    min-height: min(72vh, 720px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #cpq-{{ cpq_uid }} .cpq__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--cpq-border);
    background: rgba(255, 253, 248, 0.8);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cpq-gold);
    margin-bottom: 14px;
