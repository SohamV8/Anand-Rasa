{%- liquid
  assign cpq_uid = section.id
  assign cpq_collections = section.settings.catalog_collections | default: 'bestseller,planet-attars,zodiac-attar,chakra-attar,nakshatra-attar,stress-relief-attar,love-attar,apsara-attars,perfume-series'
-%}

{%- render 'custom-perfume-logic', cpq_section_id: cpq_uid, cpq_collections: cpq_collections -%}
{%- assign cpq_card_tpl_id = 'cpq-' | append: cpq_uid -%}
{%- render 'custom-perfume-card', cpq_card_id: cpq_card_tpl_id -%}

<section
  class="cpq section-{{ section.id }}-padding"
  id="cpq-{{ cpq_uid }}"
  data-cpq-quiz
  aria-labelledby="cpq-title-{{ cpq_uid }}"
>
  <div class="cpq__cosmos" aria-hidden="true">
    {%- for i in (1..28) -%}
      <span class="cpq__star" style="--cpq-sx: {{ i | times: 37 | modulo: 100 }}%; --cpq-sy: {{ i | times: 53 | modulo: 100 }}%; --cpq-sd: {{ i | times: 0.7 | modulo: 5 | plus: 3 }}s;"></span>
    {%- endfor -%}
  </div>

  <div class="cpq__shell">
    <header class="cpq__header">
      <p class="cpq__badge">✦ {{ section.settings.eyebrow | default: 'Anand Rasa' }}</p>
      <h1 class="cpq__title" id="cpq-title-{{ cpq_uid }}">
        {{ section.settings.heading | default: 'Discover your signature attar' }}
      </h1>
      <p class="cpq__lead">
        {{ section.settings.subheading | default: 'A personalised fragrance consultation — curated from our existing luxury attars and natural perfume oils.' }}
      </p>
      <div class="cpq__progress" role="progressbar" aria-valuemin="1" aria-valuemax="8" aria-valuenow="1" id="cpq-progress-{{ cpq_uid }}">
        <div class="cpq__progress-track">
          <div class="cpq__progress-fill" data-cpq-progress-fill style="width:12.5%"></div>
        </div>
        <p class="cpq__progress-label"><span data-cpq-step-label>Step 1</span> of 8</p>
      </div>
    </header>

    {%- if section.settings.show_trust -%}
      <ul class="cpq__trust" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_badge' -%}
            <li class="cpq__trust-item" {{ block.shopify_attributes }}>{{ block.settings.label }}</li>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.blocks.size == 0 -%}
          <li class="cpq__trust-item">Alcohol-free</li>
          <li class="cpq__trust-item">Handcrafted</li>
          <li class="cpq__trust-item">Natural fragrance</li>
          <li class="cpq__trust-item">Long-lasting</li>
          <li class="cpq__trust-item">Astrology-inspired</li>
        {%- endif -%}
      </ul>
    {%- endif -%}

    <form class="cpq__form" data-cpq-form novalidate>
      <div class="cpq__steps" data-cpq-steps>
        {%- comment -%} Step 1 {%- endcomment -%}
        <fieldset class="cpq__step is-active" data-cpq-step="1">
          <legend class="cpq__step-title">Your details</legend>
          <p class="cpq__step-sub">Optional — helps us personalise your consultation.</p>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-name-{{ cpq_uid }}">Name <span class="cpq__opt">(optional)</span></label>
            <input class="cpq__input" id="cpq-name-{{ cpq_uid }}" name="name" type="text" autocomplete="name" placeholder="Your name">
          </div>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-email-{{ cpq_uid }}">Email or phone <span class="cpq__opt">(optional)</span></label>
            <input class="cpq__input" id="cpq-email-{{ cpq_uid }}" name="contact" type="text" autocomplete="email" placeholder="For follow-up or gifting notes">
          </div>
        </fieldset>

        {%- comment -%} Step 2 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="2" hidden>
          <legend class="cpq__step-title">What are you looking for?</legend>
          <p class="cpq__step-sub">Choose a fragrance type that matches your preference.</p>
          <div class="cpq__choices cpq__choices--3" data-cpq-group="fragranceType" data-cpq-required>
            {%- assign cpq_types = 'Attar|attar,Perfume oil|perfume-oil,Spray|spray,Unisex fragrance|unisex,Spiritual fragrance|spiritual,Luxury fragrance|luxury' | split: ',' -%}
            {%- for cpq_t in cpq_types -%}
              {%- assign cpq_tp = cpq_t | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_tp[1] }}" aria-pressed="false">{{ cpq_tp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 3 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="3" hidden>
          <legend class="cpq__step-title">Purpose</legend>
          <p class="cpq__step-sub">When and why will you wear this fragrance?</p>
          <div class="cpq__choices cpq__choices--3" data-cpq-group="purpose" data-cpq-required>
            {%- assign cpq_purposes = 'Daily wear|daily,Office|office,Meditation|meditation,Sleep|sleep,Stress relief|stress,Spiritual use|spiritual,Gifting|gifting,Special occasions|special,Astrology-based|astrology' | split: ',' -%}
            {%- for cpq_p in cpq_purposes -%}
              {%- assign cpq_pp = cpq_p | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_pp[1] }}" aria-pressed="false">{{ cpq_pp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 4 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="4" hidden>
          <legend class="cpq__step-title">Mood & personality</legend>
          <p class="cpq__step-sub">Choose a fragrance that matches your mood and energy.</p>
          <div class="cpq__choices cpq__choices--2" data-cpq-group="mood" data-cpq-required>
            {%- assign cpq_moods = 'Calm|calm,Romantic|romantic,Luxurious|luxurious,Fresh|fresh,Mysterious|mysterious,Spiritual|spiritual,Grounding|grounding,Uplifting|uplifting,Sensual|sensual,Minimal|minimal' | split: ',' -%}
            {%- for cpq_m in cpq_moods -%}
              {%- assign cpq_mp = cpq_m | split: '|' -%}
              <button type="button" class="cpq__choice cpq__choice--tall" data-cpq-value="{{ cpq_mp[1] }}" aria-pressed="false">{{ cpq_mp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 5 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="5" hidden>
          <legend class="cpq__step-title">Preferred fragrance families</legend>
          <p class="cpq__step-sub">Select the notes you are naturally drawn to.</p>
          <div class="cpq__choices cpq__choices--3" data-cpq-group="families" data-cpq-required data-cpq-multi>
            {%- assign cpq_families = 'Rose|rose,Lavender|lavender,Sandalwood|sandalwood,Jasmine|jasmine,Mogra|mogra,Oud|oud,Vetiver|vetiver,Musk|musk,Amber|amber,Saffron|saffron,Citrus|citrus,Floral|floral,Woody|woody,Herbal|herbal' | split: ',' -%}
            {%- for cpq_f in cpq_families -%}
              {%- assign cpq_fp = cpq_f | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_fp[1] }}" aria-pressed="false">{{ cpq_fp[0] }}</button>
            {%- endfor -%}
          </div>
          <p class="cpq__hint">Select one or more families.</p>
        </fieldset>

        {%- comment -%} Step 6 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="6" hidden>
          <legend class="cpq__step-title">Astrology layer</legend>
          <p class="cpq__step-sub">Optional cosmic alignment — refine your attar match.</p>
          <div class="cpq__astro-grid">
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-zodiac-{{ cpq_uid }}">Zodiac sign</label>
              <select class="cpq__select" id="cpq-zodiac-{{ cpq_uid }}" name="zodiac" data-cpq-field="zodiac">
                <option value="">Prefer not to say</option>
                <option value="aries">Aries (Mesh)</option>
                <option value="taurus">Taurus (Vrishabh)</option>
                <option value="gemini">Gemini (Mithun)</option>
                <option value="cancer">Cancer (Kark)</option>
                <option value="leo">Leo (Simha)</option>
                <option value="virgo">Virgo (Kanya)</option>
                <option value="libra">Libra (Tula)</option>
                <option value="scorpio">Scorpio (Vrishchik)</option>
                <option value="sagittarius">Sagittarius (Dhanu)</option>
                <option value="capricorn">Capricorn (Makar)</option>
                <option value="aquarius">Aquarius (Kumbh)</option>
                <option value="pisces">Pisces (Meen)</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-planet-{{ cpq_uid }}">Planet</label>
              <select class="cpq__select" id="cpq-planet-{{ cpq_uid }}" name="planet" data-cpq-field="planet">
                <option value="">Prefer not to say</option>
                <option value="surya">Sun (Surya)</option>
                <option value="chandra">Moon (Chandra)</option>
                <option value="mangal">Mars (Mangal)</option>
                <option value="budh">Mercury (Budh)</option>
                <option value="guru">Jupiter (Guru)</option>
                <option value="shukra">Venus (Shukra)</option>
                <option value="shani">Saturn (Shani)</option>
                <option value="rahu">Rahu</option>
                <option value="ketu">Ketu</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-nakshatra-{{ cpq_uid }}">Nakshatra</label>
              <select class="cpq__select" id="cpq-nakshatra-{{ cpq_uid }}" name="nakshatra" data-cpq-field="nakshatra">
                <option value="">Prefer not to say</option>
                <option value="ashwini">Ashwini</option>
                <option value="bharani">Bharani</option>
                <option value="krittika">Krittika</option>
                <option value="rohini">Rohini</option>
                <option value="mrigashira">Mrigashira</option>
                <option value="ardra">Ardra</option>
                <option value="punarvasu">Punarvasu</option>
                <option value="pushya">Pushya</option>
                <option value="ashlesha">Ashlesha</option>
                <option value="magha">Magha</option>
                <option value="phalguni">Phalguni</option>
                <option value="hasta">Hasta</option>
                <option value="chitra">Chitra</option>
                <option value="swati">Swati</option>
                <option value="vishakha">Vishakha</option>
                <option value="anuradha">Anuradha</option>
                <option value="jyeshtha">Jyeshtha</option>
                <option value="mula">Mula</option>
                <option value="ashadha">Ashadha</option>
                <option value="shravana">Shravana</option>
                <option value="dhanishtha">Dhanishtha</option>
                <option value="shatabhisha">Shatabhisha</option>
                <option value="bhadrapada">Bhadrapada</option>
                <option value="revati">Revati</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-chakra-{{ cpq_uid }}">Chakra</label>
              <select class="cpq__select" id="cpq-chakra-{{ cpq_uid }}" name="chakra" data-cpq-field="chakra">
                <option value="">Prefer not to say</option>
                <option value="root">Root (Muladhara)</option>
                <option value="sacral">Sacral (Svadhisthana)</option>
                <option value="solar">Solar Plexus (Manipura)</option>
                <option value="heart">Heart (Anahata)</option>
                <option value="throat">Throat (Vishuddha)</option>
                <option value="third-eye">Third Eye (Ajna)</option>
                <option value="crown">Crown (Sahasrara)</option>
              </select>
            </div>
            <div class="cpq__field cpq__field--full">
              <label class="cpq__label" for="cpq-dob-{{ cpq_uid }}">Date of birth <span class="cpq__opt">(optional)</span></label>
              <input class="cpq__input" id="cpq-dob-{{ cpq_uid }}" name="dob" type="date" data-cpq-field="dob">
            </div>
          </div>
        </fieldset>

        {%- comment -%} Step 7 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="7" hidden>
          <legend class="cpq__step-title">Intensity</legend>
          <p class="cpq__step-sub">How strong should your fragrance feel on skin?</p>
          <div class="cpq__pills" data-cpq-group="intensity" data-cpq-required>
            <button type="button" class="cpq__pill" data-cpq-value="light" aria-pressed="false">Light</button>
            <button type="button" class="cpq__pill" data-cpq-value="medium" aria-pressed="false">Medium</button>
            <button type="button" class="cpq__pill" data-cpq-value="strong" aria-pressed="false">Strong</button>
          </div>
        </fieldset>

        {%- comment -%} Step 8 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="8" hidden>
          <legend class="cpq__step-title">Budget</legend>
          <p class="cpq__step-sub">We will prioritise attars within your preferred range.</p>
          <div class="cpq__pills" data-cpq-group="budget" data-cpq-required>
            <button type="button" class="cpq__pill" data-cpq-value="entry" aria-pressed="false">Entry</button>
            <button type="button" class="cpq__pill" data-cpq-value="mid" aria-pressed="false">Mid</button>
            <button type="button" class="cpq__pill" data-cpq-value="premium" aria-pressed="false">Premium</button>
            <button type="button" class="cpq__pill" data-cpq-value="luxury" aria-pressed="false">Luxury</button>
          </div>
        </fieldset>
      </div>

      <div class="cpq__nav">
        <button type="button" class="cpq__btn cpq__btn--ghost" data-cpq-back hidden>Back</button>
        <button type="button" class="cpq__btn cpq__btn--primary" data-cpq-next>Continue</button>
      </div>
    </form>

    <section class="cpq__results" data-cpq-results hidden aria-live="polite">
      <header class="cpq__results-head">
        <p class="cpq__results-eyebrow">Your curated attars</p>
        <h2 class="cpq__results-title" data-cpq-results-title>Your signature attar matches</h2>
        <p class="cpq__results-lead" data-cpq-results-lead>Curated from our existing Anand Rasa attars — alcohol-free, handcrafted, and aligned with your scent story.</p>
      </header>
      <div class="cpq__results-grid" data-cpq-results-grid role="list"></div>
      <div class="cpq__results-actions">
        <button type="button" class="cpq__btn cpq__btn--ghost" data-cpq-restart>Start again</button>
        <a class="cpq__btn cpq__btn--primary" href="{{ section.settings.collection_link | default: routes.all_products_collection_url }}">Explore all attars</a>
      </div>
    </section>

    {%- if section.settings.show_how -%}
      <section class="cpq__how" aria-labelledby="cpq-how-{{ cpq_uid }}">
        <h2 class="cpq__how-title" id="cpq-how-{{ cpq_uid }}">{{ section.settings.how_title | default: 'How it works' }}</h2>
        <ol class="cpq__how-list">
          <li><strong>Answer guided questions</strong> about mood, purpose, notes, and cosmic alignment.</li>
          <li><strong>We match your profile</strong> to existing attars in our Shopify catalog.</li>
          <li><strong>Discover 3–6 best matches</strong> with reasons, notes, and quick add-to-cart.</li>
        </ol>
      </section>
    {%- endif -%}

    {%- if section.settings.show_faq -%}
      <section class="cpq__faq" aria-labelledby="cpq-faq-{{ cpq_uid }}">
        <h2 class="cpq__faq-title" id="cpq-faq-{{ cpq_uid }}">{{ section.settings.faq_title | default: 'Fragrance finder FAQ' }}</h2>
        <div class="cpq__faq-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              <details class="cpq__faq-item" {{ block.shopify_attributes }}>
                <summary class="cpq__faq-q">{{ block.settings.question }}</summary>
                <div class="cpq__faq-a rte">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
          {%- assign cpq_faq_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              {%- assign cpq_faq_count = cpq_faq_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if cpq_faq_count == 0 -%}
            <details class="cpq__faq-item" open>
              <summary class="cpq__faq-q">What is a personalised attar consultation?</summary>
              <div class="cpq__faq-a"><p>Our fragrance finder recommends existing premium attars from Anand Rasa based on your mood, purpose, notes, and optional astrology preferences — without creating new products.</p></div>
            </details>
            <details class="cpq__faq-item">
              <summary class="cpq__faq-q">Are these alcohol-free attars?</summary>
              <div class="cpq__faq-a"><p>Yes. Our attars are natural perfume oils — concentrated, alcohol-free, and crafted for long-lasting wear.</p></div>
            </details>
            <details class="cpq__faq-item">
              <summary class="cpq__faq-q">Can I use zodiac or chakra preferences?</summary>
              <div class="cpq__faq-a"><p>Yes. You can align recommendations with zodiac attars, planet attars, nakshatra attars, and chakra attars from our catalog.</p></div>
            </details>
          {%- endif -%}
        </div>
      </section>
    {%- endif -%}
  </div>
</section>

<style>
  #cpq-{{ cpq_uid }} {
    --cpq-deep: #1a0a2e;
    --cpq-ink: #1e2023;
    --cpq-muted: #6b7280;
    --cpq-surface: #faf7f2;
    --cpq-card: #fffdf8;
    --cpq-gold: #b8860b;
    --cpq-gold-mid: #d4a843;
    --cpq-gold-light: #f5e6c0;
    --cpq-border: rgba(184, 134, 11, 0.18);
    position: relative;
    overflow: hidden;
    background: var(--cpq-surface);
    color: var(--cpq-ink);
    font-family: var(--font-body-family, system-ui, sans-serif);
  }
  #cpq-{{ cpq_uid }}.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media (min-width: 750px) {
    #cpq-{{ cpq_uid }}.section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #cpq-{{ cpq_uid }} .cpq__cosmos {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  #cpq-{{ cpq_uid }} .cpq__star {
    position: absolute;
    left: var(--cpq-sx);
    top: var(--cpq-sy);
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: var(--cpq-gold);
    opacity: 0.2;
    animation: cpqTwinkle var(--cpq-sd) ease-in-out infinite alternate;
  }
  @keyframes cpqTwinkle {
    from { opacity: 0.08; transform: scale(0.8); }
    to { opacity: 0.35; transform: scale(1.2); }
  }
  #cpq-{{ cpq_uid }} .cpq__shell {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 48px) clamp(16px, 3vw, 24px);
  }
  #cpq-{{ cpq_uid }} .cpq__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--cpq-border);
    background: rgba(255, 253, 248, 0.8);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cpq-gold);
    margin-bottom: 14px;
  }
  #cpq-{{ cpq_uid }} .cpq__title {
    margin: 0 0 10px;
    font-family: var(--font-heading-family, Georgia, serif);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.02em;
  }
  #cpq-{{ cpq_uid }} .cpq__lead {
    margin: 0 0 20px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--cpq-muted);
    max-width: 58ch;
  }
  #cpq-{{ cpq_uid }} .cpq__progress { margin-bottom: 18px; }
  #cpq-{{ cpq_uid }} .cpq__progress-track {
    height: 3px;
    background: rgba(184, 134, 11, 0.12);
    border-radius: 999px;
    overflow: hidden;
  }
  #cpq-{{ cpq_uid }} .cpq__progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cpq-gold), var(--cpq-gold-mid));
    transition: width 0.38s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #cpq-{{ cpq_uid }} .cpq__progress-label {
    margin: 8px 0 0;
    font-size: 12px;
    color: var(--cpq-muted);
    text-align: right;
  }
  #cpq-{{ cpq_uid }} .cpq__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
  }
  #cpq-{{ cpq_uid }} .cpq__trust-item {
    font-size: 11px;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid var(--cpq-border);
    background: var(--cpq-card);
    color: var(--cpq-muted);
  }
  #cpq-{{ cpq_uid }} .cpq__form {
    background: rgba(255, 253, 248, 0.92);
    border: 1px solid var(--cpq-border);
    border-radius: 18px;
    padding: clamp(18px, 3vw, 28px);
    box-shadow: 0 18px 48px rgba(26, 10, 46, 0.06);
    backdrop-filter: blur(8px);
  }
  #cpq-{{ cpq_uid }} .cpq__step {
    border: 0;
    margin: 0;
    padding: 0;
    min-width: 0;
    animation: cpqFadeIn 0.34s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #cpq-{{ cpq_uid }} .cpq__step[hidden] { display: none !important; }
  @keyframes cpqFadeIn {
    from { opacity: 0; transform: translateX(12px); }
    to { opacity: 1; transform: translateX(0); }
  }
  #cpq-{{ cpq_uid }} .cpq__step-title {
    margin: 0 0 6px;
    font-family: var(--font-heading-family, Georgia, serif);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 400;
  }
  #cpq-{{ cpq_uid }} .cpq__step-sub {
    margin: 0 0 16px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--cpq-muted);
  }
  #cpq-{{ cpq_uid }} .cpq__field { margin-bottom: 14px; }
  #cpq-{{ cpq_uid }} .cpq__field--full { grid-column: 1 / -1; }
  #cpq-{{ cpq_uid }} .cpq__label {
    display: block;
    margin-bottom: 6px;
    font-size: 12px;
    font-weight: 500;
