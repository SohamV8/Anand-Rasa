{%- liquid
  assign cpq_uid = section.id
  assign cpq_contact_id = 'cpq-contact-' | append: cpq_uid
  assign cpq_form_posted = false
-%}

{{ 'custom-perfume-quiz.css' | asset_url | stylesheet_tag }}

<section
  class="cpq cpq--premium section-{{ section.id }}-padding"
  id="cpq-{{ cpq_uid }}"
  data-cpq-quiz
  data-cpq-step="1"
  aria-labelledby="cpq-title-{{ cpq_uid }}"
>
  <div class="cpq__shell">
    {%- form 'contact', id: cpq_contact_id, class: 'cpq__shopify-form' -%}

      {%- if form.posted_successfully? -%}
        {%- assign cpq_form_posted = true -%}
        <div class="cpq__success" data-cpq-success tabindex="-1" role="status" aria-labelledby="cpq-success-title-{{ cpq_uid }}">
          <div class="cpq__success-icon" aria-hidden="true">
            <svg class="cpq__success-check" viewBox="0 0 52 52" focusable="false">
              <circle class="cpq__success-circle" cx="26" cy="26" r="24" fill="none"/>
              <path class="cpq__success-path" fill="none" d="M14 27l8 8 16-18"/>
            </svg>
          </div>
          <p class="cpq__success-eyebrow">Anand Rasa</p>
          <h2 class="cpq__success-title" id="cpq-success-title-{{ cpq_uid }}">
            {{ section.settings.success_heading | default: 'Thank You' }}
          </h2>
          <p class="cpq__success-sub">
            {{ section.settings.success_subheading | default: 'Your personalised fragrance consultation has been received.' }}
          </p>
          <div class="cpq__success-divider" aria-hidden="true"></div>
          <p class="cpq__success-body">
            {{ section.settings.success_body | default: 'Our fragrance specialists will carefully review your preferences and contact you with curated attar recommendations crafted around your taste, mood, and fragrance profile.' }}
          </p>
          <p class="cpq__success-foot">
            {{ section.settings.success_footnote | default: 'Thank you for choosing Anand Rasa.' }}
          </p>
          {%- if section.settings.collection_link != blank -%}
            <a class="cpq__btn cpq__btn--ghost cpq__success-cta" href="{{ section.settings.collection_link }}">Explore our attars</a>
          {%- endif -%}
        </div>
      {%- else -%}

      {%- if form.errors -%}
        <div class="cpq__form-errors" data-cpq-form-errors role="alert">
          <p class="cpq__form-errors-title">{{ 'templates.contact.form.error_heading' | t }}</p>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <input type="hidden" name="contact[tags]" value="custom-perfume-quiz,attar-consultation">
      <input type="hidden" name="contact[form_type]" value="Custom Perfume Consultation">
      <input type="hidden" name="contact[fragrance_type]" value="" data-cpq-contact-field="fragranceType">
      <input type="hidden" name="contact[purpose]" value="" data-cpq-contact-field="purpose">
      <input type="hidden" name="contact[mood]" value="" data-cpq-contact-field="mood">
      <input type="hidden" name="contact[fragrance_families]" value="" data-cpq-contact-field="families">
      <input type="hidden" name="contact[zodiac]" value="" data-cpq-contact-field="zodiac">
      <input type="hidden" name="contact[planet]" value="" data-cpq-contact-field="planet">
      <input type="hidden" name="contact[nakshatra]" value="" data-cpq-contact-field="nakshatra">
      <input type="hidden" name="contact[intensity]" value="" data-cpq-contact-field="intensity">
      <input type="hidden" name="contact[date_of_birth]" value="" data-cpq-contact-field="dob">
      <input type="hidden" name="contact[birth_time]" value="" data-cpq-contact-field="birthTime">
      <input type="hidden" name="contact[birth_place]" value="" data-cpq-contact-field="birthLocation">
      <textarea class="cpq__body-hidden" name="contact[body]" data-cpq-contact-field="body" tabindex="-1" aria-hidden="true"></textarea>

      <div class="cpq__consultation" data-cpq-consultation>
    <header class="cpq__header">
      <h1 class="cpq__title" id="cpq-title-{{ cpq_uid }}">
        {{ section.settings.heading | default: 'Find your fragrance' }}
      </h1>
      <p class="cpq__lead">
        {{ section.settings.subheading | default: 'Answer a few simple questions. Our team will suggest attars and perfume oils that suit you.' }}
      </p>
      {%- if section.settings.show_trust -%}
      <ul class="cpq__trust" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_badge' -%}
            <li class="cpq__trust-item" {{ block.shopify_attributes }}>{{ block.settings.label }}</li>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.blocks.size == 0 -%}
          <li class="cpq__trust-item">Alcohol-free attars</li>
          <li class="cpq__trust-item">Made in India</li>
          <li class="cpq__trust-item">Natural oils</li>
          <li class="cpq__trust-item">Long-lasting</li>
        {%- endif -%}
      </ul>
      {%- endif -%}
      <div class="cpq__progress" role="progressbar" aria-valuemin="1" aria-valuemax="7" aria-valuenow="1" aria-label="Consultation progress" id="cpq-progress-{{ cpq_uid }}">
        <div class="cpq__progress-track">
          <div class="cpq__progress-fill" data-cpq-progress-fill style="width:14.3%"></div>
        </div>
        <p class="cpq__progress-label"><span data-cpq-step-label>Step 1 of 7</span></p>
      </div>
    </header>

    <div class="cpq__form" data-cpq-form role="group" aria-label="Fragrance consultation">
      <div class="cpq__steps-viewport" data-cpq-steps-viewport>
      <div class="cpq__steps" data-cpq-steps>
        {%- comment -%} Step 1 {%- endcomment -%}
        <fieldset class="cpq__step is-active" data-cpq-step="1">
          <legend class="cpq__step-title">Your details</legend>
          <p class="cpq__step-sub">We will email you personalised suggestions. About 2 minutes.</p>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-name-{{ cpq_uid }}">Name <span class="cpq__opt">(optional)</span></label>
            <input class="cpq__input" id="cpq-name-{{ cpq_uid }}" type="text" name="contact[name]" autocomplete="name" placeholder="Your name" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
          </div>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-email-{{ cpq_uid }}">
              Email <span class="cpq__req" aria-hidden="true">*</span>
            </label>
            <input
              class="cpq__input"
              id="cpq-email-{{ cpq_uid }}"
              type="email"
              name="contact[email]"
              autocomplete="email"
              spellcheck="false"
              autocapitalize="off"
              required
              placeholder="you@example.com"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
            >
          </div>
          <div class="cpq__field">
            <label class="cpq__label" for="cpq-phone-{{ cpq_uid }}">Phone <span class="cpq__opt">(optional)</span></label>
            <input
              class="cpq__input"
              id="cpq-phone-{{ cpq_uid }}"
              type="tel"
              name="contact[phone]"
              autocomplete="tel"
              inputmode="tel"
              placeholder="+91 …"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            >
          </div>
        </fieldset>

        {%- comment -%} Step 2 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="2" hidden>
          <legend class="cpq__step-title">Attar or perfume oil</legend>
          <p class="cpq__step-sub">Pick the type you want.</p>
          <div class="cpq__choices cpq__choices--2 cpq__choices--visual" data-cpq-group="fragranceType" data-cpq-required>
            {%- assign cpq_types = 'Attar|attar|Planet/shukra_attar.webp,Perfume|perfume-oil|Perfume/Perfume_100ml.webp' | split: ',' -%}
            {%- for cpq_t in cpq_types -%}
              {%- assign cpq_tp = cpq_t | split: '|' -%}
              <button type="button" class="cpq__choice cpq__choice--visual" data-cpq-value="{{ cpq_tp[1] }}" aria-pressed="false">
                {%- if cpq_tp[2] != blank -%}
                  <span class="cpq__choice-media">
                    <img
                      src="{{ cpq_tp[2] | asset_url }}"
                      alt="{{ cpq_tp[0] | escape }}"
                      width="280"
                      height="280"
                      loading="lazy"
                      decoding="async"
                    >
                  </span>
                {%- endif -%}
                <span class="cpq__choice-label">{{ cpq_tp[0] }}</span>
              </button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 3 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="3" hidden>
          <legend class="cpq__step-title">Usage time</legend>
          <p class="cpq__step-sub">When will you wear this fragrance?</p>
          <div class="cpq__choices cpq__choices--chips" data-cpq-group="purpose" data-cpq-required>
            {%- assign cpq_purposes = 'Everyday|daily,Work|office,Sports|sports,Meditation|meditation,Stress relief|stress,Spiritual|spiritual,Gift|gifting,Special event|special' | split: ',' -%}
            {%- for cpq_p in cpq_purposes -%}
              {%- assign cpq_pp = cpq_p | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_pp[1] }}" aria-pressed="false">{{ cpq_pp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 4 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="4" hidden>
          <legend class="cpq__step-title">Mood</legend>
          <p class="cpq__step-sub">How should it feel on you?</p>
          <div class="cpq__choices cpq__choices--chips" data-cpq-group="mood" data-cpq-required>
            {%- assign cpq_moods = 'Calm|calm,Happy|happy,Fresh|fresh,Warm|warm,Romantic|romantic,Bold|bold,Relaxed|relaxed,Confident|confident' | split: ',' -%}
            {%- for cpq_m in cpq_moods -%}
              {%- assign cpq_mp = cpq_m | split: '|' -%}
              <button type="button" class="cpq__choice" data-cpq-value="{{ cpq_mp[1] }}" aria-pressed="false">{{ cpq_mp[0] }}</button>
            {%- endfor -%}
          </div>
        </fieldset>

        {%- comment -%} Step 5 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="5" hidden>
          <legend class="cpq__step-title">Notes</legend>
          <p class="cpq__step-sub">Tap the notes you like. You can pick more than one.</p>
          <div class="cpq__choices cpq__choices--3 cpq__choices--visual cpq__choices--notes" data-cpq-group="families" data-cpq-required data-cpq-multi>
            {%- assign cpq_families = 'Rose|rose|Notes/Rose.webp,Lavender|lavender|Notes/lavender.webp,Sandalwood|sandalwood|Notes/cedarwood.webp,Jasmine|jasmine|Notes/jasmine.webp,Mogra|mogra|Notes/motia.webp,Oud|oud|Notes/oud.webp,Vetiver|vetiver|Notes/vetiver.webp,Musk|musk|Notes/musk.webp,Amber|amber|Notes/amber.webp,Saffron|saffron|Notes/Saffron.webp,Citrus|citrus|Notes/citrus.webp,Floral|floral|Notes/Gardenia.webp,Woody|woody|Notes/wood.webp,Herbal|herbal|Notes/green_herbal.webp' | split: ',' -%}
            {%- for cpq_f in cpq_families -%}
              {%- assign cpq_fp = cpq_f | split: '|' -%}
              <button type="button" class="cpq__choice cpq__choice--visual cpq__choice--note" data-cpq-value="{{ cpq_fp[1] }}" aria-pressed="false">
                {%- if cpq_fp[2] != blank -%}
                  <span class="cpq__choice-media">
                    <img
                      src="{{ cpq_fp[2] | asset_url }}"
                      alt="{{ cpq_fp[0] | escape }}"
                      width="120"
                      height="120"
                      loading="lazy"
                      decoding="async"
                    >
                  </span>
                {%- endif -%}
                <span class="cpq__choice-label">{{ cpq_fp[0] }}</span>
              </button>
            {%- endfor -%}
          </div>
          <p class="cpq__hint">Pick at least one note.</p>
        </fieldset>

        {%- comment -%} Step 6 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="6" hidden>
          <legend class="cpq__step-title">Cosmic alignment</legend>
          <p class="cpq__step-sub">Optional. Skip anything you do not know.</p>
          <div class="cpq__astro-grid">
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-zodiac-{{ cpq_uid }}">Zodiac sign</label>
              <select class="cpq__select" id="cpq-zodiac-{{ cpq_uid }}" name="zodiac" data-cpq-field="zodiac">
                <option value="">Prefer not to say</option>
                <option value="aries">Aries (Mesh)</option>
                <option value="taurus">Taurus (Vrishabh)</option>
                <option value="gemini">Gemini (Mithun)</option>
                <option value="cancer">Cancer (Kark)</option>
                <option value="leo">Leo (Simha)</option>
                <option value="virgo">Virgo (Kanya)</option>
                <option value="libra">Libra (Tula)</option>
                <option value="scorpio">Scorpio (Vrishchik)</option>
                <option value="sagittarius">Sagittarius (Dhanu)</option>
                <option value="capricorn">Capricorn (Makar)</option>
                <option value="aquarius">Aquarius (Kumbh)</option>
                <option value="pisces">Pisces (Meen)</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-planet-{{ cpq_uid }}">Planet</label>
              <select class="cpq__select" id="cpq-planet-{{ cpq_uid }}" name="planet" data-cpq-field="planet">
                <option value="">Prefer not to say</option>
                <option value="surya">Sun (Surya)</option>
                <option value="chandra">Moon (Chandra)</option>
                <option value="mangal">Mars (Mangal)</option>
                <option value="budh">Mercury (Budh)</option>
                <option value="guru">Jupiter (Guru)</option>
                <option value="shukra">Venus (Shukra)</option>
                <option value="shani">Saturn (Shani)</option>
                <option value="rahu">Rahu</option>
                <option value="ketu">Ketu</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-nakshatra-{{ cpq_uid }}">Nakshatra</label>
              <select class="cpq__select" id="cpq-nakshatra-{{ cpq_uid }}" name="nakshatra" data-cpq-field="nakshatra">
                <option value="">Prefer not to say</option>
                <option value="ashwini">Ashwini</option>
                <option value="bharani">Bharani</option>
                <option value="krittika">Krittika</option>
                <option value="rohini">Rohini</option>
                <option value="mrigashira">Mrigashira</option>
                <option value="ardra">Ardra</option>
                <option value="punarvasu">Punarvasu</option>
                <option value="pushya">Pushya</option>
                <option value="ashlesha">Ashlesha</option>
                <option value="magha">Magha</option>
                <option value="phalguni">Phalguni</option>
                <option value="hasta">Hasta</option>
                <option value="chitra">Chitra</option>
                <option value="swati">Swati</option>
                <option value="vishakha">Vishakha</option>
                <option value="anuradha">Anuradha</option>
                <option value="jyeshtha">Jyeshtha</option>
                <option value="mula">Mula</option>
                <option value="ashadha">Ashadha</option>
                <option value="shravana">Shravana</option>
                <option value="dhanishtha">Dhanishtha</option>
                <option value="shatabhisha">Shatabhisha</option>
                <option value="bhadrapada">Bhadrapada</option>
                <option value="revati">Revati</option>
              </select>
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-dob-{{ cpq_uid }}">Date of birth <span class="cpq__opt">(optional)</span></label>
              <input class="cpq__input" id="cpq-dob-{{ cpq_uid }}" name="dob" type="date" data-cpq-field="dob" autocomplete="bday">
            </div>
            <div class="cpq__field">
              <label class="cpq__label" for="cpq-time-{{ cpq_uid }}">Time of birth <span class="cpq__opt">(optional)</span></label>
              <input class="cpq__input" id="cpq-time-{{ cpq_uid }}" name="birth_time" type="time" data-cpq-field="birthTime" autocomplete="off">
            </div>
            <div class="cpq__field cpq__field--full">
              <label class="cpq__label" for="cpq-location-{{ cpq_uid }}">Place of birth <span class="cpq__opt">(optional)</span></label>
              <input class="cpq__input" id="cpq-location-{{ cpq_uid }}" name="birth_location" type="text" data-cpq-field="birthLocation" placeholder="e.g. Mumbai, Delhi, Jaipur" autocomplete="address-level2">
            </div>
          </div>
        </fieldset>

        {%- comment -%} Step 7 {%- endcomment -%}
        <fieldset class="cpq__step" data-cpq-step="7" hidden>
          <legend class="cpq__step-title">Strength</legend>
          <p class="cpq__step-sub">How strong should it be on skin?</p>
          <div class="cpq__pills" data-cpq-group="intensity" data-cpq-required>
            <button type="button" class="cpq__pill" data-cpq-value="light" aria-pressed="false">Light</button>
            <button type="button" class="cpq__pill" data-cpq-value="medium" aria-pressed="false">Medium</button>
            <button type="button" class="cpq__pill" data-cpq-value="strong" aria-pressed="false">Strong</button>
          </div>
        </fieldset>

      </div>
      </div>

      <div class="cpq__nav" data-cpq-nav>
        <button type="button" class="cpq__btn cpq__btn--ghost" data-cpq-back hidden>Back</button>
        <button type="button" class="cpq__btn cpq__btn--primary" data-cpq-next>Continue</button>
        <button type="submit" class="cpq__btn cpq__btn--primary cpq__btn--submit" data-cpq-submit hidden>
          {{ section.settings.contact_submit_label | default: 'Send my preferences' }}
        </button>
      </div>
    </div>
      </div>

      {%- endif -%}
    {%- endform -%}

    {%- unless cpq_form_posted -%}
    <div class="cpq__below">
    {%- if section.settings.show_how -%}
      <section class="cpq__how" aria-labelledby="cpq-how-{{ cpq_uid }}">
        <h2 class="cpq__how-title" id="cpq-how-{{ cpq_uid }}">{{ section.settings.how_title | default: 'How it works' }}</h2>
        <ol class="cpq__how-list">
          <li>Answer a few short questions about your taste and routine.</li>
          <li>Our fragrance team reviews your answers.</li>
          <li>We email you attar and perfume oil suggestions from Anand Rasa.</li>
        </ol>
      </section>
    {%- endif -%}

    {%- if section.settings.show_faq -%}
      <section class="cpq__faq" aria-labelledby="cpq-faq-{{ cpq_uid }}">
        <h2 class="cpq__faq-title" id="cpq-faq-{{ cpq_uid }}">{{ section.settings.faq_title | default: 'Common questions' }}</h2>
        <div class="cpq__faq-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              <details class="cpq__faq-item" {{ block.shopify_attributes }}>
                <summary class="cpq__faq-q">{{ block.settings.question }}</summary>
                <div class="cpq__faq-a rte">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
          {%- assign cpq_faq_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              {%- assign cpq_faq_count = cpq_faq_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if cpq_faq_count == 0 -%}
            <details class="cpq__faq-item" open>
              <summary class="cpq__faq-q">What is this personalised attar consultation?</summary>
              <div class="cpq__faq-a"><p>This consultation captures your fragrance preferences and optional cosmic details. Our team reviews your submission and follows up with personalised attar guidance from Anand Rasa.</p></div>
            </details>
            <details class="cpq__faq-item">
              <summary class="cpq__faq-q">Are these alcohol-free natural perfume oils?</summary>
              <div class="cpq__faq-a"><p>Yes. Our attars are concentrated, alcohol-free perfume oils designed for intimate, long-lasting wear on skin.</p></div>
            </details>
            <details class="cpq__faq-item">
              <summary class="cpq__faq-q">Can I use zodiac or birth details?</summary>
              <div class="cpq__faq-a"><p>Yes. Optional zodiac, planet, nakshatra, date, time, and place of birth help surface zodiac attars, planet attars, and nakshatra attars that resonate with your profile.</p></div>
            </details>
          {%- endif -%}
        </div>
      </section>
    {%- endif -%}
    </div>
    {%- endunless -%}
  </div>
</section>

<style>
  #cpq-{{ cpq_uid }}.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media (min-width: 750px) {
    #cpq-{{ cpq_uid }}.section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

<script>
(function () {
  var root = document.getElementById('cpq-{{ cpq_uid }}');
  if (!root) return;

  var quizPanel = root.querySelector('[data-cpq-form]');
  var steps = Array.prototype.slice.call(root.querySelectorAll('[data-cpq-step]'));
  var btnNext = root.querySelector('[data-cpq-next]');
  var btnBack = root.querySelector('[data-cpq-back]');
  var btnSubmit = root.querySelector('[data-cpq-submit]');
  var navBar = root.querySelector('[data-cpq-nav]');
  var progressFill = root.querySelector('[data-cpq-progress-fill]');
  var progressBar = document.getElementById('cpq-progress-{{ cpq_uid }}');
  var stepLabel = root.querySelector('[data-cpq-step-label]');
  var contactForm = document.getElementById('cpq-contact-{{ cpq_uid }}');
  var cpqStorageKey = 'cpq-session-{{ cpq_uid }}';
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var stepsViewport = root.querySelector('[data-cpq-steps-viewport]');
  var current = 1;
  var total = 7;
  var answers = {
    fragranceType: '',
    purpose: '',
    mood: '',
    families: [],
    zodiac: '',
    planet: '',
    nakshatra: '',
    dob: '',
    birthTime: '',
    birthLocation: '',
    intensity: ''
  };

  if (root.querySelector('[data-cpq-success]')) {
    root.classList.add('cpq--success');
  }

  function updateProgress() {
    var pct = Math.round((current / total) * 1000) / 10;
    if (progressFill) progressFill.style.width = pct + '%';
    if (progressBar) progressBar.setAttribute('aria-valuenow', String(current));
    if (stepLabel) stepLabel.textContent = 'Step ' + current + ' of ' + total;
    if (btnBack) btnBack.hidden = current <= 1;
    var isFinal = current >= total;
    if (btnNext) btnNext.hidden = isFinal;
    if (btnSubmit) btnSubmit.hidden = !isFinal;
    if (navBar) navBar.classList.toggle('is-final', isFinal);
  }

  function staggerChoices(stepEl) {
    if (!stepEl || prefersReducedMotion) return;
    var choices = stepEl.querySelectorAll('.cpq__choice, .cpq__pill');
    for (var i = 0; i < choices.length; i++) {
      choices[i].style.setProperty('--cpq-choice-i', String(i));
    }
  }

  function showStep(n, dir) {
    dir = typeof dir === 'number' ? dir : (n > current ? 1 : -1);
    steps.forEach(function (step) {
      var num = parseInt(step.getAttribute('data-cpq-step'), 10);
      var active = num === n;
      step.classList.remove('cpq__step--enter-left', 'cpq__step--enter-right');
      step.classList.toggle('is-active', active);
      step.hidden = !active;
      if (active) {
        if (!prefersReducedMotion) {
          step.classList.add(dir > 0 ? 'cpq__step--enter-right' : 'cpq__step--enter-left');
        }
        staggerChoices(step);
      }
    });
    current = n;
    root.setAttribute('data-cpq-step', String(n));
    updateProgress();
    if (stepsViewport) stepsViewport.scrollTop = 0;
    if (!prefersReducedMotion && root.getBoundingClientRect) {
      var top = root.getBoundingClientRect().top + window.pageYOffset - 16;
      window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
    }
    var activeStep = steps.find(function (s) { return parseInt(s.getAttribute('data-cpq-step'), 10) === n; });
    if (activeStep) {
      var stepTitle = activeStep.querySelector('.cpq__step-title');
      if (stepTitle && progressBar) {
        progressBar.setAttribute('aria-valuetext', stepTitle.textContent.trim() + ', step ' + n + ' of ' + total);
      }
    }
  }

  function getGroupEl(stepNum) {
    var step = steps.find(function (s) { return parseInt(s.getAttribute('data-cpq-step'), 10) === stepNum; });
    return step;
  }

  function readAnswers() {
    ['zodiac', 'planet', 'nakshatra', 'dob', 'birthTime', 'birthLocation'].forEach(function (key) {
      var el = root.querySelector('[data-cpq-field="' + key + '"]');
      answers[key] = el ? (el.value || '').trim() : '';
    });
  }

  function getContactField(name) {
    if (!contactForm) return '';
    var el = contactForm.querySelector('[name="' + name + '"]');
    return el ? (el.value || '').trim() : '';
  }

  function humanizeValue(val) {
    if (!val) return '';
    var labelMap = { 'perfume-oil': 'Perfume oil', 'attar': 'Attar' };
    function one(v) {
      var s = String(v);
      if (labelMap[s]) return labelMap[s];
      return s.replace(/-/g, ' ');
    }
    if (Array.isArray(val)) {
      return val.map(one).join(', ');
    }
    return one(val);
  }

  function buildContactBody() {
    readAnswers();
    var lines = [
      'Custom Perfume Consultation — Anand Rasa',
      '--------------------------------------',
      'Name: ' + (getContactField('contact[name]') || '—'),
      'Email: ' + (getContactField('contact[email]') || '—'),
      'Phone: ' + (getContactField('contact[phone]') || '—'),
      'Fragrance type: ' + humanizeValue(answers.fragranceType),
      'Purpose: ' + humanizeValue(answers.purpose),
      'Mood: ' + humanizeValue(answers.mood),
      'Fragrance families: ' + humanizeValue(answers.families),
      'Zodiac: ' + humanizeValue(answers.zodiac),
      'Planet: ' + humanizeValue(answers.planet),
      'Nakshatra: ' + humanizeValue(answers.nakshatra),
      'Intensity: ' + humanizeValue(answers.intensity)
    ];
    if (answers.dob) lines.push('Date of birth: ' + answers.dob);
    if (answers.birthTime) lines.push('Time of birth: ' + answers.birthTime);
    if (answers.birthLocation) lines.push('Place of birth: ' + answers.birthLocation);
    return lines.join('\n');
  }

  function setHiddenContactField(key, value) {
    if (!contactForm) return;
    var el = contactForm.querySelector('[data-cpq-contact-field="' + key + '"]');
    if (el) el.value = value || '';
  }

  function populateContactForm() {
    if (!contactForm) return;
    readAnswers();
    setHiddenContactField('fragranceType', humanizeValue(answers.fragranceType));
    setHiddenContactField('purpose', humanizeValue(answers.purpose));
    setHiddenContactField('mood', humanizeValue(answers.mood));
    setHiddenContactField('families', humanizeValue(answers.families));
    setHiddenContactField('zodiac', humanizeValue(answers.zodiac));
    setHiddenContactField('planet', humanizeValue(answers.planet));
    setHiddenContactField('nakshatra', humanizeValue(answers.nakshatra));
    setHiddenContactField('intensity', humanizeValue(answers.intensity));
    setHiddenContactField('dob', answers.dob || '');
    setHiddenContactField('birthTime', answers.birthTime || '');
    setHiddenContactField('birthLocation', answers.birthLocation || '');
    setHiddenContactField('body', buildContactBody());
  }

  function saveQuizSession() {
    try {
      sessionStorage.setItem(cpqStorageKey, JSON.stringify({ answers: answers, step: current }));
    } catch (e) { /* storage unavailable */ }
  }

  function restoreQuizSession() {
    try {
      var raw = sessionStorage.getItem(cpqStorageKey);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

  function clearQuizSession() {
    try { sessionStorage.removeItem(cpqStorageKey); } catch (e) { /* ignore */ }
  }

  function restoreChoiceUI() {
    root.querySelectorAll('[data-cpq-group]').forEach(function (group) {
      var key = group.getAttribute('data-cpq-group');
      var isMulti = group.hasAttribute('data-cpq-multi');
      var val = answers[key];
      group.querySelectorAll('[data-cpq-value]').forEach(function (btn) {
        var v = btn.getAttribute('data-cpq-value');
        var on = isMulti ? (val && val.indexOf(v) >= 0) : val === v;
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    });
  }

  function initFormErrorState() {
    var errorsEl = root.querySelector('[data-cpq-form-errors]');
    if (!errorsEl) return;
    var saved = restoreQuizSession();
    if (!saved || !saved.answers) return;
    Object.keys(saved.answers).forEach(function (key) {
      if (answers.hasOwnProperty(key)) answers[key] = saved.answers[key];
    });
    if (saved.step) showStep(saved.step, -1);
    restoreChoiceUI();
    populateContactForm();
  }

  function validateStep(n) {
    if (n === 1) {
      var emailEl = contactForm && contactForm.querySelector('[name="contact[email]"]');
      return emailEl ? emailEl.checkValidity() : true;
    }
    if (n === 6) return true;
    var step = getGroupEl(n);
    if (!step) return true;
    var groups = step.querySelectorAll('[data-cpq-required]');
    for (var i = 0; i < groups.length; i++) {
      var g = groups[i];
      var groupKey = g.getAttribute('data-cpq-group');
      var isMulti = g.hasAttribute('data-cpq-multi');
      if (isMulti) {
        if (!answers[groupKey] || answers[groupKey].length === 0) return false;
      } else if (!answers[groupKey]) return false;
    }
    return true;
  }

  function bindChoices() {
    root.querySelectorAll('[data-cpq-group]').forEach(function (group) {
      var key = group.getAttribute('data-cpq-group');
      var isMulti = group.hasAttribute('data-cpq-multi');
      if (answers[key] === undefined || answers[key] === null) {
        answers[key] = isMulti ? [] : '';
      }
    });
    if (!quizPanel) return;
    quizPanel.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-cpq-value]');
      if (!btn) return;
      var group = btn.closest('[data-cpq-group]');
      if (!group) return;
      var key = group.getAttribute('data-cpq-group');
      var isMulti = group.hasAttribute('data-cpq-multi');
      var val = btn.getAttribute('data-cpq-value');
      if (isMulti) {
        var idx = answers[key].indexOf(val);
        if (idx >= 0) {
          answers[key].splice(idx, 1);
          btn.setAttribute('aria-pressed', 'false');
        } else {
          answers[key].push(val);
          btn.setAttribute('aria-pressed', 'true');
        }
      } else {
        group.querySelectorAll('[data-cpq-value]').forEach(function (b) {
          b.setAttribute('aria-pressed', 'false');
        });
        btn.setAttribute('aria-pressed', 'true');
        answers[key] = val;
      }
    });
  }

  function shakeNext() {
    if (btnNext) {
      btnNext.classList.add('is-shake');
      setTimeout(function () { btnNext.classList.remove('is-shake'); }, 350);
    }
  }

  if (btnNext) {
    btnNext.addEventListener('click', function () {
      readAnswers();
      if (!validateStep(current)) {
        shakeNext();
        return;
      }
      showStep(current + 1, 1);
    });
  }

  if (btnBack) {
    btnBack.addEventListener('click', function () {
      if (current > 1) showStep(current - 1, -1);
    });
  }

  if (contactForm) {
    contactForm.addEventListener('submit', function (e) {
      readAnswers();
      var invalidStep = 0;
      for (var s = 1; s <= total; s++) {
        if (!validateStep(s)) {
          invalidStep = s;
          break;
        }
      }
      if (invalidStep) {
        e.preventDefault();
        showStep(invalidStep, invalidStep > current ? 1 : -1);
        if (invalidStep === 1) {
          var emailEl = contactForm.querySelector('[name="contact[email]"]');
          if (emailEl) emailEl.focus();
        } else {
          shakeNext();
        }
        return;
      }
      populateContactForm();
      saveQuizSession();
    });
  }

  var successEl = root.querySelector('[data-cpq-success]');
  if (successEl) {
    clearQuizSession();
    successEl.focus();
  }

  bindChoices();
  staggerChoices(steps[0]);
  updateProgress();
  initFormErrorState();
})();
</script>

{%- if section.settings.show_faq -%}
  {%- assign cpq_faq_schema_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq' and block.settings.question != blank -%}
      {%- assign cpq_faq_schema_count = cpq_faq_schema_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if cpq_faq_schema_count > 0 -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign cpq_faq_first = true -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' and block.settings.question != blank -%}
              {%- unless cpq_faq_first -%},{%- endunless -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer | strip_html | strip | json }}
                }
              }
              {%- assign cpq_faq_first = false -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
    </script>
  {%- else -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is this personalised attar consultation?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "This consultation captures your fragrance preferences and optional cosmic details. Our team reviews your submission and follows up with personalised attar guidance from Anand Rasa."
            }
          },
          {
            "@type": "Question",
            "name": "Are these alcohol-free natural perfume oils?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Our attars are concentrated, alcohol-free perfume oils designed for intimate, long-lasting wear on skin."
            }
          },
          {
            "@type": "Question",
            "name": "Can I use zodiac or birth details?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Optional zodiac, planet, nakshatra, date, time, and place of birth help surface zodiac attars, planet attars, and nakshatra attars that resonate with your profile."
            }
          }
        ]
      }
    </script>
  {%- endif -%}
{%- endif -%}

