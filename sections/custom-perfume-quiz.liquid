<script>
(function () {
  var root = document.getElementById('cpq-{{ cpq_uid }}');
  if (!root) return;

  var catalogEl = document.getElementById('cpq-catalog-{{ cpq_uid }}');
  var catalog = [];
  try { catalog = JSON.parse(catalogEl ? catalogEl.textContent : '[]'); } catch (e) { catalog = []; }

  var cardTpl = document.getElementById('cpq-{{ cpq_uid }}-tpl');
  var form = root.querySelector('[data-cpq-form]');
  var stepsWrap = root.querySelector('[data-cpq-steps]');
  var steps = Array.prototype.slice.call(root.querySelectorAll('[data-cpq-step]'));
  var btnNext = root.querySelector('[data-cpq-next]');
  var btnBack = root.querySelector('[data-cpq-back]');
  var btnRestart = root.querySelector('[data-cpq-restart]');
  var progressFill = root.querySelector('[data-cpq-progress-fill]');
  var progressBar = document.getElementById('cpq-progress-{{ cpq_uid }}');
  var stepLabel = root.querySelector('[data-cpq-step-label]');
  var results = root.querySelector('[data-cpq-results]');
  var resultsGrid = root.querySelector('[data-cpq-results-grid]');
  var resultsTitle = root.querySelector('[data-cpq-results-title]');
  var resultsLead = root.querySelector('[data-cpq-results-lead]');

  var current = 1;
  var total = 8;
  var answers = {
    name: '',
    contact: '',
    fragranceType: '',
    purpose: '',
    mood: '',
    families: [],
    zodiac: '',
    planet: '',
    nakshatra: '',
    chakra: '',
    dob: '',
    intensity: '',
    budget: ''
  };

  var SCORE_MAP = {
    fragranceType: {
      attar: ['attar'],
      'perfume-oil': ['perfume', 'oil', 'attar'],
      spray: ['spray', 'perfume'],
      unisex: ['unisex', 'attar'],
      spiritual: ['spiritual', 'meditation', 'chakra', 'planet', 'nakshatra', 'zodiac'],
      luxury: ['luxury', 'premium', 'bestseller']
    },
    purpose: {
      daily: ['daily', 'wear', 'office'],
      office: ['office', 'daily', 'wear'],
      meditation: ['meditation', 'spiritual', 'calm', 'chakra'],
      sleep: ['sleep', 'calm', 'lavender', 'stress'],
      stress: ['stress', 'calm', 'relief', 'lavender', 'sandalwood'],
      spiritual: ['spiritual', 'chakra', 'planet', 'nakshatra', 'pooja'],
      gifting: ['gift', 'love', 'romantic'],
      special: ['luxury', 'oud', 'special', 'bestseller'],
      astrology: ['zodiac', 'planet', 'nakshatra', 'chakra', 'mesh', 'vrishabh']
    },
    mood: {
      calm: ['calm', 'lavender', 'sandalwood', 'shanta', 'stress'],
      romantic: ['rose', 'love', 'mogra', 'jasmine', 'srungara'],
      luxurious: ['luxury', 'oud', 'amber', 'saffron', 'premium'],
      fresh: ['citrus', 'bergamot', 'green', 'neroli'],
      mysterious: ['oud', 'musk', 'amber', 'dark'],
      spiritual: ['sandalwood', 'frankincense', 'chakra', 'spiritual'],
      grounding: ['vetiver', 'sandalwood', 'root', 'earth'],
      uplifting: ['citrus', 'bergamot', 'joy', 'floral'],
      sensual: ['musk', 'rose', 'amber', 'jasmine'],
      minimal: ['musk', 'white', 'subtle', 'clean']
    },
    families: {
      rose: ['rose'], lavender: ['lavender'], sandalwood: ['sandalwood', 'chandan'],
      jasmine: ['jasmine'], mogra: ['mogra'], oud: ['oud'], vetiver: ['vetiver'],
      musk: ['musk'], amber: ['amber'], saffron: ['saffron'], citrus: ['citrus'],
      floral: ['floral', 'rose', 'jasmine', 'mogra'], woody: ['woody', 'sandalwood', 'cedar', 'vetiver'],
      herbal: ['herbal', 'green']
    },
    zodiac: {
      aries: ['aries', 'mesh', 'mars', 'mangal'], taurus: ['taurus', 'vrishabh', 'venus', 'shukra'],
      gemini: ['gemini', 'mithun', 'mercury', 'budh'], cancer: ['cancer', 'kark', 'moon', 'chandra'],
      leo: ['leo', 'simha', 'sun', 'surya'], virgo: ['virgo', 'kanya', 'mercury', 'budh'],
      libra: ['libra', 'tula', 'venus', 'shukra'], scorpio: ['scorpio', 'mars', 'mangal'],
      sagittarius: ['sagittarius', 'dhanu', 'jupiter', 'guru'], capricorn: ['capricorn', 'makar', 'saturn', 'shani'],
      aquarius: ['aquarius', 'kumbh', 'saturn', 'shani'], pisces: ['pisces', 'meen', 'jupiter', 'guru']
    },
    planet: {
      surya: ['surya', 'sun'], chandra: ['chandra', 'moon'], mangal: ['mangal', 'mars'],
      budh: ['budh', 'mercury'], guru: ['guru', 'jupiter'], shukra: ['shukra', 'venus'],
      shani: ['shani', 'saturn'], rahu: ['rahu'], ketu: ['ketu']
    },
    nakshatra: {
      ashwini: ['ashwini'], bharani: ['bharani'], krittika: ['krittika', 'kritika'],
      rohini: ['rohini'], mrigashira: ['mrigashira'], ardra: ['ardra'],
      punarvasu: ['punarvasu'], pushya: ['pushya'], ashlesha: ['ashlesha'],
      magha: ['magha'], phalguni: ['phalguni'], hasta: ['hasta'], chitra: ['chitra'],
      swati: ['swati'], vishakha: ['vishakha'], anuradha: ['anuradha'],
      jyeshtha: ['jyeshtha'], mula: ['mula'], ashadha: ['ashadha'],
      shravana: ['shravana'], dhanishtha: ['dhanishtha'], shatabhisha: ['shatabhisha'],
      bhadrapada: ['bhadrapada'], revati: ['revati']
    },
    chakra: {
      root: ['root', 'muladhara'], sacral: ['sacral', 'svadhisthana'],
      solar: ['solar', 'manipura'], heart: ['heart', 'anahata'],
      throat: ['throat', 'vishuddha'], 'third-eye': ['third-eye', 'ajna'],
      crown: ['crown', 'sahasrara']
    },
    intensity: {
      light: ['light', 'soft', 'subtle'], medium: ['medium', 'balanced'],
      strong: ['strong', 'intense', 'oud', 'long']
    },
    budget: {
      entry: [], mid: [], premium: ['premium', 'luxury', 'bestseller'], luxury: ['luxury', 'premium', 'oud']
    }
  };

  function formatMoney(cents) {
    if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
      return Shopify.formatMoney(cents, {{ shop.money_format | json }});
    }
    return '₹' + (cents / 100).toFixed(0);
  }

  function updateProgress() {
    var pct = (current / total) * 100;
    if (progressFill) progressFill.style.width = pct + '%';
    if (progressBar) progressBar.setAttribute('aria-valuenow', String(current));
    if (stepLabel) stepLabel.textContent = 'Step ' + current;
    if (btnBack) btnBack.hidden = current <= 1;
    if (btnNext) btnNext.textContent = current >= total ? 'Reveal my attars' : 'Continue';
  }

  function showStep(n) {
    steps.forEach(function (step) {
      var num = parseInt(step.getAttribute('data-cpq-step'), 10);
      var active = num === n;
      step.classList.toggle('is-active', active);
      step.hidden = !active;
    });
    current = n;
    updateProgress();
  }

  function getGroupEl(stepNum) {
    var step = steps.find(function (s) { return parseInt(s.getAttribute('data-cpq-step'), 10) === stepNum; });
    return step;
  }

  function readAnswers() {
    var nameEl = root.querySelector('#cpq-name-{{ cpq_uid }}');
    var contactEl = root.querySelector('#cpq-email-{{ cpq_uid }}');
    answers.name = nameEl ? nameEl.value.trim() : '';
    answers.contact = contactEl ? contactEl.value.trim() : '';
    ['zodiac', 'planet', 'nakshatra', 'chakra', 'dob'].forEach(function (key) {
      var el = root.querySelector('[data-cpq-field="' + key + '"]');
      answers[key] = el ? el.value : '';
    });
  }

  function validateStep(n) {
    if (n === 1) return true;
    if (n === 6) return true;
    var step = getGroupEl(n);
    if (!step) return true;
    var groups = step.querySelectorAll('[data-cpq-required]');
    for (var i = 0; i < groups.length; i++) {
      var g = groups[i];
      var groupKey = g.getAttribute('data-cpq-group');
      var isMulti = g.hasAttribute('data-cpq-multi');
      if (isMulti) {
        if (!answers[groupKey] || answers[groupKey].length === 0) return false;
      } else if (!answers[groupKey]) return false;
    }
    return true;
  }

  function bindChoices() {
    root.querySelectorAll('[data-cpq-group]').forEach(function (group) {
      var key = group.getAttribute('data-cpq-group');
      var isMulti = group.hasAttribute('data-cpq-multi');
      if (!answers[key]) answers[key] = isMulti ? [] : '';
      group.querySelectorAll('[data-cpq-value]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var val = btn.getAttribute('data-cpq-value');
          if (isMulti) {
            var idx = answers[key].indexOf(val);
            if (idx >= 0) {
              answers[key].splice(idx, 1);
              btn.setAttribute('aria-pressed', 'false');
            } else {
              answers[key].push(val);
              btn.setAttribute('aria-pressed', 'true');
            }
          } else {
            group.querySelectorAll('[data-cpq-value]').forEach(function (b) {
              b.setAttribute('aria-pressed', 'false');
            });
            btn.setAttribute('aria-pressed', 'true');
            answers[key] = val;
          }
        });
      });
    });
  }

  function scoreProduct(p, a) {
    var text = (p.keywords + '|' + (p.notes || '') + '|' + (p.title || '') + '|' + (p.collections || []).join('|')).toLowerCase();
    var score = 0;
    var reasons = [];

    function addScore(mapKey, answerKey, weight, label) {
      var val = a[answerKey];
      if (!val) return;
      var keys = Array.isArray(val) ? val : [val];
      keys.forEach(function (k) {
        var terms = (SCORE_MAP[mapKey] && SCORE_MAP[mapKey][k]) || [k];
        terms.forEach(function (term) {
          if (text.indexOf(term) >= 0) {
            score += weight;
            if (label && reasons.indexOf(label) === -1) reasons.push(label);
          }
        });
      });
    }

    addScore('fragranceType', 'fragranceType', 2, 'Matches your fragrance type');
    addScore('purpose', 'purpose', 4, 'Aligned with your purpose');
    addScore('mood', 'mood', 4, 'Reflects your mood');
    addScore('families', 'families', 5, 'Features your preferred notes');
    addScore('zodiac', 'zodiac', 6, 'Aligned with your zodiac');
    addScore('planet', 'planet', 6, 'Connected to your planet');
    addScore('nakshatra', 'nakshatra', 6, 'Resonates with your nakshatra');
    addScore('chakra', 'chakra', 6, 'Supports your chakra');
    addScore('intensity', 'intensity', 2, 'Matches your intensity preference');

    if (a.budget === 'premium' || a.budget === 'luxury') {
      if (text.indexOf('luxury') >= 0 || text.indexOf('oud') >= 0 || text.indexOf('bestseller') >= 0) {
        score += 3;
        reasons.push('Premium positioning');
      }
    }

    if (p.tags && p.tags.some(function (t) { return String(t).toLowerCase().indexOf('bestseller') >= 0; })) {
      score += 1;
    }

    if (!reasons.length) reasons.push('Curated from our attar collection');

    return { score: score, reasons: reasons };
  }

  function rankProducts() {
    readAnswers();
    var ranked = catalog.map(function (p) {
      var r = scoreProduct(p, answers);
      return { product: p, score: r.score, reasons: r.reasons };
    }).filter(function (x) { return x.score > 0; });

    ranked.sort(function (a, b) { return b.score - a.score; });
    if (!ranked.length) {
      ranked = catalog.slice(0, 6).map(function (p) {
        return { product: p, score: 1, reasons: ['Popular attar from Anand Rasa'] };
      });
    }
    return ranked.slice(0, 6);
  }

  function renderResults(matches) {
    if (!resultsGrid || !cardTpl) return;
    resultsGrid.innerHTML = '';
    var greeting = answers.name ? answers.name + ', here are your signature attar matches' : 'Your signature attar matches';
    if (resultsTitle) resultsTitle.textContent = greeting;
    if (resultsLead) {
      resultsLead.textContent = 'Find the attar that feels aligned with your scent story — curated from our premium attars and natural perfume oils.';
    }

    matches.forEach(function (match, index) {
      var p = match.product;
      var node = cardTpl.content.cloneNode(true);
      var card = node.querySelector('[data-cpq-card]');
      var link = node.querySelector('[data-cpq-link]');
      var img = node.querySelector('[data-cpq-img]');
      var rank = node.querySelector('[data-cpq-rank]');
      var type = node.querySelector('[data-cpq-type]');
      var titleLink = node.querySelector('[data-cpq-title-link]');
      var desc = node.querySelector('[data-cpq-desc]');
      var why = node.querySelector('[data-cpq-why]');
      var use = node.querySelector('[data-cpq-use]');
      var price = node.querySelector('[data-cpq-price]');
      var compare = node.querySelector('[data-cpq-compare]');
      var view = node.querySelector('[data-cpq-view]');
      var atc = node.querySelector('[data-cpq-atc]');

      if (index === 0 && rank) {
        rank.hidden = false;
        rank.textContent = 'Best match';
      }
      if (link) { link.href = p.url; link.setAttribute('aria-label', p.title); }
      if (img) { img.src = p.image; img.alt = p.title; }
      if (type) type.textContent = p.type || 'Attar';
      if (titleLink) { titleLink.textContent = p.title; titleLink.href = p.url; }
      if (desc) desc.textContent = p.description || 'Handcrafted luxury attar from Anand Rasa.';
      if (why) why.textContent = 'Why this matches you: ' + match.reasons.slice(0, 2).join(' · ');
      if (use) use.textContent = 'Recommended for: ' + (answers.purpose ? answers.purpose.replace('-', ' ') : 'daily ritual wear');
      if (price) price.textContent = formatMoney(p.price);
      if (compare && p.compareAtPrice && p.compareAtPrice > p.price) {
        compare.hidden = false;
        compare.textContent = formatMoney(p.compareAtPrice);
      }
      if (view) view.href = p.url;
      if (atc) {
        atc.disabled = !p.available;
        atc.addEventListener('click', function () {
          fetch((window.routes && window.routes.cart_add_url) || '/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({ id: p.variantId, quantity: 1 })
          }).then(function (res) { return res.json(); })
            .then(function () {
              atc.classList.add('is-added');
              atc.textContent = 'Added';
              document.dispatchEvent(new CustomEvent('cart:refresh'));
            })
            .catch(function () { atc.textContent = 'Try again'; });
        });
      }
      resultsGrid.appendChild(node);
    });
  }

  function shakeNext() {
    if (btnNext) {
      btnNext.classList.add('is-shake');
      setTimeout(function () { btnNext.classList.remove('is-shake'); }, 350);
    }
  }

  if (btnNext) {
    btnNext.addEventListener('click', function () {
      readAnswers();
      if (!validateStep(current)) {
        shakeNext();
        return;
      }
      if (current >= total) {
        var matches = rankProducts();
        form.hidden = true;
        results.hidden = false;
        renderResults(matches);
        root.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }
      showStep(current + 1);
    });
  }

  if (btnBack) {
    btnBack.addEventListener('click', function () {
      if (current > 1) showStep(current - 1);
    });
  }

  if (btnRestart) {
    btnRestart.addEventListener('click', function () {
      results.hidden = true;
      form.hidden = false;
      showStep(1);
    });
  }

  bindChoices();
  updateProgress();
})();
</script>

{%- if section.settings.show_faq -%}
  {%- assign cpq_faq_schema_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq' and block.settings.question != blank -%}
      {%- assign cpq_faq_schema_count = cpq_faq_schema_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if cpq_faq_schema_count > 0 -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign cpq_faq_first = true -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' and block.settings.question != blank -%}
              {%- unless cpq_faq_first -%},{%- endunless -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer | strip_html | strip | json }}
                }
              }
              {%- assign cpq_faq_first = false -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
    </script>
  {%- endif -%}
{%- endif -%}

