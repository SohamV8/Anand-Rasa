<script>
(function () {
  var root = document.getElementById('cpq-{{ cpq_uid }}');
  if (!root) return;

  var quizPanel = root.querySelector('[data-cpq-form]');
  var steps = Array.prototype.slice.call(root.querySelectorAll('[data-cpq-step]'));
  var btnNext = root.querySelector('[data-cpq-next]');
  var btnBack = root.querySelector('[data-cpq-back]');
  var btnSubmit = root.querySelector('[data-cpq-submit]');
  var navBar = root.querySelector('[data-cpq-nav]');
  var progressFill = root.querySelector('[data-cpq-progress-fill]');
  var progressBar = document.getElementById('cpq-progress-{{ cpq_uid }}');
  var stepLabel = root.querySelector('[data-cpq-step-label]');
  var contactForm = document.getElementById('cpq-contact-{{ cpq_uid }}');
  var cpqStorageKey = 'cpq-session-{{ cpq_uid }}';
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var stepsViewport = root.querySelector('[data-cpq-steps-viewport]');
  var current = 1;
  var total = 7;
  var answers = {
    fragranceType: '',
    purpose: '',
    mood: '',
    families: [],
    zodiac: '',
    planet: '',
    nakshatra: '',
    dob: '',
    birthTime: '',
    birthLocation: '',
    intensity: ''
  };

  if (root.querySelector('[data-cpq-success]')) {
    root.classList.add('cpq--success');
  }

  function updateProgress() {
    var pct = Math.round((current / total) * 1000) / 10;
    if (progressFill) progressFill.style.width = pct + '%';
    if (progressBar) progressBar.setAttribute('aria-valuenow', String(current));
    if (stepLabel) stepLabel.textContent = 'Step ' + current;
    if (btnBack) btnBack.hidden = current <= 1;
    var isFinal = current >= total;
    if (btnNext) btnNext.hidden = isFinal;
    if (btnSubmit) btnSubmit.hidden = !isFinal;
    if (navBar) navBar.classList.toggle('is-final', isFinal);
  }

  function staggerChoices(stepEl) {
    if (!stepEl || prefersReducedMotion) return;
    var choices = stepEl.querySelectorAll('.cpq__choice, .cpq__pill');
    for (var i = 0; i < choices.length; i++) {
      choices[i].style.setProperty('--cpq-choice-i', String(i));
    }
  }

  function showStep(n, dir) {
    dir = typeof dir === 'number' ? dir : (n > current ? 1 : -1);
    steps.forEach(function (step) {
      var num = parseInt(step.getAttribute('data-cpq-step'), 10);
      var active = num === n;
      step.classList.remove('cpq__step--enter-left', 'cpq__step--enter-right');
      step.classList.toggle('is-active', active);
      step.hidden = !active;
      if (active) {
        if (!prefersReducedMotion) {
          step.classList.add(dir > 0 ? 'cpq__step--enter-right' : 'cpq__step--enter-left');
        }
        staggerChoices(step);
      }
    });
    current = n;
    updateProgress();
    if (stepsViewport) stepsViewport.scrollTop = 0;
  }

  function getGroupEl(stepNum) {
    var step = steps.find(function (s) { return parseInt(s.getAttribute('data-cpq-step'), 10) === stepNum; });
    return step;
  }

  function readAnswers() {
    ['zodiac', 'planet', 'nakshatra', 'dob', 'birthTime', 'birthLocation'].forEach(function (key) {
      var el = root.querySelector('[data-cpq-field="' + key + '"]');
      answers[key] = el ? (el.value || '').trim() : '';
    });
  }

  function getContactField(name) {
    if (!contactForm) return '';
    var el = contactForm.querySelector('[name="' + name + '"]');
    return el ? (el.value || '').trim() : '';
  }

  function humanizeValue(val) {
    if (!val) return '';
    if (Array.isArray(val)) {
      return val.map(function (v) { return String(v).replace(/-/g, ' '); }).join(', ');
    }
    return String(val).replace(/-/g, ' ');
  }

  function buildContactBody() {
    readAnswers();
    var lines = [
      'Custom Perfume Consultation — Anand Rasa',
      '--------------------------------------',
      'Name: ' + (getContactField('contact[name]') || '—'),
      'Email: ' + (getContactField('contact[email]') || '—'),
      'Phone: ' + (getContactField('contact[phone]') || '—'),
      'Fragrance type: ' + humanizeValue(answers.fragranceType),
      'Purpose: ' + humanizeValue(answers.purpose),
      'Mood: ' + humanizeValue(answers.mood),
      'Fragrance families: ' + humanizeValue(answers.families),
      'Zodiac: ' + humanizeValue(answers.zodiac),
      'Planet: ' + humanizeValue(answers.planet),
      'Nakshatra: ' + humanizeValue(answers.nakshatra),
      'Intensity: ' + humanizeValue(answers.intensity)
    ];
    if (answers.dob) lines.push('Date of birth: ' + answers.dob);
    if (answers.birthTime) lines.push('Time of birth: ' + answers.birthTime);
    if (answers.birthLocation) lines.push('Place of birth: ' + answers.birthLocation);
    return lines.join('\n');
  }

  function setHiddenContactField(key, value) {
    if (!contactForm) return;
    var el = contactForm.querySelector('[data-cpq-contact-field="' + key + '"]');
    if (el) el.value = value || '';
  }

  function populateContactForm() {
    if (!contactForm) return;
    readAnswers();
    setHiddenContactField('fragranceType', humanizeValue(answers.fragranceType));
    setHiddenContactField('purpose', humanizeValue(answers.purpose));
    setHiddenContactField('mood', humanizeValue(answers.mood));
    setHiddenContactField('families', humanizeValue(answers.families));
    setHiddenContactField('zodiac', humanizeValue(answers.zodiac));
    setHiddenContactField('planet', humanizeValue(answers.planet));
    setHiddenContactField('nakshatra', humanizeValue(answers.nakshatra));
    setHiddenContactField('intensity', humanizeValue(answers.intensity));
    setHiddenContactField('dob', answers.dob || '');
    setHiddenContactField('birthTime', answers.birthTime || '');
    setHiddenContactField('birthLocation', answers.birthLocation || '');
    setHiddenContactField('body', buildContactBody());
  }

  function saveQuizSession() {
    try {
      sessionStorage.setItem(cpqStorageKey, JSON.stringify({ answers: answers, step: current }));
    } catch (e) { /* storage unavailable */ }
  }

  function restoreQuizSession() {
    try {
      var raw = sessionStorage.getItem(cpqStorageKey);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

  function clearQuizSession() {
    try { sessionStorage.removeItem(cpqStorageKey); } catch (e) { /* ignore */ }
  }

  function restoreChoiceUI() {
    root.querySelectorAll('[data-cpq-group]').forEach(function (group) {
      var key = group.getAttribute('data-cpq-group');
      var isMulti = group.hasAttribute('data-cpq-multi');
      var val = answers[key];
      group.querySelectorAll('[data-cpq-value]').forEach(function (btn) {
        var v = btn.getAttribute('data-cpq-value');
        var on = isMulti ? (val && val.indexOf(v) >= 0) : val === v;
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    });
  }

  function initFormErrorState() {
    var errorsEl = root.querySelector('[data-cpq-form-errors]');
    if (!errorsEl) return;
    var saved = restoreQuizSession();
    if (!saved || !saved.answers) return;
    Object.keys(saved.answers).forEach(function (key) {
      if (answers.hasOwnProperty(key)) answers[key] = saved.answers[key];
    });
    if (saved.step) showStep(saved.step, -1);
    restoreChoiceUI();
    populateContactForm();
  }

  function validateStep(n) {
    if (n === 1) {
      var emailEl = contactForm && contactForm.querySelector('[name="contact[email]"]');
      return emailEl ? emailEl.checkValidity() : true;
    }
    if (n === 6) return true;
    var step = getGroupEl(n);
    if (!step) return true;
    var groups = step.querySelectorAll('[data-cpq-required]');
    for (var i = 0; i < groups.length; i++) {
      var g = groups[i];
      var groupKey = g.getAttribute('data-cpq-group');
      var isMulti = g.hasAttribute('data-cpq-multi');
      if (isMulti) {
        if (!answers[groupKey] || answers[groupKey].length === 0) return false;
      } else if (!answers[groupKey]) return false;
    }
    return true;
  }

  function bindChoices() {
    root.querySelectorAll('[data-cpq-group]').forEach(function (group) {
      var key = group.getAttribute('data-cpq-group');
      var isMulti = group.hasAttribute('data-cpq-multi');
      if (answers[key] === undefined || answers[key] === null) {
        answers[key] = isMulti ? [] : '';
      }
    });
    if (!quizPanel) return;
    quizPanel.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-cpq-value]');
      if (!btn) return;
      var group = btn.closest('[data-cpq-group]');
      if (!group) return;
      var key = group.getAttribute('data-cpq-group');
      var isMulti = group.hasAttribute('data-cpq-multi');
      var val = btn.getAttribute('data-cpq-value');
      if (isMulti) {
        var idx = answers[key].indexOf(val);
        if (idx >= 0) {
          answers[key].splice(idx, 1);
          btn.setAttribute('aria-pressed', 'false');
        } else {
          answers[key].push(val);
          btn.setAttribute('aria-pressed', 'true');
        }
      } else {
        group.querySelectorAll('[data-cpq-value]').forEach(function (b) {
          b.setAttribute('aria-pressed', 'false');
        });
        btn.setAttribute('aria-pressed', 'true');
        answers[key] = val;
      }
    });
  }

  function shakeNext() {
    if (btnNext) {
      btnNext.classList.add('is-shake');
      setTimeout(function () { btnNext.classList.remove('is-shake'); }, 350);
    }
  }

  if (btnNext) {
    btnNext.addEventListener('click', function () {
      readAnswers();
      if (!validateStep(current)) {
        shakeNext();
        return;
      }
      showStep(current + 1, 1);
    });
  }

  if (btnBack) {
    btnBack.addEventListener('click', function () {
      if (current > 1) showStep(current - 1, -1);
    });
  }

  if (contactForm) {
    contactForm.addEventListener('submit', function (e) {
      readAnswers();
      var invalidStep = 0;
      for (var s = 1; s <= total; s++) {
        if (!validateStep(s)) {
          invalidStep = s;
          break;
        }
      }
      if (invalidStep) {
        e.preventDefault();
        showStep(invalidStep, invalidStep > current ? 1 : -1);
        if (invalidStep === 1) {
          var emailEl = contactForm.querySelector('[name="contact[email]"]');
          if (emailEl) emailEl.focus();
        } else {
          shakeNext();
        }
        return;
      }
      populateContactForm();
      saveQuizSession();
    });
  }

  var successEl = root.querySelector('[data-cpq-success]');
  if (successEl) {
    clearQuizSession();
    successEl.focus();
  }

  bindChoices();
  staggerChoices(steps[0]);
  updateProgress();
  initFormErrorState();
})();
</script>

{%- if section.settings.show_faq -%}
  {%- assign cpq_faq_schema_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq' and block.settings.question != blank -%}
      {%- assign cpq_faq_schema_count = cpq_faq_schema_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if cpq_faq_schema_count > 0 -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign cpq_faq_first = true -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' and block.settings.question != blank -%}
              {%- unless cpq_faq_first -%},{%- endunless -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer | strip_html | strip | json }}
                }
              }
              {%- assign cpq_faq_first = false -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
    </script>
  {%- endif -%}
{%- endif -%}

