<style type="text/css">
  .template-404 .title + * {
    margin-top: 1rem;
  }

  @media screen and (min-width: 750px) {
    .template-404 .title + * {
      margin-top: 2rem;
    }
  }
</style>

<div class="template-404 page-width page-margin center">
  <p>
    {{ 'templates.404.subtext' | t }}
  </p>
  <h1 class="title">
    {{ 'templates.404.title' | t }}
  </h1>
  <a href="{{ routes.all_products_collection_url }}" class="button">
    {{ 'general.continue_shopping' | t }}
  </a>
</div>

<script>
  (function () {
    var path = (window.location.pathname || '').replace(/\/+$/, '');
    if (!path) return;

    var legacyPaths = {
      '/pages/incense-bundle-offer': true,
      '/collections/incense': true
    };

    if (legacyPaths[path]) {
      window.location.replace('/collections/incense-stick');
      return;
    }

    var vipPath = path.replace(/\/pages\/vip-club$/, '');
    if (vipPath !== path) {
      window.location.replace((vipPath || '/') + '?view=vip-club');
    }
  })();
</script>
