          {%- if paginate.pages > 1 -%}
            <div style="grid-column:1/-1;display:flex;justify-content:center;align-items:center;gap:8px;padding:24px 0 0;">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" style="width:40px;height:40px;border:1px solid rgba(30,32,35,.2);display:flex;align-items:center;justify-content:center;font-size:18px;color:#1e2023;text-decoration:none;transition:all .2s;" onmouseover="this.style.background='#1e2023';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='#1e2023'">&#8249;</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" style="width:40px;height:40px;border:1px solid rgba(30,32,35,.2);display:flex;align-items:center;justify-content:center;font-size:13px;color:#1e2023;text-decoration:none;">{{ part.title }}</a>
                {%- else -%}
                  <span style="width:40px;height:40px;{%- if part.title == paginate.current_page -%}background:#1e2023;color:#fff;{%- else -%}color:#9ca3af;{%- endif -%}border:1px solid rgba(30,32,35,.2);display:flex;align-items:center;justify-content:center;font-size:13px;">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" style="width:40px;height:40px;border:1px solid rgba(30,32,35,.2);display:flex;align-items:center;justify-content:center;font-size:18px;color:#1e2023;text-decoration:none;transition:all .2s;" onmouseover="this.style.background='#1e2023';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='#1e2023'">&#8250;</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <div class="arc-empty">
          <h2 class="arc-empty__h">No products yet</h2>
          <p class="arc-empty__p">Check back soon — new products are being added.</p>
        </div>
      {%- endif -%}
    </div>

