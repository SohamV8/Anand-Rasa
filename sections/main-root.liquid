{% render 'chakra-product-base', section: section, product: product %}

{% schema %}
{
  "name": "Root Chakra Attar",
  "settings": [
    { "type": "header", "content": "Brand & hero — Root Chakra" },
    { "type": "text", "id": "brand_text", "label": "Brand line (above title)", "default": "ANAND RAS" },
    { "type": "text", "id": "product_label", "label": "Product label (hidden in new layout; optional SEO)", "default": "Root Chakra Attar" },
    { "type": "textarea", "id": "short_description", "label": "Short description (below title)", "info": "Shown under the product title. Quantity appears above Add to cart. Overrides the short line when set.", "default": "A grounding attar for stability and survival energy — created to support security, balance, and a strong foundation in daily life." },
    { "type": "text", "id": "product_tagline", "label": "Short line (fallback)", "info": "Used if the textarea above is empty. Then metafield, then product excerpt.", "default": "Security • Foundation • Balance" },
    { "type": "range", "id": "rating", "label": "Star rating (display)", "min": 1, "max": 5, "step": 1, "default": 5 },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "0" },
    { "type": "checkbox", "id": "show_buy_now", "label": "Show Buy Now button", "default": true },
    { "type": "text", "id": "trust_1", "label": "Trust line 1 — Root Chakra", "default": "Grounding & stability" },
    { "type": "text", "id": "trust_2", "label": "Trust line 2 — Root Chakra", "default": "Secure foundation" },
    { "type": "text", "id": "trust_3", "label": "Trust line 3 — Root Chakra", "default": "Balanced presence" },
    { "type": "header", "content": "Info strip (3 columns) — Root Chakra" },
    { "type": "text", "id": "strip_col1", "label": "Column 1 — Description", "default": "Grounding & stability" },
    { "type": "text", "id": "strip_col2", "label": "Column 2 — Details", "default": "A steady, earthy aroma crafted for security, balance, and a calm sense of rooted strength." },
    { "type": "text", "id": "strip_col3", "label": "Column 3 — Category", "default": "Chakra Attar" },
    { "type": "header", "content": "Why choose section — Root Chakra" },
    { "type": "text", "id": "why_heading", "label": "Heading", "default": "Why Choose Root Chakra Attar" },
    { "type": "textarea", "id": "why_sub", "label": "Subheading", "default": "Crafted to support grounding, stability, and survival energy — a fragrance for security and balance." },
    { "type": "header", "content": "Specifications table — Root Chakra" },
    { "type": "text", "id": "spec_origin", "label": "Country of Origin", "default": "India" },
    { "type": "text", "id": "spec_item_form", "label": "Item Form", "default": "Luxury Attar" },
    { "type": "text", "id": "spec_item_type", "label": "Item Type", "default": "Security, Foundation, Balance" },
    { "type": "text", "id": "spec_sticks", "label": "Number of Sticks", "default": "40" },
    { "type": "text", "id": "spec_burn", "label": "Burning Time", "default": "30+ minutes" },
    { "type": "text", "id": "spec_length", "label": "Length", "default": "3.5 inches" },
    { "type": "text", "id": "spec_fragrance", "label": "Fragrance (optional row)", "default": "Earthy woods • warm resin • subtle spice" },
    { "type": "text", "id": "spec_ingredients", "label": "Key ingredients (optional row)", "default": "Natural resins, essential oils, premium aromatic botanicals" },
    { "type": "header", "content": "Recommended products — Root Chakra" },
    { "type": "collection", "id": "related_collection", "label": "Collection" },
    { "type": "text", "id": "related_heading", "label": "Heading", "default": "You May Also Like" },
    { "type": "text", "id": "related_sub", "label": "Subheading", "default": "More chakra-aligned aromas for your ritual" }
  ],
  "presets": [{ "name": "Root Chakra Attar" }],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
