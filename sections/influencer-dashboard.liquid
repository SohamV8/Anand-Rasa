{% comment %}
  Legacy route bridge.
  Force-loads the secure /pages/partner dashboard view.
{% endcomment %}

{%- style -%}
  .ar-inf-legacy {
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 16px {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: #ffffff;
  }

  .ar-inf-legacy__wrap {
    width: min(100%, 760px);
    margin: 0 auto;
    padding: clamp(28px, 5vw, 44px);
    border: 1px solid rgba(18, 16, 14, 0.08);
    border-radius: 28px;
    background: linear-gradient(180deg, #fffdfb 0%, #ffffff 100%);
    box-shadow: 0 14px 38px rgba(18, 16, 14, 0.06);
    text-align: center;
  }

  .ar-inf-legacy__eyebrow {
    margin: 0 0 12px;
    color: #6f6860;
    font: 600 14px/1.2 Poppins, system-ui, sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ar-inf-legacy__title {
    margin: 0 0 14px;
    color: #12100e;
    font: 500 clamp(2.1rem, 5vw, 3rem)/1.02 "Cormorant Garamond", Georgia, serif;
    letter-spacing: -0.03em;
  }

  .ar-inf-legacy__copy {
    margin: 0 auto;
    max-width: 42ch;
    color: #3d3832;
    font: 400 16px/1.6 Poppins, system-ui, sans-serif;
  }

  .ar-inf-legacy__actions {
    display: grid;
    gap: 12px;
    width: min(100%, 360px);
    margin: 28px auto 0;
  }

  .ar-inf-legacy__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 14px 20px;
    border-radius: 999px;
    font: 600 16px/1.2 Poppins, system-ui, sans-serif;
    text-decoration: none;
  }

  .ar-inf-legacy__btn--primary {
    background: #12100e;
    color: #ffffff;
  }

  .ar-inf-legacy__btn--secondary {
    border: 1px solid rgba(18, 16, 14, 0.12);
    color: #12100e;
    background: #ffffff;
  }

  @media screen and (min-width: 750px) {
    .ar-inf-legacy {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="ar-inf-legacy" aria-labelledby="ar-inf-legacy-title">
  <div class="ar-inf-legacy__wrap">
    <p class="ar-inf-legacy__eyebrow">Partner Dashboard</p>
    <h1 id="ar-inf-legacy-title" class="ar-inf-legacy__title">Opening secure dashboard…</h1>
    <p class="ar-inf-legacy__copy">Redirecting to the authenticated partner portal now.</p>

    <div class="ar-inf-legacy__actions">
      <a class="ar-inf-legacy__btn ar-inf-legacy__btn--primary" href="/pages/partner?view=partner">Open secure dashboard</a>
      <a class="ar-inf-legacy__btn ar-inf-legacy__btn--secondary" href="/pages/contact">Need help?</a>
    </div>
  </div>
</section>

<script>
  (function () {
    try {
      var url = new URL(window.location.href);
      if (url.pathname !== '/pages/partner') return;
      if (url.searchParams.get('view') === 'partner') return;
      url.searchParams.set('view', 'partner');
      window.location.replace(url.toString());
    } catch (_e) {}
  })();
</script>

{% schema %}
{
  "name": "Influencer Dashboard",
  "tag": "section",
  "class": "section ar-inf-dashboard-section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Influencer Dashboard"
    }
  ]
}
{% endschema %}
