{%- comment -%}
  ANAND RASA - Header (replaces Dawn header)
{%- endcomment -%}

<style>
  .ar-nav *, .ar-nav *::before, .ar-nav *::after { box-sizing:border-box; }

  /* Fixed bar so it never scrolls away (sticky can fail inside section wrappers). */
  #shopify-section-{{ section.id }} { position: relative; z-index: 200; }
  .ar-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 200;
    background: #fff;
    border-bottom: 1px solid rgba(30, 32, 35, 0.1);
    font-family: var(--font-body-family);
    box-shadow: 0 1px 0 rgba(30, 32, 35, 0.06);
  }
  .ar-nav__inner { max-width:1440px; margin:0 auto; display:grid; grid-template-columns:1fr auto 1fr; align-items:center; padding:0 48px; height:76px; gap:24px; }
  .ar-nav__left  { display:flex; align-items:center; gap:36px; }
  .ar-nav__right { display:flex; align-items:center; gap:28px; justify-content:flex-end; }
  .ar-nav__link  { font-size:14px; font-weight:400; letter-spacing:.01em; color:#1e2023; text-decoration:none; transition:opacity .2s; white-space:nowrap; }
  .ar-nav__link:hover { opacity:.55; }
  .ar-nav__logo { text-decoration:none; display:flex; flex-direction:column; align-items:center; line-height:1; justify-self:center; }
  .ar-nav__logo-img { height:72px; width:auto; display:block; object-fit:contain; }
  .ar-nav__logo-text { font-family:var(--font-heading-family); font-size:30px; font-weight:700; color:#1e2023; display:block; line-height:1; letter-spacing:-.01em; }
  .ar-nav__logo-sub { font-size:11px; font-weight:300; letter-spacing:.22em; color:#6b7280; display:block; margin-top:3px; text-transform:lowercase; }
  .ar-nav__icon { display:flex; align-items:center; color:#1e2023; text-decoration:none; transition:opacity .2s; position:relative; }
  .ar-nav__icon:hover { opacity:.55; }
  .ar-nav__icon svg { width:22px; height:22px; }
  .ar-nav__cart-count { position:absolute; top:-6px; right:-6px; background:#1e2023; color:#fff; font-size:9px; width:15px; height:15px; border-radius:50%; display:flex; align-items:center; justify-content:center; }

  .ar-nav__burger { display:none; flex-direction:column; gap:5px; cursor:pointer; background:none; border:none; padding:4px; }
  .ar-nav__burger span { display:block; width:22px; height:1.5px; background:#1e2023; transition:all .3s; }

  .ar-nav__drawer { display:none; position:fixed; inset:0; background:#fff; z-index:300; padding:28px 24px; flex-direction:column; gap:20px; overflow-y:auto; }
  .ar-nav__drawer.is-open { display:flex; }
  .ar-nav__drawer-close { align-self:flex-end; background:none; border:none; font-size:30px; cursor:pointer; color:#1e2023; line-height:1; }
  .ar-nav__drawer-link { font-family:var(--font-body-family); font-size:20px; font-weight:400; color:#1e2023; text-decoration:none; border-bottom:1px solid rgba(30,32,35,.08); padding-bottom:16px; }
  .ar-nav__drawer-toggle { font-family:var(--font-body-family); font-size:20px; font-weight:400; color:#1e2023; text-decoration:none; border-bottom:1px solid rgba(30,32,35,.08); padding-bottom:16px; background:none; border:none; cursor:pointer; text-align:left; width:100%; display:flex; align-items:center; justify-content:space-between; }
  .ar-nav__drawer-toggle svg { transition:transform .3s; }
  .ar-nav__drawer-toggle.is-open svg { transform:rotate(180deg); }
  .ar-nav__drawer-sub-menu { display:none; flex-direction:column; gap:12px; padding:8px 0 8px 20px; }
  .ar-nav__drawer-sub-menu.is-open { display:flex; }

  .ar-mega__trigger { position:relative; display:flex; align-items:center; }
  .ar-mega__label { display:flex; align-items:center; gap:4px; cursor:pointer; }
  .ar-mega__chevron { transition:transform .25s ease; flex-shrink:0; }
  .ar-mega__trigger.is-open .ar-mega__chevron { transform:rotate(180deg); }
  .ar-mega__dropdown { visibility:hidden; opacity:0; position:absolute; top:calc(100% + 16px); right:-40px; background:#fff; border:1px solid rgba(30,32,35,.08); box-shadow:0 20px 60px rgba(0,0,0,.1),0 4px 16px rgba(0,0,0,.05); border-radius:16px; min-width:640px; z-index:400; transform:translateY(-8px); transition:opacity .3s ease,transform .3s ease,visibility .3s; overflow:hidden; }
  .ar-mega__trigger.is-open .ar-mega__dropdown { visibility:visible; opacity:1; transform:translateY(0); }
  .ar-mega__inner { display:grid; grid-template-columns:1fr 1fr; min-height:380px; }
  .ar-mega__links { padding:32px 36px; display:flex; flex-direction:column; gap:2px; }
  .ar-mega__col-title { font-size:10px; font-weight:600; letter-spacing:.2em; text-transform:uppercase; color:#9ca3af; margin-bottom:16px; display:block; }
  .ar-mega__link { display:block; font-size:15px; color:#374151; padding:9px 0; transition:color .2s,padding-left .25s; font-weight:400; text-decoration:none; border-bottom:1px solid rgba(30,32,35,.04); }
  .ar-mega__link:last-child { border-bottom:none; }
  .ar-mega__link:hover { color:#1e2023; padding-left:8px; }
  .ar-mega__feature { background:linear-gradient(135deg,#faf9f7 0%,#f5f0eb 100%); display:flex; align-items:center; justify-content:center; padding:24px; border-left:1px solid rgba(30,32,35,.06); border-radius:0 16px 16px 0; }
  .ar-mega__feature-media { position:relative; width:100%; min-height:300px; display:flex; align-items:center; justify-content:center; }
  .ar-mega__feature-img { position:absolute; inset:0; width:100%; height:100%; max-width:100%; max-height:340px; margin:auto; object-fit:contain; display:block; border-radius:8px; opacity:0; transition:opacity .3s ease; will-change:opacity; pointer-events:none; }
  .ar-mega__feature-video { position:absolute; inset:0; width:100%; height:100%; max-width:100%; max-height:340px; margin:auto; object-fit:contain; display:none; border-radius:8px; }
  .ar-mega__feature-img.is-active { opacity:1; }
  #header-preview-image { transition: opacity .3s ease; }
  .ar-mega__feature-ph { width:100%; height:100%; min-height:300px; display:flex; align-items:center; justify-content:center; color:#9ca3af; font-size:13px; font-family:var(--font-body-family); }

  @media(max-width:900px){
    .ar-nav__inner { grid-template-columns:1fr auto 1fr; padding:0 20px; }
    .ar-nav__left  { display:none; }
    .ar-nav__right .ar-nav__link { display:none; }
    .ar-nav__burger { display:flex; }
    .ar-nav__logo-img { height:56px; }
    .ar-mega__dropdown { display:none !important; }
  }
</style>

{%- assign mega_blocks = section.blocks | where: 'type', 'mega_item' -%}
{%- assign mega_fallback_image = section.settings.mega_menu_image -%}
{%- if mega_fallback_image == blank and mega_blocks.size > 0 -%}
  {%- for block in mega_blocks -%}
    {%- if block.settings.image != blank -%}
      {%- assign mega_fallback_image = block.settings.image -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- capture ar_header_giftsets_url -%}{% render 'ar-collection-url', handle: 'giftsets' %}{%- endcapture -%}
{%- assign ar_header_about_url = pages['about-us'].url | default: pages['about'].url | default: pages['about-anand-rasa'].url -%}
{%- if ar_header_about_url == blank -%}
  {%- capture ar_header_about_url -%}{% render 'ar-page-url', handle: 'about' %}{%- endcapture -%}
{%- endif -%}
{%- if blogs['news'] != empty -%}
  {%- assign ar_header_blog_url = blogs['news'].url -%}
{%- else -%}
  {%- assign ar_header_blog_url = routes.root_url -%}
{%- endif -%}

<nav class="ar-nav" aria-label="Main navigation">
  <div class="ar-nav__inner">
    <div class="ar-nav__left">
      <a href="{{ section.settings.nav_l1_url | default: '/collections/all' }}" class="ar-nav__link">{{ section.settings.nav_l1 | default: 'Shop' }}</a>
      <a href="{{ section.settings.nav_l2_url | default: ar_header_blog_url }}" class="ar-nav__link">{{ section.settings.nav_l2 | default: 'Blogs' }}</a>
      <a href="{{ section.settings.nav_l3_url | default: ar_header_giftsets_url }}" class="ar-nav__link">{{ section.settings.nav_l3 | default: 'Gift Sets' }}</a>
    </div>

    <a href="{{ routes.root_url }}" class="ar-nav__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 600 }}"
          srcset="{{ section.settings.logo | image_url: width: 200 }} 200w, {{ section.settings.logo | image_url: width: 400 }} 400w, {{ section.settings.logo | image_url: width: 600 }} 600w"
          sizes="(max-width: 900px) 120px, 180px"
          alt="{{ section.settings.logo.alt | default: shop.name }}"
          width="{{ section.settings.logo_width | default: 180 }}"
          height="auto"
          loading="eager"
          class="ar-nav__logo-img"
        >
      {%- else -%}
        <span class="ar-nav__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        {%- if section.settings.logo_subtext != blank -%}<span class="ar-nav__logo-sub">{{ section.settings.logo_subtext }}</span>{%- endif -%}
      {%- endif -%}
    </a>

    <div class="ar-nav__right">
      <div class="ar-mega__trigger" id="ar-mega-trigger-{{ section.id }}">
        <a href="{{ section.settings.nav_r1_url | default: '/collections' }}" class="ar-nav__link ar-mega__label">
          {{ section.settings.nav_r1 | default: 'Collections' }}
          <svg class="ar-mega__chevron" width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="ar-mega__dropdown" id="ar-mega-dropdown-{{ section.id }}">
          <div class="ar-mega__inner">
            <div class="ar-mega__links">
              <span class="ar-mega__col-title">Collections</span>
              {%- if mega_blocks.size > 0 -%}
                {%- for block in mega_blocks -%}
                  {%- liquid
                    assign ar_mega_hover_image = ''
                    assign ar_mega_hover_video = ''
                    assign ar_mega_title_key = block.settings.title | default: '' | downcase | strip
                    assign ar_mega_link_key = block.settings.link | default: '' | downcase
                    assign ar_mega_link_url = block.settings.link
                    if ar_mega_link_url == blank
                      if ar_mega_title_key contains 'best'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'bestseller'
                        endcapture
                      elsif ar_mega_title_key contains 'planet'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'planet-attars'
                        endcapture
                      elsif ar_mega_title_key contains 'zodiac'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'zodiac-attars'
                        endcapture
                      elsif ar_mega_title_key contains 'nakshatra' or ar_mega_title_key contains 'naksahtra'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'nakshatra-attars'
                        endcapture
                      elsif ar_mega_title_key contains 'chakra'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'chakra-attars'
                        endcapture
                      elsif ar_mega_title_key contains 'stress'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'stress-relief'
                        endcapture
                      elsif ar_mega_title_key contains 'love'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'love-attar'
                        endcapture
                      elsif ar_mega_title_key contains 'incense'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'incense-sticks'
                        endcapture
                      elsif ar_mega_title_key contains 'gift' or ar_mega_title_key contains 'discovery'
                        capture ar_mega_link_url
                          render 'ar-collection-url', handle: 'giftsets'
                        endcapture
                      endif
                    endif
                    assign ar_mega_link_url = ar_mega_link_url | strip
                    if ar_mega_link_url == blank
                      assign ar_mega_link_url = routes.collections_url
                    endif
                    if block.settings.image != blank
                      assign ar_mega_hover_image = block.settings.image | image_url: width: 900
                    else
                      if ar_mega_title_key contains 'planet' or ar_mega_link_key contains 'planet-attars'
                        assign ar_mega_hover_image = 'PlanetHero.webp' | asset_url
                      elsif ar_mega_title_key contains 'zodiac' or ar_mega_link_key contains 'zodiac-attars'
                        assign ar_mega_hover_image = 'PlanetHero.webp' | asset_url
                      elsif ar_mega_title_key contains 'nakshatra' or ar_mega_link_key contains 'nakshatra-attars'
                        assign ar_mega_hover_video = 'NakshatraGif1.webm' | asset_url
                        assign ar_mega_hover_image = 'PlanetHero.webp' | asset_url
                      elsif ar_mega_title_key contains 'chakra' or ar_mega_link_key contains 'chakra-attars'
                        assign ar_mega_hover_image = 'chakra.webp' | asset_url
                      elsif ar_mega_title_key contains 'stress' or ar_mega_link_key contains 'stress-relief'
                        assign ar_mega_hover_image = 'stress.webp' | asset_url
                      elsif ar_mega_title_key contains 'love' or ar_mega_link_key contains 'love-attar'
                        assign ar_mega_hover_image = 'love.webp' | asset_url
                      elsif ar_mega_title_key contains 'incense' or ar_mega_link_key contains 'incense-sticks'
                        assign ar_mega_hover_image = 'incense.jpeg' | asset_url
                      endif
                    endif
                    if ar_mega_hover_image == blank and mega_fallback_image != blank
                      assign ar_mega_hover_image = mega_fallback_image | image_url: width: 900
                    elsif ar_mega_hover_image == blank
                      assign ar_mega_hover_image = 'PlanetHero.webp' | asset_url
                    endif
                  -%}
                  <a
                    href="{{ ar_mega_link_url }}"
                    class="ar-mega__link"
                    data-image="{{ ar_mega_hover_image }}"
                    data-video="{{ ar_mega_hover_video }}"
                    data-mega-alt="{{ block.settings.title | escape }}"
                    {{ block.shopify_attributes }}
                    {%- if ar_mega_hover_image != blank -%}
                      data-mega-image="{{ ar_mega_hover_image }}"
                    {%- endif -%}
                  >
                    {{ block.settings.title | default: 'Collection' }}
                  </a>
                {%- endfor -%}
              {%- else -%}
              <a href="{% render 'ar-collection-url', handle: 'bestseller' %}" class="ar-mega__link" {% if mega_fallback_image != blank %}data-image="{{ mega_fallback_image | image_url: width: 900 }}"{% endif %}>Bestseller</a>
                <a href="{% render 'ar-collection-url', handle: 'planet-attars' %}" class="ar-mega__link" data-image="{{ 'PlanetHero.webp' | asset_url }}">Planet Attars</a>
                <a href="{% render 'ar-collection-url', handle: 'zodiac-attars' %}" class="ar-mega__link" data-image="{{ 'PlanetHero.webp' | asset_url }}">Zodiac Attars</a>
                <a href="{% render 'ar-collection-url', handle: 'nakshatra-attars' %}" class="ar-mega__link" data-image="{{ 'PlanetHero.webp' | asset_url }}" data-video="{{ 'NakshatraGif1.webm' | asset_url }}">Nakshatra Attars</a>
                <a href="{% render 'ar-collection-url', handle: 'stress-relief' %}" class="ar-mega__link" data-image="{{ 'stress.webp' | asset_url }}">Stress Relief Attars</a>
                <a href="{% render 'ar-collection-url', handle: 'chakra-attars' %}" class="ar-mega__link" data-image="{{ 'chakra.webp' | asset_url }}">Chakra Attars</a>
                <a href="{% render 'ar-collection-url', handle: 'love-attar' %}" class="ar-mega__link" data-image="{{ 'love.webp' | asset_url }}">Love Attars</a>
                <a href="{% render 'ar-collection-url', handle: 'incense-sticks' %}" class="ar-mega__link" data-image="{{ 'incense.jpeg' | asset_url }}">Incense Sticks</a>
              {%- endif -%}
            </div>
            <div class="ar-mega__feature">
              {%- assign ar_mega_primary_src = '' -%}
              {%- assign ar_mega_primary_width = 900 -%}
              {%- assign ar_mega_primary_height = 1200 -%}
              {%- if mega_fallback_image != blank -%}
                {%- assign ar_mega_primary_src = mega_fallback_image | image_url: width: 900 -%}
                {%- assign ar_mega_primary_width = mega_fallback_image.width | default: 900 -%}
                {%- assign ar_mega_primary_height = mega_fallback_image.height | default: 1200 -%}
              {%- else -%}
                {%- assign ar_mega_primary_src = 'PlanetHero.webp' | asset_url -%}
              {%- endif -%}
              <div class="ar-mega__feature-media">
                <img
                  src="{{ ar_mega_primary_src }}"
                  alt="Featured Collection"
                  width="{{ ar_mega_primary_width }}"
                  height="{{ ar_mega_primary_height }}"
                  loading="lazy"
                  class="ar-mega__feature-img is-active js-ar-mega-feature-primary"
                  id="header-preview-image"
                  data-ar-mega-feature-primary-id="ar-mega-feature-primary-{{ section.id }}"
                >
                <img
                  src="{{ ar_mega_primary_src }}"
                  alt="Featured Collection"
                  width="{{ ar_mega_primary_width }}"
                  height="{{ ar_mega_primary_height }}"
                  loading="lazy"
                  class="ar-mega__feature-img js-ar-mega-feature-secondary"
                  id="ar-mega-feature-secondary-{{ section.id }}"
                >
                <video class="ar-mega__feature-video js-ar-mega-feature-video" muted loop playsinline preload="metadata" aria-label="Collection preview"></video>
              </div>
            </div>
          </div>
        </div>
      </div>

      <a href="{{ section.settings.nav_r2_url | default: ar_header_about_url }}" class="ar-nav__link">{{ section.settings.nav_r2 | default: 'About' }}</a>

      <a href="{{ routes.cart_url }}" class="ar-nav__icon" aria-label="Cart">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.836l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.847-7.148a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.273"/></svg>
        {%- if cart.item_count > 0 -%}<span class="ar-nav__cart-count">{{ cart.item_count }}</span>{%- endif -%}
      </a>

      <a href="{{ routes.account_url }}" class="ar-nav__icon" aria-label="Account">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
      </a>

      <button class="ar-nav__burger js-ar-burger" aria-label="Open menu"><span></span><span></span><span></span></button>
    </div>
  </div>
</nav>

<div class="ar-nav__drawer js-ar-drawer" aria-hidden="true">
  <button class="ar-nav__drawer-close js-ar-close" aria-label="Close menu">&times;</button>
  <a href="{{ section.settings.nav_l1_url | default: '/collections/all' }}" class="ar-nav__drawer-link">{{ section.settings.nav_l1 | default: 'Shop' }}</a>
  <a href="{{ section.settings.nav_l2_url | default: ar_header_blog_url }}" class="ar-nav__drawer-link">{{ section.settings.nav_l2 | default: 'Blogs' }}</a>
  <a href="{{ section.settings.nav_l3_url | default: ar_header_giftsets_url }}" class="ar-nav__drawer-link">{{ section.settings.nav_l3 | default: 'Gift Sets' }}</a>
  <button class="ar-nav__drawer-toggle js-ar-drawer-toggle" aria-expanded="false">
    {{ section.settings.nav_r1 | default: 'Collections' }}
    <svg width="14" height="14" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <div class="ar-nav__drawer-sub-menu js-ar-drawer-sub">
    {%- if mega_blocks.size > 0 -%}
      {%- for block in mega_blocks -%}
        {%- liquid
          assign ar_drawer_title_key = block.settings.title | default: '' | downcase | strip
          assign ar_drawer_link_url = block.settings.link | strip
          if ar_drawer_link_url == blank
            if ar_drawer_title_key contains 'best'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'bestseller'
              endcapture
            elsif ar_drawer_title_key contains 'planet'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'planet-attars'
              endcapture
            elsif ar_drawer_title_key contains 'zodiac'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'zodiac-attars'
              endcapture
            elsif ar_drawer_title_key contains 'nakshatra' or ar_drawer_title_key contains 'naksahtra'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'nakshatra-attars'
              endcapture
            elsif ar_drawer_title_key contains 'chakra'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'chakra-attars'
              endcapture
            elsif ar_drawer_title_key contains 'stress'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'stress-relief'
              endcapture
            elsif ar_drawer_title_key contains 'love'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'love-attar'
              endcapture
            elsif ar_drawer_title_key contains 'incense'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'incense-sticks'
              endcapture
            elsif ar_drawer_title_key contains 'gift' or ar_drawer_title_key contains 'discovery'
              capture ar_drawer_link_url
                render 'ar-collection-url', handle: 'giftsets'
              endcapture
            endif
          endif
          assign ar_drawer_link_url = ar_drawer_link_url | strip
          if ar_drawer_link_url == blank
            assign ar_drawer_link_url = routes.collections_url
          endif
        -%}
        <a href="{{ ar_drawer_link_url }}" class="ar-nav__drawer-link ar-nav__drawer-sub">{{ block.settings.title | default: 'Collection' }}</a>
      {%- endfor -%}
    {%- else -%}
      <a href="{% render 'ar-collection-url', handle: 'bestseller' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Bestseller</a>
      <a href="{% render 'ar-collection-url', handle: 'planet-attars' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Planets Attars</a>
      <a href="{% render 'ar-collection-url', handle: 'zodiac-attars' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Zodiac Attars</a>
      <a href="{% render 'ar-collection-url', handle: 'nakshatra-attars' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Nakshatra Attars</a>
      <a href="{% render 'ar-collection-url', handle: 'stress-relief' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Stress Relief Attars</a>
      <a href="{% render 'ar-collection-url', handle: 'chakra-attars' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Chakra Attars</a>
      <a href="{% render 'ar-collection-url', handle: 'love-attar' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Love Attars</a>
      <a href="{% render 'ar-collection-url', handle: 'incense-sticks' %}" class="ar-nav__drawer-link ar-nav__drawer-sub">Incense Sticks</a>
    {%- endif -%}
  </div>
  <a href="{{ section.settings.nav_r2_url | default: ar_header_about_url }}" class="ar-nav__drawer-link">{{ section.settings.nav_r2 | default: 'About' }}</a>
  <a href="{{ routes.cart_url }}" class="ar-nav__drawer-link">Cart ({{ cart.item_count }})</a>
  <a href="{{ routes.account_url }}" class="ar-nav__drawer-link">Account</a>
</div>

<script>
  (function () {
    'use strict';
    var sectionId = '{{ section.id }}';
    var sectionRoot = document.getElementById('shopify-section-{{ section.id }}') || document;
    var burger = sectionRoot.querySelector('.js-ar-burger');
    var drawer = sectionRoot.querySelector('.js-ar-drawer');
    var close = sectionRoot.querySelector('.js-ar-close');

    function openDrawer() {
      if (!drawer) return;
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      if (!drawer) return;
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    if (burger) burger.addEventListener('click', openDrawer);
    if (close) close.addEventListener('click', closeDrawer);
    if (drawer) drawer.addEventListener('click', function (e) { if (e.target === drawer) closeDrawer(); });
    window.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeDrawer(); });

    var drawerToggle = sectionRoot.querySelector('.js-ar-drawer-toggle');
    var drawerSub = sectionRoot.querySelector('.js-ar-drawer-sub');
    if (drawerToggle && drawerSub) {
      drawerToggle.addEventListener('click', function () {
        var isOpen = drawerSub.classList.contains('is-open');
        drawerSub.classList.toggle('is-open', !isOpen);
        drawerToggle.classList.toggle('is-open', !isOpen);
        drawerToggle.setAttribute('aria-expanded', String(!isOpen));
      });
    }

    function initMegaMenuHover(root) {
      if (!root || root.dataset.arMegaInited === 'true') return;
      root.dataset.arMegaInited = 'true';

      var trigger = root.querySelector('#ar-mega-trigger-' + sectionId);
      var dropdown = root.querySelector('#ar-mega-dropdown-' + sectionId);
      if (!trigger || !dropdown) return;

      var closeTimer;
      function open() { clearTimeout(closeTimer); trigger.classList.add('is-open'); }
      function scheduleClose() { closeTimer = setTimeout(function () { trigger.classList.remove('is-open'); }, 280); }
      trigger.addEventListener('mouseenter', open);
      trigger.addEventListener('mouseleave', scheduleClose);
      dropdown.addEventListener('mouseenter', function () { clearTimeout(closeTimer); });
      dropdown.addEventListener('mouseleave', scheduleClose);
      trigger.addEventListener('focusin', open);
      trigger.addEventListener('focusout', function (e) { if (!trigger.contains(e.relatedTarget)) scheduleClose(); });

      var primaryImage = root.querySelector('#header-preview-image') || root.querySelector('#ar-mega-feature-primary-' + sectionId);
      var secondaryImage = root.querySelector('#ar-mega-feature-secondary-' + sectionId);
      var previewVideo = root.querySelector('.js-ar-mega-feature-video');
      if (!primaryImage || !secondaryImage) return;

      var fallbackSrc = primaryImage.getAttribute('src');
      var fallbackAlt = primaryImage.getAttribute('alt') || 'Featured Collection';
      var activeImage = primaryImage;
      var inactiveImage = secondaryImage;
      function swapTo(src, altText) {
        var nextSrc = src || fallbackSrc;
        var nextAlt = altText || fallbackAlt;
        if (!nextSrc || activeImage.getAttribute('src') === nextSrc) return;
        if (previewVideo) {
          previewVideo.pause();
          previewVideo.removeAttribute('src');
          previewVideo.style.display = 'none';
        }
        primaryImage.style.display = '';
        secondaryImage.style.display = '';
        inactiveImage.src = nextSrc;
        inactiveImage.alt = nextAlt;
        inactiveImage.classList.add('is-active');
        activeImage.classList.remove('is-active');
        var temp = activeImage;
        activeImage = inactiveImage;
        inactiveImage = temp;
      }

      var menuLinks = dropdown.querySelectorAll('.ar-mega__link');
      menuLinks.forEach(function (link) {
        var hoverSrc = link.getAttribute('data-image') || link.getAttribute('data-mega-image');
        var hoverVideo = link.getAttribute('data-video');
        function showVideoOrImage() {
          if (hoverVideo && previewVideo) {
            primaryImage.classList.remove('is-active');
            secondaryImage.classList.remove('is-active');
            primaryImage.style.display = 'none';
            secondaryImage.style.display = 'none';
            previewVideo.src = hoverVideo;
            previewVideo.style.display = 'block';
            previewVideo.play().catch(function(){
              previewVideo.style.display = 'none';
              swapTo(hoverSrc, link.getAttribute('data-mega-alt'));
            });
          } else {
            swapTo(hoverSrc, link.getAttribute('data-mega-alt'));
          }
        }
        link.addEventListener('mouseenter', function () {
          showVideoOrImage();
        });
        link.addEventListener('focus', function () {
          showVideoOrImage();
        });
      });

      if (previewVideo) {
        previewVideo.addEventListener('error', function () {
          previewVideo.style.display = 'none';
          swapTo(fallbackSrc, fallbackAlt);
        });
      }

      dropdown.addEventListener('mouseleave', function () {
        swapTo(fallbackSrc, fallbackAlt);
      });
    }

    initMegaMenuHover(sectionRoot);

    document.addEventListener('shopify:section:load', function (event) {
      if (!event.target || event.target.id !== ('shopify-section-' + sectionId)) return;
      initMegaMenuHover(event.target);
    });
  })();
</script>

