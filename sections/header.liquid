    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 120,
      "max": 260,
      "step": 10,
      "default": 180
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (fallback)"
    },
    {
      "type": "text",
      "id": "logo_subtext",
      "label": "Logo subtext"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "nav_l1",
      "label": "Left link 1 label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "nav_l1_url",
      "label": "Left link 1 URL"
    },
    {
      "type": "text",
      "id": "nav_l2",
      "label": "Left link 2 label",
      "default": "Blogs"
    },
    {
      "type": "url",
      "id": "nav_l2_url",
      "label": "Left link 2 URL"
    },
    {
      "type": "text",
      "id": "nav_l3",
      "label": "Left link 3 label",
      "default": "VIP CLUB"
    },
    {
      "type": "url",
      "id": "nav_l3_url",
      "label": "Left link 3 URL",
      "info": "Leave empty or clear an old Gift Sets URL to use the VIP Club destination below."
    },
    {
      "type": "url",
      "id": "nav_l3_vip_url",
      "label": "VIP Club page URL (optional)",
      "info": "Optional override. If empty: uses your Page with handle “vip-club” (or “vip”) when it exists; otherwise the VIP layout at the home URL with ?view=vip-club (works without creating a page)."
    },
    {
      "type": "text",
      "id": "nav_r1",
      "label": "Right dropdown label",
      "default": "Collections"
    },
    {
      "type": "url",
      "id": "nav_r1_url",
      "label": "Right dropdown URL"
    },
    {
      "type": "image_picker",
      "id": "mega_menu_image",
      "label": "Mega menu fallback image"
    },
    {
      "type": "text",
      "id": "nav_r2",
      "label": "Right link label",
      "default": "About"
    },
    {
      "type": "url",
      "id": "nav_r2_url",
      "label": "Right link URL"
    }
  ],
  "blocks": [
    {
      "type": "mega_item",
      "name": "Mega menu item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Menu title",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Menu link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Hover preview image"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
