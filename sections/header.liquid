  <a href="{{ routes.account_url }}" class="ar-nav__drawer-link">
    <span>Account</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
  <button type="button" class="ar-nav__drawer-link" data-open-cart-drawer>
    <span>Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
</div>

<script>
  (function () {
    'use strict';
    var sectionId = '{{ section.id }}';
    var sectionRoot = document.getElementById('shopify-section-{{ section.id }}') || document;
    var nav = sectionRoot.querySelector('.ar-nav');
    var burger = sectionRoot.querySelector('.js-ar-burger');
    var drawer = sectionRoot.querySelector('.js-ar-drawer');
    var close = sectionRoot.querySelector('.js-ar-close');
    var backdrop = sectionRoot.querySelector('.js-ar-backdrop');
    var searchToggle = sectionRoot.querySelector('.js-ar-search-toggle');
    var searchPanel = sectionRoot.querySelector('.js-ar-search-panel');
    var searchClose = sectionRoot.querySelector('.js-ar-search-close');
    var searchInput = sectionRoot.querySelector('.js-ar-search-input');
    var searchForm = sectionRoot.querySelector('.ar-search-panel__form');

    function lockScroll(lock) {
      document.body.style.overflow = lock ? 'hidden' : '';
    }
    function showBackdrop(show) {
      if (!backdrop) return;
      backdrop.classList.toggle('is-open', show);
      backdrop.setAttribute('aria-hidden', show ? 'false' : 'true');
    }
    function isAnyPanelOpen() {
      var drawerOpen = drawer && drawer.classList.contains('is-open');
      var searchOpen = searchPanel && searchPanel.classList.contains('is-open');
      return drawerOpen || searchOpen;
    }

    function openDrawer() {
      if (!drawer) return;
      closeSearch();
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      if (burger) { burger.classList.add('is-open'); burger.setAttribute('aria-expanded', 'true'); burger.setAttribute('aria-label', 'Close menu'); }
      showBackdrop(true);
      lockScroll(true);
    }
    function closeDrawer() {
      if (!drawer) return;
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      if (burger) { burger.classList.remove('is-open'); burger.setAttribute('aria-expanded', 'false'); burger.setAttribute('aria-label', 'Open menu'); }
      if (!isAnyPanelOpen()) { showBackdrop(false); lockScroll(false); }
    }

    function openSearch() {
      if (!searchPanel) return;
      closeDrawer();
      searchPanel.classList.add('is-open');
      searchPanel.setAttribute('aria-hidden', 'false');
      if (searchToggle) searchToggle.setAttribute('aria-expanded', 'true');
      showBackdrop(true);
      lockScroll(true);
      setTimeout(function () { if (searchInput) { try { searchInput.focus({ preventScroll: true }); } catch (e) { searchInput.focus(); } } }, 220);
    }
    function closeSearch() {
      if (!searchPanel || !searchPanel.classList.contains('is-open')) return;
      searchPanel.classList.remove('is-open');
      searchPanel.setAttribute('aria-hidden', 'true');
      if (searchToggle) searchToggle.setAttribute('aria-expanded', 'false');
      if (!isAnyPanelOpen()) { showBackdrop(false); lockScroll(false); }
    }
    function toggleSearch() {
      if (searchPanel && searchPanel.classList.contains('is-open')) { closeSearch(); }
      else { openSearch(); }
    }

    if (burger) {
      burger.addEventListener('click', function () {
        if (drawer && drawer.classList.contains('is-open')) closeDrawer();
        else openDrawer();
      });
    }
    if (close) close.addEventListener('click', closeDrawer);
    if (backdrop) backdrop.addEventListener('click', function () { closeDrawer(); closeSearch(); });
    if (searchToggle) searchToggle.addEventListener('click', toggleSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);
    if (searchForm) {
      searchForm.addEventListener('submit', function () {
        closeSearch();
      });
    }

    sectionRoot.querySelectorAll('.ar-nav__drawer-link').forEach(function (link) {
      if (link.classList.contains('ar-nav__drawer-toggle')) return;
      link.addEventListener('click', function () { closeDrawer(); });
    });
    sectionRoot.querySelectorAll('[data-open-cart-drawer]').forEach(function (trigger) {
      trigger.addEventListener('click', function () { closeDrawer(); closeSearch(); });
    });
    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') { closeDrawer(); closeSearch(); }
    });

    // Stagger index for drawer link animations
    if (drawer) {
      var topLinks = drawer.querySelectorAll(':scope > .ar-nav__drawer-link');
      topLinks.forEach(function (el, i) { el.style.setProperty('--ar-stagger', String(i + 1)); });
    }

    // Scroll-aware shrink
    if (nav) {
      var lastY = window.scrollY;
      var ticking = false;
      function onScroll() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(function () {
          var y = window.scrollY;
          var scrolled = y > 16;
          nav.classList.toggle('is-scrolled', scrolled);
          if (searchPanel) searchPanel.classList.toggle('is-scrolled', scrolled);
          lastY = y;
          ticking = false;
        });
      }
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    var drawerToggle = sectionRoot.querySelector('.js-ar-drawer-toggle');
    var drawerSub = sectionRoot.querySelector('.js-ar-drawer-sub');
    if (drawerToggle && drawerSub) {
      drawerToggle.addEventListener('click', function () {
        var isOpen = drawerSub.classList.contains('is-open');
        drawerSub.classList.toggle('is-open', !isOpen);
        drawerToggle.classList.toggle('is-open', !isOpen);
        drawerToggle.setAttribute('aria-expanded', String(!isOpen));
      });
    }

    function initMegaMenuHover(root) {
      if (!root || root.dataset.arMegaInited === 'true') return;
      root.dataset.arMegaInited = 'true';

      var trigger = root.querySelector('#ar-mega-trigger-' + sectionId);
      var dropdown = root.querySelector('#ar-mega-dropdown-' + sectionId);
      if (!trigger || !dropdown) return;

      var closeTimer;
      function open() { clearTimeout(closeTimer); trigger.classList.add('is-open'); }
      function scheduleClose() { closeTimer = setTimeout(function () { trigger.classList.remove('is-open'); }, 280); }
      trigger.addEventListener('mouseenter', open);
      trigger.addEventListener('mouseleave', scheduleClose);
      dropdown.addEventListener('mouseenter', function () { clearTimeout(closeTimer); });
      dropdown.addEventListener('mouseleave', scheduleClose);
      trigger.addEventListener('focusin', open);
      trigger.addEventListener('focusout', function (e) { if (!trigger.contains(e.relatedTarget)) scheduleClose(); });

      var primaryImage = root.querySelector('#header-preview-image') || root.querySelector('#ar-mega-feature-primary-' + sectionId);
      var secondaryImage = root.querySelector('#ar-mega-feature-secondary-' + sectionId);
      var previewVideo = root.querySelector('.js-ar-mega-feature-video');
      if (!primaryImage || !secondaryImage) return;

      var fallbackSrc = primaryImage.getAttribute('src');
      var fallbackAlt = primaryImage.getAttribute('alt') || 'Featured Collection';
      var activeImage = primaryImage;
      var inactiveImage = secondaryImage;
      function swapTo(src, altText) {
        var nextSrc = src || fallbackSrc;
        var nextAlt = altText || fallbackAlt;
        if (!nextSrc || activeImage.getAttribute('src') === nextSrc) return;
        if (previewVideo) {
          previewVideo.pause();
          previewVideo.removeAttribute('src');
          previewVideo.style.display = 'none';
        }
        primaryImage.style.display = '';
        secondaryImage.style.display = '';
        inactiveImage.src = nextSrc;
        inactiveImage.alt = nextAlt;
        inactiveImage.classList.add('is-active');
        activeImage.classList.remove('is-active');
        var temp = activeImage;
        activeImage = inactiveImage;
        inactiveImage = temp;
      }

      var menuLinks = dropdown.querySelectorAll('.ar-mega__link');
      menuLinks.forEach(function (link) {
        var hoverSrc = link.getAttribute('data-image') || link.getAttribute('data-mega-image');
        var hoverVideo = link.getAttribute('data-video');
        function showVideoOrImage() {
          if (hoverVideo && previewVideo) {
            primaryImage.classList.remove('is-active');
            secondaryImage.classList.remove('is-active');
            primaryImage.style.display = 'none';
            secondaryImage.style.display = 'none';
            previewVideo.src = hoverVideo;
            previewVideo.style.display = 'block';
            previewVideo.play().catch(function(){
              previewVideo.style.display = 'none';
              swapTo(hoverSrc, link.getAttribute('data-mega-alt'));
            });
          } else {
            swapTo(hoverSrc, link.getAttribute('data-mega-alt'));
          }
        }
        link.addEventListener('mouseenter', function () {
          showVideoOrImage();
        });
        link.addEventListener('focus', function () {
          showVideoOrImage();
        });
      });

      if (previewVideo) {
        previewVideo.addEventListener('error', function () {
          previewVideo.style.display = 'none';
          swapTo(fallbackSrc, fallbackAlt);
        });
      }

      dropdown.addEventListener('mouseleave', function () {
        swapTo(fallbackSrc, fallbackAlt);
      });
    }

    initMegaMenuHover(sectionRoot);

    document.addEventListener('shopify:section:load', function (event) {
      if (!event.target || event.target.id !== ('shopify-section-' + sectionId)) return;
      initMegaMenuHover(event.target);
    });
  })();
</script>

{% schema %}
{
  "name": "Anand Rasa Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
