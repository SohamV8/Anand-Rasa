{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .main-page-faq {
    margin-top: 3rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-top: 1.75rem;
  }

  .main-page-faq__title {
    margin: 0 0 1rem;
    font-size: 1.5rem;
    line-height: 1.3;
  }

  .main-page-faq__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .main-page-faq__question {
    cursor: pointer;
    font-weight: 600;
    padding: 1rem 0;
    list-style: none;
  }

  .main-page-faq__question::-webkit-details-marker {
    display: none;
  }

  .main-page-faq__answer {
    padding: 0 0 1rem;
  }
{%- endstyle -%}

{%- liquid
  assign ar_page_faq_items = page.metafields.custom.faq_items.value
  assign ar_main_page_about = false
  if template.name == 'page' and template.suffix == 'about'
    assign ar_main_page_about = true
  endif
-%}
<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  {%- unless ar_main_page_about -%}
    <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      {{ page.title | escape }}
    </h1>
    <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ page.content }}
    </div>
  {%- endunless -%}

  {%- if ar_page_faq_items != blank -%}
    <section class="main-page-faq" aria-label="Frequently asked questions">
      <h2 class="main-page-faq__title">Frequently asked questions</h2>
      {%- for faq_item in ar_page_faq_items -%}
        {%- assign ar_question = faq_item.question | default: faq_item.title | strip -%}
        {%- assign ar_answer = faq_item.answer | default: faq_item.content | strip -%}
        {%- if ar_question != blank and ar_answer != blank -%}
          <details class="main-page-faq__item">
            <summary class="main-page-faq__question">{{ ar_question }}</summary>
            <div class="main-page-faq__answer rte">{{ ar_answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </section>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign ar_faq_first = true -%}
          {%- for faq_item in ar_page_faq_items -%}
            {%- assign ar_question = faq_item.question | default: faq_item.title | strip -%}
            {%- assign ar_answer = faq_item.answer | default: faq_item.content | strip_html | strip -%}
            {%- if ar_question != blank and ar_answer != blank -%}
              {%- unless ar_faq_first -%},{%- endunless -%}
              {
                "@type": "Question",
                "name": {{ ar_question | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ ar_answer | json }}
                }
              }
              {%- assign ar_faq_first = false -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
    </script>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
