{%- comment -%}
  ANAND RASA - Footer (replaces Dawn footer)
{%- endcomment -%}

<style>
  .arf *, .arf *::before, .arf *::after { box-sizing:border-box; }

  .arf { background:#fff; font-family:var(--font-body-family); border-top:1px solid rgba(30,32,35,.08); }
  .arf a,
  .arf a:hover,
  .arf a:visited,
  .arf a:focus,
  .arf a:active { text-decoration: none; }
  .arf__main { max-width:1440px; margin:0 auto; padding:56px 48px 40px; display:grid; grid-template-columns:1.35fr 1fr 1fr 1fr; gap:48px; }
  @media(max-width:1024px){ .arf__main { grid-template-columns:1fr 1fr; padding:48px 32px 32px; } }
  @media(max-width:580px)  { .arf__main { grid-template-columns:1fr; padding:40px 24px 24px; } }

  .arf__logo-img  { height:80px; width:auto; display:block; margin-bottom:6px; object-fit:contain; }
  .arf__logo-sub  { font-size:12px; font-weight:300; letter-spacing:.22em; color:#9ca3af; display:block; margin-bottom:20px; text-transform:lowercase; }
  .arf__logo-text { font-family:var(--font-heading-family); font-size:28px; font-weight:600; color:#1e2023; display:block; line-height:1; margin-bottom:4px; }
  .arf__tagline   { font-size:14px; line-height:1.75; color:#4b5563; max-width:280px; font-weight:300; margin-bottom:24px; }
  .arf__address   { display:flex; flex-direction:column; gap:4px; }
  .arf__addr-line { font-size:13px; color:#4b5563; line-height:1.6; font-weight:300; }
  .arf__addr-line a { color:#4b5563; transition:color .2s; }
  .arf__addr-line a:hover { color:#1e2023; }

  .arf__col-title { font-family:var(--font-heading-family); font-size:11px; font-weight:600; letter-spacing:.2em; text-transform:uppercase; color:#1e2023; display:block; margin-bottom:24px; }
  .arf__links { display:flex; flex-direction:column; gap:14px; }
  .arf__link  { font-size:14px; color:#4b5563; transition:color .2s; font-weight:300; }
  .arf__link:hover { color:#1e2023; }

  .arf__social-row { display:flex; align-items:center; justify-content:space-between; padding:20px 48px; border-top:1px solid rgba(30,32,35,.08); border-bottom:1px solid rgba(30,32,35,.08); max-width:1440px; margin:0 auto; flex-wrap:wrap; gap:16px; }
  @media(max-width:768px){ .arf__social-row { padding:20px 24px; } }
  .arf__socials    { display:flex; align-items:center; gap:20px; }
  .arf__social-btn { width:38px; height:38px; border:1px solid rgba(30,32,35,.18); border-radius:50%; display:flex; align-items:center; justify-content:center; color:#4b5563; text-decoration:none; transition:all .25s; flex-shrink:0; }
  .arf__social-btn:hover { background:#1e2023; color:#fff; border-color:#1e2023; }
  .arf__social-btn svg { width:18px; height:18px; display:block; flex-shrink:0; }
  .arf__social-btn img { width:18px; height:18px; object-fit:contain; display:block; border-radius:0; }

  .arf__payments  { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
  .arf__pay-slot  { height:36px; min-width:52px; border:1px solid rgba(30,32,35,.15); border-radius:4px; display:flex; align-items:center; justify-content:center; padding:4px 10px; font-size:11px; color:#9ca3af; }
  .arf__pay-slot img { height:24px; width:auto; max-width:100%; object-fit:contain; display:block; }

  .arf__brand-img-wrap { width:100%; overflow:hidden; padding:0 clamp(16px, 4vw, 48px); text-align:center; }
  .arf__brand-img { width:100%; max-width:min(1200px, 100%); margin:0 auto; display:block; height:auto; max-height:min(240px, 28vw); object-fit:contain; object-position:center 48%; }
  .arf__brand-img-ph { width:100%; min-height:220px; background:#faf9f7; display:flex; align-items:center; justify-content:center; font-size:13px; color:#9ca3af; letter-spacing:.05em; border-top:1px solid rgba(30,32,35,.06); text-align:center; padding:24px; font-family:var(--font-body-family); }

  .arf__bottom { max-width:1440px; margin:0 auto; padding:16px 48px; display:flex; align-items:center; justify-content:center; }
  .arf__copy { font-size:12px; color:#9ca3af; text-align:center; }
</style>

<footer class="arf">
  <div class="arf__main">
    <div>
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 600 }}"
          srcset="{{ section.settings.logo | image_url: width: 200 }} 200w, {{ section.settings.logo | image_url: width: 400 }} 400w, {{ section.settings.logo | image_url: width: 600 }} 600w"
          sizes="160px"
          alt="{{ section.settings.logo.alt | default: shop.name }}"
          width="{{ section.settings.logo_width | default: 160 }}"
          height="auto"
          loading="lazy"
          class="arf__logo-img"
        >
        {%- if section.settings.logo_subtext != blank -%}<span class="arf__logo-sub">{{ section.settings.logo_subtext }}</span>{%- endif -%}
      {%- else -%}
        <span class="arf__logo-text">{{ shop.name }}</span>
        {%- if section.settings.logo_subtext != blank -%}<span class="arf__logo-sub">{{ section.settings.logo_subtext }}</span>{%- endif -%}
      {%- endif -%}

      <p class="arf__tagline">{{ section.settings.footer_tagline | default: 'Luxury spiritual attars inspired by Vedic tradition.' }}</p>

      <div class="arf__address">
        <span class="arf__addr-line">{{ section.settings.footer_business | default: 'Anand Rasa Fragrance' }}</span>
        <span class="arf__addr-line">{{ section.settings.footer_address | default: 'Gurugram, Haryana, India' }}</span>
        <span class="arf__addr-line"><a href="mailto:{{ section.settings.footer_email | default: 'anandrasafragnance@gmail.com' }}">{{ section.settings.footer_email | default: 'anandrasafragnance@gmail.com' }}</a></span>
        <span class="arf__addr-line"><a href="tel:{{ section.settings.footer_phone | default: '+919311336643' }}">{{ section.settings.footer_phone | default: '+91-93113-36643' }}</a></span>
        <span class="arf__addr-line"><a href="https://wa.me/{{ section.settings.footer_whatsapp | default: '919311336643' }}" target="_blank" rel="noopener">WhatsApp: {{ section.settings.footer_whatsapp_display | default: '+91-93113-36643' }}</a></span>
      </div>
    </div>

    <div>
      <span class="arf__col-title">Collections</span>
      <div class="arf__links">
        <a href="{% render 'ar-collection-url', handle: 'bestseller' %}" class="arf__link">Bestseller</a>
        <a href="{% render 'ar-collection-url', handle: 'planet-attars' %}" class="arf__link">Planets Attar</a>
        <a href="{% render 'ar-collection-url', handle: 'zodiac-attars' %}" class="arf__link">Zodiac Attar</a>
        <a href="{% render 'ar-collection-url', handle: 'nakshatra-attars' %}" class="arf__link">Nakshatra Attar</a>
        <a href="{% render 'ar-collection-url', handle: 'chakra-attars' %}" class="arf__link">Chakra Attar</a>
        <a href="{% render 'ar-collection-url', handle: 'stress-relief' %}" class="arf__link">Stress Relief Attar</a>
        <a href="{% render 'ar-collection-url', handle: 'love-attar' %}" class="arf__link">Love Attar</a>
        <a href="{% render 'ar-collection-url', handle: 'incense-sticks' %}" class="arf__link">Incense Sticks</a>
        <a href="{% render 'ar-collection-url', handle: 'giftsets' %}" class="arf__link">Gift Sets</a>
      </div>
    </div>

    <div>
      <span class="arf__col-title">Support</span>
      <div class="arf__links">
        <a href="{% render 'ar-page-url', handle: 'contact' %}" class="arf__link">Contact Us</a>
        <a href="{% if shop.shipping_policy %}{{ shop.shipping_policy.url }}{% else %}/policies/shipping-policy{% endif %}" class="arf__link">Shipping Policy</a>
        <a href="{% render 'ar-page-url', handle: 'bulk-enquiry' %}" class="arf__link">Bulk Enquiry</a>
        <a href="{% render 'ar-page-url', handle: 'faq' %}" class="arf__link">FAQ</a>
        <a href="{% render 'ar-page-url', handle: 'find-fragrance' %}" class="arf__link">Astro Fragrance Finder</a>
      </div>
    </div>

    <div>
      <span class="arf__col-title">Company</span>
      <div class="arf__links">
        <a href="{% render 'ar-page-url', handle: 'about' %}" class="arf__link">About Anand Rasa</a>
        <a href="{% if blogs['news'] != empty %}{{ blogs['news'].url }}{% else %}/blogs/news{% endif %}" class="arf__link">Blog</a>
        <a href="{% if shop.privacy_policy %}{{ shop.privacy_policy.url }}{% else %}/policies/privacy-policy{% endif %}" class="arf__link">Privacy Policy</a>
        <a href="{% if shop.terms_of_service %}{{ shop.terms_of_service.url }}{% else %}/policies/terms-of-service{% endif %}" class="arf__link">Terms &amp; Conditions</a>
        <a href="{% if shop.refund_policy %}{{ shop.refund_policy.url }}{% else %}/policies/refund-policy{% endif %}" class="arf__link">Refund Policy</a>
      </div>
    </div>
  </div>

  <div class="arf__social-row">
    <div class="arf__socials">
      {%- if section.settings.icon_instagram != blank -%}
        <a href="{{ section.settings.instagram | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="Instagram">
          <img src="{{ section.settings.icon_instagram | image_url: width: 72 }}" srcset="{{ section.settings.icon_instagram | image_url: width: 36 }} 1x, {{ section.settings.icon_instagram | image_url: width: 72 }} 2x" alt="Instagram" width="18" height="18" loading="lazy">
        </a>
      {%- elsif section.settings.icon_instagram_url != blank -%}
        <a href="{{ section.settings.instagram | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="Instagram">
          <img src="{{ section.settings.icon_instagram_url }}" alt="Instagram" width="18" height="18" loading="lazy">
        </a>
      {%- else -%}
        <a href="{{ section.settings.instagram | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.icon_facebook != blank -%}
        <a href="{{ section.settings.facebook | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="Facebook">
          <img src="{{ section.settings.icon_facebook | image_url: width: 72 }}" srcset="{{ section.settings.icon_facebook | image_url: width: 36 }} 1x, {{ section.settings.icon_facebook | image_url: width: 72 }} 2x" alt="Facebook" width="18" height="18" loading="lazy">
        </a>
      {%- elsif section.settings.icon_facebook_url != blank -%}
        <a href="{{ section.settings.facebook | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="Facebook">
          <img src="{{ section.settings.icon_facebook_url }}" alt="Facebook" width="18" height="18" loading="lazy">
        </a>
      {%- else -%}
        <a href="{{ section.settings.facebook | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.icon_youtube != blank -%}
        <a href="{{ section.settings.youtube | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="YouTube">
          <img src="{{ section.settings.icon_youtube | image_url: width: 72 }}" srcset="{{ section.settings.icon_youtube | image_url: width: 36 }} 1x, {{ section.settings.icon_youtube | image_url: width: 72 }} 2x" alt="YouTube" width="18" height="18" loading="lazy">
        </a>
      {%- elsif section.settings.icon_youtube_url != blank -%}
        <a href="{{ section.settings.youtube | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="YouTube">
          <img src="{{ section.settings.icon_youtube_url }}" alt="YouTube" width="18" height="18" loading="lazy">
        </a>
      {%- else -%}
        <a href="{{ section.settings.youtube | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.4 19.6C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-2A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.icon_linkedin != blank -%}
        <a href="{{ section.settings.linkedin | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="LinkedIn">
          <img src="{{ section.settings.icon_linkedin | image_url: width: 72 }}" srcset="{{ section.settings.icon_linkedin | image_url: width: 36 }} 1x, {{ section.settings.icon_linkedin | image_url: width: 72 }} 2x" alt="LinkedIn" width="18" height="18" loading="lazy">
        </a>
      {%- elsif section.settings.icon_linkedin_url != blank -%}
        <a href="{{ section.settings.linkedin | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="LinkedIn">
          <img src="{{ section.settings.icon_linkedin_url }}" alt="LinkedIn" width="18" height="18" loading="lazy">
        </a>
      {%- else -%}
        <a href="{{ section.settings.linkedin | default: '#' }}" class="arf__social-btn" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="arf__payments">
      {%- if section.settings.pay_visa != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_visa | image_url: width: 100 }}" srcset="{{ section.settings.pay_visa | image_url: width: 50 }} 1x, {{ section.settings.pay_visa | image_url: width: 100 }} 2x" alt="Visa" width="40" height="24" loading="lazy"></div>
      {%- elsif section.settings.pay_visa_url != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_visa_url }}" alt="Visa" width="40" height="24" loading="lazy"></div>
      {%- else -%}
        <div class="arf__pay-slot">VISA</div>
      {%- endif -%}

      {%- if section.settings.pay_mc != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_mc | image_url: width: 100 }}" srcset="{{ section.settings.pay_mc | image_url: width: 50 }} 1x, {{ section.settings.pay_mc | image_url: width: 100 }} 2x" alt="Mastercard" width="40" height="24" loading="lazy"></div>
      {%- elsif section.settings.pay_mc_url != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_mc_url }}" alt="Mastercard" width="40" height="24" loading="lazy"></div>
      {%- else -%}
        <div class="arf__pay-slot">MC</div>
      {%- endif -%}

      {%- if section.settings.pay_upi != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_upi | image_url: width: 100 }}" srcset="{{ section.settings.pay_upi | image_url: width: 50 }} 1x, {{ section.settings.pay_upi | image_url: width: 100 }} 2x" alt="UPI" width="40" height="24" loading="lazy"></div>
      {%- elsif section.settings.pay_upi_url != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_upi_url }}" alt="UPI" width="40" height="24" loading="lazy"></div>
      {%- else -%}
        <div class="arf__pay-slot">UPI</div>
      {%- endif -%}

      {%- if section.settings.pay_rp != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_rp | image_url: width: 100 }}" srcset="{{ section.settings.pay_rp | image_url: width: 50 }} 1x, {{ section.settings.pay_rp | image_url: width: 100 }} 2x" alt="RuPay" width="40" height="24" loading="lazy"></div>
      {%- elsif section.settings.pay_rp_url != blank -%}
        <div class="arf__pay-slot"><img src="{{ section.settings.pay_rp_url }}" alt="RuPay" width="40" height="24" loading="lazy"></div>
      {%- else -%}
        <div class="arf__pay-slot">RP</div>
      {%- endif -%}
    </div>
  </div>

  <div class="arf__brand-img-wrap">
    {%- if section.settings.footer_brand_image != blank -%}
      <img
        src="{{ section.settings.footer_brand_image | image_url: width: 1600 }}"
        srcset="{{ section.settings.footer_brand_image | image_url: width: 800 }} 800w, {{ section.settings.footer_brand_image | image_url: width: 1200 }} 1200w, {{ section.settings.footer_brand_image | image_url: width: 1600 }} 1600w, {{ section.settings.footer_brand_image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ shop.name }}"
        width="{{ section.settings.footer_brand_image.width | default: 2000 }}"
        height="{{ section.settings.footer_brand_image.height | default: 400 }}"
        loading="lazy"
        class="arf__brand-img"
      >
    {%- elsif section.settings.footer_brand_image_url != blank -%}
      <img
        src="{{ section.settings.footer_brand_image_url }}"
        sizes="100vw"
        alt="{{ shop.name }}"
        width="2000"
        height="400"
        loading="lazy"
        class="arf__brand-img"
      >
    {%- else -%}
      <div class="arf__brand-img-ph">Upload your brand image — Theme Editor → Footer Brand Image</div>
    {%- endif -%}
  </div>

  <div class="arf__bottom">
    <p class="arf__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
  </div>
</footer>

{% schema %}
{
  "name": "Anand Rasa Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Footer logo width (px)",
      "min": 120,
      "max": 260,
      "step": 10,
      "default": 160
    },
    {
      "type": "text",
      "id": "logo_subtext",
      "label": "Logo subtext"
    },
    {
      "type": "header",
      "content": "Footer - Brand Info"
    },
    {
      "type": "textarea",
      "id": "footer_tagline",
      "label": "Tagline",
      "default": "Luxury spiritual attars inspired by Vedic tradition."
    },
    {
      "type": "text",
      "id": "footer_business",
      "label": "Business name",
      "default": "Anand Rasa Fragrance"
    },
    {
      "type": "text",
      "id": "footer_address",
      "label": "Address",
      "default": "Gurugram, Haryana, India"
    },
    {
      "type": "text",
      "id": "footer_email",
      "label": "Email",
      "default": "anandrasafragnance@gmail.com"
    },
    {
      "type": "text",
      "id": "footer_phone",
      "label": "Phone",
      "default": "+91-93113-36643"
    },
    {
      "type": "text",
      "id": "footer_whatsapp",
      "label": "WhatsApp number (digits only)",
      "default": "919311336643"
    },
    {
      "type": "text",
      "id": "footer_whatsapp_display",
      "label": "WhatsApp display text",
      "default": "+91-93113-36643"
    },
    {
      "type": "header",
      "content": "Footer - Social Links"
    },
    {
      "type": "text",
      "id": "instagram",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/anand__rasa/"
    },
    {
      "type": "text",
      "id": "facebook",
      "label": "Facebook URL",
      "default": "https://www.facebook.com/profile.php?id=61584373649018"
    },
    {
      "type": "text",
      "id": "youtube",
      "label": "YouTube URL"
    },
    {
      "type": "text",
      "id": "linkedin",
      "label": "LinkedIn URL"
    },
    {
      "type": "header",
      "content": "Footer - Social Icon Images"
    },
    {
      "type": "image_picker",
      "id": "icon_instagram",
      "label": "Instagram icon"
    },
    {
      "type": "url",
      "id": "icon_instagram_url",
      "label": "Instagram icon URL fallback"
    },
    {
      "type": "image_picker",
      "id": "icon_facebook",
      "label": "Facebook icon"
    },
    {
      "type": "url",
      "id": "icon_facebook_url",
      "label": "Facebook icon URL fallback"
    },
    {
      "type": "image_picker",
      "id": "icon_youtube",
      "label": "YouTube icon"
    },
    {
      "type": "url",
      "id": "icon_youtube_url",
      "label": "YouTube icon URL fallback"
    },
    {
      "type": "image_picker",
      "id": "icon_linkedin",
      "label": "LinkedIn icon"
    },
    {
      "type": "url",
      "id": "icon_linkedin_url",
      "label": "LinkedIn icon URL fallback"
    },
    {
      "type": "header",
      "content": "Footer - Payment Badge Images"
    },
    {
      "type": "image_picker",
      "id": "pay_visa",
      "label": "Visa badge image"
    },
    {
      "type": "url",
      "id": "pay_visa_url",
      "label": "Visa badge image URL fallback"
    },
    {
      "type": "image_picker",
      "id": "pay_mc",
      "label": "Mastercard badge image"
    },
    {
      "type": "url",
      "id": "pay_mc_url",
      "label": "Mastercard badge image URL fallback"
    },
    {
      "type": "image_picker",
      "id": "pay_upi",
      "label": "UPI badge image"
    },
    {
      "type": "url",
      "id": "pay_upi_url",
      "label": "UPI badge image URL fallback"
    },
    {
      "type": "image_picker",
      "id": "pay_rp",
      "label": "Razorpay badge image"
    },
    {
      "type": "url",
      "id": "pay_rp_url",
      "label": "Razorpay badge image URL fallback"
    },
    {
      "type": "header",
      "content": "Footer - Brand Image"
    },
    {
      "type": "image_picker",
      "id": "footer_brand_image",
      "label": "Brand image at bottom"
    },
    {
      "type": "url",
      "id": "footer_brand_image_url",
      "label": "Brand image URL fallback"
    }
  ]
}
{% endschema %}
