    },
    {
      "type": "number",
      "id": "plan_5_bundle_cents",
      "label": "Plan 5 bundle price (cents)",
      "default": 240000,
      "info": "₹2400 = 240000. Used for savings calculation in the ritual dock."
    },
    {
      "type": "header",
      "content": "Ritual size plans (advanced)"
    },
    {
      "type": "paragraph",
      "content": "Configure up to two ritual sizes. Set Plan B size to 0 for a single-plan page (e.g. a dedicated “Pick any 4” page)."
    },
    {
      "type": "number",
      "id": "plan_a_size",
