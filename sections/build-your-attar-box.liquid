    {
      "type": "header",
      "content": "Product grid"
    },
    {
      "type": "text",
      "id": "grid_title",
      "label": "Grid heading",
      "default": "Select Your Attars"
    },
    {
      "type": "textarea",
      "id": "grid_sub",
      "label": "Grid subcopy",
      "default": "Our bestselling 6ml attars — tap to add each fragrance to your ritual box."
    },
    {
      "type": "text",
      "id": "complete_message",
      "label": "Box complete message",
      "default": "Your ritual box is complete."
    },
    {
      "type": "text",
      "id": "cta_ready",
      "label": "Add to cart CTA",
      "default": "Add Ritual Box to Cart"
    },
    {
      "type": "text",
      "id": "msg_added",
      "label": "Success toast",
      "default": "Your ritual box was added to cart."
    }
  ],
  "presets": [
    {
      "name": "Build Your Attar Box"
    }
  ]
