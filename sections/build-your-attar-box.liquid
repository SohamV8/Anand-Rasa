    },
    {
      "type": "text",
      "id": "hero_cta",
      "label": "Hero CTA",
      "default": "Start Building"
    },
    {
      "type": "header",
      "content": "Plans"
    },
    {
      "type": "text",
      "id": "plans_title",
      "label": "Plans heading",
      "default": "Choose Your Ritual Size"
    },
    {
      "type": "textarea",
      "id": "plans_sub",
      "label": "Plans subcopy",
      "default": "Select how many 6ml attars you would like in your box. Pricing is fixed for each ritual size."
    },
    {
      "type": "text",
      "id": "plan_3_price_display",
      "label": "Plan 3 display price",
      "default": "₹1200"
    },
    {
      "type": "text",
      "id": "plan_3_price",
      "label": "Plan 3 dock label",
      "default": "₹1200 Ritual Box"
    },
    {
      "type": "text",
      "id": "plan_5_price_display",
