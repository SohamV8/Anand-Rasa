{% comment %}
  Build Your Attar Box — luxury ritual box builder.
  Assign template "build-your-box" to a page with handle build-your-box.
{% endcomment %}

{%- liquid
  if template.suffix == 'build-4-perfumes'
    assign byb_handles = 'perfume-series,perfume,perfumes,perfume-collection' | split: ','
  else
    assign byb_handles = section.settings.collection_handles | default: 'bestseller,Bestseller,best-seller,bestsellers,best-sellers' | split: ','
  endif
  assign byb_collection = blank
  for byb_h in byb_handles
    assign byb_h_clean = byb_h | strip
    if byb_h_clean != blank and collections[byb_h_clean] != empty
      assign byb_collection = collections[byb_h_clean]
      break
    endif
  endfor

  assign byb_hero_eyebrow = section.settings.hero_eyebrow | default: 'Personal Fragrance Ritual'
  assign byb_hero_title = section.settings.hero_title | default: 'Build Your Attar Box'
  assign byb_hero_lead = section.settings.hero_lead | default: 'Curate your own handcrafted fragrance ritual from our bestselling luxury attars.'
  assign byb_hero_sub = section.settings.hero_sub | default: 'Choose your favorites. Build your ritual. Experience Indian perfumery in its purest form.'
  assign byb_hero_cta = section.settings.hero_cta | default: 'Start Building'
  assign byb_plans_title = section.settings.plans_title | default: 'Choose Your Ritual Size'
  assign byb_plans_sub = section.settings.plans_sub | default: 'Select how many 6ml attars you would like in your box. Pricing is fixed for each ritual size.'
  assign byb_grid_title = section.settings.grid_title | default: 'Select Your Attars'
  assign byb_grid_sub = section.settings.grid_sub | default: 'Our bestselling 6ml attars — tap to add each fragrance to your ritual box.'
  assign byb_complete_msg = section.settings.complete_message | default: 'Your ritual box is complete.'
  assign byb_plan_3_price = section.settings.plan_3_price | default: '₹1200 Ritual Box'
  assign byb_plan_5_price = section.settings.plan_5_price | default: '₹2400 Ritual Box'
  assign byb_cta_ready = section.settings.cta_ready | default: 'Add Ritual Box to Cart'
  assign byb_msg_added = section.settings.msg_added | default: 'Your ritual box was added to cart.'
  assign byb_plan_3_cents = section.settings.plan_3_bundle_cents | default: 120000
  assign byb_plan_5_cents = section.settings.plan_5_bundle_cents | default: 240000

  comment
    Configurable plans. Plan A is required; Plan B is optional (hidden when its
    size is 0/blank). Defaults reproduce the original 3 + 5 dual-plan page.
  endcomment
  assign byb_size_label = section.settings.size_label | default: '6ml'

  assign byb_plan_a_size = section.settings.plan_a_size | default: 3
  assign byb_plan_a_name = section.settings.plan_a_name | default: 'Choose Any 3'
  assign byb_plan_a_detail = section.settings.plan_a_detail | default: '3 × 6ml luxury attars'
  assign byb_plan_a_display = section.settings.plan_a_price_display | default: '₹1200'
  assign byb_plan_a_label = section.settings.plan_a_dock_label | default: byb_plan_3_price
  assign byb_plan_a_cents = section.settings.plan_a_bundle_cents | default: byb_plan_3_cents

  assign byb_plan_b_size = section.settings.plan_b_size | default: 5
  assign byb_plan_b_name = section.settings.plan_b_name | default: 'Choose Any 5'
  assign byb_plan_b_detail = section.settings.plan_b_detail | default: '5 × 6ml luxury attars'
  assign byb_plan_b_display = section.settings.plan_b_price_display | default: '₹2400'
  assign byb_plan_b_label = section.settings.plan_b_dock_label | default: byb_plan_5_price
  assign byb_plan_b_cents = section.settings.plan_b_bundle_cents | default: byb_plan_5_cents

  assign byb_plan_b_on = false
  if byb_plan_b_size and byb_plan_b_size > 0
    assign byb_plan_b_on = true
  endif

  assign byb_assets_only = section.settings.card_images_assets_only
  assign byb_group_astro = section.settings.group_products_by_astro
  if template.suffix == 'astrology-ritual-set'
    assign byb_assets_only = true
    assign byb_group_astro = true
  endif

  assign byb_hub_mode = false
  if template.suffix == 'build-your-box'
    assign byb_hub_mode = true
  endif

  unless byb_hub_mode
    if template.suffix == 'build-4-perfumes'
      assign byb_size_label = section.settings.size_label | default: '20ml'
    else
      assign byb_size_label = '6ml'
    endif
  endunless

  assign byb_grid_handles = section.settings.collection_handles
  if template.suffix == 'build-4-perfumes'
    assign byb_grid_handles = 'perfume-series,perfume,perfumes,perfume-collection'
  endif

  if byb_hub_mode
    capture byb_hub_url_3
      render 'ar-page-url', handle: 'build-3-attars'
    endcapture
    capture byb_hub_url_5
      render 'ar-page-url', handle: 'build-5-attars'
    endcapture
    capture byb_hub_url_perfume
      render 'ar-page-url', handle: 'build-4-perfumes'
    endcapture
    capture byb_hub_url_astro
      render 'ar-page-url', handle: 'astrology-ritual-set'
    endcapture
    capture byb_hub_url_incense
      render 'ar-page-url', handle: 'build-3-incense'
    endcapture
    assign byb_hub_url_3 = byb_hub_url_3 | strip
    assign byb_hub_url_5 = byb_hub_url_5 | strip
    assign byb_hub_url_perfume = byb_hub_url_perfume | strip
    assign byb_hub_url_astro = byb_hub_url_astro | strip
    assign byb_hub_url_incense = byb_hub_url_incense | strip
    if section.settings.hub_url_3 != blank
      assign byb_hub_url_3 = section.settings.hub_url_3
    endif
    if section.settings.hub_url_5 != blank
      assign byb_hub_url_5 = section.settings.hub_url_5
    endif
    if section.settings.hub_url_perfume != blank
      assign byb_hub_url_perfume = section.settings.hub_url_perfume
    endif
    if section.settings.hub_url_astro != blank
      assign byb_hub_url_astro = section.settings.hub_url_astro
    endif
    if section.settings.hub_url_incense != blank
      assign byb_hub_url_incense = section.settings.hub_url_incense
    endif
    assign byb_hub_perfume_name = section.settings.hub_perfume_name | default: 'Pick Any 4 · 20ml Perfumes'
    assign byb_hub_perfume_detail = section.settings.hub_perfume_detail | default: '4 × 20ml luxury perfumes'
    assign byb_hub_perfume_price = section.settings.hub_perfume_price | default: '₹2100'
    assign byb_hub_astro_name = section.settings.hub_astro_name | default: 'Astrology Ritual Set'
    assign byb_hub_astro_detail = section.settings.hub_astro_detail | default: 'Planet, Zodiac & Nakshatra attars'
    assign byb_hub_astro_price = section.settings.hub_astro_price | default: '₹2500'
    assign byb_hub_incense_name = section.settings.hub_incense_name | default: 'Pick Any 3 · Incense Sticks'
    assign byb_hub_incense_detail = section.settings.hub_incense_detail | default: '3 × premium incense sticks'
    assign byb_hub_incense_price = section.settings.hub_incense_price | default: '₹600'
  endif
-%}

{% render 'build-box-attar-assets', part: 'styles', hub_mode: byb_hub_mode %}

<div
  class="byb{% if byb_hub_mode %} byb--hub{% elsif byb_plan_b_on == false %} byb--fixed-plan{% endif %}"
  {% unless byb_hub_mode %}data-byb-root data-section-id="{{ section.id }}"{% if byb_plan_b_on == false %} data-byb-default-plan="{{ byb_plan_a_size }}"{% endif %}{% endunless %}
>
  {%- unless byb_hub_mode -%}
  <script type="application/json" data-byb-config>
    {
      "plans": {
        "{{ byb_plan_a_size }}": {
          "bundleCents": {{ byb_plan_a_cents }},
          "label": {{ byb_plan_a_label | json }},
          "display": {{ byb_plan_a_display | json }}
        }{% if byb_plan_b_on %},
        "{{ byb_plan_b_size }}": {
          "bundleCents": {{ byb_plan_b_cents }},
          "label": {{ byb_plan_b_label | json }},
          "display": {{ byb_plan_b_display | json }}
        }{% endif %}
      },
      "ctaReady": {{ byb_cta_ready | json }},
      "msgComplete": {{ byb_complete_msg | json }},
      "msgAdded": {{ byb_msg_added | json }},
      "moneyFormat": {{ shop.money_format | json }},
      "currency": {{ cart.currency.iso_code | default: shop.currency | json }}
    }
  </script>
  {%- endunless -%}

  {%- comment -%} ── Hero ── {%- endcomment -%}
  <header class="byb-hero byb-hero--cinematic">
    <div class="byb-hero__wash" aria-hidden="true"></div>
    <div class="byb-hero__orb byb-hero__orb--a" aria-hidden="true"></div>
    <div class="byb-hero__orb byb-hero__orb--b" aria-hidden="true"></div>
    <div class="byb-hero__grid">
      <div class="byb-hero__content">
        <p class="byb-hero__eyebrow" data-byb-hero-item>{{ byb_hero_eyebrow }}</p>
        <h1 class="byb-hero__title" data-byb-hero-item>{{ byb_hero_title }}</h1>
        <p class="byb-hero__lead" data-byb-hero-item>{{ byb_hero_lead }}</p>
        <p class="byb-hero__sub" data-byb-hero-item>{{ byb_hero_sub }}</p>
        {%- if byb_hub_mode -%}
          <a href="#build-box-plans" class="byb-hero__cta" data-byb-hero-item>
            <span class="byb-hero__cta-label">{{ byb_hero_cta }}</span>
          </a>
        {%- else -%}
          <button type="button" class="byb-hero__cta" data-byb-hero-item data-byb-hero-cta>
            <span class="byb-hero__cta-label">{{ byb_hero_cta }}</span>
          </button>
        {%- endif -%}
      </div>
      <div class="byb-hero__media-wrap" data-byb-hero-media aria-hidden="true">
        <div class="byb-hero__media-frame">
          <span class="byb-hero__glow"></span>
          <img
            class="byb-hero__img"
            src="{{ 'wooden_attar_box.webp' | asset_url }}"
            alt="{{ byb_hero_title | escape }} — handcrafted wooden attar discovery box"
            width="1400"
            height="1050"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          >
        </div>
      </div>
    </div>
  </header>

  {%- comment -%} Hub landing — ritual box options link out to dedicated builder pages. {%- endcomment -%}
  {%- if byb_hub_mode -%}
  <section class="byb-plans byb-plans--hub" id="build-box-plans" aria-labelledby="byb-plans-heading" data-byb-reveal>
    <div class="byb-plans__inner">
      <h2 id="byb-plans-heading" class="byb-plans__title">{{ byb_plans_title }}</h2>
      <p class="byb-plans__sub">{{ byb_plans_sub }}</p>
      <div class="byb-plans__grid byb-plans__grid--hub" role="list">
        <a href="{{ byb_hub_url_3 }}" class="byb-plan byb-plan--link" role="listitem">
          <h3 class="byb-plan__name">{{ byb_plan_a_name }}</h3>
          <p class="byb-plan__detail">{{ byb_plan_a_detail }}</p>
          <p class="byb-plan__price">{{ byb_plan_a_display }}</p>
        </a>
        <a href="{{ byb_hub_url_5 }}" class="byb-plan byb-plan--link" role="listitem">
          <h3 class="byb-plan__name">{{ byb_plan_b_name }}</h3>
          <p class="byb-plan__detail">{{ byb_plan_b_detail }}</p>
          <p class="byb-plan__price">{{ byb_plan_b_display }}</p>
        </a>
        <a href="{{ byb_hub_url_perfume }}" class="byb-plan byb-plan--link" role="listitem">
          <h3 class="byb-plan__name">{{ byb_hub_perfume_name }}</h3>
          <p class="byb-plan__detail">{{ byb_hub_perfume_detail }}</p>
          <p class="byb-plan__price">{{ byb_hub_perfume_price }}</p>
        </a>
        <a href="{{ byb_hub_url_astro }}" class="byb-plan byb-plan--link" role="listitem">
          <h3 class="byb-plan__name">{{ byb_hub_astro_name }}</h3>
          <p class="byb-plan__detail">{{ byb_hub_astro_detail }}</p>
          <p class="byb-plan__price">{{ byb_hub_astro_price }}</p>
        </a>
        <a href="{{ byb_hub_url_incense }}" class="byb-plan byb-plan--link" role="listitem">
          <h3 class="byb-plan__name">{{ byb_hub_incense_name }}</h3>
          <p class="byb-plan__detail">{{ byb_hub_incense_detail }}</p>
          <p class="byb-plan__price">{{ byb_hub_incense_price }}</p>
        </a>
      </div>
    </div>
  </section>
  {%- comment -%} Plan picker — only when two ritual sizes are offered on a builder page. {%- endcomment -%}
  {%- elsif byb_plan_b_on -%}
  <section class="byb-plans" id="build-box-plans" aria-labelledby="byb-plans-heading" data-byb-reveal>
    <div class="byb-plans__inner">
      <h2 id="byb-plans-heading" class="byb-plans__title">{{ byb_plans_title }}</h2>
      <p class="byb-plans__sub">{{ byb_plans_sub }}</p>
      <div class="byb-plans__grid" role="group" aria-label="Ritual box size">
        <button
          type="button"
          class="byb-plan"
          data-byb-plan
          data-plan-size="{{ byb_plan_a_size }}"
          data-plan-price="{{ byb_plan_a_label | escape }}"
          aria-pressed="false"
        >
          <span class="byb-plan__badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <h3 class="byb-plan__name">{{ byb_plan_a_name }}</h3>
          <p class="byb-plan__detail">{{ byb_plan_a_detail }}</p>
          <p class="byb-plan__price">{{ byb_plan_a_display }}</p>
        </button>
        <button
          type="button"
          class="byb-plan"
          data-byb-plan
          data-plan-size="{{ byb_plan_b_size }}"
          data-plan-price="{{ byb_plan_b_label | escape }}"
          aria-pressed="false"
        >
          <span class="byb-plan__badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <h3 class="byb-plan__name">{{ byb_plan_b_name }}</h3>
          <p class="byb-plan__detail">{{ byb_plan_b_detail }}</p>
          <p class="byb-plan__price">{{ byb_plan_b_display }}</p>
        </button>
      </div>
    </div>
  </section>
  {%- endif -%}

  {%- unless byb_hub_mode -%}
  {%- comment -%} ── Product grid ── {%- endcomment -%}
  <section
    class="byb-grid-section is-locked"
    data-byb-grid-section
    aria-labelledby="byb-grid-heading"
    data-byb-reveal
  >
    <div class="byb-grid-section__head">
      <h2 id="byb-grid-heading" class="byb-grid-section__title">{{ byb_grid_title }}</h2>
      <p class="byb-grid-section__sub">{{ byb_grid_sub }}</p>
      <p class="byb-grid-section__complete" aria-live="polite">{{ byb_complete_msg }}</p>
    </div>

    {%- if byb_grid_handles != blank and byb_group_astro -%}
      {% render 'build-box-products-grid-astro', collection_handles: byb_grid_handles, size_label: byb_size_label, assets_only: byb_assets_only %}
    {%- elsif byb_grid_handles != blank -%}
      {% render 'build-box-products-grid', collection_handles: byb_grid_handles, size_label: byb_size_label, assets_only: byb_assets_only %}
    {%- elsif byb_collection != blank and byb_collection.products_count > 0 -%}
      {% render 'build-box-products-grid', collection: byb_collection, size_label: byb_size_label, assets_only: byb_assets_only %}
    {%- else -%}
      <div class="byb-empty">
        <p>
          Bestseller attars are being prepared for this experience.
          {%- if section.settings.empty_collection_url != blank -%}
            <a href="{{ section.settings.empty_collection_url }}">Browse the collection</a>
          {%- endif -%}
        </p>
      </div>
    {%- endif -%}
  </section>

  {% render 'build-box-ritual-dock', cta_ready: byb_cta_ready %}

  {% render 'build-box-quickview-modal' %}

  <div class="byb-toast" data-byb-toast role="status" aria-live="polite"></div>
  {%- endunless -%}
</div>

{% render 'build-box-attar-assets', part: 'scripts', hub_mode: byb_hub_mode %}

