    {
      "type": "text",
      "id": "plan_b_name",
      "label": "Plan B — card title",
      "default": "Choose Any 5"
    },
    {
      "type": "text",
      "id": "plan_b_detail",
      "label": "Plan B — card detail",
      "default": "5 × 6ml luxury attars"
    },
    {
      "type": "text",
      "id": "plan_b_price_display",
      "label": "Plan B — display price",
      "default": "₹2400"
