{% doc %}
  @prompt
    Create a premium “Frequently Asked Questions (FAQ)” section for a product page (incense / pooja brand).
    
    SECTION TITLE:
    
    * Heading: “Frequently Asked Questions”
    * Center aligned
    * Elegant serif font (luxury feel)
    * Color: dark brown or charcoal
    * Medium-large size with spacing above and below
    
    LAYOUT:
    
    * Accordion-style FAQ (expand/collapse)
    * Single column layout (centered)
    * Max width: medium (not full width, keep it clean)
    * Each question in a separate row
    
    FAQ ITEMS (exact content):
    
    1. Question: “Is this actually chemical-free or just a claim?”
       Answer: “Our incense is made using natural ingredients like flower waste, herbs, and essential oils. We avoid charcoal and harmful chemicals, ensuring a cleaner and more mindful experience.”
    
    2. Question: “Will the fragrance actually spread across the room?”
       Answer: “Yes, the fragrance is designed to gently diffuse and create a calming atmosphere without being overpowering. Ideal for both small and medium-sized spaces.”
    
    3. Question: “Why does this cost more than local agarbatti?”
       Answer: “Our products use premium natural ingredients, ethical sourcing, and handcrafted processes, which ensures better quality, longer-lasting fragrance, and a healthier experience.”
    
    4. Question: “Is it safe for daily use around kids and elderly?”
       Answer: “Yes, our incense is designed to be safer than conventional options, as it is free from toxic chemicals. However, always ensure proper ventilation while using.”
    
    5. Question: “What if I don’t like the fragrance?”
       Answer: “We stand by our product quality. If you're not satisfied, you can reach out to our support team for assistance or possible replacement options.”
    
    DESIGN STYLE:
    
    * Background: light beige / off-white
    * Each FAQ row:
    
      * Thin divider line between items
      * Slight padding top & bottom
      * Clean, minimal look (no heavy borders)
    
    TYPOGRAPHY:
    
    * Question text:
    
      * Slightly bold
      * Dark color
    * Answer text:
    
      * Regular weight
      * Slightly lighter color
      * Smaller than question
    
    INTERACTION:
    
    * Accordion behavior:
    
      * Click to expand/collapse
      * Smooth animation
    * Icon:
    
      * Right side arrow or chevron
      * Rotates when expanded
      * Minimal gold or neutral color
    
    SPACING:
    
    * Generous vertical spacing between items
    * Comfortable reading spacing inside answers
    
    OPTIONAL ENHANCEMENTS:
    
    * First question expanded by default
    * Subtle hover effect on questions
    * Smooth fade-in on scroll
    
    TECH REQUIREMENTS:
    
    * Fully responsive
    * Shopify Dawn theme compatible
    * Editable questions & answers via theme editor
    * Lightweight and fast loading
    
    GOAL:
    Create a clean, trustworthy, and premium FAQ section that reduces buyer hesitation and improves conversions.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    text-align: center;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.3;
  }

  .ai-faq-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
    padding: {{ block.settings.item_padding }}px 0;
  }

  .ai-faq-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-faq-question-button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    padding: 0;
    text-align: left;
    cursor: pointer;
    gap: 20px;
  }

  .ai-faq-question-button-{{ ai_gen_id }}:hover .ai-faq-question-text-{{ ai_gen_id }} {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_size }}px;
    font-weight: {{ block.settings.question_weight }};
    color: {{ block.settings.question_color }};
    margin: 0;
    flex-grow: 1;
    line-height: 1.5;
    transition: color 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.4s ease, margin-top 0.4s ease;
    opacity: 0;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 1000px;
    opacity: 1;
    margin-top: {{ block.settings.answer_spacing }}px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    font-weight: {{ block.settings.answer_weight }};
    color: {{ block.settings.answer_color }};
    line-height: 1.7;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-faq-question-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_size }}px * 0.9);
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_size }}px * 0.9);
    }

    .ai-faq-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <ul class="ai-faq-list-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign question_key = 'question_' | append: i
          assign answer_key = 'answer_' | append: i
          assign question = block.settings[question_key]
          assign answer = block.settings[answer_key]
        %}

        {% if question != blank and answer != blank %}
          <li class="ai-faq-item-{{ ai_gen_id }} {% if i == 1 and block.settings.first_open %}active{% endif %}" data-faq-item>
            <button
              class="ai-faq-question-button-{{ ai_gen_id }}"
              aria-expanded="{% if i == 1 and block.settings.first_open %}true{% else %}false{% endif %}"
              data-faq-button
            >
              <h3 class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</h3>
              <span class="ai-faq-icon-{{ ai_gen_id }}" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            </button>
            <div class="ai-faq-answer-{{ ai_gen_id }}" data-faq-answer>
              <p class="ai-faq-answer-content-{{ ai_gen_id }}">{{ answer }}</p>
            </div>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('[data-faq-button]');
          
          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            if (isActive) {
              this.closeItem(item);
            } else {
              this.openItem(item);
            }
          });
        });
      }

      openItem(item) {
        const button = item.querySelector('[data-faq-button]');
        item.classList.add('active');
        button.setAttribute('aria-expanded', 'true');
      }

      closeItem(item) {
        const button = item.querySelector('[data-faq-button]');
        item.classList.remove('active');
        button.setAttribute('aria-expanded', 'false');
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

