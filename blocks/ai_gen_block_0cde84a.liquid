{% doc %}
  @prompt
    generate 3 section customer testimonial 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-testimonials-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-stars-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: currentColor;
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.6;
    color: {{ block.settings.quote_color }};
    margin: 0;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: #f4f4f4;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-avatar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.card_border_color }};
    color: {{ block.settings.quote_color }};
    font-size: {{ block.settings.avatar_size | divided_by: 2 }}px;
    font-weight: 600;
  }

  .ai-testimonial-author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-testimonial-author-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-testimonial-author-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_title_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-testimonials-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 16px;
    }
  }
{% endstyle %}

<customer-testimonials-{{ ai_gen_id }}
  class="ai-testimonials-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-testimonials-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-testimonials-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign testimonial_enabled_key = 'testimonial_' | append: i | append: '_enabled'
          assign testimonial_quote_key = 'testimonial_' | append: i | append: '_quote'
          assign testimonial_author_key = 'testimonial_' | append: i | append: '_author'
          assign testimonial_title_key = 'testimonial_' | append: i | append: '_title'
          assign testimonial_avatar_key = 'testimonial_' | append: i | append: '_avatar'
          assign testimonial_rating_key = 'testimonial_' | append: i | append: '_rating'

          assign testimonial_enabled = block.settings[testimonial_enabled_key]
          assign testimonial_quote = block.settings[testimonial_quote_key]
          assign testimonial_author = block.settings[testimonial_author_key]
          assign testimonial_title = block.settings[testimonial_title_key]
          assign testimonial_avatar = block.settings[testimonial_avatar_key]
          assign testimonial_rating = block.settings[testimonial_rating_key]
        %}

        {% if testimonial_enabled %}
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            {% if block.settings.show_stars %}
              <div class="ai-testimonial-stars-{{ ai_gen_id }}">
                {% for star in (1..testimonial_rating) %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>
            {% endif %}

            {% if testimonial_quote != blank %}
              <p class="ai-testimonial-quote-{{ ai_gen_id }}">{{ testimonial_quote }}</p>
            {% endif %}

            <div class="ai-testimonial-author-{{ ai_gen_id }}">
              <div class="ai-testimonial-avatar-{{ ai_gen_id }}">
                {% if testimonial_avatar %}
                  <img
                    src="{{ testimonial_avatar | image_url: width: 100 }}"
                    alt="{{ testimonial_author | escape }}"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {% else %}
                  <div class="ai-testimonial-avatar-placeholder-{{ ai_gen_id }}">
                    {% if testimonial_author != blank %}
                      {{ testimonial_author | slice: 0 | upcase }}
                    {% else %}
                      ?
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="ai-testimonial-author-info-{{ ai_gen_id }}">
                {% if testimonial_author != blank %}
                  <div class="ai-testimonial-author-name-{{ ai_gen_id }}">{{ testimonial_author }}</div>
                {% endif %}
                {% if testimonial_title != blank %}
                  <div class="ai-testimonial-author-title-{{ ai_gen_id }}">{{ testimonial_title }}</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</customer-testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const cards = this.querySelectorAll('.ai-testimonial-card-{{ ai_gen_id }}');
        cards.forEach((card, index) => {
          card.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('customer-testimonials-{{ ai_gen_id }}', CustomerTestimonials{{ ai_gen_id }});
  })();
</script>

