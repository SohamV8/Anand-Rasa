            "custom_liquid": "<style>\n.icon-list-custom {\n  max-width: 44rem;\n  display: flex;\n  flex-wrap: wrap;\n  list-style: none;\n  justify-content: center;\n  margin: 0 0 10px 0;\n  gap: 6px;\n  padding: 14px 10px 8px 10px;\n  margin-top: -2rem;\n  background-color: #f5f5f5;\n  border-radius: 6px;\n}\n\n.icon-list-custom li {\n  display: flex;\n  align-items: center;\n}\n\n.icon-list-custom .icon-svg {\n  width: 36px;\n  height: 22px;\n  object-fit: contain;\n}\n</style>\n\n<ul class=\"icon-list-custom\" role=\"list\">\n  {% assign enabled_payment_types = 'visa, master, paypal, apple_pay, google_pay, klarna' | remove: ' ' | split: ',' %}\n  {% for type in enabled_payment_types %}\n    <li>{{ type | payment_type_svg_tag: class: 'icon-svg' }}</li>\n  {% endfor %}\n</ul>"
