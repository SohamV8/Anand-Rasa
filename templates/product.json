        "custom_liquid_wxQXP7": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"ar-product-header\">\n\n  <div class=\"ar-trust-badge\">\n    <span class=\"stars\">★★★★★</span>\n    <span class=\"text\"><strong>Excellent</strong> 4.8/5</span>\n    <span class=\"dot\">•</span>\n    <span class=\"text\"><strong>2000+</strong> Reviews</span>\n  </div>\n\n</div>\n\n<style>\n/* Trust Badge */\n.ar-trust-badge{\n    display:flex;\n    align-items:center;\n    justify-content:flex-start; /* Left align */\n    gap:12px;\n    margin-bottom:8px; /* Reduce space below reviews */\n    font-size:16px;\n    color:#4A4038;\n    line-height:1;\n}\n\n.ar-trust-badge .stars{\n    color:#C8A03A;\n    font-size:18px;\n    letter-spacing:2px;\n}\n\n.ar-trust-badge .dot{\n    color:#C8A03A;\n    font-size:14px;\n}\n\n/* Remove top spacing from product title */\n.product__title,\n.product-title,\nh1.product__title,\n.product-single__title{\n    margin-top:0 !important;\n    padding-top:0 !important;\n    line-height:1.05;\n}\n\n/* Mobile */\n@media(max-width:768px){\n    .ar-trust-badge{\n        gap:8px;\n        font-size:14px;\n        margin-bottom:6px;\n    }\n\n    .ar-trust-badge .stars{\n        font-size:16px;\n    }\n}\n</style>"
