{%- comment -%}
  Anandrasa robots.txt production template.

  Default crawl rules come from robots.default_groups (Shopify-managed).
  Then we append AI crawler Allow blocks. No duplicate Sitemap line after
  those groups. Long documentation lives in theme docs or repo README.

  Do not put Liquid tag-like brace sequences inside this comment block.
{%- endcomment -%}

{%- for group in robots.default_groups -%}
  {{- group.user_agent }}
  {%- for rule in group.rules -%}
    {{ rule }}
  {%- endfor -%}

  {%- for sitemap in group.sitemaps -%}
    {{ sitemap }}
  {%- endfor -%}

{%- endfor -%}
